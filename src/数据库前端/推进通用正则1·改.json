<div class="recall-wrapper-v4" style="position:relative;margin-bottom:8px;"><style>@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600&display=swap');.recall-wrapper-v4 .recall-container{border:1px solid #e2e8f0;border-radius:12px;padding:6px 12px;font-size:15px;color:#475569;background-color:#f5f5f5 !important;box-shadow:0 1px 2px rgba(0,0,0,0.05);transition:all 0.2s;line-height:1.5;font-family:'Noto Serif SC',sans-serif;display:block}.recall-wrapper-v4 .recall-container.theme-night{background-color:#2a2a2a !important;border-color:#444;color:#94a3b8}.recall-wrapper-v4 .recall-summary{list-style:none;outline:none;display:flex;align-items:center;justify-content:space-between;font-weight:500;cursor:pointer;user-select:none;background:transparent;padding-right:30px}.recall-wrapper-v4 .recall-summary::-webkit-details-marker{display:none}.recall-wrapper-v4 .recall-content{margin-top:6px;padding-top:6px;border-top:1px dashed #cbd5e1;font-size:14px;line-height:1.6;color:inherit;word-wrap:break-word;white-space:pre-wrap;font-family:inherit}.recall-wrapper-v4 .recall-container.theme-night .recall-content{border-color:#444}.recall-wrapper-v4 .badge{font-size:11px;padding:2px 8px;border-radius:10px;background:rgba(0,0,0,0.06);border:1px solid rgba(0,0,0,0.08);font-family:Consolas,Monaco,'Andale Mono',monospace;font-weight:bold;color:inherit;min-width:18px;text-align:center;margin-right:8px}.recall-wrapper-v4 .recall-container.theme-night .badge{background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.15)}.recall-wrapper-v4 .theme-btn{position:absolute;top:8px;right:10px;background:none;border:none;cursor:pointer;padding:4px;color:inherit;display:flex;align-items:center;border-radius:50%;transition:0.2s;z-index:20}.recall-wrapper-v4 .theme-btn:hover{background:rgba(0,0,0,0.05)}.recall-wrapper-v4 .recall-container.theme-night .theme-btn:hover{background:rgba(255,255,255,0.1)}</style><div class="theme-btn" onclick="const p=this.closest('.recall-wrapper-v4').querySelector('.recall-container');p.classList.toggle('theme-night');localStorage.setItem('mr_theme_mode',p.classList.contains('theme-night')?'night':'day');" title="切换日/夜模式"><svg style="width:18px;height:18px;fill:currentColor" viewBox="0 0 24 24"><path d="M12,18C11.11,18 10.26,17.8 9.5,17.45C11.56,16.5 13,14.42 13,12C13,9.58 11.56,7.5 9.5,6.55C10.26,6.2 11.11,6 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18M20,12C20,15.31 17.31,18 14,18C13.03,18 12.12,17.76 11.3,17.33C11.73,17.76 12.33,18 13,18C16.31,18 19,15.31 19,12C19,8.68 16.31,6 13,6C12.33,6 11.73,6.24 11.3,6.67C12.12,6.24 13.03,6 14,6C17.31,6 20,8.69 20,12M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" /></svg></div><details class="recall-container"><summary class="recall-summary"><div style="display:flex;align-items:center;gap:6px"><svg style="width:18px;height:18px;fill:currentColor" viewBox="0 0 24 24"><path d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" /></svg><span>记忆召回</span></div><span class="badge" id="recall-count">0</span></summary><div class="recall-content">$2</div></details><script>(function(){try{const w=document.currentScript.previousElementSibling;const c=`$2`;const m=c.match(/AM\d+/gi);w.querySelector('#recall-count').textContent=(m?m.length:0);if(localStorage.getItem('mr_theme_mode')==='night')w.classList.add('theme-night');}catch(e){}})()</script></div>
