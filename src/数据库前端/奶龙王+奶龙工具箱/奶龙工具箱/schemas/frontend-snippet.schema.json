{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Frontend Snippet",
  "type": "object",
  "required": ["name", "kind", "html", "scope_class"],
  "properties": {
    "name": { "type": "string" },
    "kind": { "type": "string" },
    "description": { "type": "string" },
    "html": { "type": "string", "minLength": 1 },
    "css": { "type": "string" },
    "scope_class": { "type": "string", "minLength": 1 },
    "mobile_notes": { "type": "array", "items": { "type": "string" } },
    "security_notes": { "type": "array", "items": { "type": "string" } },
    "allowed_contexts": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
