{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SillyTavern Worldbook Entry Object",
  "type": "object",
  "required": ["key", "content"],
  "properties": {
    "uid": { "type": ["number", "string"] },
    "key": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "keysecondary": { "type": "array", "items": { "type": "string" } },
    "comment": { "type": "string" },
    "content": { "type": "string", "minLength": 1 },
    "constant": { "type": "boolean" },
    "selective": { "type": "boolean" },
    "order": { "type": "number" },
    "position": { "type": "number" },
    "disable": { "type": "boolean" },
    "probability": { "type": "number" },
    "useProbability": { "type": "boolean" },
    "depth": { "type": ["number", "null"] },
    "group": { "type": "string" },
    "groupOverride": { "type": "boolean" },
    "groupWeight": { "type": "number" },
    "scanDepth": { "type": ["number", "null"] },
    "caseSensitive": { "type": ["boolean", "null"] },
    "matchWholeWords": { "type": ["boolean", "null"] },
    "sticky": { "type": "number" },
    "cooldown": { "type": "number" },
    "delay": { "type": "number" },
    "displayIndex": { "type": "number" }
  },
  "additionalProperties": true
}
