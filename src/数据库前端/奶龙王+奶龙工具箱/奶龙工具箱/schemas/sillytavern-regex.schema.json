{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SillyTavern Regex Script",
  "type": "object",
  "required": ["id", "scriptName", "findRegex", "replaceString", "placement"],
  "properties": {
    "id": { "type": "string" },
    "scriptName": { "type": "string" },
    "findRegex": { "type": "string" },
    "replaceString": { "type": "string" },
    "trimStrings": { "type": "array", "items": { "type": "string" } },
    "placement": { "type": "array" },
    "disabled": { "type": "boolean" },
    "markdownOnly": { "type": "boolean" },
    "promptOnly": { "type": "boolean" },
    "runOnEdit": { "type": "boolean" },
    "substituteRegex": { "type": "number" },
    "minDepth": { "type": ["number", "null"] },
    "maxDepth": { "type": ["number", "null"] }
  },
  "additionalProperties": true
}
