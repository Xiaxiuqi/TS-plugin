{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Worldbook Single Entry",
  "type": "object",
  "required": ["keys", "content", "comment"],
  "properties": {
    "uid": { "type": ["number", "string"] },
    "keys": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "secondary_keys": { "type": "array", "items": { "type": "string" } },
    "content": { "type": "string", "minLength": 1 },
    "comment": { "type": "string" },
    "constant": { "type": "boolean" },
    "selective": { "type": "boolean" },
    "enabled": { "type": "boolean" },
    "position": { "type": "number" },
    "depth": { "type": ["number", "null"] },
    "order": { "type": "number" },
    "insertion_order": { "type": "number" },
    "probability": { "type": "number" },
    "use_regex": { "type": "boolean" },
    "group": { "type": "string" },
    "group_override": { "type": "boolean" },
    "group_weight": { "type": "number" },
    "sticky": { "type": "number" },
    "cooldown": { "type": "number" },
    "delay": { "type": "number" },
    "scan_depth": { "type": ["number", "null"] },
    "case_sensitive": { "type": ["boolean", "null"] },
    "match_whole_words": { "type": ["boolean", "null"] }
  },
  "additionalProperties": true
}
