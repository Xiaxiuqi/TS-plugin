{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Worldbook Entry API Knowledge Base",
  "type": "object",
  "required": ["name", "language", "updated_at", "sources", "fields", "mappings"],
  "properties": {
    "name": { "type": "string" },
    "language": { "type": "string" },
    "updated_at": { "type": "string" },
    "sources": { "type": "array", "items": { "type": "string" } },
    "scope_note": { "type": "string" },
    "fields": { "type": "object" },
    "mappings": { "type": "array", "items": { "type": "object", "required": ["single_entry", "st_worldbook"] } },
    "position_values": { "type": "array", "items": { "type": "object" } },
    "compatibility_notes": { "type": "array", "items": { "type": "string" } },
    "related_examples": { "type": "array", "items": { "type": "string" } },
    "related_schemas": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
