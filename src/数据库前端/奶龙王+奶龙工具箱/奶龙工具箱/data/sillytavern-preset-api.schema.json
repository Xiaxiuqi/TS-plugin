{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SillyTavern Preset API Knowledge Base",
  "type": "object",
  "required": ["name", "language", "updated_at", "sources", "fields", "prompt_types", "backend_notes"],
  "properties": {
    "name": { "type": "string" },
    "language": { "type": "string" },
    "updated_at": { "type": "string" },
    "sources": { "type": "array", "items": { "type": "string" } },
    "scope_note": { "type": "string" },
    "fields": { "type": "object" },
    "prompt_types": { "type": "array", "items": { "type": "object" } },
    "backend_notes": { "type": "array", "items": { "type": "object" } },
    "boundaries": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
