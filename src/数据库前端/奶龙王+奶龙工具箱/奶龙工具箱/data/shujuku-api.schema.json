{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "shujuku API Knowledge Base",
  "type": "object",
  "required": ["name", "language", "updated_at", "sources", "extension", "groups"],
  "properties": {
    "name": { "type": "string" },
    "language": { "type": "string" },
    "updated_at": { "type": "string" },
    "sources": { "type": "array", "items": { "type": "string" } },
    "scope_note": { "type": "string" },
    "extension": { "type": "object" },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "title", "apis"],
        "properties": {
          "name": { "type": "string" },
          "title": { "type": "string" },
          "apis": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "signature", "description"],
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "types": { "type": "object" },
    "integration_notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
