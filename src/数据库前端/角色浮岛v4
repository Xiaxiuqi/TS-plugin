rder: 1; }\n\n.ci-sub-buttons { display: contents; } \n.ci-sub-buttons .ci-btn[data-type="main"] { order: 2; display: none; }\n.ci-sub-buttons .ci-btn[data-type="side"] { order: 3; display: none; }\n.ci-sub-buttons .ci-btn[data-type="retired"] { order: 4; display: none; }\n\n#ci-island-container.expanded .ci-sub-buttons .ci-btn { display: flex; }\n#ci-island-container.expanded #ci-main-trigger { background: #333; color: #fff; }\n\n#ci-map-btn { order: 5; }\n#ci-options-btn { order: 6; display: none; }\n#ci-refresh-btn { order: 7; }\n#ci-settings-btn { order: 8; }\n\n/* [Opt #4] 选项气泡定位 */\n.ci-options-container {\n    position: fixed; display: flex; flex-direction: column; gap: 8px; align-items: flex-end;\n    pointer-events: none; opacity: 0; transition: 0.3s; \n    z-index: 2002;\n    max-height: 80vh; overflow-y: auto; /* [Fix] Height limit */\n    scrollbar-width: none; /* Hide scrollbar */\n}\n.ci-options-container::-webkit-scrollbar { width: 0; height: 0; }\n.ci-options-container.visible { opacity: 1; pointer-events: auto; }\n\n.ci-option-bubble {\n    background: var(--ci-bg); border: 1px solid var(--ci-border);\n    padding: 8px 12px; border-radius: 12px 12px 2px 12px;\n    box-shadow: var(--ci-shadow); color: var(--ci-text); font-size: 12px;\n    max-width: 200px; cursor: pointer; backdrop-filter: blur(5px);\n    animation: popIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;\n    flex-shrink: 0;\n}\n.ci-option-bubble:hover { background: #fff; transform: scale(1.05); }\n@keyframes popIn { from { opacity: 0; transform: scale(0.8) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }\n\n.ci-tooltip { display: none; position: absolute; right: 42px; background: rgba(0,0,0,0.8); color: white; padding: 4px 8px; border-radius: 4px; font-size: 11px; white-space: nowrap; pointer-events: none; z-index: 99; }\n.ci-btn:hover .ci-tooltip { display: block; }\n\n/* 主面板 */\n#ci-panel, #ci-map-panel { \n    position: fixed; width: 400px; height: 600px; \n    background: var(--ci-bg); backdrop-filter: var(--ci-glass); -webkit-backdrop-filter: var(--ci-glass); \n    border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.25); z-index: 2001; \n    display: none; flex-direction: column; border: var(--ci-border); \n    opacity: 0; transform: scale(0.95); \n    transition: opacity 0.25s ease, transform 0.25s ease, left 0.3s cubic-bezier(0.2, 0, 0, 1), top 0.3s cubic-bezier(0.2, 0, 0, 1), width 0.1s, height 0.1s; \n}\n#ci-panel.visible, #ci-map-panel.visible { display: flex !important; opacity: 1 !important; transform: scale(1) !important; }\n#ci-panel.no-transition, #ci-map-panel.no-transition { transition: none !important; }\n\n#ci-map-panel { background: var(--map-bg); border: 2px solid var(--map-border); color: var(--map-text); }\n#ci-map-panel.pinned {\n    border: 2px solid #2196f3 !important;\n    box-shadow: 0 0 10px rgba(33, 150, 243, 0.5);\n}\n\n#ci-map-content { flex: 1; overflow: hidden; position: relative; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.02); }\n#ci-map-svg { width: 100%; height: 100%; cursor: grab; display: block; }\n#ci-map-svg:active { cursor: grabbing; }\n\n.ci-map-controls { position: absolute; right: 10px; top: 10px; z-index: 10; display: flex; flex-direction: column; gap: 5px; }\n.ci-map-btn-circle { \n    background: var(--ci-bg); border: 1px solid var(--ci-border); color: var(--ci-text); \n    border-radius: 50%; cursor: pointer; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; \n    box-shadow: 0 2px 5px rgba(0,0,0,0.1); transition: 0.2s; \n}\n.ci-map-btn-circle:hover { transform: scale(1.1); background: #fff; }\n\n.map-location-group { cursor: pointer; transition: all 0.2s ease; }\n.map-location-rect { fill: rgba(140, 110, 84, 0.3); stroke: var(--map-accent); stroke-width: 1.5px; transition: all 0.3s ease; }\n.map-location-group:hover .map-location-rect { fill: rgba(180, 138, 92, 0.6); }\n.map-location-label { fill: var(--map-text); text-anchor: middle; dominant-baseline: middle; pointer-events: none; user-select: none; font-size: 14px; font-weight: bold; transition: all 0.3s ease; text-shadow: 0 0 2px rgba(255,255,255,0.8); }\n\n.protagonist-map-avatar { pointer-events: none; }\n.pulse-wave {\n    fill: none; stroke: var(--map-highlight); stroke-width: 2px;\n    transform-box: fill-box; transform-origin: center;\n    animation: pulse 2s infinite;\n}\n@keyframes pulse {\n    0% { transform: scale(1); opacity: 1; }\n    100% { transform: scale(2.5); opacity: 0; }\n}\n\n.ci-panel-header { padding: 12px 16px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(0,0,0,0.06); font-weight: bold; color: #333; font-size: 14px; user-select: none; flex-shrink: 0; }\n.ci-header-cats { display: flex; gap: 4px; margin-left: 10px; }\n.ci-cat-dot { width: 8px; height: 8px; border-radius: 50%; background: #ddd; cursor: pointer; transition: 0.2s; }\n.ci-cat-dot.active { transform: scale(1.4); }\n.ci-cat-dot[data-type="main"].active { background: #ffca28; }\n.ci-cat-dot[data-type="side"].active { background: #42a5f5; }\n.ci-cat-dot[data-type="retired"].active { background: #bdbdbd; }\n\n.ci-close-btn, .ci-edit-btn, .ci-pin-btn { cursor: pointer; padding: 4px; border-radius: 50%; opacity: 0.6; transition: 0.2s; width: 24px; height: 24px; display:flex; align-items:center; justify-content:center; }\n.ci-close-btn:hover, .ci-edit-btn:hover, .ci-pin-btn:hover { opacity: 1; background: rgba(0,0,0,0.05); }\n.ci-edit-btn.active { color: #4caf50; opacity: 1; background: rgba(76, 175, 80, 0.1); }\n.ci-panel-content { flex: 1; overflow-y: auto; padding: 12px; position: relative; background: rgba(245,245,247,0.5); }\n.ci-panel-content::-webkit-scrollbar, .ci-info-scroll::-webkit-scrollbar, .ci-bag-grid::-webkit-scrollbar { width: 0; height: 0; }\n.ci-panel-content, .ci-info-scroll, .ci-bag-grid { scrollbar-width: none; -ms-overflow-style: none; }\n\n.ci-grid-view { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); grid-auto-rows: min-content; gap: 16px; width: 100%; padding-bottom: 40px; }\n.ci-card { background: #fff; border-radius: 12px; padding: 12px; display: flex; flex-direction: column; align-items: center; box-shadow: var(--ci-card-shadow); border: 1px solid rgba(0,0,0,0.04); position: relative; cursor: pointer; transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s; height: auto; min-height: 200px; }\n.ci-card:hover { transform: translateY(-2px); box-shadow: var(--ci-card-shadow-hover); z-index: 2; border-color: rgba(0,0,0,0.1); }\n\n.ci-card.is-expanded { grid-column: span 2; grid-row: span 3; width: 100%; height: 100%; cursor: default; padding: 0; margin: 0; background: transparent; box-shadow: none; border: none; z-index: 10; overflow: visible !important; }\n.ci-expanded-box { \n    width: 100%; \n    min-width: 0; \n    height: 450px; \n    min-height: 300px; \n    position: relative; \n    background: #fff; \n    border-radius: 16px; \n    box-shadow: var(--ci-card-shadow) !important; \n    border: 1px solid rgba(0,0,0,0.1); \n    display: flex; \n    flex-direction: row; \n    overflow: hidden; \n    animation: expandAnim 0.3s cubic-bezier(0.2, 0.8, 0.2, 1); \n    z-index: 101; \n}\n\n/* [Mod 1] Responsive Card Layout */\n#ci-panel[style*="width: 3"] .ci-expanded-box, \n#ci-panel[style*="width: 2"] .ci-expanded-box { \n    flex-direction: column;\n    height: auto !important; /* Allow grow vertically */\n    min-height: 500px; /* Ensure min height for vertical layout */\n}\n#ci-panel[style*="width: 3"] .ci-nb-left,\n#ci-panel[style*="width: 2"] .ci-nb-left {\n    width: 100%;\n    height: auto; /* Flexible height */\n    min-height: 200px;\n    border-right: none;\n    border-bottom: 1px solid #f0f0f0;\n}\n#ci-panel[style*="width: 3"] .ci-nb-right,\n#ci-panel[style*="width: 2"] .ci-nb-right {\n    width: 100%;\n    height: 300px; /* Fixed height for bag part */\n}\n\n@keyframes expandAnim { from { opacity: 0; transform: scale(0.98); } to { opacity: 1; transform: scale(1); } }\n.ci-card-compact { display: flex; flex-direction: column; align-items: center; width: 100%; height: 100%; padding-bottom: 10px; }\n.ci-card.is-expanded .ci-card-compact { display: none; }\n\n.ci-card-avatar { width: 64px; height: 64px; border-radius: 16px; background: #f0f0f0; margin-bottom: 10px; overflow: hidden; display: flex; align-items: center; justify-content: center; font-size: 26px; color: #aaa; box-shadow: inset 0 0 10px rgba(0,0,0,0.03); flex-shrink: 0; }\n.ci-card-avatar img { width: 100%; height: 100%; object-fit: cover; }\n.ci-card-name { font-weight: 700; font-size: 15px; color: #333; text-align: center; width: 100%; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.ci-card-role { font-size: 10px; color: #666; background: #f5f5f7; padding: 2px 8px; border-radius: 10px; margin-bottom: 8px; max-width: 90%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.ci-card-info { font-size: 11px; color: #999; text-align: center; margin-bottom: 4px; }\n\n.ci-card-thought {\n    font-size: 10px; color: #555; font-style: italic;\n    background: #f9f9f9; padding: 4px 8px; border-radius: 6px;\n    margin: 4px 0; text-align: center; width: 95%;\n    border-left: 2px solid var(--ci-accent);\n    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;\n}\n.ci-tag-group {\n    display: flex; flex-wrap: wrap; gap: 4px; justify-content: center; margin-top: 6px; width: 100%;\n}\n.ci-tag {\n    font-size: 9px; padding: 2px 6px; border-radius: 4px;\n    background: #e3f2fd; color: #1976d2; cursor: help;\n    border: 1px solid rgba(25, 118, 210, 0.1);\n    white-space: nowrap;\n}\n.ci-tag.warn { background: #fff3e0; color: #e65100; border-color: #ffe0b2; }\n.ci-tag.danger { background: #ffebee; color: #c62828; border-color: #ffcdd2; }\n\n.ci-menu-trigger { position: absolute; top: 8px; right: 8px; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ddd; cursor: pointer; transition: 0.2s; z-index: 20; }\n.ci-menu-trigger:hover, .ci-menu-trigger.active { background: rgba(0,0,0,0.05); color: #333; }\n.ci-card-menu-popover { position: absolute; top: 36px; right: 8px; background: #333; border-radius: 8px; padding: 6px; display: none; flex-direction: column; gap: 4px; z-index: 30; box-shadow: 0 8px 20px rgba(0,0,0,0.25); }\n.ci-menu-trigger.active + .ci-card-menu-popover { display: flex; }\n.ci-menu-item { display: flex; align-items: center; gap: 8px; color: #fff; font-size: 11px; padding: 8px 12px; cursor: pointer; border-radius: 6px; white-space: nowrap; }\n.ci-menu-item:hover { background: rgba(255,255,255,0.2); }\n\n.ci-nb-left { width: 40%; background: #fff; border-right: 1px solid #f0f0f0; padding: 16px; display: flex; flex-direction: column; overflow: hidden; position: relative; transition: all 0.2s; }\n.ci-editing .ci-nb-left { box-shadow: inset 0 0 0 2px var(--ci-edit-border); background-color: var(--ci-edit-highlight); cursor: pointer; }\n.ci-nb-right { width: 60%; background: #fafafa; padding: 0; display: flex; flex-direction: column; position: relative; overflow: hidden; }\n\n.ci-big-avatar-box { width: 80px; height: 80px; margin: 0 auto 10px; border-radius: 16px; background: #eee; overflow: hidden; position: relative; cursor: pointer; flex-shrink: 0; box-shadow: 0 4px 10px rgba(0,0,0,0.1); display: flex; align-items: center; justify-content: center; font-size: 30px; color: #ccc; z-index: 2; }\n.ci-big-avatar-box img { width: 100%; height: 100%; object-fit: cover; }\n.ci-upload-hint { position: absolute; bottom: 0; width: 100%; background: rgba(0,0,0,0.6); color: white; font-size: 10px; text-align: center; opacity: 0; transition: 0.2s; padding: 2px 0; }\n.ci-big-avatar-box:hover .ci-upload-hint { opacity: 1; }\n.ci-info-scroll { flex: 1; overflow-y: auto; padding-right: 2px