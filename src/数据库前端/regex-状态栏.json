}

function updateProtagonistDisplay() {
    const p = GameState.protagonist;
    if (!p) return;

    document.getElementById('protagonistName').textContent = p.name;
    document.getElementById('protagonistProfession').textContent = p.profession;
    document.getElementById('protagonistLevel').textContent = 'Lv.' + p.level;

