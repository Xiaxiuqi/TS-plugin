}

function updateBattleSkills() {
    const container = document.getElementById('battleSkills');
    const p = GameState.protagonist;

    container.innerHTML = GameState.skills.slice(0, 6).map((s, i) => {
        let resOk = true;
        if (p) {
            if (s.costType === '法力') resOk = p.res.mp.cur >= s.costVal;
            else if (s.costType === '体力') resOk = p.res.sp.cur >= s.costVal;
        }
        const icon = getSkillIcon(s.name);
        const selected = GameState.selectedSkills.some(ss => ss.name === s.name);

        return '<div class="skill-slot' + (resOk ? '' : ' disabled') + (selected ? ' selected' : '') + '" onclick="toggleSkillSelection(' + i + ')">' +
            '<div class="skill-check">✓</div>' +
            '<div class="skill-icon">' + icon + '</div>' +
            '<div class="skill-name">' + s.name + '</div>' +
            '<div class="skill-cost">' + s.costType + ':' + s.costVal + '</div></div>';
    }).join('');

    updateSelectedSkillsDisplay();

    // 更新战斗角色显示
    updateBattleCharacters();
}

