/**
 * 检查位置变化并更新地图（即使地图面板关闭也会在后台更新）
 */
async function checkLocationAndUpdateMap() {
    const newLocation = await getCurrentLocation();

    if (newLocation && newLocation !== MapState.currentLocation) {
        console.log('[地图系统] 位置变化:', MapState.currentLocation, '->', newLocation);

        // 无论地图面板是否打开，都更新地图（后台更新）
        await refreshMap();
    }
}

// 防抖工具函数
function debounce(func, wait) {
    let timeout;
    return function(...args) {
        clearTimeout(timeout);
        timeout = setTimeout(() => func.apply(this, args), wait);
    };
}

// 初始化地图系统（增强防重复机制）
async function initMapSystem() {
    // 防止重复初始化 - 第一层：检查是否正在初始化
    if (MapState.isInitializing) {
        console.log('[地图系统] 正在初始化中，跳过重复调用');
        return;
    }

    // 防止重复初始化 - 第二层：防抖检查（500ms内的重复调用直接跳过）
    const now = Date.now();
    if (now - MapState.lastInitTime < 500) {
        console.log('[地图系统] 防抖：500ms内重复调用，跳过');
        return;
    }

    // 先获取位置，用于后续检查
    const location = await getCurrentLocation();

    // 防止重复初始化 - 第三层：检查是否已初始化且位置未变
    if (MapState.initialized && MapState.initializedLocation === location) {
        const currentMode = GameState.currentMode;
        // 如果模式和位置都没变，跳过初始化
        if ((currentMode === 'battle' && MapState.svgTemplate) ||
            (currentMode !== 'battle' && MapState.svgTemplate)) {
            console.log('[地图系统] 已初始化且位置未变，跳过重复初始化');
            return;
        }
    }

    MapState.isInitializing = true;
    MapState.lastInitTime = now;
    console.log('[地图系统] 开始初始化...');

    try {
        // 初始化 IndexedDB 并加载缓存
        await MapCache.init();
        console.log('[地图系统] MapCache初始化完成, 内存缓存数量:', Object.keys(MapCache.data).length);
        AvatarCache.init();

        // 获取当前位置
        if (!location) {
            console.log('[地图系统] 无法获取当前位置，跳过地图初始化');
            return;
        }
        MapState.currentLocation = location;
        console.log('[地图系统] 当前位置:', location);

        // 检查当前模式
        const currentMode = GameState.currentMode;
        console.log('[地图系统] 当前模式:', currentMode);

        if (currentMode === 'battle') {
            // 战斗模式：初始化战斗地图（会自动加载缓存或生成新地图）
            console.log('[地图系统] 战斗模式，初始化战斗地图');
            await initBattleMap();
            // 自动展开战斗地图面板
            autoExpandBattleMapPanel();
        } else {
            // 日常模式：检查缓存，没有则生成
            const cached = MapCache.get(location);
            if (cached && cached.svgTemplate) {
                // 有缓存，直接加载
                console.log('[地图系统] 使用缓存地图:', location);
                MapState.svgTemplate = cached.svgTemplate;

                // 获取角色并设置位置
                const chars = getCharactersInCurrentLocation();
                if (cached.positions) {
                    MapState.characterPositions = applyAIPositions(chars, cached.positions);
                    console.log('[地图系统] 从缓存加载角色坐标');
                } else {
                    MapState.characterPositions = generateDefaultPositions(chars);
                    console.log('[地图系统] 使用默认角色位置');
                }

                // 更新显示
                updateMapDisplay();
                // 自动展开地图面板
                autoExpandMapPanel();
            } else {
                // 无缓存，生成新地图（refreshMap内部会自动展开地图面板）
                console.log('[地图系统] 无缓存，生成新地图');
                await refreshMap();
            }
        }

        // 标记初始化完成
        MapState.initialized = true;
        MapState.initializedLocation = location;
        console.log('[地图系统] 初始化完成');
    } finally {
        MapState.isInitializing = false;
    }
}

// 防抖版本的 initMapSystem（用于表格更新回调）
const debouncedInitMapSystem = debounce(initMapSystem, 300);

// ==================== AI地图生成（两阶段）====================

/**
 * 第一阶段：生成地图结构数据（JSON格式，包含角色坐标）
 * @param {string} locationName - 地点名称
 * @param {string} storyContext - 剧情上下文
 * @param {boolean} isBattleMode - 是否战斗模式
 * @returns {Promise<object>} - 地图结构数据
 */
async function generateMapStructure(locationName, storyContext, isBattleMode = false) {
    // 根据模式获取角色信息
    let chars;
    if (isBattleMode) {
        // 战斗模式：从战斗表获取角色
        chars = getBattleCharactersForMap();
        console.log('[地图系统] 战斗模式角色:', chars);
    } else {
        // 日常模式：从场景表获取角色
        chars = getCharactersInCurrentLocation();
    }

    const characterList = [];

    // 主角
    if (chars.protagonist) {
        characterList.push(`- 主角：${chars.protagonist.name}`);
    }
    // 友方
    if (chars.allies && chars.allies.length > 0) {
        chars.allies.forEach(ally => {
            characterList.push(`- 友方：${ally.name}`);
        });
    }
    // 敌方（战斗模式）
    if (isBattleMode && chars.enemies && chars.enemies.length > 0) {
        chars.enemies.forEach(enemy => {
            characterList.push(`- 敌方：${enemy.name}`);
        });
    }

    const characterInfo = characterList.length > 0
        ? `\n\n当前在场角色：\n${characterList.join('\n')}`
        : '';

    const modeText = isBattleMode ? '战斗场景' : '日常场景';

    const systemPrompt = `你是一个资深DND地牢架构师。请根据主题设计一个紧凑、真实的场景平面图结构。

主题：${locationName}
模式：${modeText}

关键设计原则：
1. **紧凑连接**：房间/区域之间应该物理上紧挨着，不用长长的线连接
2. **走廊即房间**：走廊本身就是一个长条形的区域，角色可以站在里面
3. **无缝拼接**：区域坐标(x,y,width,height)应该让它们边缘贴合，形成连通的整体
4. **不规则布局**：地图布局不用规则分布，可以有不对称和不规则的形状

请生成JSON格式数据：
1. mapName: 地图名称（字符串）
2. mapSize: { width: 800, height: 600 }
3. rooms: 区域列表，每个包含：
   - id: 唯一ID（如 "room_1"）
   - name: 区域名称（中文）
   - type: 类型 (entrance/corridor/room/hall/secret_room/outdoor/clearing)
   - shape: 形状 (rectangular/circular/irregular/cave_blob)
   - x, y, width, height: 边界框坐标（x: 0-800, y: 0-600）
   - description: 简短描述
   - color: 建议颜色 (hex格式)
4. doors: 门/通道列表（可选）：
   - x, y: 位置
   - type: 类型 (open/door/secret_door)
   - orientation: 方向 (horizontal/vertical)
   - connects: [room_id_1, room_id_2]
5. features: 装饰物体列表（可选，如 column/statue/chest/tree/rock/fireplace...)
   - x, y: 位置
   - type: 类型
   - description: 描述
6. characters: 角色坐标列表，每个包含：
   - name: 角色名称（**必须完全匹配下面"当前在场角色"列表中的名称，一个字都不能差！**）
   - faction: 阵营 (protagonist/ally/enemy)
   - x, y: 坐标位置（x: 0-800, y: 0-600）
   - roomId: 所在区域ID（可选）

【超级重要】角色名称匹配规则：
- **characters 列表中的 name 字段必须与"当前在场角色"列表中的名称完全一致！**
- 例如：如果列表中是"工会登记员"，那 characters 中的 name 必须也是"工会登记员"，不能是"谢顶工会登记员"或"登记员"
- 例如：如果列表中是"格鲁姆（缺门牙）"，那 name 必须也是"格鲁姆（缺门牙）"，不能是"格鲁姆"或"格鲁姆（缺门牙半兽人）"
- **这是系统硬性要求，名称不匹配将导致角色无法正确显示在地图上！**

角色坐标分配原则（非常重要）：
- **必须根据剧情上下文来分配角色位置！**
- 仔细阅读剧情，理解每个角色当前在做什么、应该在哪里
- 例如：柜台小姐应该在柜台后面，守卫应该在门口，厨师应该在厨房
- 例如：如果剧情说"主角走到壁炉旁"，那主角坐标应该靠近壁炉
- 例如：如果剧情说"商人在展示商品"，那商人应该在商品区域
- 主角默认放在地图中心偏左的位置（除非剧情有其他指示）
- 友方角色根据剧情逻辑围绕在主角附近或各自的工作位置
- 敌方角色放在地图右侧或对角位置（战斗模式）

请生成一个包含3-6个区域的场景结构。只返回JSON，不要其他解释。`;

    const userPrompt = `剧情上下文：
${storyContext.substring(0, 40000)}${characterInfo}

请生成该场景的结构数据（JSON格式）：`;

    try {
        const response = await callSillyTavernAI(systemPrompt, userPrompt);
        if (response) {
            // 提取JSON
            const jsonMatch = response.match(/\{[\s\S]*\}/);
            if (jsonMatch) {
                const structure = JSON.parse(jsonMatch[0]);
                console.log('[地图系统] 第一阶段：生成结构数据成功', structure);
                return structure;
            }
        }
    } catch (e) {
        console.error('[地图系统] 第一阶段失败:', e);
    }

    return null;
}

/**
 * 第二阶段：根据结构数据生成SVG地图
 * @param {object} structure - 地图结构数据
 * @param {boolean} isBattleMode - 是否战斗模式
 * @returns {Promise<string>} - SVG字符串
 */
async function generateMapSVG(structure, isBattleMode = false) {
    const borderColor = isBattleMode ? '#8b0000' : '#5c4033';
    const titleColor = isBattleMode ? '#8b0000' : '#3d2914';

    const systemPrompt = `你是一个顶级DND地图绘制大师。请根据以下结构数据，绘制一张极具艺术感的、手绘风格的地图。

【最重要的规则 - 必须遵守】：
- **地面不涂色！** 所有房间、走廊、区域的地面必须保持透明（fill="none" 或 fill="transparent"）
- 背景羊皮纸颜色会自然透出，形成自然的地面色调
- 墙壁、边界使用线条绘制（stroke），不填充

【需要填充颜色的元素】：
- **家具**：桌子、椅子、柜台、床、书架等 - 使用淡棕色/深褐色填充
- **障碍物**：岩石、柱子、箱子等 - 使用灰色/棕色填充
- **标志性建筑/装饰**：壁炉、雕像、喷泉、篝火等 - 使用适当的颜色填充
- **门**：可以使用深棕色填充
- **植被**：树木、灌木 - 使用绿色填充
- 这些元素应该有基本的颜色，让地图更加生动

核心绘制要求：

0. **形态革命（关键需求）**：
   - **拒绝矩形**：地图绝不是一个个方块拼起来的！
   - **有机形状**：对于 shape="irregular" 或 "cave_blob" 的区域，必须使用 \`<path>\` 绘制不规则的、有机的曲线轮廓
   - 即使是 rectangular 区域，也要画得稍微歪斜一点
   - 参考边界：width/height 只是大致范围，请大胆地绘制多边形或不规则形状

1. **线条绘制规则（关键）**：
   - **墙壁**：使用粗笔触 (stroke-width="4"~"6")，颜色深邃 (#2c3e50)，fill="none"
   - **房间轮廓**：只画边框，不填充！使用 stroke 绘制轮廓线
   - **门**：用线条或简单符号表示，不填充
   - **装饰物**：用简单的线条画，不要填充颜色

2. **手绘风格**：
   - 定义 "pencil-effect" 滤镜：高频噪声 (baseFrequency="0.7")
   - 将滤镜应用到区域轮廓和墙壁
   - **文字保护**：绝对禁止将滤镜应用到 <text> 标签！

3. **背景**：
   - SVG 第一层必须是 <rect> 填充羊皮纸颜色
   - 羊皮纸颜色：#faf0dc → #f4e4bc → #d4c4a0 渐变
   - 这是唯一的填充色！

4. **排版与装饰**：
   - 标题使用 font-family="Cinzel, serif"，居中显示在地图顶部
   - 区域标签使用 font-family="MedievalSharp, cursive"
   - 画华丽装饰边框包围整个地图（只用线条，不填充）
   - 绘制指南针、比例尺、墨水污渍效果（只用线条）

5. **ViewBox 扩展**：
   - 设置 viewBox="-50 -150 900 850"
   - 大标题放置在 y = -80 左右

边框颜色：${borderColor}
标题颜色：${titleColor}

【再次强调】：所有区域内部必须透明（fill="none"），只画线条！

只输出 <svg> 代码，不要markdown标记，不要解释。`;

    // 只发送地图结构数据，不包含角色坐标（角色由前端渲染）
    const mapStructureOnly = {
        mapName: structure.mapName,
        mapSize: structure.mapSize,
        rooms: structure.rooms,
        doors: structure.doors,
        features: structure.features
    };

    const userPrompt = `结构数据：
${JSON.stringify(mapStructureOnly, null, 2)}

请根据以上结构数据绘制SVG地图。注意：不要在地图上绘制任何人物或角色标记，只需要绘制地形、房间、门和装饰物即可。`;

    try {
        const response = await callSillyTavernAI(systemPrompt, userPrompt);
        if (response) {
            // 提取SVG
            const svgMatch = response.match(/<svg[\s\S]*<\/svg>/i);
            if (svgMatch) {
                console.log('[地图系统] 第二阶段：生成SVG成功');
                return svgMatch[0];
            }
        }
    } catch (e) {
        console.error('[地图系统] 第二阶段失败:', e);
    }

    return null;
}

/**
 * 从结构数据中提取角色坐标
 * @param {object} structure - 地图结构数据
 * @returns {object} - 角色坐标
 */
function extractPositionsFromStructure(structure) {
    const positions = {
        protagonist: null,
        allies: [],
        enemies: []
    };

    if (!structure.characters || !Array.isArray(structure.characters)) {
        return positions;
    }

    structure.characters.forEach(char => {
        const pos = {
            name: char.name,
            x: char.x,
            y: char.y
        };

        if (char.faction === 'protagonist') {
            positions.protagonist = pos;
        } else if (char.faction === 'ally') {
            positions.allies.push(pos);
        } else if (char.faction === 'enemy') {
            positions.enemies.push(pos);
        }
    });

    return positions;
}

/**
 * 通过AI生成地形图SVG（两阶段：先生成结构，再生成SVG）
 * @param {string} locationName - 地点名称
 * @param {string} storyContext - 剧情上下文
 * @param {boolean} isBattleMode - 是否战斗模式
 * @returns {Promise<{svg: string, positions: object, structure: object}>} - SVG字符串、角色坐标和结构数据
 */
async function generateMapByAI(locationName, storyContext, isBattleMode = false) {
    console.log('[地图系统] 开始两阶段地图生成...');

    // 第一阶段：生成结构数据（包含角色坐标）
    const structure = await generateMapStructure(locationName, storyContext, isBattleMode);
    if (!structure) {
        console.error('[地图系统] 第一阶段失败：无法生成结构数据');
        return null;
    }

    // 从结构数据中提取角色坐标
    const positions = extractPositionsFromStructure(structure);
    console.log('[地图系统] 从结构数据提取角色坐标:', positions);

    // 第二阶段：根据结构数据生成SVG
    const svg = await generateMapSVG(structure, isBattleMode);
    if (!svg) {
        console.error('[地图系统] 第二阶段失败：无法生成SVG');
        return null;
    }

    // 验证SVG
    if (!validateSVG(svg)) {
        console.error('[地图系统] SVG验证失败');
        return null;
    }

    console.log('[地图系统] 两阶段地图生成完成');
    return { svg, positions, structure };
}

/**
 * 调用AI接口（根据用户设置选择API来源）
 */
async function callSillyTavernAI(systemPrompt, userPrompt) {
    try {
        console.log('[地图系统] 当前API设置:', Settings.apiSource);

        // 根据用户设置决定使用哪种API
        if (Settings.apiSource === 'custom' && Settings.customApiUrl) {
            // 使用自定义API
            console.log('[地图系统] 使用自定义API调用AI');
            try {
                const messages = [
                    { role: 'system', content: systemPrompt },
                    { role: 'user', content: userPrompt }
                ];

                const response = await fetch(Settings.customApiUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${Settings.customApiKey}`
                    },
                    body: JSON.stringify({
                        model: Settings.customModelName || 'gpt-4',
                        messages: messages,
                        max_tokens: 60000
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    const content = data.choices?.[0]?.message?.content || data.response || data.text;
                    if (content) {
                        console.log('[地图系统] 自定义API调用成功');
                        return content;
                    }
                }
                console.warn('[地图系统] 自定义API调用失败，尝试其他方案');
            } catch (customErr) {
                console.error('[地图系统] 自定义API异常:', customErr);
            }
        }

        // 使用数据库API（当设置为database时优先使用，或自定义API失败时回退）
        if (Settings.apiSource === 'database' || Settings.apiSource !== 'custom') {
            const api = getAutoCardAPI();
            console.log('[地图系统] 获取API结果:', api ? 'API可用' : 'API不可用');
            if (api) {
                console.log('[地图系统] API方法检查 - callAI:', typeof api.callAI === 'function');
            }

            if (api && typeof api.callAI === 'function') {
                console.log('[地图系统] 使用数据库callAI调用AI');
                try {
                    const messages = [
                        { role: 'system', content: systemPrompt },
                        { role: 'user', content: userPrompt }
                    ];
                    const response = await api.callAI(messages, { max_tokens: 60000 });
                    if (response) {
                        console.log('[地图系统] 数据库callAI调用成功');
                        return response;
                    }
                    console.warn('[地图系统] 数据库callAI返回空，尝试其他方案');
                } catch (dbErr) {
                    console.error('[地图系统] 数据库callAI异常:', dbErr);
                }
            } else {
                console.warn('[地图系统] 数据库API不可用或callAI方法不存在');
            }
        }

        // 备用方案1：使用SillyTavern的generateQuietPrompt
        if (typeof parent !== 'undefined' && typeof parent.generateQuietPrompt === 'function') {
            console.log('[地图系统] 使用generateQuietPrompt调用AI');
            const fullPrompt = `${systemPrompt}\n\n---\n\n${userPrompt}`;
            const response = await parent.generateQuietPrompt(fullPrompt);
            return response;
        }

        // 备用方案2：使用SillyTavern的generate API
        if (typeof parent !== 'undefined' && typeof parent.generate === 'function') {
            console.log('[地图系统] 使用generate调用AI');
            const response = await parent.generate(userPrompt, false, false, systemPrompt);
            return response;
        }

        // 备用方案3：通过eventSource触发
        if (typeof parent !== 'undefined' && typeof parent.eventSource !== 'undefined' && typeof parent.eventSource.emit === 'function') {
            console.log('[地图系统] 尝试通过eventSource调用');
            // 这种方式比较复杂，暂时跳过
        }

        console.warn('[地图系统] 未找到可用的AI接口');
        console.warn('[地图系统] 请检查：1. API设置是否正确 2. 数据库API是否已加载 3. SillyTavern接口是否可用');
        return null;
    } catch (e) {
        console.error('[地图系统] AI调用异常:', e);
        return null;
    }
}

/**
 * 从AI响应中提取SVG内容
 */
function extractSVG(response) {
    if (!response) return null;

    // 尝试提取<svg>...</svg>内容
    const svgMatch = response.match(/<svg[^>]*>[\s\S]*?<\/svg>/i);
    if (svgMatch) {
        return svgMatch[0];
    }

    // 如果响应本身就是SVG
    if (response.includes('<svg') && response.includes('</svg>')) {
        return response;
    }

    return null;
}

/**
 * 从AI响应中提取SVG内容和角色坐标
 * @param {string} response - AI响应文本
 * @returns {{svg: string, positions: object}} - SVG和角色坐标
 */
function extractSVGAndPositions(response) {
    if (!response) return { svg: null, positions: null };

    // 提取SVG内容
    const svgMatch = response.match(/<svg[^>]*>[\s\S]*?<\/svg>/i);
    const svg = svgMatch ? svgMatch[0] : null;

    // 提取角色坐标JSON
    let positions = null;
    try {
        // 尝试匹配 JSON 格式的坐标数据
        const jsonMatch = response.match(/\{"positions":\s*\{[\s\S]*?\}\s*\}/);
        if (jsonMatch) {
            const data = JSON.parse(jsonMatch[0]);
            positions = data.positions;
            console.log('[地图系统] 提取到角色坐标:', positions);
        }
    } catch (e) {
        console.warn('[地图系统] 解析角色坐标失败:', e);
    }

    return { svg, positions };
}

/**
 * 验证SVG是否有效
 */
function validateSVG(svg) {
    if (!svg) return false;

    // 检查基本结构
    if (!svg.includes('<svg') || !svg.includes('</svg>')) {
        return false;
    }

    // 检查viewBox
    if (!svg.includes('viewBox')) {
        return false;
    }

    return true;
}

