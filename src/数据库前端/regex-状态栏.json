// ==================== 任务弹窗 ====================
let currentQuestFilter = 'all';

function openQuestModal() {
    currentQuestFilter = 'all';
    renderQuestList();
    openModal('questModal');
}

function filterQuests(type) {
    currentQuestFilter = type;
    document.querySelectorAll('.quest-tab').forEach(tab => {
        tab.classList.toggle('active', tab.textContent.includes(type === 'all' ? '全部' : (type === '主线任务' ? '主线' : '支线')));
    });
    renderQuestList();
}

function renderQuestList() {
    const container = document.getElementById('questList');
    let quests = GameState.quests;

    if (currentQuestFilter !== 'all') {
        quests = quests.filter(q => q.type === currentQuestFilter);
    }

    if (quests.length === 0) {
        container.innerHTML = '<div style="text-align:center;color:var(--ink-light);padding:40px;">暂无任务</div>';
        return;
    }

    container.innerHTML = quests.map((q, i) => {
        const isMain = q.type === '主线任务';
        const typeClass = isMain ? 'main-quest' : 'side-quest';
        const typeLabelClass = isMain ? 'main' : 'side';

        return '<div class="quest-item ' + typeClass + '" onclick="toggleQuestDetail(' + i + ')">' +
            '<div class="quest-item-header">' +
            '<span class="quest-item-name">' + q.name + '</span>' +
            '<span class="quest-item-type ' + typeLabelClass + '">' + (isMain ? '主线' : '支线') + '</span></div>' +
            '<div class="quest-item-progress">📍 ' + q.progress + '</div>' +
            '<div class="quest-item-desc" id="questDesc' + i + '" style="display:none;">' +
            '<div class="quest-detail-content">' +
            '<div class="quest-detail-row"><span class="quest-detail-label">发布者</span><span class="quest-detail-value">' + q.publisher + '</span></div>' +
            '<div class="quest-detail-row"><span class="quest-detail-label">描述</span><span class="quest-detail-value">' + q.desc + '</span></div>' +
            '<div class="quest-detail-row"><span class="quest-detail-label">时限</span><span class="quest-detail-value">' + q.deadline + '</span></div>' +
            '<div class="quest-detail-row"><span class="quest-detail-label">奖励</span><span class="quest-detail-value" style="color:var(--success);">' + q.reward + '</span></div>' +
            (q.penalty !== '-' ? '<div class="quest-detail-row"><span class="quest-detail-label">惩罚</span><span class="quest-detail-value" style="color:var(--danger);">' + q.penalty + '</span></div>' : '') +
            '</div></div></div>';
    }).join('');
}

function toggleQuestDetail(index) {
    const desc = document.getElementById('questDesc' + index);
    if (desc) {
        desc.style.display = desc.style.display === 'none' ? 'block' : 'none';
    }
}

