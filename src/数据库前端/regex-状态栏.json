
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RPG 角色面板 - 羊皮纸风格</title>
    <style>
        /* ==================== 羊皮纸主题变量 ==================== */
        :root {
            /* 羊皮纸背景 */
            --parchment-bg: #f4e4bc;
            --parchment-dark: #d4c4a0;
            --parchment-light: #faf0dc;
            --parchment-card: #faf6eb;

            /* 墨水/文字 */
            --ink-primary: #3d2914;
            --ink-secondary: #5c4033;
            --ink-light: #8b7355;

            /* 装饰/边框 */
            --border-gold: #b8860b;
            --border-dark: #8b4513;
            --accent-red: #8b0000;
            --accent-blue: #1e3a5f;

            /* 资源条颜色 */
            --hp-color: #c0392b;
            --hp-bg: #e74c3c;
            --sp-color: #d68910;
            --sp-bg: #f39c12;
            --mp-color: #2980b9;
            --mp-bg: #3498db;
            --exp-color: #8e44ad;

            /* 状态效果 */
            --success: #2e7d32;
            --warning: #f9a825;
            --danger: #c62828;

            /* 阴影 */
            --shadow-light: 2px 2px 8px rgba(61, 41, 20, 0.15);
            --shadow-medium: 4px 4px 12px rgba(61, 41, 20, 0.25);
        }

        /* 战斗模式变体 */
        .battle-mode {
            --parchment-bg: #e8d4c4;
            --parchment-dark: #c8b4a0;
            --parchment-light: #f0e0d0;
            --accent-red: #b22222;
        }

        /* ==================== 基础样式 ==================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Microsoft YaHei', 'Segoe UI', serif;
            background: var(--parchment-bg);
            background-image:
                url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
            color: var(--ink-primary);
            padding: 10px;
            padding-bottom: 0;
            transition: background 0.5s ease;
        }

        /* ==================== 主容器 ==================== */
        .main-container {
            max-width: 800px;
            margin: 0 auto;
            display: none;
        }

        .main-container.active {
            display: block;
        }

        /* ==================== 羊皮纸卡片 ==================== */
        .parchment-card {
            background: var(--parchment-card);
            border: 2px solid var(--border-dark);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 12px;
            box-shadow: var(--shadow-medium);
            position: relative;
        }

        .parchment-card::before {
            content: '';
            position: absolute;
            top: 4px;
            left: 4px;
            right: 4px;
            bottom: 4px;
            border: 1px solid var(--border-gold);
            border-radius: 4px;
            pointer-events: none;
            opacity: 0.5;
        }

        .card-title {
            font-size: 14px;
            font-weight: bold;
            color: var(--accent-red);
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border-dark);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-title::before {
            content: '✦';
            color: var(--border-gold);
        }

        /* ==================== 主角卡片布局 ==================== */
        .protagonist-card {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .protagonist-info {
            flex: 1;
            min-width: 200px;
        }

        .protagonist-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .character-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--border-gold), var(--border-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
            color: var(--parchment-light);
            border: 3px solid var(--border-gold);
            box-shadow: var(--shadow-light);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .avatar-upload-prompt {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0,0,0,0.6);
            color: white;
            text-align: center;
            font-size: 10px;
            padding: 2px 0;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .character-avatar:hover .avatar-upload-prompt {
            opacity: 1;
        }

        .character-name {
            font-size: 18px;
            font-weight: bold;
            color: var(--ink-primary);
        }

        .character-profession {
            font-size: 12px;
            color: var(--ink-light);
        }

        .level-badge {
            background: linear-gradient(135deg, #ffd700, #ff8c00);
            color: #1a1a1a;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            margin-left: auto;
        }

        /* 雷达图区域 */
        .radar-container {
            width: 200px;
            height: 200px;
            flex-shrink: 0;
        }

        #radarCanvas {
            width: 200px;
            height: 200px;
            cursor: pointer;
        }

        /* ==================== 资源条 ==================== */
        .resource-bars {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-top: 10px;
        }

        .resource-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .resource-label {
            width: 30px;
            font-size: 11px;
            font-weight: bold;
            color: var(--ink-secondary);
        }

        .resource-bar-container {
            flex: 1;
            height: 18px;
            background: rgba(0, 0, 0, 0.15);
            border-radius: 9px;
            overflow: hidden;
            position: relative;
            border: 1px solid var(--border-dark);
        }

        .resource-bar {
            height: 100%;
            border-radius: 8px;
            transition: width 0.5s ease;
            position: relative;
        }

        .resource-bar.hp { background: linear-gradient(90deg, var(--hp-color), var(--hp-bg)); }
        .resource-bar.sp { background: linear-gradient(90deg, var(--sp-color), var(--sp-bg)); }
        .resource-bar.mp { background: linear-gradient(90deg, var(--mp-color), var(--mp-bg)); }
        .resource-bar.exp { background: linear-gradient(90deg, #7b1fa2, var(--exp-color)); }

        .resource-value {
            position: absolute;
            right: 6px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 10px;
            font-weight: bold;
            color: #fff;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
        }

        /* ==================== 功能按钮区 ==================== */
        .action-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .action-btn {
            padding: 10px 20px;
            border: 2px solid var(--border-dark);
            border-radius: 6px;
            background: linear-gradient(180deg, var(--parchment-light), var(--parchment-dark));
            color: var(--ink-primary);
            font-size: 13px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: var(--shadow-light);
        }

        .action-btn:hover {
            background: linear-gradient(180deg, #fff, var(--parchment-light));
            transform: translateY(-2px);
            box-shadow: var(--shadow-medium);
        }

        .action-btn:active {
            transform: translateY(0);
        }

        .action-btn .icon {
            margin-right: 5px;
        }

        /* ==================== NPC列表 ==================== */
        .npc-list {
            display: flex;
            gap: 10px;
            overflow-x: auto;
            padding-bottom: 8px;
        }

        .npc-card {
            min-width: 100px;
            padding: 10px;
            background: var(--parchment-light);
            border: 1px solid var(--border-dark);
            border-radius: 8px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
        }

        .npc-card:hover {
            background: #fff;
            transform: translateY(-2px);
            box-shadow: var(--shadow-light);
        }

        .npc-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 8px;
            font-size: 16px;
            color: #fff;
        }

        .npc-name {
            font-size: 12px;
            font-weight: bold;
            color: var(--ink-primary);
        }

        .npc-profession {
            font-size: 10px;
            color: var(--ink-light);
        }

        /* ==================== 重要人物列表 ==================== */
        .character-list {
            display: flex;
            gap: 10px;
            overflow-x: auto;
            padding-bottom: 8px;
        }

        .character-card {
            min-width: 120px;
            padding: 10px;
            background: var(--parchment-light);
            border: 1px solid var(--border-dark);
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .character-card:hover {
            background: #fff;
            box-shadow: var(--shadow-light);
        }

        .character-card-header {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
        }

        .character-card-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--border-gold), var(--border-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #fff;
        }

        .character-card-name {
            font-size: 12px;
            font-weight: bold;
        }

        .character-card-level {
            font-size: 10px;
            color: var(--ink-light);
        }

        .mini-bar {
            height: 4px;
            background: rgba(0, 0, 0, 0.15);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 4px;
        }

        .mini-bar-fill {
            height: 100%;
            border-radius: 2px;
        }

        /* ==================== 自由点数提示样式 ==================== */
        .free-points-hint {
            position: absolute;
            top: -5px;
            right: -5px;
            background: linear-gradient(135deg, var(--accent-red), #c62828);
            color: #fff;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            display: flex;
            align-items: center;
            gap: 4px;
            animation: pulse 1.5s infinite;
            cursor: pointer;
            z-index: 10;
        }

        .free-points-hint:hover {
            transform: scale(1.1);
        }

        .hint-icon {
            font-size: 14px;
        }

        .hint-text {
            font-size: 10px;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        /* ==================== 战斗模式样式 ==================== */
        /* 战斗角色卡片网格 */
        .battle-character-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 12px;
            margin-bottom: 12px;
        }

        .battle-card {
            /* 继承羊皮纸卡片基础样式 */
        }

        .battle-portraitser {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 12px;
        }

        .battle-portrait {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            overflow: hidden;
            background: var(--parchment-dark);
            border: 2px solid var(--border-gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            color: var(--ink-light);
        }

        .battle-name {
            font-weight: bold;
            font-size: 1.1em;
            margin-top: 8px;
            color: var(--ink-primary);
        }

        .battle-skills {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .skill-slot {
            padding: 12px 8px;
            background: var(--parchment-light);
            border: 2px solid var(--border-dark);
            border-radius: 8px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .skill-slot:hover {
            background: #fff;
            transform: translateY(-2px);
        }

        .skill-slot.selected {
            border-color: var(--accent-red);
            background: rgba(139, 0, 0, 0.1);
        }

        .skill-slot.disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .skill-icon {
            font-size: 24px;
            margin-bottom: 4px;
        }

        .skill-name {
            font-size: 11px;
            font-weight: bold;
            color: var(--ink-primary);
        }

        .skill-cost {
            font-size: 9px;
            color: var(--ink-light);
            margin-top: 2px;
        }

        .skill-check {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 16px;
            height: 16px;
            background: var(--accent-red);
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 10px;
        }

        .skill-slot.selected .skill-check {
            display: flex;
        }

        /* 已选技能显示 */
        .selected-skills {
            margin-top: 10px;
            padding: 10px;
            background: rgba(0, 0, 0, 0.05);
            border-radius: 6px;
            min-height: 40px;
        }

        .selected-skills-label {
            font-size: 11px;
            color: var(--ink-light);
            margin-bottom: 5px;
        }

        .selected-skills-list {
            font-size: 12px;
            color: var(--ink-primary);
        }

        /* 战斗操作按钮 */
        .battle-actions {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .battle-actions .action-btn {
            flex: 1;
        }

        /* ==================== 弹窗样式 ==================== */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(61, 41, 20, 0.7);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            padding: 10px;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal {
            background: var(--parchment-card);
            border: 3px solid var(--border-dark);
            border-radius: 12px;
            padding: 20px;
            max-width: 500px;
            width: 100%;
            max-height: 85vh;
            overflow-y: auto;
            position: relative;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .modal::before {
            content: '';
            position: absolute;
            top: 6px;
            left: 6px;
            right: 6px;
            bottom: 6px;
            border: 1px solid var(--border-gold);
            border-radius: 8px;
            pointer-events: none;
            opacity: 0.5;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--border-dark);
        }

        .modal-title {
            font-size: 16px;
            font-weight: bold;
            color: var(--accent-red);
        }

        .modal-close {
            background: none;
            border: none;
            color: var(--ink-primary);
            font-size: 24px;
            cursor: pointer;
            padding: 0 5px;
        }

        .modal-close:hover {
            color: var(--accent-red);
        }

        /* ==================== 装备人体布局 ==================== */
        .equipment-layout {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            padding: 15px;
        }

        .equip-row {
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .equip-slot {
            width: 70px;
            height: 70px;
            background: var(--parchment-light);
            border: 2px solid var(--border-dark);
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .equip-slot:hover {
            background: #fff;
            transform: scale(1.05);
        }

        .equip-slot.empty {
            opacity: 0.6;
        }

        .equip-slot.empty:hover {
            opacity: 1;
            border-color: var(--border-gold);
        }

        .equip-slot-icon {
            font-size: 24px;
        }

        .equip-slot-name {
            font-size: 9px;
            text-align: center;
            margin-top: 2px;
            color: var(--ink-secondary);
            max-width: 65px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .equip-slot-label {
            position: absolute;
            top: -8px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--parchment-card);
            padding: 0 5px;
            font-size: 10px;
            color: var(--ink-light);
            white-space: nowrap;
        }

        /* 装备名称浮窗 */
        .equip-slot-tooltip {
            position: absolute;
            bottom: calc(100% + 8px);
            left: 50%;
            transform: translateX(-50%);
            background: var(--ink-primary);
            color: var(--parchment-light);
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s;
            z-index: 10;
        }

        .equip-slot:not(.empty):hover .equip-slot-tooltip {
            opacity: 1;
        }

        /* 装备选择列表弹窗 */
        .equip-select-list {
            max-height: 200px;
            overflow-y: auto;
            margin: 10px 0;
        }

        .equip-select-item {
            display: flex;
            align-items: center;
            padding: 8px 10px;
            border: 1px solid var(--border-dark);
            border-radius: 6px;
            margin-bottom: 6px;
            cursor: pointer;
            transition: all 0.2s;
            background: var(--parchment-light);
        }

        .equip-select-item:hover {
            background: #fff;
            border-color: var(--border-gold);
            transform: translateX(3px);
        }

        .equip-select-item:last-child {
            margin-bottom: 0;
        }

        .equip-select-icon {
            font-size: 20px;
            margin-right: 10px;
        }

        .equip-select-info {
            flex: 1;
        }

        .equip-select-name {
            font-weight: bold;
            color: var(--ink-primary);
            font-size: 13px;
        }

        .equip-select-stats {
            font-size: 11px;
            color: var(--success);
            margin-top: 2px;
        }

        .equip-select-empty {
            text-align: center;
            padding: 20px;
            color: var(--ink-light);
            font-size: 13px;
        }

        /* 人体轮廓装饰 */
        .body-outline {
            position: absolute;
            width: 100%;
            height: 100%;
            pointer-events: none;
            opacity: 0.1;
        }

        /* ==================== 任务弹窗样式 ==================== */
        .quest-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 15px;
        }

        .quest-tab {
            flex: 1;
            padding: 8px 12px;
            background: var(--parchment-light);
            border: 2px solid var(--border-dark);
            border-radius: 6px;
            color: var(--ink-secondary);
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .quest-tab:hover {
            background: var(--parchment-card);
        }

        .quest-tab.active {
            background: var(--border-gold);
            color: #fff;
            border-color: var(--border-dark);
        }

        .quest-list {
            max-height: 400px;
            overflow-y: auto;
        }

        .quest-item {
            background: var(--parchment-light);
            border: 2px solid var(--border-dark);
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .quest-item:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-light);
        }

        .quest-item.main-quest {
            border-left: 4px solid var(--accent-red);
        }

        .quest-item.side-quest {
            border-left: 4px solid var(--accent-blue);
        }

        .quest-item-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .quest-item-name {
            font-size: 14px;
            font-weight: bold;
            color: var(--ink-primary);
        }

        .quest-item-type {
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 10px;
            background: var(--border-gold);
            color: #fff;
        }

        .quest-item-type.main {
            background: var(--accent-red);
        }

        .quest-item-type.side {
            background: var(--accent-blue);
        }

        .quest-item-progress {
            font-size: 11px;
            color: var(--success);
            margin-bottom: 6px;
        }

        .quest-item-desc {
            font-size: 12px;
            color: var(--ink-secondary);
            line-height: 1.4;
            margin-bottom: 8px;
        }

        .quest-item-meta {
            display: flex;
            gap: 15px;
            font-size: 10px;
            color: var(--ink-light);
        }

        .quest-detail-content {
            padding: 10px 0;
            border-top: 1px solid var(--border-dark);
            margin-top: 10px;
        }

        .quest-detail-row {
            display: flex;
            margin-bottom: 8px;
            font-size: 12px;
        }

        .quest-detail-label {
            width: 70px;
            color: var(--ink-light);
            flex-shrink: 0;
        }

        .quest-detail-value {
            color: var(--ink-primary);
            flex: 1;
        }

        /* ==================== 背包网格 ==================== */
        .inventory-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
        }

        .inventory-item {
            aspect-ratio: 1;
            background: var(--parchment-light);
            border: 1px solid var(--border-dark);
            border-radius: 6px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            padding: 5px;
            position: relative;
        }

        .inventory-item:hover {
            background: #fff;
            transform: scale(1.05);
            box-shadow: var(--shadow-light);
        }

        .inventory-item.equipable {
            border-color: var(--border-gold);
        }

        .inventory-item-icon {
            font-size: 24px;
        }

        .inventory-item-name {
            font-size: 9px;
            text-align: center;
            margin-top: 2px;
            color: var(--ink-secondary);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            width: 100%;
        }

        .inventory-item-count {
            position: absolute;
            bottom: 2px;
            right: 4px;
            font-size: 10px;
            font-weight: bold;
            color: var(--ink-primary);
        }

        /* 筛选标签 */
        .filter-tabs {
            display: flex;
            gap: 5px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }

        .filter-tab {
            padding: 5px 12px;
            border: 1px solid var(--border-dark);
            border-radius: 15px;
            background: var(--parchment-light);
            font-size: 11px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .filter-tab:hover,
        .filter-tab.active {
            background: var(--border-gold);
            color: #fff;
        }

        /* ==================== 技能列表 ==================== */
        .skill-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .skill-item {
            padding: 12px;
            background: var(--parchment-light);
            border: 1px solid var(--border-dark);
            border-radius: 8px;
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .skill-item-icon {
            font-size: 28px;
            flex-shrink: 0;
        }

        .skill-item-info {
            flex: 1;
        }

        .skill-item-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 4px;
        }

        .skill-item-name {
            font-size: 14px;
            font-weight: bold;
            color: var(--ink-primary);
        }

        .skill-item-level {
            font-size: 11px;
            color: var(--border-gold);
            font-weight: bold;
        }

        .skill-item-meta {
            font-size: 11px;
            color: var(--ink-light);
            margin-bottom: 4px;
        }

        .skill-item-desc {
            font-size: 11px;
            color: var(--ink-secondary);
        }

        .skill-item-proficiency {
            margin-top: 6px;
        }

        .proficiency-bar {
            height: 6px;
            background: rgba(0, 0, 0, 0.15);
            border-radius: 3px;
            overflow: hidden;
        }

        .proficiency-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--border-gold), #ffd700);
            border-radius: 3px;
        }

        .proficiency-text {
            font-size: 9px;
            color: var(--ink-light);
            margin-top: 2px;
            text-align: right;
        }

        /* ==================== 角色详情 ==================== */
        .character-detail-header {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
        }

        .character-detail-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            color: #fff;
            flex-shrink: 0;
        }

        .character-detail-info {
            flex: 1;
        }

        .character-detail-name {
            font-size: 20px;
            font-weight: bold;
            color: var(--ink-primary);
            margin-bottom: 4px;
        }

        .character-detail-meta {
            font-size: 12px;
            color: var(--ink-light);
            margin-bottom: 10px;
        }

        .character-detail-resources {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .character-attributes {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
            margin-bottom: 15px;
        }

        .attribute-item {
            display: flex;
            justify-content: space-between;
            padding: 6px 10px;
            background: var(--parchment-light);
            border-radius: 4px;
            font-size: 12px;
        }

        .attribute-name {
            color: var(--ink-light);
        }

        .attribute-value {
            font-weight: bold;
            color: var(--ink-primary);
        }

        .character-info-section {
            margin-bottom: 15px;
            padding: 10px;
            background: rgba(0,0,0,0.03);
            border-radius: 8px;
        }

        .info-row {
            display: flex;
            margin-bottom: 8px;
            font-size: 12px;
        }

        .info-row:last-child {
            margin-bottom: 0;
        }

        .info-label {
            width: 70px;
            flex-shrink: 0;
            color: var(--ink-light);
        }

        .info-value {
            flex: 1;
            color: var(--ink-primary);
        }

        .character-skills {
            margin-bottom: 15px;
        }

        .character-skills-title {
            font-size: 12px;
            font-weight: bold;
            color: var(--ink-secondary);
            margin-bottom: 8px;
        }

        .character-skill-tag {
            display: inline-block;
            padding: 4px 10px;
            background: var(--parchment-light);
            border: 1px solid var(--border-dark);
            border-radius: 12px;
            font-size: 11px;
            margin-right: 5px;
            margin-bottom: 5px;
        }

        .interaction-buttons {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .interaction-btn {
            padding: 8px 16px;
            border: 2px solid var(--border-dark);
            border-radius: 6px;
            background: var(--parchment-light);
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .interaction-btn:hover {
            background: var(--border-gold);
            color: #fff;
        }

        /* ==================== 加点弹窗 ==================== */
        .point-allocation {
            margin-bottom: 15px;
        }

        .allocation-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid var(--parchment-dark);
        }

        .allocation-name {
            font-size: 13px;
            width: 50px;
        }

        .allocation-current {
            font-size: 16px;
            font-weight: bold;
            width: 30px;
            text-align: center;
        }

        .allocation-controls {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .allocation-btn {
            width: 28px;
            height: 28px;
            border: 2px solid var(--border-dark);
            border-radius: 50%;
            background: var(--parchment-light);
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .allocation-btn:hover:not(:disabled) {
            background: var(--border-gold);
            color: #fff;
        }

        .allocation-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        .allocation-change {
            font-size: 13px;
            min-width: 40px;
            text-align: center;
        }

        .allocation-change.positive { color: var(--success); }
        .allocation-change.negative { color: var(--danger); }

        .free-points-display {
            text-align: center;
            padding: 10px;
            background: rgba(184, 134, 11, 0.1);
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .free-points-value {
            font-size: 28px;
            font-weight: bold;
            color: var(--border-gold);
        }

        .free-points-label {
            font-size: 11px;
            color: var(--ink-light);
        }

        .preview-section {
            background: rgba(0, 0, 0, 0.05);
            border-radius: 8px;
            padding: 12px;
            margin-top: 15px;
        }

        .preview-title {
            font-size: 11px;
            color: var(--ink-light);
            margin-bottom: 8px;
        }

        .preview-items {
            display: flex;
            justify-content: space-around;
        }

        .preview-item {
            text-align: center;
        }

        .preview-label {
            font-size: 10px;
            color: var(--ink-light);
        }

        .preview-values {
            font-size: 13px;
        }

        .preview-old {
            color: var(--ink-light);
            text-decoration: line-through;
        }

        .preview-new {
            color: var(--success);
            font-weight: bold;
        }

        .modal-buttons {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .modal-btn {
            flex: 1;
            padding: 12px;
            border: 2px solid var(--border-dark);
            border-radius: 8px;
            font-size: 13px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
        }

        .modal-btn.primary {
            background: var(--border-gold);
            color: #fff;
        }

        .modal-btn.primary:hover {
            background: var(--accent-red);
        }

        .modal-btn.secondary {
            background: var(--parchment-light);
            color: var(--ink-primary);
        }

        .modal-btn.secondary:hover {
            background: var(--parchment-dark);
        }

        /* ==================== 目标选择 ==================== */
        .target-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 300px;
            overflow-y: auto;
        }

        .target-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            background: var(--parchment-light);
            border: 2px solid transparent;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .target-item:hover {
            background: #fff;
        }

        .target-item.selected {
            border-color: var(--accent-red);
            background: rgba(139, 0, 0, 0.1);
        }

        .target-avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #fff;
        }

        .target-item.ally .target-avatar {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
        }

        .target-item.enemy .target-avatar {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
        }

        .target-info {
            flex: 1;
        }

        .target-name {
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 4px;
        }

        .target-status {
            display: flex;
            gap: 10px;
            font-size: 11px;
            color: var(--ink-light);
        }

        /* ==================== 响应式设计 ==================== */
        @media (min-width: 768px) {
            .protagonist-card {
                flex-wrap: nowrap;
            }

            .radar-container {
                width: 200px;
                height: 200px;
            }

            .battle-skills {
                grid-template-columns: repeat(6, 1fr);
            }

            .inventory-grid {
                grid-template-columns: repeat(5, 1fr);
            }
        }

        @media (max-width: 400px) {
            .battle-skills {
                grid-template-columns: repeat(2, 1fr);
            }

            .inventory-grid {
                grid-template-columns: repeat(3, 1fr);
            }

            .equip-slot {
                width: 60px;
                height: 60px;
            }
        }

        /* ==================== 加载状态 ==================== */
        .loading {
            text-align: center;
            padding: 30px;
            color: var(--ink-light);
        }

        .loading-spinner {
            width: 30px;
            height: 30px;
            border: 3px solid var(--parchment-dark);
            border-top-color: var(--border-gold);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 10px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ==================== 地图面板样式 ==================== */
        #mapPanel {
            margin-top: 12px;
        }

        #mapPanel .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            padding-bottom: 8px;
            border-bottom: 2px solid var(--border-dark);
        }

        #mapPanel .section-title {
            font-size: 16px;
            font-weight: bold;
            color: var(--accent-red);
            margin: 0;
        }

        #mapPanel .header-actions {
            display: flex;
            gap: 8px;
        }

        #mapPanel .btn-action {
            background: var(--parchment-dark);
            border: 1px solid var(--border-dark);
            border-radius: 4px;
            padding: 4px 8px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }

        #mapPanel .btn-action:hover {
            background: var(--border-gold);
            color: white;
        }

        #mapPanel .btn-close {
            background: var(--accent-red);
            color: white;
            border: none;
            border-radius: 4px;
            width: 24px;
            height: 24px;
            cursor: pointer;
            font-size: 14px;
        }

        .map-location {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 0;
            border-bottom: 1px solid var(--border-dark);
            margin-bottom: 10px;
        }

        .map-location .location-label {
            color: var(--ink-secondary);
            font-weight: bold;
        }

        .map-location .location-name {
            color: var(--ink-primary);
            font-weight: bold;
        }

        .map-mode {
            margin-left: auto;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 11px;
            background: var(--parchment-dark);
        }

        .map-mode.battle {
            background: #ffebee;
            color: #c62828;
        }

        .map-container {
            background: var(--parchment-light);
            border: 2px solid var(--border-dark);
            border-radius: 8px;
            padding: 10px;
            position: relative;
            min-height: 250px;
            overflow: hidden;
        }

        .map-viewport {
            width: 100%;
            min-height: 226px;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            touch-action: none;
            user-select: none;
            cursor: grab;
        }

        .map-viewport.dragging {
            cursor: grabbing;
        }

        .map-zoom-controls {
            position: absolute;
            top: 14px;
            right: 14px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            z-index: 20;
        }

        .map-zoom-btn {
            width: 32px;
            height: 32px;
            border: 1px solid var(--border-dark);
            border-radius: 6px;
            background: rgba(255, 248, 220, 0.92);
            color: var(--ink-primary);
            font-size: 20px;
            font-weight: bold;
            line-height: 1;
            cursor: pointer;
            box-shadow: var(--shadow-light);
            transition: all 0.2s ease;
        }

        .map-zoom-btn:hover {
            background: var(--border-gold);
            color: #fff;
            transform: translateY(-1px);
        }

        #mapSvg {
            display: block;
            width: 100%;
            max-width: 100%;
            height: auto;
            background: var(--parchment-card);
            border-radius: 4px;
            transform-origin: center center;
            transition: transform 0.12s ease-out;
            will-change: transform;
        }

        .battle-mode #mapSvg {
            border: 2px solid var(--accent-red);
        }

        .map-legend {
            display: flex;
            gap: 15px;
            justify-content: center;
            padding: 8px;
            border-top: 1px solid var(--border-dark);
            margin-top: 10px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            color: var(--ink-secondary);
        }

        .dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            border: 2px solid;
            background: transparent;
        }

        .dot.player { border-color: #2e7d32; }
        .dot.friendly { border-color: #1e3a5f; }
        .dot.enemy { border-color: #c62828; }

        .map-status {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 6px 0;
            margin-top: 8px;
            font-size: 12px;
            color: var(--ink-light);
        }

        .status-indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--success);
        }

        .status-indicator.loading {
            background: var(--warning);
            animation: pulse 1s infinite;
        }

        .status-indicator.error {
            background: var(--danger);
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* ==================== 战斗地图面板样式 ==================== */
        #battleMapPanel {
            margin-bottom: 12px;
            border-color: var(--accent-red);
        }

        #battleMapPanel::before {
            border-color: #ff6b6b;
        }

        .battle-map-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid var(--accent-red);
            margin-bottom: 10px;
        }

        .battle-map-location {
            font-weight: bold;
            color: var(--ink-primary);
        }

        .battle-map-container {
            background: linear-gradient(135deg, #f0e0d0, #e8d4c4);
            border: 2px solid var(--accent-red);
            border-radius: 8px;
            padding: 10px;
            position: relative;
            min-height: 280px;
            overflow: hidden;
        }

        .battle-map-container .map-viewport {
            min-height: 256px;
        }

        #battleMapSvg {
            display: block;
            width: 100%;
            max-width: 100%;
            height: auto;
            border-radius: 4px;
            transform-origin: center center;
            transition: transform 0.12s ease-out;
            will-change: transform;
        }

        .battle-map-legend {
            display: flex;
            gap: 20px;
            justify-content: center;
            padding: 8px;
            border-top: 1px solid var(--accent-red);
            margin-top: 10px;
        }

        .battle-map-legend .legend-item {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            color: var(--ink-secondary);
        }

        /* 地图通用样式增强 */
        .map-container svg, .battle-map-container svg {
            filter: drop-shadow(2px 2px 4px rgba(61, 41, 20, 0.2));
        }

        /* 角色标记动画 */
        .character-marker {
            transition: transform 0.2s ease;
            transform-origin: center center;
        }

        .character-marker:hover {
            transform: scale(1.2);
            filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.8));
        }

        /* ==================== 设置面板 ==================== */
        .settings-btn {
            position: fixed;
            top: 10px;
            right: 10px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--border-gold), var(--border-dark));
            border: 3px solid var(--border-gold);
            color: var(--parchment-light);
            font-size: 20px;
            cursor: pointer;
            z-index: 1000;
            box-shadow: var(--shadow-medium);
            transition: all 0.3s ease;
        }

        .settings-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 0 15px rgba(184, 134, 11, 0.5);
        }

        .settings-panel {
            position: fixed;
            top: 60px;
            right: 10px;
            width: 300px;
            max-height: 400px;
            overflow-y: auto;
            background: var(--parchment-card);
            border: 2px solid var(--border-dark);
            border-radius: 8px;
            box-shadow: var(--shadow-medium);
            z-index: 999;
            padding: 15px;
        }

        .settings-panel::before {
            content: '';
            position: absolute;
            top: 4px;
            left: 4px;
            right: 4px;
            bottom: 4px;
            border: 1px solid var(--border-gold);
            border-radius: 4px;
            pointer-events: none;
            opacity: 0.5;
        }

        .settings-panel h3 {
            color: var(--accent-red);
            margin-bottom: 15px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border-dark);
            font-size: 16px;
        }

        .setting-item {
            margin-bottom: 15px;
        }

        .setting-item label {
            display: block;
            margin-bottom: 5px;
            color: var(--ink-primary);
            font-weight: bold;
            font-size: 13px;
        }

        .setting-item select,
        .setting-item input {
            width: 100%;
            padding: 8px;
            border: 1px solid var(--border-dark);
            border-radius: 4px;
            background: var(--parchment-light);
            color: var(--ink-primary);
            font-size: 13px;
            font-family: 'Microsoft YaHei', 'Segoe UI', serif;
        }

        .settings-panel button {
            width: 100%;
            padding: 10px;
            margin-top: 10px;
            background: linear-gradient(135deg, var(--border-gold), var(--border-dark));
            border: 2px solid var(--border-gold);
            border-radius: 6px;
            color: var(--parchment-light);
            font-weight: bold;
            cursor: pointer;
            font-size: 14px;
            font-family: 'Microsoft YaHei', 'Segoe UI', serif;
            transition: all 0.3s ease;
        }

        .settings-panel button:hover {
            transform: scale(1.02);
            box-shadow: 0 0 10px rgba(184, 134, 11, 0.4);
        }

        #customApiSettings {
            display: none;
        }
    </style>
</head>
<body>
    <!-- 设置设置 -->
    <button class="settings-btn" onclick="toggleSettingsPanel()" title="设置">⚙️</button>

    <!-- 设置面板 -->
    <div id="settingsPanel" class="settings-panel" style="display: none;">
        <h3>API 设置</h3>
        <div class="setting-item">
            <label>API 来源：</label>
            <select id="apiSource" onchange="onApiSourceChange()">
                <option value="database">使用数据库 API</option>
                <option value="custom">自定义 API</option>
            </select>
        </div>
        <div id="customApiSettings">
            <div class="setting-item">
                <label>API 地址：</label>
                <input type="text" id="customApiUrl" placeholder="http://localhost:5000/api/chat">
            </div>
            <div class="setting-item">
                <label>API Key：</label>
                <input type="password" id="customApiKey" placeholder="输入 API Key">
            </div>
            <div class="setting-item">
                <label>模型名称：</label>
                <input type="text" id="customModelName" placeholder="gpt-4">
            </div>
        </div>
        <h3>地图设置</h3>
        <div class="setting-item">
