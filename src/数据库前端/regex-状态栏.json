    </div>
<script>
// ==================== 全局状态 ====================
const GameState = {
    currentMode: 'normal',
    protagonist: null,
    characters: [],
    skills: [],
    inventory: [],
    equipment: {},
    battleState: null,
    // 标志：正在写入表格中，用于阻止 loadTableData 在写入期间被触发
    isWritingToTables: false,
    // 标志：正在将当前合并态固化到最新楼层，避免跨楼层重新初始化时回档
    isPersistingSnapshot: false,
    battleCharacters: [],  // 战斗场景中的角色（从战斗场景表读取）
    selectedSkills: [],
    pendingAllocation: {},
    currentNpc: null,
    currentFilter: 'all',
    quests: [],  // 任务列表

    // 基础属性（不含装备加成）- 用于前端显示和计算
    baseAttrs: { str: 0, dex: 0, con: 0, int: 0, wis: 0, cha: 0 },
    // 装备加成缓存
    equipmentBonus: { str: 0, dex: 0, con: 0, int: 0, wis: 0, cha: 0 },
    // 上次装备哈希，用于检测变化
    lastEquipmentHash: '',

    // 自由点数系统（前端计算，使用 localStorage 持久化）
    freePoints: 0,
    usedFreePoints: 0,  // 已使用的自由点数（从 localStorage 加载）
    lastRecordedLevel: 0,  // 上次记录的等级，用于检测升级

    attrNames: { str: '力量', dex: '敏捷', con: '体质', int: '智力', wis: '感知', cha: '魅力' },
    attrKeys: { '力量': 'str', '敏捷': 'dex', '体质': 'con', '智力': 'int', '感知': 'wis', '魅力': 'cha' },

    calcMaxHP(con) { return con * 10 + 50; },
    calcMaxSP(con, str) { return con * 5 + str * 3 + 20; },
    calcMaxMP(int) { return int * 8 + 20; },

    // 计算当前装备的总加成
    calcEquipmentBonus() {
        const bonus = { str: 0, dex: 0, con: 0, int: 0, wis: 0, cha: 0 };
        const attrMap = this.attrKeys;

        for (const slot in this.equipment) {
            const equip = this.equipment[slot];
            if (equip && equip.stats) {
                equip.stats.split(',').forEach(s => {
                    const trimmed = s.trim();
                    const m = trimmed.match(/(.+)\+(\d+)/);
                    if (m) {
                        const attrName = m[1].trim();
                        const attrKey = attrMap[attrName] || attrName.toLowerCase().substring(0, 3);
                        if (bonus.hasOwnProperty(attrKey)) {
                            bonus[attrKey] += parseInt(m[2]);
                        }
                    }
                });
            }
        }
        return bonus;
    },

    // 生成装备哈希用于检测变化
    getEquipmentHash() {
        return JSON.stringify(this.equipment);
    },

    // 从总属性反推基础属性
    deriveBaseAttrs(totalAttrs) {
        const bonus = this.calcEquipmentBonus();
        this.equipmentBonus = bonus;
        this.baseAttrs = {
            str: totalAttrs.str - bonus.str,
            dex: totalAttrs.dex - bonus.dex,
            con: totalAttrs.con - bonus.con,
            int: totalAttrs.int - bonus.int,
            wis: totalAttrs.wis - bonus.wis,
            cha: totalAttrs.cha - bonus.cha
        };
        return this.baseAttrs;
    },

    // 计算总属性（基础+加成）
    getTotalAttrs() {
        return {
            str: this.baseAttrs.str + this.equipmentBonus.str,
            dex: this.baseAttrs.dex + this.equipmentBonus.dex,
            con: this.baseAttrs.con + this.equipmentBonus.con,
            int: this.baseAttrs.int + this.equipmentBonus.int,
            wis: this.baseAttrs.wis + this.equipmentBonus.wis,
            cha: this.baseAttrs.cha + this.equipmentBonus.cha
        };
    }
};

// ==================== 初始化 ====================
document.addEventListener('DOMContentLoaded', async function() {
    // 使用 window 对象上的全局标志防止跨实例重复初始化
    if (window.__rpgFrontendInitialized) {
        console.log('[RPG前端] 已经初始化过，跳过重复初始化');
        return;
    }
    window.__rpgFrontendInitialized = true;

    console.log('[RPG前端] 首次初始化...');

    // 先加载表格数据（地图系统需要从中获取当前位置）
    // 注意：loadTableData 内部会调用 debouncedInitMapSystem，无需在此重复调用
    await loadTableData();

    // 移除重复的 initMapSystem 调用，因为 loadTableData 内部已经会调用
    // await initMapSystem();

    initAvatarUpload(); // 初始化头像上传功能
    loadSettings(); // 加载用户设置

    // 注册表格更新回调
    const api = getAutoCardAPI();
    if (api) {
        api.registerTableUpdateCallback(loadTableData);
    }
});

// 获取AutoCardUpdaterAPI（可能在父窗口中）
function getAutoCardAPI() {
    // 优先使用父窗口的API（在iframe中运行时）
    if (typeof parent !== 'undefined' && parent.AutoCardUpdaterAPI) {
        return parent.AutoCardUpdaterAPI;
    }
    // 其次使用当前窗口的API
    if (window.AutoCardUpdaterAPI) {
        return window.AutoCardUpdaterAPI;
    }
    return null;
}

// ==================== 数据加载 ====================
// 记录上次的主角位置，用于判断是否需要更新地图
let lastKnownLocation = '';
// 记录上次的战斗角色列表（用于角色变化检测）
let lastBattleCharacters = null;
// 是否正在加载数据
let isLoadingData = false;

// 获取全局防抖状态（跨 iframe 共享）
function getGlobalDebounceState() {
    // 尝试使用父窗口的全局状态（如果在 iframe 中）
    try {
        if (typeof parent !== 'undefined' && parent.__rpgDebounceState) {
            return parent.__rpgDebounceState;
        }
    } catch (e) {
        // 跨域问题，忽略
    }
    // 使用当前窗口的全局状态
    if (!window.__rpgDebounceState) {
        window.__rpgDebounceState = {
            lastLoadTime: 0,
            isLoading: false
        };
    }
    return window.__rpgDebounceState;
}

// 实际的数据加载函数
async function loadTableDataInternal() {
    // 如果正在写入表格，跳过加载以避免读取到中间状态
    if (GameState.isWritingToTables) {
        console.log('[RPG前端] 正在写入表格中，跳过数据加载');
        return;
    }

    const debounceState = getGlobalDebounceState();

    // 防抖检查：300ms 内的重复调用直接跳过
    const now = Date.now();
    if (now - debounceState.lastLoadTime < 300) {
        console.log('[RPG前端] 全局防抖：300ms内重复调用，跳过');
        return;
    }

    // 防止并发加载
    if (debounceState.isLoading) {
        console.log('[RPG前端] 数据正在加载中，跳过重复调用');
        return;
    }

    debounceState.lastLoadTime = now;
    debounceState.isLoading = true;
    isLoadingData = true;

    console.log('[RPG前端] 开始加载数据...');

    try {
        const api = getAutoCardAPI();
        if (!api) {
            console.warn('[RPG前端] API不可用，使用测试数据');
            loadTestData();
            updateUI();
            return;
        }

        console.log('[RPG前端] API可用，从表格读取数据');
        const jsonData = await api.exportTableAsJson();

        if (!jsonData) {
            console.warn('[RPG前端] 返回数据为空，使用测试数据');
            loadTestData();
            updateUI();
            return;
        }

        // 如果返回的是对象，直接使用；如果是字符串，解析JSON
        const tables = typeof jsonData === 'string' ? JSON.parse(jsonData) : jsonData;

        console.log('[RPG前端] 解析到的表格:', Object.keys(tables));

        // 在解析表格前，先获取当前位置用于后续比较
        const previousLocation = lastKnownLocation;

        // 从表格中获取当前位置（同步方式，避免异步竞态）
        let newLocation = '';
        for (const uid in tables) {
            const sheet = tables[uid];
            if (sheet && (sheet.name === '全局数据表' || sheet.name === '全局表')) {
                if (sheet.content && sheet.content.length >= 2) {
                    const headers = sheet.content[0];
                    const row = sheet.content[1];
                    const locationIndex = headers.indexOf('主角当前所在地点');
                    if (locationIndex !== -1 && locationIndex < row.length) {
                        newLocation = String(row[locationIndex] || '').trim();
                        break;
                    }
                }
            }
        }

        // 更新记录的位置
        lastKnownLocation = newLocation;

        // 保存旧的战斗角色数据用于比较
        const previousBattleCharacters = lastBattleCharacters;

        parseTables(tables);
        updateUI();

        // 检查当前模式
        const currentMode = GameState.currentMode;

        if (currentMode === 'battle') {
            // 战斗模式：检测角色变化
            const newBattleCharacters = GameState.battleCharacters;
            const charactersChanged = hasBattleCharactersChanged(previousBattleCharacters, newBattleCharacters);

            // 更新记录的战斗角色
            lastBattleCharacters = JSON.parse(JSON.stringify(newBattleCharacters));

            if (newLocation && newLocation !== previousLocation) {
                // 位置变化：完整重新初始化地图
                console.log('[RPG前端] 战斗模式-位置变化:', previousLocation, '->', newLocation, '，触发地图重新初始化');
                initMapSystem();
            } else if (charactersChanged) {
                // 角色变化但位置不变：只重新渲染角色（强制刷新）
                console.log('[RPG前端] 战斗模式-角色变化，重新渲染战斗地图');
                renderBattleMap(null, true);  // 传入 forceRefresh=true 强制重新获取角色数据
            } else {
                console.log('[RPG前端] 战斗模式-位置和角色均未变化，跳过地图更新');
            }
        } else {
            // 日常模式：只有位置变化时才更新地图
            if (newLocation && newLocation !== previousLocation) {
                console.log('[RPG前端] 日常模式-位置变化:', previousLocation, '->', newLocation, '，触发地图更新');
                initMapSystem();
            } else {
                console.log('[RPG前端] 日常模式-位置未变化，跳过地图更新');
            }
        }

        console.log('[RPG前端] 数据加载完成');
    } catch (e) {
        console.error('[RPG前端] 加载失败:', e);
        loadTestData();
        updateUI();
    } finally {
        isLoadingData = false;
        // 重置全局防抖状态
        const debounceState = getGlobalDebounceState();
        debounceState.isLoading = false;
    }
}

// 导出函数供回调使用
const loadTableData = loadTableDataInternal;

/**
 * 检测战斗角色是否发生变化
 * @param {Array} previous - 之前的战斗角色列表
 * @param {Array} current - 当前的战斗角色列表
 * @returns {boolean} - 是否发生变化
 */
function hasBattleCharactersChanged(previous, current) {
    // 首次加载，视为变化
    if (!previous) return true;

    // 数量变化
    if (previous.length !== current.length) {
        console.log('[RPG前端] 战斗角色数量变化:', previous.length, '->', current.length);
        return true;
    }

    // 比较每个角色的关键字段
    for (let i = 0; i < current.length; i++) {
        const prevChar = previous[i];
        const currChar = current[i];

        if (!prevChar || !currChar) return true;

        // 检查名称变化
        if (prevChar.name !== currChar.name) {
            console.log('[RPG前端] 角色名称变化:', prevChar.name, '->', currChar.name);
            return true;
        }

        // 检查阵营变化
        if (prevChar.faction !== currChar.faction) {
            console.log('[RPG前端] 角色阵营变化:', prevChar.faction, '->', currChar.faction);
            return true;
        }

        // 检查HP变化（死亡/存活状态）
        const prevHp = prevChar.res?.hp?.cur || 0;
        const currHp = currChar.res?.hp?.cur || 0;
        const prevMaxHp = prevChar.res?.hp?.max || 1;
        const currMaxHp = currChar.res?.hp?.max || 1;

        // 如果HP从>0变为0，或从0变为>0，视为变化
        if ((prevHp > 0 && currHp === 0) || (prevHp === 0 && currHp > 0)) {
            console.log('[RPG前端] 角色存活状态变化:', currChar.name);
            return true;
        }
    }

    return false;
}

function parseTables(tables) {
    console.log('[RPG前端] 开始解析表格数据...');
    console.log('[RPG前端] 收到的所有表格:', Object.keys(tables).map(uid => tables[uid]?.name).filter(Boolean));

    const parsedSheets = {};

    for (const uid in tables) {
        const sheet = tables[uid];
        if (!sheet) continue;

        const name = sheet.name;
        const content = sheet.content;

        if (!name) {
            console.log('[RPG前端] 跳过无名称的sheet:', uid);
            continue;
        }

        if (!content || content.length < 2) {
            console.log('[RPG前端] 跳过空表格:', name);
            continue;
        }

        const headers = content[0];
        const rows = content.slice(1);
        console.log('[RPG前端] 解析表格:', name, '列:', headers, '行数:', rows.length);

        parsedSheets[name] = {
            name,
            headers,
            rows
        };
    }

    const useSheet = (tableNames, handler) => {
        for (const tableName of tableNames) {
            const entry = parsedSheets[tableName];
            if (!entry) continue;

            const { name, headers, rows } = entry;
            const get = (row, colName, required = false) => {
                const idx = headers.indexOf(colName);
                if (idx === -1) {
                    if (required) {
                        console.warn('[RPG前端] 未找到列:', colName, '表格:', name, '可用列:', headers);
                    }
                    return undefined;
                }
                if (idx >= row.length) {
                    if (required) {
                        console.warn('[RPG前端] 列索引越界:', colName, '索引:', idx, '行长度:', row.length);
                    }
                    return undefined;
                }
                return row[idx];
            };

            handler(rows, get, name);
            return true;
        }
        return false;
    };

    useSheet(['全局数据表', '全局表'], (rows, get) => {
        if (rows[0]) {
            const mode = get(rows[0], '本轮故事模式') || '';
            GameState.currentMode = mode.includes('战斗') ? 'battle' : 'normal';
            console.log('[RPG前端] 全局数据 - 模式:', GameState.currentMode);
        }
    });

    // 先解析装备，再解析主角，避免基础属性在重初始化时被旧装备状态错误反推
    useSheet(['主角装备表'], (rows, get) => {
        parseEquipment(rows, get);
        console.log('[RPG前端] 装备:', GameState.equipment);
    });

    useSheet(['主角信息'], (rows, get) => {
        if (rows[0]) {
            parseProtagonist(rows[0], get);
            console.log('[RPG前端] 主角信息:', GameState.protagonist);
        }
    });

    useSheet(['背包物品表'], (rows, get) => {
        parseInventory(rows, get);
        console.log('[RPG前端] 背包物品数:', GameState.inventory.length);
    });

    useSheet(['重要人物表', '重要角色表'], (rows, get) => {
        parseCharacters(rows, get);
        console.log('[RPG前端] 重要人物数:', GameState.characters.length);
    });

    useSheet(['主角技能表'], (rows, get) => {
        parseSkills(rows, get);
        console.log('[RPG前端] 主角技能数:', GameState.skills.length);
    });

    useSheet(['任务与事件表'], (rows, get) => {
        parseQuests(rows, get);
        console.log('[RPG前端] 任务数:', GameState.quests.length);
    });

    useSheet(['战斗场景表'], (rows, get) => {
        parseBattleScene(rows, get);
        console.log('[RPG前端] 战斗场景人员数:', GameState.battleCharacters.length);
    });

    console.log('[RPG前端] 表格解析完成');
}

function parseProtagonist(row, get) {
    // 从表格读取的总属性（含装备加成）
    const totalAttrs = {
        str: parseInt(get(row, '力量')) || 10,
        dex: parseInt(get(row, '敏捷')) || 10,
        con: parseInt(get(row, '体质')) || 10,
        int: parseInt(get(row, '智力')) || 10,
        wis: parseInt(get(row, '感知')) || 10,
        cha: parseInt(get(row, '魅力')) || 10
    };

    // 反推基础属性（总属性 - 装备加成）
    const baseAttrs = GameState.deriveBaseAttrs(totalAttrs);

    // 获取当前等级
    const currentLevel = parseInt(get(row, '当前等级')) || 1;

    // 自由点数计算（使用 localStorage 持久化已使用点数）
    // 规则：1级不给初始点数，之后每升1级获得3点自由点数
    // 公式：剩余点数 = (等级-1) × 3 - 已使用点数

    // 从 localStorage 加载已使用的自由点数
    const savedUsedPoints = localStorage.getItem('rpg_usedFreePoints');
    GameState.usedFreePoints = savedUsedPoints ? parseInt(savedUsedPoints) : 0;

    // 计算总获得点数 = (等级-1) × 3
    const totalEarnedPoints = Math.max(0, (currentLevel - 1) * 3);

    // 剩余点数 = 总获得点数 - 已使用点数
    GameState.freePoints = Math.max(0, totalEarnedPoints - GameState.usedFreePoints);

    console.log('[RPG前端] 自由点数计算: 等级=', currentLevel, ', 总获得=', totalEarnedPoints, ', 已使用=', GameState.usedFreePoints, ', 剩余=', GameState.freePoints);

    GameState.lastRecordedLevel = currentLevel;

    // 计算资源上限（根据属性）
    const maxHP = GameState.calcMaxHP(totalAttrs.con);
    const maxSP = GameState.calcMaxSP(totalAttrs.con, totalAttrs.str);
    const maxMP = GameState.calcMaxMP(totalAttrs.int);

    // 从表格读取当前资源值
    const tableHP = parseRes(get(row, '生命值'));
    const tableSP = parseRes(get(row, '体力值'));
    const tableMP = parseRes(get(row, '法力值'));

    // 调整当前值：如果高于计算后的上限则设为上限
    const curHP = Math.min(tableHP.cur, maxHP);
    const curSP = Math.min(tableSP.cur, maxSP);
    const curMP = Math.min(tableMP.cur, maxMP);

    // 检查是否需要回写表格（上限变化或当前值超出上限）
    const needUpdate = (tableHP.max !== maxHP || tableSP.max !== maxSP || tableMP.max !== maxMP ||
                        tableHP.cur !== curHP || tableSP.cur !== curSP || tableMP.cur !== curMP);

    if (needUpdate) {
        // 异步回写表格（不阻塞当前解析）
        setTimeout(() => writeResourcesToTable(curHP, maxHP, curSP, maxSP, curMP, maxMP), 100);
    }

    GameState.protagonist = {
        name: get(row, '人物名称') || '未知',
        profession: get(row, '职业') || '-',
        level: currentLevel,
        exp: parseRes(get(row, '当前经验值')),
        freePoints: GameState.freePoints,  // 使用前端计算的自由点数
        // attrs存储总属性（用于显示）
        attrs: totalAttrs,
        // baseAttrs存储基础属性（用于计算和回写）
        baseAttrs: baseAttrs,
        res: {
            hp: { cur: curHP, max: maxHP },
            sp: { cur: curSP, max: maxSP },
            mp: { cur: curMP, max: maxMP }
        }
    };

    // 更新装备哈希
    GameState.lastEquipmentHash = GameState.getEquipmentHash();
}

// 回写资源值到表格
async function writeResourcesToTable(curHP, maxHP, curSP, maxSP, curMP, maxMP) {
    const api = getAutoCardAPI();
    if (!api || !api.updateRow) {
        console.warn('[RPG前端] API不可用，无法回写资源值');
        return;
    }

    try {
        const success = await api.updateRow('主角信息', 1, {
            '生命值': `${curHP}/${maxHP}`,
            '体力值': `${curSP}/${maxSP}`,
            '法力值': `${curMP}/${maxMP}`
        });

        if (success) {
            console.log('[RPG前端] 资源值已回写表格:', `HP:${curHP}/${maxHP}`, `SP:${curSP}/${maxSP}`, `MP:${curMP}/${maxMP}`);
        }
    } catch (e) {
        console.error('[RPG前端] 回写资源值失败:', e);
    }
}

function parseRes(val) {
    if (!val) return { cur: 100, max: 100 };
    const p = String(val).split('/');
    return { cur: parseInt(p[0]) || 0, max: parseInt(p[1]) || 100 };
}

function parseCharacters(rows, get) {
    GameState.characters = [];
    console.log('[RPG前端] 解析重要人物，行数:', rows.length);

    rows.forEach((row, idx) => {
        // 修复：检查行是否有效，而不是检查row[0]（第一列可能是null）
        if (!row || row.length === 0) return;

        // 检查关键字段是否有值
        const name = get(row, '姓名');
        if (!name) return;

        const inScene = get(row, '是否离场') === '否';

        GameState.characters.push({
            name: name || '未知',
            gender: get(row, '性别/年龄') || '-',
            intro: get(row, '一句话介绍') || '-',
            appearance: get(row, '外貌特征') || '-',
            profession: get(row, '职业') || '-',
            level: parseInt(get(row, '当前等级')) || 1,
            attrs: {
                str: parseInt(get(row, '力量')) || 10,
                dex: parseInt(get(row, '敏捷')) || 10,
                con: parseInt(get(row, '体质')) || 10,
                int: parseInt(get(row, '智力')) || 10,
                wis: parseInt(get(row, '感知')) || 10,
                cha: parseInt(get(row, '魅力')) || 10
            },
            res: {
                hp: parseRes(get(row, '生命值')),
                sp: parseRes(get(row, '体力值')),
                mp: parseRes(get(row, '法力值'))
            },
            skills: get(row, '当前技能') || '',
            inScene: inScene
        });

        console.log('[RPG前端] 重要人物', idx, ':', name, '在场:', inScene);
    });
}

function parseSkills(rows, get) {
    GameState.skills = [];
    console.log('[RPG前端] 解析技能，行数:', rows.length);
    rows.forEach((row, idx) => {
        // 修复：检查行是否有效，而不是检查row[0]（第一列可能是null）
        if (!row || row.length === 0) return;
        // 检查关键字段是否有值
        const skillName = get(row, '技能名称');
        if (!skillName) return;

        const skill = {
            name: skillName || '未知',
            type: get(row, '技能类型') || '主动',
            level: parseInt(get(row, '技能等级')) || 1,
            desc: get(row, '效果描述') || '-',
            costType: get(row, '消耗类型') || '法力',
            costVal: parseInt(get(row, '消耗数值')) || 0,
            prof: parseRes(get(row, '当前熟练度'))
        };
        GameState.skills.push(skill);
        console.log('[RPG前端] 技能', idx, ':', skill.name, '等级:', skill.level);
    });
}

function parseInventory(rows, get) {
    GameState.inventory = [];
    console.log('[RPG前端] 解析背包，行数:', rows.length);
    rows.forEach((row, idx) => {
        // 修复：检查行是否有效，而不是检查row[0]（第一列可能是null）
        if (!row || row.length === 0) return;
        // 检查关键字段是否有值
        const itemName = get(row, '物品名称');
        if (!itemName) return;

        const item = {
            name: itemName || '未知',
            count: parseInt(get(row, '数量')) || 1,
            desc: get(row, '描述/效果') || '-',
            category: get(row, '类别') || '杂物',
            slot: get(row, '装备部位') || '',
            stats: get(row, '属性加成') || '',
            effect: get(row, '特殊效果') || ''
        };
        GameState.inventory.push(item);
        console.log('[RPG前端] 物品', idx, ':', item.name, 'x', item.count);
    });
}

function normalizeTableEquipSlot(slot, equipType = '', accessoryIndex = 0) {
    if (!slot) return '';
    if (slot === '手部') return equipType === '武器_副手' ? '左手' : '右手';
    if (slot === '饰品') return accessoryIndex > 1 ? '饰品2' : '饰品1';
    return slot;
}

function normalizeInventoryEquipSlot(slot) {
    if (!slot) return '';
    if (slot === '左手' || slot === '右手') return '手部';
    if (slot === '饰品1' || slot === '饰品2') return '饰品';
    return slot;
}

function getEquipmentTableRows() {
    const slots = ['头部', '左手', '右手', '身体', '腿部', '饰品1', '饰品2'];
    const rows = [];
    let accessoryCount = 0;
    let handCount = 0;

    for (const slot of slots) {
        const equip = GameState.equipment[slot];
        if (!equip || !equip.name) continue;

        let tableSlot = equip.originalSlot || normalizeInventoryEquipSlot(slot) || slot;
        let tableType = equip.type || '';

        if (slot === '左手' || slot === '右手') {
            tableSlot = '手部';
            handCount++;
            if (tableType === '武器') {
                tableType = handCount === 1 ? '武器_主手' : '武器_副手';
            }
        }

        if (slot === '饰品1' || slot === '饰品2') {
            tableSlot = '饰品';
            accessoryCount++;
            if (tableType === '饰品') {
                tableType = accessoryCount === 1 ? '饰品1' : '饰品2';
            }
        }

        rows.push({
            slot,
            tableSlot,
            tableType,
            equip
        });
    }

    return rows;
}

function parseEquipment(rows, get) {
    GameState.equipment = {};
    console.log('[RPG前端] 解析装备，行数:', rows.length);

    let accessoryCount = 0;
    rows.forEach((row, idx) => {
        if (!row || row.length === 0) return;

        const rawSlot = get(row, '装备部位');
        const equipType = get(row, '装备类型') || '';
        if (rawSlot === '饰品') accessoryCount++;
        const slot = normalizeTableEquipSlot(rawSlot, equipType, accessoryCount);
        const equipName = get(row, '装备名称');
        const normalizedType = equipType.startsWith('武器') ? '武器' : (equipType.startsWith('饰品') ? '饰品' : equipType);

        if (slot && equipName) {
            GameState.equipment[slot] = {
                name: equipName,
                type: normalizedType,
                stats: get(row, '属性加成'),
                effect: get(row, '特殊效果'),
                originalSlot: rawSlot
            };
            console.log('[RPG前端] 装备', idx, ':', slot, '-', equipName, '原始部位:', rawSlot, '类型:', equipType);
        }
    });
}

function parseQuests(rows, get) {
    GameState.quests = [];
    console.log('[RPG前端] 解析任务，行数:', rows.length);
    rows.forEach((row, idx) => {
        // 修复：检查行是否有效，而不是检查row[0]（第一列可能是null）
        if (!row || row.length === 0) return;
        // 检查关键字段是否有值
        const questName = get(row, '任务名称');
        if (!questName) return;

        const quest = {
            name: questName || '未知任务',
            type: get(row, '任务类型') || '支线任务',
            publisher: get(row, '发布者') || '-',
            desc: get(row, '详细描述') || '-',
            progress: get(row, '当前进度') || '-',
            deadline: get(row, '任务时限') || '-',
            reward: get(row, '奖励') || '-',
            penalty: get(row, '惩罚') || '-'
        };
        GameState.quests.push(quest);
        console.log('[RPG前端] 任务', idx, ':', quest.name, '类型:', quest.type);
    });
}

// 解析战斗场景表
function parseBattleScene(rows, get) {
    GameState.battleCharacters = [];
    console.log('[RPG前端] 解析战斗场景，行数:', rows.length);
    rows.forEach((row, idx) => {
        if (!row || row.length === 0) return;

        const name = get(row, '角色名称');
        if (!name) return;

        const faction = get(row, '阵营') || '敌方';  // 阵营：主角方/敌方/中立
        const character = {
            name: name,
            faction: faction,
            isEnemy: faction === '敌方',  // 判断是否是敌人
            profession: get(row, '职业') || '-',
            level: parseInt(get(row, '当前等级')) || 1,
            attrs: {
                str: parseInt(get(row, '力量')) || 10,
                dex: parseInt(get(row, '敏捷')) || 10,
                con: parseInt(get(row, '体质')) || 10,
                int: parseInt(get(row, '智力')) || 10,
                wis: parseInt(get(row, '感知')) || 10,
                cha: parseInt(get(row, '魅力')) || 10
            },
            res: {
                hp: parseRes(get(row, '生命值')),
                sp: parseRes(get(row, '体力值')),
                mp: parseRes(get(row, '法力值'))
            },
            skills: get(row, '可用技能') || '',
            status: get(row, '当前状态') || '正常',
            characterType: get(row, '角色类型') || '杂兵'
        };
        GameState.battleCharacters.push(character);
        console.log('[RPG前端] 战斗角色', idx, ':', name, '阵营:', character.faction);
    });
}

