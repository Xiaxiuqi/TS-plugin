/**
 * 生成角色SVG元素（羊皮纸风格，支持战斗血条）
 * 主角：优先使用用户上传的自定义头像，否则用首字母
 * 其他角色：使用首字母圆头像
 */
function generateCharacterSvg(charData, type) {
    const { name, position, hp } = charData;

    // 只有主角使用自定义头像，其他角色都用首字母
    const customAvatar = (type === 'protagonist') ? AvatarCache.protagonist : null;

    const strokeColor = type === 'protagonist' ? '#2e7d32'
                      : type === 'ally' ? '#1e3a5f'
                      : '#c62828';

    const x = position ? position.x : 100;
    const y = position ? position.y : 100;
    const isBattle = GameState.currentMode === 'battle';
    const radius = isBattle ? 16 : 14;
    const fontSize = isBattle ? 14 : 12;

    let svg = `<g id="${type}-${name.replace(/\s/g, '_')}" class="character-marker" style="transform-origin: ${x}px ${y}px;">`;

    // 角色圆圈和头像
    if (customAvatar) {
        // 有自定义头像时使用图片
        svg += `
            <circle cx="${x}" cy="${y}" r="${radius}" fill="#faf0dc" stroke="${strokeColor}" stroke-width="2"/>
            <clipPath id="clip-${name.replace(/\s/g, '_')}">
                <circle cx="${x}" cy="${y}" r="${radius - 2}"/>
            </clipPath>
            <image href="${customAvatar}" x="${x - radius + 2}" y="${y - radius + 2}" width="${(radius - 2) * 2}" height="${(radius - 2) * 2}" clip-path="url(#clip-${name.replace(/\s/g, '_')})"/>`;
    } else {
        // 使用首字母圆头像
        const initial = name ? name.charAt(0) : '?';
        svg += `
            <circle cx="${x}" cy="${y}" r="${radius}" fill="#faf0dc" stroke="${strokeColor}" stroke-width="2"/>
            <text x="${x}" y="${y + 5}" text-anchor="middle" font-size="${fontSize}" font-weight="bold" fill="${strokeColor}">${initial}</text>`;
    }

    // 名称
    svg += `<text x="${x}" y="${y - radius - 6}" text-anchor="middle" fill="${strokeColor}" font-size="9" font-weight="bold">${name}</text>`;

    // 战斗模式显示HP血条
    if (hp && isBattle) {
        const hpParts = hp.split('/');
        const hpCur = parseInt(hpParts[0]) || 0;
        const hpMax = parseInt(hpParts[1]) || 100;
        const hpPercent = Math.max(0, Math.min(100, (hpCur / hpMax) * 100));
        const barWidth = 44;
        const barHeight = 8;
        const barX = x - barWidth / 2;
        const barY = y + radius + 6;

        // 血条背景
        svg += `<rect x="${barX}" y="${barY}" width="${barWidth}" height="${barHeight}" rx="2" fill="#faf0dc" stroke="${strokeColor}" stroke-width="0.5"/>`;
        // 血条填充
        const hpColor = hpPercent > 50 ? strokeColor : hpPercent > 25 ? '#f9a825' : '#c62828';
        svg += `<rect x="${barX + 1}" y="${barY + 1}" width="${(barWidth - 2) * hpPercent / 100}" height="${barHeight - 2}" rx="1" fill="${hpColor}" opacity="0.8"/>`;
        // 血量文字
        svg += `<text x="${x}" y="${barY + 6}" text-anchor="middle" fill="#fff" font-size="5" font-weight="bold">${hp}</text>`;
    }

    svg += '</g>';
    return svg;
}

/**
 * 生成默认角色位置
 */
function generateDefaultPositions(chars) {
    const positions = {
        protagonist: null,
        allies: [],
        enemies: []
    };

    // 主角位置（左侧中间）- 新坐标范围 800x600
    if (chars.protagonist) {
        positions.protagonist = {
            ...chars.protagonist,
            position: { x: 200, y: 300 }
        };
    }

    // 友方位置（左侧分布）
    chars.allies.forEach((ally, i) => {
        positions.allies.push({
            ...ally,
            position: { x: 150 + (i % 3) * 80, y: 200 + Math.floor(i / 3) * 100 }
        });
    });

    // 敌方位置（右侧分布）
    chars.enemies.forEach((enemy, i) => {
        positions.enemies.push({
            ...enemy,
            position: { x: 550 + (i % 2) * 80, y: 150 + Math.floor(i / 2) * 100 }
        });
    });

    return positions;
}

/**
 * 应用AI生成的角色坐标
 * @param {object} chars - 角色数据（包含protagonist, allies, enemies）
 * @param {object} aiPositions - AI生成的坐标
 * @returns {object} - 合并后的角色位置数据
 */
function applyAIPositions(chars, aiPositions) {
    const positions = {
        protagonist: null,
        allies: [],
        enemies: []
    };

    if (!aiPositions) {
        return generateDefaultPositions(chars);
    }

    // 应用主角坐标 - 新坐标范围 800x600
    if (chars.protagonist && aiPositions.protagonist) {
        positions.protagonist = {
            ...chars.protagonist,
            position: {
                x: aiPositions.protagonist.x || 200,
                y: aiPositions.protagonist.y || 300
            }
        };
    } else if (chars.protagonist) {
        positions.protagonist = {
            ...chars.protagonist,
            position: { x: 200, y: 300 }
        };
    }

    // 应用友方坐标
    if (aiPositions.allies && Array.isArray(aiPositions.allies)) {
        chars.allies.forEach((ally, i) => {
            // 尝试按名称匹配AI生成的坐标（使用模糊匹配）
            let aiAlly = aiPositions.allies.find(a => a.name === ally.name);

            // 如果精确匹配失败，尝试模糊匹配（包含关系）
            if (!aiAlly) {
                aiAlly = aiPositions.allies.find(a => {
                    const aiName = (a.name || '').replace(/[（）\(\)]/g, '');
                    const allyName = (ally.name || '').replace(/[（）\(\)]/g, '');
                    return aiName.includes(allyName) || allyName.includes(aiName);
                });
            }

            const defaultPos = { x: 150 + (i % 3) * 80, y: 200 + Math.floor(i / 3) * 100 };

            if (aiAlly) {
                console.log('[地图系统] 匹配友方坐标:', ally.name, '->', aiAlly.name, '坐标:', aiAlly.x, aiAlly.y);
            }

            positions.allies.push({
                ...ally,
                position: aiAlly ? { x: aiAlly.x || defaultPos.x, y: aiAlly.y || defaultPos.y } : defaultPos
            });
        });
    } else {
        // 没有AI坐标，使用默认
        chars.allies.forEach((ally, i) => {
            positions.allies.push({
                ...ally,
                position: { x: 150 + (i % 3) * 80, y: 200 + Math.floor(i / 3) * 100 }
            });
        });
    }

    // 应用敌方坐标
    if (aiPositions.enemies && Array.isArray(aiPositions.enemies)) {
        // 如果 chars.enemies 为空，直接使用 aiPositions.enemies（战斗模式下可能需要）
        if (chars.enemies.length === 0) {
            console.log('[地图系统] chars.enemies 为空，直接使用 aiPositions.enemies');
            aiPositions.enemies.forEach((enemy, i) => {
                const defaultPos = { x: 550 + (i % 2) * 80, y: 150 + Math.floor(i / 2) * 100 };
                positions.enemies.push({
                    name: enemy.name,
                    position: { x: enemy.x || defaultPos.x, y: enemy.y || defaultPos.y }
                });
            });
        } else {
            // 匹配 chars.enemies 和 aiPositions.enemies
            chars.enemies.forEach((enemy, i) => {
                // 尝试按名称匹配AI生成的坐标（使用模糊匹配）
                let aiEnemy = aiPositions.enemies.find(e => e.name === enemy.name);

                // 如果精确匹配失败，尝试模糊匹配（包含关系）
                if (!aiEnemy) {
                    aiEnemy = aiPositions.enemies.find(e => {
                        const aiName = (e.name || '').replace(/[（）\(\(\)]/g, '');
                        const enemyName = (enemy.name || '').replace(/[（）\(\(\)]/g, '');
                        return aiName.includes(enemyName) || enemyName.includes(aiName);
                    });
                }

                const defaultPos = { x: 550 + (i % 2) * 80, y: 150 + Math.floor(i / 2) * 100 };

                if (aiEnemy) {
                    console.log('[地图系统] 匹配敌方坐标:', enemy.name, '->', aiEnemy.name, '坐标:', aiEnemy.x, aiEnemy.y);
                }

                positions.enemies.push({
                    ...enemy,
                    position: aiEnemy ? { x: aiEnemy.x || defaultPos.x, y: aiEnemy.y || defaultPos.y } : defaultPos
                });
            });
        }
    } else {
        // 没有AI坐标，使用默认 - 新坐标范围 800x600
        chars.enemies.forEach((enemy, i) => {
            positions.enemies.push({
                ...enemy,
                position: { x: 550 + (i % 2) * 80, y: 150 + Math.floor(i / 2) * 100 }
            });
        });
    }

    return positions;
}

/**
 * 渲染完整地图SVG
 */
function renderFullMapSVG() {
    let template = MapState.svgTemplate || generateDefaultMapSVG(MapState.currentLocation || '未知地点');
    const positions = MapState.characterPositions;

    let charactersSvg = '';

    if (positions.protagonist) {
        charactersSvg += generateCharacterSvg(positions.protagonist, 'protagonist');
    }

    positions.allies.forEach((ally, i) => {
        charactersSvg += generateCharacterSvg(ally, 'ally');
    });

    positions.enemies.forEach((enemy, i) => {
        charactersSvg += generateCharacterSvg(enemy, 'enemy');
    });

    // 插入角色SVG到</svg>之前
    if (template.includes('</svg>')) {
        return template.replace('</svg>', charactersSvg + '</svg>');
    }
    return template + charactersSvg + '</svg>';
}

/**
 * 更新地图显示
 */
function updateMapDisplay() {
    const viewport = document.getElementById('mapViewport');
    const locationElement = document.getElementById('mapLocationName');
    const modeElement = document.getElementById('mapMode');

    if (viewport) {
        const fullSvg = renderFullMapSVG();
        // 只替换地图视口内容，保留缩放按钮
        viewport.innerHTML = fullSvg;
        initializeMapInteractions('normal');

        // 重新绑定角色点击事件
        bindCharacterClickEvents();
    }

    if (locationElement) {
        locationElement.textContent = MapState.currentLocation || '未知';
    }

    if (modeElement) {
        if (GameState.currentMode === 'battle') {
            modeElement.textContent = '⚔️ 战斗中';
            modeElement.className = 'map-mode battle';
        } else {
            modeElement.textContent = '';
            modeElement.className = 'map-mode';
        }
    }
}

/**
 * 绑定地图上角色图标的点击事件
 */
function bindCharacterClickEvents() {
    const container = document.getElementById('mapContainer');
    if (!container) {
        console.warn('[地图系统] 未找到地图容器 mapContainer');
        return;
    }

    // 查找所有角色标记
    const characterMarkers = container.querySelectorAll('.character-marker');
    console.log('[地图系统] 找到角色标记数量:', characterMarkers.length);

    if (characterMarkers.length === 0) {
        // 如果没找到，可能是 SVG 还没渲染完成，延迟重试
        setTimeout(() => {
            const retryMarkers = container.querySelectorAll('.character-marker');
            console.log('[地图系统] 延迟重试找到角色标记数量:', retryMarkers.length);
            bindClickEventsToMarkers(retryMarkers, false);
        }, 100);
        return;
    }

    bindClickEventsToMarkers(characterMarkers, false);
}

/**
 * 为角色标记绑定点击事件（通用函数）
 * @param {NodeList} markers - 角色标记元素列表
 * @param {boolean} isBattle - 是否战斗模式
 */
function bindClickEventsToMarkers(markers, isBattle) {
    markers.forEach(marker => {
        // SVG 元素需要设置 style.cursor
        try {
            marker.style.cursor = 'pointer';
        } catch(e) {
            // 某些浏览器可能不支持直接设置 SVG 元素的 style
        }

        // 移除旧的事件监听器（如果有）
        marker.removeEventListener('click', marker._clickHandler);

        // 创建新的点击处理函数
        const clickHandler = function(e) {
            e.stopPropagation();
            e.preventDefault();

            const id = this.id;
            // 解析ID格式: "protagonist-角色名" 或 "ally-角色名" 或 "enemy-角色名"
            const parts = id.split('-');
            const type = parts[0];
            const name = parts.slice(1).join('_').replace(/_/g, ' ');

            console.log('[地图系统] 点击角色:', name, '类型:', type, '战斗模式:', isBattle);

            if (isBattle) {
                // 战斗模式：检查是否已选择技能
                if (GameState.selectedSkills && GameState.selectedSkills.length > 0) {
                    // 已选择技能，将此角色设为技能释放目标
                    selectSkillTarget(name, type);
                } else {
                    // 未选择技能，显示角色详情
                    openBattleCharacterDetail(name, type);
                }
            } else {
                // 日常模式调用角色详情弹窗
                openCharacterDetailFromMap(name, type);
            }
        };

        // 保存处理函数引用以便后续移除
        marker._clickHandler = clickHandler;

        // 添加事件监听
        marker.addEventListener('click', clickHandler);
    });
}

/**
 * 选择技能释放目标
 * @param {string} name - 目标角色名称
 * @param {string} type - 目标类型 (protagonist/ally/enemy)
 */
function selectSkillTarget(name, type) {
    if (!GameState.selectedSkills || GameState.selectedSkills.length === 0) {
        alert('请先选择要释放的技能');
        return;
    }

    const skillNames = GameState.selectedSkills.map(s => s.name).join('、');
    const targetType = (type === 'enemy') ? '敌方' : '我方';

    // 确认是否对该目标释放技能
    if (confirm(`确定要对 ${targetType}「${name}」释放技能【${skillNames}】吗？`)) {
        // 构建技能释放消息
        const msg = `[对${targetType}${name}使用技能] ${skillNames}`;
        sendToChat(msg);

        // 清空已选技能
        GameState.selectedSkills = [];
        updateBattleSkills();
        updateSelectedSkillsDisplay();

        console.log('[战斗系统] 技能释放:', msg);
    }
}

/**
 * 从地图上打开角色详情弹窗
 * @param {string} name - 角色名称
 * @param {string} type - 角色类型 (protagonist/ally/enemy)
 */
function openCharacterDetailFromMap(name, type) {
    if (GameState.currentMode === 'battle') {
        // 战斗模式：从战斗场景表获取数据
        openBattleCharacterDetail(name, type);
    } else {
        // 日常模式：从角色列表获取数据
        openCharacterDetail(name);
    }
}

/**
 * 战斗模式下打开角色详情弹窗（从战斗表获取数据）
 * @param {string} name - 角色名称
 * @param {string} type - 角色类型 (protagonist/ally/enemy)
 */
function openBattleCharacterDetail(name, type) {
    console.log('[地图系统] 打开战斗角色详情:', name, '类型:', type);
    let char = null;

    // 主角特殊处理
    if (type === 'protagonist' && GameState.protagonist) {
        console.log('[地图系统] 使用主角数据');
        char = {
            name: GameState.protagonist.name,
            gender: GameState.protagonist.gender || '未知',
            profession: GameState.protagonist.profession || '冒险者',
            level: GameState.protagonist.level || 1,
            attrs: GameState.protagonist.attrs || {},
            res: GameState.protagonist.res || { hp: {cur: 0, max: 100}, sp: {cur: 0, max: 100}, mp: {cur: 0, max: 100} },
            skills: GameState.protagonist.skills || '',
            intro: GameState.protagonist.intro || '主角',
            appearance: GameState.protagonist.appearance || '',
            inScene: true,
            isEnemy: false
        };
    } else {
        // 从战斗场景表查找
        char = GameState.battleCharacters?.find(c => c.name === name);
        console.log('[地图系统] 从战斗表查找:', name, '结果:', char ? '找到' : '未找到');
    }

    if (!char) {
        console.warn('[地图系统] 未找到战斗角色:', name,
            '战斗角色列表:', GameState.battleCharacters?.map(c => c.name).join(', '));
        // 显示提示信息
        alert('未找到战斗角色信息：' + name);
        return;
    }

    GameState.currentNpc = char;
    document.getElementById('characterModalTitle').textContent = char.name + (char.isEnemy ? ' (敌方)' : ' (我方)');

    const a = char.attrs || {};
    const maxHP = char.res?.hp?.max || 100;
    const maxSP = char.res?.sp?.max || 100;
    const maxMP = char.res?.mp?.max || 100;
    const curHP = char.res?.hp?.cur || 0;
    const curSP = char.res?.sp?.cur || 0;
    const curMP = char.res?.mp?.cur || 0;

    let html = '<div class="character-detail-header">' +
        '<div class="character-detail-avatar">' + char.name.charAt(0) + '</div>' +
        '<div class="character-detail-info">' +
        '<div class="character-detail-name">' + char.name + '</div>' +
        '<div class="character-detail-meta">' + (char.gender || '未知') + ' | ' + (char.profession || '未知') + ' | Lv.' + (char.level || 1) + '</div>' +
        '<div class="character-detail-resources">' +
        '<div class="resource-item"><span class="resource-label">HP</span>' +
        '<div class="resource-bar-container"><div class="resource-bar hp" style="width:' + (curHP/maxHP*100) + '%"></div>' +
        '<span class="resource-value">' + curHP + '/' + maxHP + '</span></div></div>' +
        '<div class="resource-item"><span class="resource-label">SP</span>' +
        '<div class="resource-bar-container"><div class="resource-bar sp" style="width:' + (curSP/maxSP*100) + '%"></div>' +
        '<span class="resource-value">' + curSP + '/' + maxSP + '</span></div></div>' +
        '<div class="resource-item"><span class="resource-label">MP</span>' +
        '<div class="resource-bar-container"><div class="resource-bar mp" style="width:' + (curMP/maxMP*100) + '%"></div>' +
        '<span class="resource-value">' + curMP + '/' + maxMP + '</span></div></div></div></div></div>';

    // 战斗状态信息
    if (char.status) {
        html += '<div class="character-info-section">';
        html += '<div class="info-row"><span class="info-label">当前状态</span><span class="info-value">' + char.status + '</span></div>';
        if (char.characterType) {
            html += '<div class="info-row"><span class="info-label">角色类型</span><span class="info-value">' + char.characterType + '</span></div>';
        }
        html += '</div>';
    }

    // 属性
    html += '<div class="character-attributes">';
    ['力量', '敏捷', '体质', '智力', '感知', '魅力'].forEach(n => {
        const key = Object.keys(GameState.attrNames).find(k => GameState.attrNames[k] === n);
        const val = a[key] || 10;
        html += '<div class="attribute-item"><span class="attribute-name">' + n + '</span><span class="attribute-value">' + val + '</span></div>';
    });
    html += '</div>';

    // 技能
    if (char.skills) {
        html += '<div class="character-skills"><div class="character-skills-title">可用技能</div>';
        char.skills.split(',').forEach(s => {
            html += '<span class="character-skill-tag">' + s.trim() + '</span>';
        });
        html += '</div>';
    }

    // 战斗模式下不显示互动按钮（敌人不能互动，战斗中的友军也不能普通互动）

    document.getElementById('characterDetail').innerHTML = html;
    openModal('characterModal');
}

/**
 * 设置地图状态
 */
function setMapStatus(status, text) {
    const indicator = document.getElementById('mapStatusIndicator');
    const statusText = document.getElementById('mapStatusText');

    if (indicator) {
        indicator.className = 'status-indicator ' + status;
    }
    if (statusText) {
        statusText.textContent = text;
    }
}

/**
 * 强制刷新地图（删除缓存并重新生成）
 * 用户点击刷新按钮时调用
 */
async function forceRefreshMap() {
    if (MapState.isGenerating) {
        console.log('[地图系统] 正在生成中');
        return;
    }

    try {
        MapState.isGenerating = true;
        setMapStatus('loading', '正在重新生成地图...');

        // 获取当前位置
        const location = await getCurrentLocation();
        if (!location) {
            setMapStatus('error', '无法获取当前位置');
            MapState.isGenerating = false;
            return;
        }

        MapState.currentLocation = location;

        // 删除当前地点的缓存
        console.log('[地图系统] 删除缓存并重新生成:', location);
        await MapCache.clearLocation(location);

        // 获取剧情上下文
        const storyContext = getRecentStoryContext(3);
        const storyHash = hashText(storyContext + location);

        const isBattleMode = GameState.currentMode === 'battle';
        let aiPositions = null;

        // 检查是否启用了地图生成
        if (!Settings.enableMapGeneration) {
            console.log('[地图系统] 地图生成已禁用，使用默认地图（不缓存）');
            MapState.svgTemplate = generateDefaultMapSVG(location, isBattleMode);
            // 禁用地图生成时使用默认地图，不写入缓存
        } else {
            // 生成新的地形图和坐标
            console.log('[地图系统] 重新生成地图...');
            setMapStatus('loading', '正在AI生成地图...');

            const aiResult = await generateMapByAI(location, storyContext, isBattleMode);

            if (aiResult && aiResult.svg && validateSVG(aiResult.svg)) {
                MapState.svgTemplate = aiResult.svg;
                aiPositions = aiResult.positions;
                console.log('[地图系统] AI生成成功，坐标:', aiPositions);
                MapCache.set(location, MapState.svgTemplate, storyHash, aiPositions, aiResult.structure);
            } else {
                console.log('[地图系统] AI生成失败，使用默认地图（不缓存）');
                MapState.svgTemplate = generateDefaultMapSVG(location, isBattleMode);
                // AI生成失败时使用默认地图，不写入缓存
            }
        }

        // 获取角色并设置位置
        const chars = getCharactersInCurrentLocation();

        if (aiPositions) {
            MapState.characterPositions = applyAIPositions(chars, aiPositions);
        } else {
            MapState.characterPositions = generateDefaultPositions(chars);
        }

        // 更新显示
        updateMapDisplay();
        setMapStatus('', '已更新');


        console.log('[地图系统] 强制刷新完成');
    } catch (e) {
        console.error('[地图系统] 强制刷新失败:', e);
        setMapStatus('error', '生成失败');
    } finally {
        MapState.isGenerating = false;
    }
}

/**
 * 刷新地图（使用缓存或生成新地图）
 * 当地点变化时自动调用
 */
async function refreshMap() {
    if (MapState.isGenerating) {
        console.log('[地图系统] 正在生成中，跳过重复刷新');
        return;
    }

    // 立即设置标志，防止竞态条件
    MapState.isGenerating = true;

    try {
        setMapStatus('loading', '正在生成地图...');

        // 获取当前位置
        const location = await getCurrentLocation();
        if (!location) {
            setMapStatus('error', '无法获取当前位置');
            MapState.isGenerating = false;
            return;
        }

        const previousLocation = MapState.currentLocation;
        const locationChanged = previousLocation !== location;

        MapState.currentLocation = location;

        // 获取剧情上下文
        const storyContext = getRecentStoryContext(3);
        const storyHash = hashText(storyContext + location);

        // 检查缓存
        console.log('[地图系统] 检查缓存, location:', location);
        console.log('[地图系统] 内存缓存内容:', Object.keys(MapCache.data));
        const cached = MapCache.get(location);
        console.log('[地图系统] 缓存结果:', cached ? '有缓存' : '无缓存', cached ? 'svgTemplate长度=' + (cached.svgTemplate ? cached.svgTemplate.length : 0) : '');

        let aiPositions = null; // AI生成的角色坐标

        if (cached && cached.svgTemplate) {
            // 有缓存就直接使用地形图
            console.log('[地图系统] 使用缓存地图:', location);
            MapState.svgTemplate = cached.svgTemplate;

            // 检查是否需要重新生成角色坐标（剧情变化时）
            if (cached.storyHash === storyHash && cached.positions) {
                // 剧情没变，使用缓存的角色坐标
                console.log('[地图系统] 使用缓存的角色坐标');
                aiPositions = cached.positions;
            } else {
                // 剧情变了，需要重新生成角色坐标（但保留地形图）
                console.log('[地图系统] 剧情变化，重新生成角色坐标');
                const chars = getCharactersInCurrentLocation();
                aiPositions = await generateCharacterPositionsOnly(location, storyContext, chars);
                // 更新缓存中的坐标和hash
                MapCache.set(location, cached.svgTemplate, storyHash, aiPositions);
            }
        } else {
            // 无缓存
            const isBattleMode = GameState.currentMode === 'battle';

            // 检查是否启用了地图生成
            if (!Settings.enableMapGeneration) {
                console.log('[地图系统] 地图生成已禁用，使用默认地图（不缓存）');
                MapState.svgTemplate = generateDefaultMapSVG(location, isBattleMode);
                // 禁用地图生成时使用默认地图，不写入缓存
            } else {
                // 生成新的地形图和坐标
                console.log('[地图系统] 无缓存，生成新地图');
                setMapStatus('loading', '正在AI生成地图...');

                const aiResult = await generateMapByAI(location, storyContext, isBattleMode);

                if (aiResult && aiResult.svg && validateSVG(aiResult.svg)) {
                    MapState.svgTemplate = aiResult.svg;
                    aiPositions = aiResult.positions;
                    console.log('[地图系统] AI生成成功，坐标:', aiPositions);
                    // 缓存时保存SVG、坐标和结构数据
                    MapCache.set(location, MapState.svgTemplate, storyHash, aiPositions, aiResult.structure);
                } else {
                    // 回退到默认地图
                    console.log('[地图系统] AI生成失败，使用默认地图（不缓存）');
                    MapState.svgTemplate = generateDefaultMapSVG(location, isBattleMode);
                    // AI生成失败时使用默认地图，不写入缓存
                }
            }
        }

        // 获取角色并设置位置
        const chars = getCharactersInCurrentLocation();

        // 如果AI生成了坐标，使用AI坐标；否则使用默认位置
        if (aiPositions) {
            MapState.characterPositions = applyAIPositions(chars, aiPositions);
        } else {
            MapState.characterPositions = generateDefaultPositions(chars);
        }

        // 更新显示
        updateMapDisplay();
        setMapStatus('', '已更新');


        console.log('[地图系统] 地图刷新完成');

        // 自动打开地图窗口
        autoExpandMapPanel();
    } catch (e) {
        console.error('[地图系统] 刷新失败:', e);
        setMapStatus('error', '生成失败');
    } finally {
        MapState.isGenerating = false;
    }
}

/**
 * 仅刷新角色位置（地形图不变）
 * 当地点不变但角色变动时调用
 */
async function refreshCharacterPositionsOnly() {
    if (MapState.isGenerating) {
        console.log('[地图系统] 正在生成中');
        return;
    }

    try {
        MapState.isGenerating = true;
        setMapStatus('loading', '正在更新角色位置...');

        const location = MapState.currentLocation;
        if (!location) {
            console.log('[地图系统] 无当前位置，执行完整刷新');
            MapState.isGenerating = false;
            return await refreshMap();
        }

        // 获取剧情上下文（用于AI生成坐标）
        const storyContext = getRecentStoryContext(3);

        // 获取当前角色
        const chars = getCharactersInCurrentLocation();

        // 尝试让AI仅生成角色坐标（不生成地形图）
        const aiPositions = await generateCharacterPositionsOnly(location, storyContext, chars);

        if (aiPositions) {
            MapState.characterPositions = applyAIPositions(chars, aiPositions);
            console.log('[地图系统] 角色坐标更新成功');
        } else {
            // AI生成失败，使用默认位置
            MapState.characterPositions = generateDefaultPositions(chars);
            console.log('[地图系统] 使用默认角色位置');
        }

        // 更新显示（使用现有地形图）
        updateMapDisplay();
        setMapStatus('', '角色位置已更新');

        console.log('[地图系统] 角色位置刷新完成');
    } catch (e) {
        console.error('[地图系统] 角色位置刷新失败:', e);
        setMapStatus('error', '更新失败');
    } finally {
        MapState.isGenerating = false;
    }
}

/**
 * 仅生成角色坐标（不生成地形图）
 * @param {string} locationName - 地点名称
 * @param {string} storyContext - 剧情上下文
 * @param {object} chars - 当前角色数据
 * @returns {Promise<object>} - 角色坐标
 */
async function generateCharacterPositionsOnly(locationName, storyContext, chars) {
    // 构建角色列表
    const characterList = [];
    if (chars.protagonist) {
        characterList.push(`- 主角：${chars.protagonist.name}`);
    }
    chars.allies.forEach(ally => {
        characterList.push(`- 友方：${ally.name}`);
    });
    if (chars.enemies) {
        chars.enemies.forEach(enemy => {
            characterList.push(`- 敌方：${enemy.name}`);
        });
    }

    if (characterList.length === 0) {
        return null;
    }

    // 获取当前地图SVG参数（如果存在）
    const mapSvgParam = MapState.svgTemplate ? `当前地图SVG（400x300）：
${MapState.svgTemplate.substring(0, 5000)}

请根据地图中的地形元素（如山脉、森林、建筑、水体等）合理安排角色位置。` : '';

    const systemPrompt = `你是一位RPG游戏的场景设计师，需要根据地图布局和剧情内容为角色分配合适的坐标位置。

${mapSvgParam}

角色坐标要求：
- 坐标范围：x在20-380之间，y在40-280之间（留出标题区域）
- 坐标要符合剧情场景逻辑（如：在篝火旁的角色应该靠近火堆位置）
- 角色位置应避开地图上的障碍物或特殊地形
- 战斗场景中，双方角色应有合理的站位距离

输出格式（必须是有效的JSON）：
{"positions":{"protagonist":{"name":"角色名","x":100,"y":150},"allies":[{"name":"角色名","x":120,"y":130}],"enemies":[{"name":"角色名","x":300,"y":150}]}}
如果某类角色不存在，对应数组为空或不包含该字段

只输出JSON，不要有任何其他文字。`;

    const userPrompt = `地点：${locationName}
剧情上下文：
${storyContext.substring(0, 60000)}

当前在场角色：
${characterList.join('\n')}

请为这些角色分配合适的坐标位置：`;

    try {
        const response = await callSillyTavernAI(systemPrompt, userPrompt);
        if (response) {
            // 尝试解析JSON
            try {
                // 尝试匹配 JSON 格式的坐标数据
                const jsonMatch = response.match(/\{"positions":\s*\{[\s\S]*?\}\s*\}/);
                if (jsonMatch) {
                    const data = JSON.parse(jsonMatch[0]);
                    console.log('[地图系统] AI生成角色坐标成功:', data.positions);
                    return data.positions;
                }
                // 尝试直接解析
                const directParse = JSON.parse(response);
                if (directParse.positions) {
                    return directParse.positions;
                }
            } catch (parseErr) {
                console.warn('[地图系统] 解析AI坐标响应失败:', parseErr);
            }
        }
    } catch (e) {
        console.error('[地图系统] 生成角色坐标失败:', e);
    }

    return null;
}

/**
 * 切换地图面板
 */
function toggleMapPanel() {
    const panel = document.getElementById('mapPanel');
    if (!panel) return;

    const isVisible = panel.style.display !== 'none';
    panel.style.display = isVisible ? 'none' : 'block';

}

/**
 * 自动展开地图面板（当地图生成完成时）
 */
function autoExpandMapPanel() {
    const panel = document.getElementById('mapPanel');
    if (!panel) return;

    // 检查面板是否已打开
    const isVisible = panel.style.display !== 'none';

    if (!isVisible) {
        // 面板未打开，自动展开
        console.log('[地图系统] 自动展开地图面板');
        panel.style.display = 'block';
        AvatarCache.init();
    }
}

/**
 * 自动展开战斗地图面板（当地图生成完成时）
 */
function autoExpandBattleMapPanel() {
    const panel = document.getElementById('battleMapPanel');
    if (!panel) return;

    // 检查面板是否已打开
    const isVisible = panel.style.display !== 'none';

    if (!isVisible) {
        // 面板未打开，自动展开
        console.log('[地图系统] 自动展开战斗地图面板');
        panel.style.display = 'block';
    }
}

/**
 * 清除当前地点的地图缓存
 */
async function clearCurrentMapCache() {
    const location = MapState.currentLocation;
    if (!location) {
        alert('当前没有选中任何地点');
        return;
    }

    if (confirm(`确定要清除「${location}」的地图缓存吗？`)) {
        // 清除日常地图缓存
        await MapCache.clearLocation(location);
        // 清除战斗地图缓存
        await MapCache.clearLocation(`battle_${location}`);

        // 清除当前状态
        MapState.svgTemplate = '';

        // 更新显示
        const viewport = document.getElementById('mapViewport');
        if (viewport) {
            viewport.innerHTML = '<svg id="mapSvg" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg"><text x="200" y="150" text-anchor="middle" fill="#8b7355" font-size="14">缓存已清除</text></svg>';
            resetMapView('normal');
            initializeMapInteractions('normal');
        }

        setMapStatus('', `已清除「${location}」的缓存`);
        console.log('[地图系统] 已清除当前地点缓存:', location);
    }
}

/**
 * 清空所有地图缓存
 */
async function clearAllMapCache() {
    if (confirm('确定要清空所有地图缓存吗？这将清除所有地点的缓存数据。')) {
        await MapCache.clear();
        MapState.currentLocation = '';
        MapState.svgTemplate = '';

        const viewport = document.getElementById('mapViewport');
        if (viewport) {
            viewport.innerHTML = '<svg id="mapSvg" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg"><text x="200" y="150" text-anchor="middle" fill="#8b7355" font-size="14">所有缓存已清空</text></svg>';
            resetMapView('normal');
            initializeMapInteractions('normal');
        }

        document.getElementById('mapLocationName').textContent = '-';
        setMapStatus('', '所有缓存已清空');

        console.log('[地图系统] 所有缓存已清空');
    }
}

/**
 * 清空地图缓存（旧函数，保留兼容性）
 */
function clearMapCache() {
    clearAllMapCache();
}

/**
 * 清除当前战场的地图缓存并重新生成
 */
async function clearCurrentBattleMapCache() {
    const location = MapState.currentLocation;
    if (!location) {
        alert('当前没有选中任何战场');
        return;
    }

    if (confirm(`确定要清除「${location}」的战场地图缓存并重新生成吗？`)) {
        console.log('[地图系统] 清除当前战场缓存:', location);
        await MapCache.clearLocation(location);

        // 重新生成战斗地图
        await refreshBattleMap();
    }
}

/**
 * 清空所有战场地图缓存
 */
async function clearAllBattleMapCache() {
    if (confirm('确定要清空所有战场地图缓存吗？这将清除所有战场的缓存数据。')) {
        // 获取所有缓存键
        const keys = Object.keys(MapCache.data);
        let cleared = 0;

        for (const key of keys) {
            // 清除所有缓存（战斗和日常都清除）
            await MapCache.clearLocation(key);
            cleared++;
        }

        // 清除当前状态
        MapState.svgTemplate = '';

        const viewport = document.getElementById('battleMapViewport');
        if (viewport) {
            viewport.innerHTML = '<svg id="battleMapSvg" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg"><text x="200" y="150" text-anchor="middle" fill="#8b0000" font-size="14">所有战场缓存已清空</text></svg>';
            resetMapView('battle');
            initializeMapInteractions('battle');
        }

        setMapStatus('', `已清空 ${cleared} 个缓存`);
        console.log('[地图系统] 所有战场缓存已清空');
    }
}

