/**
 * 初始化战斗地图
 * 逻辑：先检查缓存，有缓存则直接使用；无缓存则显示战棋棋盘，然后异步生成地形图
 */
let isBattleMapInitializing = false;

async function initBattleMap() {
    console.log('[地图系统] 初始化战斗地图');

    // 防止重复初始化（使用独立标志，不依赖 isGenerating）
    if (isBattleMapInitializing) {
        console.log('[地图系统] 战斗地图正在初始化中，跳过重复调用');
        return;
    }
    isBattleMapInitializing = true;

    // 防止重复初始化
    if (MapState.isGenerating) {
        console.log('[地图系统] 战斗地图正在生成中，跳过重复初始化');
        isBattleMapInitializing = false;
        return;
    }

    // 清除旧的角色位置数据（避免使用过期数据）
    MapState.characterPositions = null;
    MapState.svgTemplate = null;

    // 获取当前位置
    const location = await getCurrentLocation();
    if (location) {
        MapState.currentLocation = location;
    } else if (!MapState.currentLocation) {
        MapState.currentLocation = '战场';
    }

    // 更新战斗地图位置显示
    const locationEl = document.getElementById('battleMapLocation');
    if (locationEl) {
        locationEl.textContent = MapState.currentLocation;
    }

    // 获取战斗角色
    const battleChars = getBattleCharactersForMap();

    // 第一步：检查是否启用了地图生成
    if (!Settings.enableMapGeneration) {
        console.log('[地图系统] 地图生成已禁用，使用战棋棋盘');
        const defaultPositions = generateDefaultBattlePositions(battleChars);
        MapState.characterPositions = defaultPositions;
        renderBattleMap(defaultPositions);
        autoExpandBattleMapPanel();
        console.log('[地图系统] 战斗棋盘渲染完成');
        isBattleMapInitializing = false;
        return;
    }

    // 第二步：检查缓存
    const cacheKey = MapState.currentLocation;
    console.log('[地图系统] 查找缓存, key:', cacheKey);
    console.log('[地图系统] 当前缓存列表:', Object.keys(MapCache.data));
    const cached = MapCache.get(cacheKey);
    console.log('[地图系统] 缓存查找结果:', cached ? '找到' : '未找到');

    if (cached && cached.svgTemplate) {
        // 有缓存，直接使用缓存的地图
        console.log('[地图系统] 使用缓存的地图:', cacheKey);
        MapState.svgTemplate = cached.svgTemplate;

        // 生成默认位置作为基础
        let aiPositions = generateDefaultBattlePositions(battleChars);

        // 如果缓存中有坐标，应用缓存坐标
        if (cached.positions) {
            console.log('[地图系统] 缓存坐标数据:', JSON.stringify(cached.positions));
            aiPositions = applyAIPositions(battleChars, cached.positions);
        }

        // 保存到MapState
        MapState.characterPositions = aiPositions;

        renderBattleMap(aiPositions);
        autoExpandBattleMapPanel();
        console.log('[地图系统] 缓存地图渲染完成');
        isBattleMapInitializing = false;
        return;
    }

    // 第三步：无缓存，显示默认战棋棋盘，然后异步生成地形图
    console.log('[地图系统] 无缓存，显示默认棋盘并异步生成地形图');

    // 先显示默认战棋棋盘
    const defaultPositions = generateDefaultBattlePositions(battleChars);
    MapState.characterPositions = defaultPositions;
    renderBattleMap(defaultPositions);
    autoExpandBattleMapPanel();
    console.log('[地图系统] 战斗棋盘初始渲染完成');

    // 异步生成地形图
    setMapStatus('loading', '正在生成战斗地图...');
    MapState.isGenerating = true;

    try {
        // 获取剧情上下文
        const storyContext = getRecentStoryContext(3);
        const storyHash = hashText(storyContext + MapState.currentLocation);

        // 生成地形图
        const aiResult = await generateMapByAI(MapState.currentLocation, storyContext, true);

        if (aiResult && aiResult.svg && validateSVG(aiResult.svg)) {
            MapState.svgTemplate = aiResult.svg;
            console.log('[地图系统] 战斗地图AI生成成功');

            // 缓存
            MapCache.set(cacheKey, MapState.svgTemplate, storyHash, aiResult.positions, aiResult.structure);

            // 使用AI生成的坐标
            let newPositions = defaultPositions;
            if (aiResult.positions) {
                newPositions = applyAIPositions(battleChars, aiResult.positions);
            }

            // 保存到MapState
            MapState.characterPositions = newPositions;

            // 重新渲染
            renderBattleMap(newPositions);
            setMapStatus('', '战斗地图已生成');
        } else {
            console.log('[地图系统] AI生成失败，保持战棋棋盘');
            setMapStatus('', '使用默认棋盘');
        }
    } catch (e) {
        console.error('[地图系统] 战斗地图生成失败:', e);
        setMapStatus('error', '生成失败');
    } finally {
        MapState.isGenerating = false;
        isBattleMapInitializing = false;
    }
}

/**
 * 生成默认战斗位置（主角团在左，敌人在右）
 */
function generateDefaultBattlePositions(chars) {
    const positions = {
        protagonist: null,
        allies: [],
        enemies: []
    };

    // 主角在左侧中间
    if (chars.protagonist) {
        positions.protagonist = {
            ...chars.protagonist,
            position: { x: 100, y: 300 }
        };
    }

    // 友方在左侧分散站位
    chars.allies.forEach((ally, i) => {
        const row = i % 2;
        const col = Math.floor(i / 2);
        positions.allies.push({
            ...ally,
            position: {
                x: 80 + row * 80,
                y: 150 + col * 150
            }
        });
    });

    // 敌方在右侧分散站位
    chars.enemies.forEach((enemy, i) => {
        const row = i % 2;
        const col = Math.floor(i / 2);
        positions.enemies.push({
            ...enemy,
            position: {
                x: 700 - row * 80,
                y: 150 + col * 100
            }
        });
    });

    return positions;
}

/**
 * 渲染战斗地图
 * @param {object} aiPositions - AI生成的角色坐标（可选）
 * @param {boolean} forceRefresh - 是否强制刷新角色数据（可选）
 */
let lastBattleMapRenderTime = 0;
function renderBattleMap(aiPositions = null, forceRefresh = false) {
    // 防抖：300ms内的重复调用直接跳过（除非有新的位置数据或强制刷新）
    const now = Date.now();
    if (!aiPositions && !forceRefresh && now - lastBattleMapRenderTime < 300) {
        console.log('[地图系统] 战斗地图渲染防抖：300ms内重复调用，跳过');
        return;
    }
    lastBattleMapRenderTime = now;

    const viewport = document.getElementById('battleMapViewport');
    if (!viewport) {
        console.warn('[地图系统] 未找到战斗地图视口');
        return;
    }

    // 优先使用已设置的地形图，否则根据设置决定使用战棋棋盘还是默认地图
    let template;
    if (MapState.svgTemplate) {
        template = MapState.svgTemplate;
    } else if (!Settings.enableMapGeneration) {
        // 关闭AI生成时，使用战棋棋盘
        template = generateBattleChessboardSVG(MapState.currentLocation || '战场');
    } else {
        // 其他情况使用默认地图
        template = generateDefaultMapSVG(MapState.currentLocation || '战场', true);
    }

    // 确定角色位置数据
    let battleChars;
    if (aiPositions) {
        // 使用传入的位置数据
        console.log('[地图系统] 使用传入的位置数据');
        console.log('[地图系统] 传入数据 - 主角:', aiPositions.protagonist?.name, '友方数:', aiPositions.allies?.length, '敌方数:', aiPositions.enemies?.length);
        battleChars = aiPositions;
        // 同步更新到 MapState
        MapState.characterPositions = aiPositions;
    } else if (forceRefresh) {
        // 强制刷新：重新获取战斗角色并生成默认位置
        console.log('[地图系统] 强制刷新，重新获取战斗角色');
        const newChars = getBattleCharactersForMap();
        battleChars = generateDefaultBattlePositions(newChars);
        MapState.characterPositions = battleChars;
        console.log('[地图系统] 刷新数据 - 主角:', battleChars.protagonist?.name, '友方数:', battleChars.allies?.length, '敌方数:', battleChars.enemies?.length);
    } else if (MapState.characterPositions &&
        (MapState.characterPositions.protagonist ||
         MapState.characterPositions.allies?.length > 0 ||
         MapState.characterPositions.enemies?.length > 0)) {
        // 使用已保存的角色位置
        battleChars = MapState.characterPositions;
        console.log('[地图系统] 使用已保存的角色位置');
        console.log('[地图系统] 保存数据 - 主角:', battleChars.protagonist?.name, '友方数:', battleChars.allies?.length, '敌方数:', battleChars.enemies?.length);
    } else {
        // 重新获取战斗角色
        battleChars = getBattleCharactersForMap();
        console.log('[地图系统] 重新获取战斗角色');
        console.log('[地图系统] 获取数据 - 主角:', battleChars.protagonist?.name, '友方数:', battleChars.allies?.length, '敌方数:', battleChars.enemies?.length);
    }

    // 生成角色SVG
    let charactersSvg = '';

    // 主角
    if (battleChars.protagonist) {
        charactersSvg += generateCharacterSvg(battleChars.protagonist, 'protagonist');
    }

    // 友方
    battleChars.allies.forEach(ally => {
        charactersSvg += generateCharacterSvg(ally, 'ally');
    });

    // 敌方
    battleChars.enemies.forEach(enemy => {
        charactersSvg += generateCharacterSvg(enemy, 'enemy');
    });

    // 组合完整SVG
    let fullSvg = template;

    // 在</svg>之前插入角色元素
    if (fullSvg.includes('</svg>')) {
        fullSvg = fullSvg.replace('</svg>', charactersSvg + '</svg>');
    } else {
        fullSvg += charactersSvg + '</svg>';
    }

    // 使用innerHTML更新地图视口，保留缩放按钮
    viewport.innerHTML = fullSvg;
    initializeMapInteractions('battle');

    // 绑定角色点击事件
    bindBattleMapCharacterClickEvents();

    console.log('[地图系统] 战斗地图渲染完成, 角色:',
        '我方', (battleChars.allies.length || 0) + (battleChars.protagonist ? 1 : 0),
        '敌方', battleChars.enemies.length);
}

/**
 * 绑定战斗地图上角色图标的点击事件
 */
function bindBattleMapCharacterClickEvents() {
    const container = document.querySelector('.battle-map-container');
    if (!container) {
        console.warn('[地图系统] 未找到战斗地图容器');
        return;
    }

    // 查找所有角色标记
    const characterMarkers = container.querySelectorAll('.character-marker');
    console.log('[地图系统] 战斗地图找到角色标记数量:', characterMarkers.length);

    if (characterMarkers.length === 0) {
        // 如果没找到，可能是 SVG 还没渲染完成，延迟重试
        setTimeout(() => {
            const retryMarkers = container.querySelectorAll('.character-marker');
            console.log('[地图系统] 战斗地图延迟重试找到角色标记数量:', retryMarkers.length);
            bindClickEventsToMarkers(retryMarkers, true);
        }, 100);
        return;
    }

    bindClickEventsToMarkers(characterMarkers, true);
}

/**
 * 获取战斗角色数据（用于地图显示）
 */
function getBattleCharactersForMap() {
    const result = {
        protagonist: null,
        allies: [],
        enemies: []
    };

    // 主角
    if (GameState.protagonist) {
        result.protagonist = {
            name: GameState.protagonist.name,
            hp: `${GameState.protagonist.res?.hp?.cur || 0}/${GameState.protagonist.res?.hp?.max || 100}`,
            position: { x: 100, y: 300 }  // 主角默认位置
        };
    }

    // 从战斗场景表获取角色（包括主角方和敌方）
    if (GameState.battleCharacters && GameState.battleCharacters.length > 0) {
        let allyIndex = 0;
        let enemyIndex = 0;

        GameState.battleCharacters.forEach((char) => {
            const hpData = char.res?.hp || char.hp;
            const hpCur = hpData && hpData.cur !== undefined ? hpData.cur : 0;
            const hpMax = hpData && hpData.max !== undefined ? hpData.max : 100;

            if (char.isEnemy) {
                // 敌方在右侧分散站位
                const row = enemyIndex % 2;
                const col = Math.floor(enemyIndex / 2);
                result.enemies.push({
                    name: char.name,
                    hp: `${hpCur}/${hpMax}`,
                    position: {
                        x: 700 - row * 80,
                        y: 150 + col * 100
                    }
                });
                enemyIndex++;
            } else if (char.name !== GameState.protagonist?.name) {
                // 友方在左侧分散站位
                const row = allyIndex % 2;
                const col = Math.floor(allyIndex / 2);
                result.allies.push({
                    name: char.name,
                    hp: `${hpCur}/${hpMax}`,
                    position: {
                        x: 80 + row * 80,
                        y: 150 + col * 150
                    }
                });
                allyIndex++;
            }
        });
    }

    console.log('[地图系统] 战斗角色 - 我方:', result.allies.length, '敌方:', result.enemies.length);
    return result;
}

/**
 * 刷新战斗地图（强制重新生成）
 * 与日常模式的 forceRefreshMap() 逻辑一致
 */
async function refreshBattleMap() {
    console.log('[地图系统] 强制刷新战斗地图');

    if (MapState.isGenerating) {
        console.log('[地图系统] 正在生成中，跳过');
        return;
    }

    try {
        MapState.isGenerating = true;
        setMapStatus('loading', '正在重新生成战斗地图...');

        // 获取当前位置
        const location = await getCurrentLocation();
        if (!location) {
            setMapStatus('error', '无法获取当前位置');
            MapState.isGenerating = false;
            return;
        }

        MapState.currentLocation = location;

        // 删除当前地点的缓存
        console.log('[地图系统] 删除战斗地图缓存并重新生成:', location);
        await MapCache.clearLocation(location);

        // 获取剧情上下文
        const storyContext = getRecentStoryContext(3);
        const storyHash = hashText(storyContext + location);

        // 获取战斗角色
        const battleChars = getBattleCharactersForMap();
        let aiPositions = null;

        // 检查是否启用了地图生成
        if (!Settings.enableMapGeneration) {
            console.log('[地图系统] 地图生成已禁用，使用战棋棋盘');
            MapState.svgTemplate = generateBattleChessboardSVG(location);
            MapCache.set(location, MapState.svgTemplate, storyHash, null, null);
            aiPositions = generateDefaultBattlePositions(battleChars);
        } else {
            // 生成新的地形图和坐标
            console.log('[地图系统] 重新生成战斗地图...');
            setMapStatus('loading', '正在AI生成战斗地图...');

            const aiResult = await generateMapByAI(location, storyContext, true);

            if (aiResult && aiResult.svg && validateSVG(aiResult.svg)) {
                MapState.svgTemplate = aiResult.svg;
                aiPositions = aiResult.positions;
                console.log('[地图系统] 战斗地图AI生成成功，坐标:', aiPositions);
                MapCache.set(location, MapState.svgTemplate, storyHash, aiPositions, aiResult.structure);
            } else {
                console.log('[地图系统] AI生成失败，使用战棋棋盘');
                MapState.svgTemplate = generateBattleChessboardSVG(location);
                MapCache.set(location, MapState.svgTemplate, storyHash, null, null);
                aiPositions = generateDefaultBattlePositions(battleChars);
            }
        }

        // 应用角色位置
        if (aiPositions) {
            MapState.characterPositions = applyAIPositions(battleChars, aiPositions);
        } else {
            MapState.characterPositions = generateDefaultBattlePositions(battleChars);
        }

        // 更新显示
        renderBattleMap();
        setMapStatus('', '战斗地图已更新');

        // 如果战斗地图面板未打开，自动展开
        autoExpandBattleMapPanel();

        console.log('[地图系统] 战斗地图强制刷新完成');
    } catch (e) {
        console.error('[地图系统] 战斗地图刷新失败:', e);
        setMapStatus('error', '生成失败');
    } finally {
        MapState.isGenerating = false;
    }
}

/**
 * 更新战斗地图角色位置
 */
function updateBattleMapPositions() {
    if (GameState.currentMode !== 'battle') return;

    const battleMapPanel = document.getElementById('battleMapPanel');
    if (battleMapPanel) {
        renderBattleMap();
    }
}
</script>
</body>
</html>
