const MapCache = {
    dbName: 'RPGMapCache',
    storeName: 'maps',
    db: null,
    data: {}, // 内存缓存

    // 初始化 IndexedDB
    async init() {
        return new Promise((resolve, reject) => {
            // 使用版本2，与AvatarCache保持一致
            const request = indexedDB.open(this.dbName, 2);

            request.onerror = (event) => {
                console.error('[地图系统] IndexedDB 打开失败，使用内存缓存', event.target.error);
                resolve(false);
            };

            request.onsuccess = (event) => {
                this.db = event.target.result;
                console.log('[地图系统] IndexedDB 连接成功');
                this.loadFromIndexedDB().then(() => resolve(true));
            };

            request.onupgradeneeded = (event) => {
                const db = event.target.result;
                // 创建地图存储表
                if (!db.objectStoreNames.contains(this.storeName)) {
                    db.createObjectStore(this.storeName, { keyPath: 'location' });
                    console.log('[地图系统] 创建 maps 存储表');
                }
                // 创建头像存储表（如果不存在）
                if (!db.objectStoreNames.contains('avatars')) {
                    db.createObjectStore('avatars', { keyPath: 'id' });
                    console.log('[地图系统] 创建 avatars 存储表');
                }
            };
        });
    },

    // 从 IndexedDB 加载所有缓存
    async loadFromIndexedDB() {
        if (!this.db) return;

        return new Promise((resolve) => {
            const transaction = this.db.transaction([this.storeName], 'readonly');
            const store = transaction.objectStore(this.storeName);
            const request = store.getAll();

            request.onsuccess = (event) => {
                const items = event.target.result || [];
                items.forEach(item => {
                    this.data[item.location] = {
                        svgTemplate: item.svgTemplate,
                        timestamp: item.timestamp,
                        storyHash: item.storyHash,
                        positions: item.positions || null, // 加载角色坐标
                        structure: item.structure || null // 加载地图结构数据
                    };
                });
                console.log('[地图系统] 已从IndexedDB加载缓存，共', Object.keys(this.data).length, '个地点');
                resolve();
            };

            request.onerror = () => {
                console.error('[地图系统] 从IndexedDB加载失败');
                resolve();
            };
        });
    },

    load() {
        // 兼容旧的同步调用方式，从内存缓存读取
        console.log('[地图系统] 使用内存缓存，共', Object.keys(this.data).length, '个地点');
    },

    // 保存到 IndexedDB
    async saveToIndexedDB(locationName, data) {
        if (!this.db) return;

        return new Promise((resolve) => {
            const transaction = this.db.transaction([this.storeName], 'readwrite');
            const store = transaction.objectStore(this.storeName);

            const item = {
                location: locationName,
                svgTemplate: data.svgTemplate,
                timestamp: data.timestamp,
                storyHash: data.storyHash,
                positions: data.positions || null, // 保存角色坐标
                structure: data.structure || null // 保存地图结构数据
            };

            const request = store.put(item);
            request.onsuccess = () => {
                console.log('[地图系统] 已保存到IndexedDB:', locationName);
                resolve(true);
            };
            request.onerror = () => {
                console.error('[地图系统] 保存到IndexedDB失败:', locationName);
                resolve(false);
            };
        });
    },

    save() {
        // 保存所有内存缓存到 IndexedDB
        Object.keys(this.data).forEach(locationName => {
            this.saveToIndexedDB(locationName, this.data[locationName]);
        });
    },

    get(locationName) {
        return this.data[locationName] || null;
    },

    set(locationName, svgTemplate, storyHash, positions = null, structure = null) {
        this.data[locationName] = {
            svgTemplate,
            timestamp: Date.now(),
            storyHash,
            positions, // 保存角色坐标
            structure // 保存地图结构数据
        };
        this.saveToIndexedDB(locationName, this.data[locationName]);
        console.log('[地图系统] 已缓存地图:', locationName);
    },

    // 清除指定地点的缓存
    async clearLocation(locationName) {
        // 从内存删除
        delete this.data[locationName];

        // 从 IndexedDB 删除
        if (this.db) {
            return new Promise((resolve) => {
                const transaction = this.db.transaction([this.storeName], 'readwrite');
                const store = transaction.objectStore(this.storeName);
                const request = store.delete(locationName);

                request.onsuccess = () => {
                    console.log('[地图系统] 已清除地点缓存:', locationName);
                    resolve(true);
                };
                request.onerror = () => {
                    console.error('[地图系统] 清除地点缓存失败:', locationName);
                    resolve(false);
                };
            });
        }
        return true;
    },

    // 清除所有缓存
    async clear() {
        // 清空内存
        this.data = {};

        // 清空 IndexedDB
        if (this.db) {
            return new Promise((resolve) => {
                const transaction = this.db.transaction([this.storeName], 'readwrite');
                const store = transaction.objectStore(this.storeName);
                const request = store.clear();

                request.onsuccess = () => {
                    console.log('[地图系统] 所有缓存已清空');
                    resolve(true);
                };
                request.onerror = () => {
                    console.error('[地图系统] 清空缓存失败');
                    resolve(false);
                };
            });
        }
        return true;
    }
};

// 地图状态
function createMapViewState() {
    return {
        scale: 1,
        minScale: 0.6,
        maxScale: 2.5,
        translateX: 0,
        translateY: 0,
        isDragging: false,
        pointerId: null,
        startX: 0,
        startY: 0,
        moved: false,
        suppressClickUntil: 0,
        locationKey: ''
    };
}

const MapState = {
    currentLocation: '',
    svgTemplate: '',
    isGenerating: false,
    isInitializing: false,  // 防止重复初始化
    initialized: false,     // 标记是否已完成初始化
    initializedLocation: '', // 记录已初始化的位置
    lastInitTime: 0,        // 上次初始化时间戳
    lastStoryHash: '',
    characterPositions: {
        protagonist: null,
        allies: [],
        enemies: []
    },
    mapView: createMapViewState(),
    battleMapView: createMapViewState()
};

function getMapInteractionElements(viewType = 'normal') {
    const isBattle = viewType === 'battle';
    const container = isBattle
        ? document.getElementById('battleMapContainer')
        : document.getElementById('mapContainer');
    const viewport = isBattle
        ? document.getElementById('battleMapViewport')
        : document.getElementById('mapViewport');
    const svg = viewport ? viewport.querySelector('svg') : null;
    const state = isBattle ? MapState.battleMapView : MapState.mapView;
    return { isBattle, container, viewport, svg, state };
}

function clampMapViewState(viewType = 'normal') {
    const { viewport, svg, state } = getMapInteractionElements(viewType);
    if (!viewport || !svg || !state) {
        return;
    }

    const scale = state.scale;
    const baseWidth = svg.clientWidth || viewport.clientWidth || 0;
    const baseHeight = svg.clientHeight || viewport.clientHeight || 0;
    const maxTranslateX = Math.max(0, (baseWidth * (scale - 1)) / 2);
    const maxTranslateY = Math.max(0, (baseHeight * (scale - 1)) / 2);

    state.translateX = Math.min(maxTranslateX, Math.max(-maxTranslateX, state.translateX));
    state.translateY = Math.min(maxTranslateY, Math.max(-maxTranslateY, state.translateY));

    if (scale <= 1) {
        state.translateX = 0;
        state.translateY = 0;
    }
}

function applyMapTransform(viewType = 'normal') {
    const { svg, state } = getMapInteractionElements(viewType);
    if (!svg || !state) {
        return;
    }

    clampMapViewState(viewType);
    svg.style.transform = `translate(${state.translateX}px, ${state.translateY}px) scale(${state.scale})`;
    svg.style.cursor = state.isDragging ? 'grabbing' : 'grab';
}

function syncMapViewLocation(viewType = 'normal') {
    const { state } = getMapInteractionElements(viewType);
    if (!state) {
        return;
    }

    const locationKey = `${viewType}:${MapState.currentLocation || 'unknown'}`;
    if (state.locationKey !== locationKey) {
        state.locationKey = locationKey;
        state.scale = 1;
        state.translateX = 0;
        state.translateY = 0;
        state.isDragging = false;
        state.pointerId = null;
        state.moved = false;
    }
}

function resetMapView(viewType = 'normal') {
    const { state, viewport } = getMapInteractionElements(viewType);
    if (!state) {
        return;
    }

    state.scale = 1;
    state.translateX = 0;
    state.translateY = 0;
    state.isDragging = false;
    state.pointerId = null;
    state.moved = false;

    if (viewport) {
        viewport.classList.remove('dragging');
    }

    applyMapTransform(viewType);
}

function initializeMapInteractions(viewType = 'normal') {
    syncMapViewLocation(viewType);

    const { viewport, state } = getMapInteractionElements(viewType);
    if (!viewport || !state) {
        return;
    }

    if (viewport.dataset.dragBound === 'true') {
        applyMapTransform(viewType);
        return;
    }

    viewport.dataset.dragBound = 'true';

    viewport.addEventListener('pointerdown', (event) => {
        if (event.pointerType !== 'touch' && event.button !== 0) {
            return;
        }

        const current = getMapInteractionElements(viewType);
        if (!current.svg) {
            return;
        }

        state.isDragging = true;
        state.pointerId = event.pointerId;
        state.startX = event.clientX - state.translateX;
        state.startY = event.clientY - state.translateY;
        state.moved = false;
        viewport.classList.add('dragging');

        if (typeof viewport.setPointerCapture === 'function') {
            try {
                viewport.setPointerCapture(event.pointerId);
            } catch (e) {}
        }

        event.preventDefault();
    }, { passive: false });

    viewport.addEventListener('pointermove', (event) => {
        if (!state.isDragging || state.pointerId !== event.pointerId) {
            return;
        }

        const nextX = event.clientX - state.startX;
        const nextY = event.clientY - state.startY;

        if (!state.moved && (Math.abs(nextX - state.translateX) > 3 || Math.abs(nextY - state.translateY) > 3)) {
            state.moved = true;
        }

        state.translateX = nextX;
        state.translateY = nextY;
        applyMapTransform(viewType);
        event.preventDefault();
    }, { passive: false });

    const stopDragging = (event) => {
        if (!state.isDragging) {
            return;
        }

        if (event.pointerId !== undefined && state.pointerId !== null && state.pointerId !== event.pointerId) {
            return;
        }

        if (typeof viewport.releasePointerCapture === 'function' && state.pointerId !== null) {
            try {
                viewport.releasePointerCapture(state.pointerId);
            } catch (e) {}
        }

        state.isDragging = false;
        state.pointerId = null;
        viewport.classList.remove('dragging');

        if (state.moved) {
            state.suppressClickUntil = Date.now() + 180;
        }

        applyMapTransform(viewType);
    };

    viewport.addEventListener('pointerup', stopDragging);
    viewport.addEventListener('pointercancel', stopDragging);
    viewport.addEventListener('click', (event) => {
        if (Date.now() < state.suppressClickUntil) {
            event.preventDefault();
            event.stopPropagation();
            if (typeof event.stopImmediatePropagation === 'function') {
                event.stopImmediatePropagation();
            }
        }
    }, true);

    applyMapTransform(viewType);
}

function zoomMap(viewType = 'normal', delta = 0.2) {
    syncMapViewLocation(viewType);

    const { state } = getMapInteractionElements(viewType);
    if (!state) {
        return;
    }

    state.scale = Math.max(
        state.minScale,
        Math.min(state.maxScale, Number((state.scale + delta).toFixed(2)))
    );

    applyMapTransform(viewType);
}

window.addEventListener('resize', () => {
    applyMapTransform('normal');
    applyMapTransform('battle');
});

// 头像缓存（使用 IndexedDB）
const AvatarCache = {
    dbName: 'RPGMapCache',  // 与地图缓存使用同一个数据库
    storeName: 'avatars',
    db: null,
    protagonist: null,
    characters: {},
    initialized: false,

    // 初始化 IndexedDB
    async init() {
        if (this.initialized) return;

        return new Promise((resolve) => {
            // 如果 MapCache 已经打开了数据库，使用同一个
            if (MapCache.db) {
                this.db = MapCache.db;
                // 检查是否有 avatars 存储表，没有则创建
                if (!this.db.objectStoreNames.contains(this.storeName)) {
                    // 需要升级数据库版本
                    this.db.close();
                    this.initWithUpgrade().then(() => {
                        this.loadProtagonistAvatar().then(() => {
                            this.initialized = true;
                            resolve();
                        });
                    });
                } else {
                    this.loadProtagonistAvatar().then(() => {
                        this.initialized = true;
                        resolve();
                    });
                }
            } else {
                this.initWithUpgrade().then(() => {
                    this.loadProtagonistAvatar().then(() => {
                        this.initialized = true;
                        resolve();
                    });
                });
            }
        });
    },

    // 初始化并升级数据库
    async initWithUpgrade() {
        return new Promise((resolve, reject) => {
            const request = indexedDB.open(this.dbName, 2);  // 版本2，添加 avatars 表

            request.onerror = () => {
                console.error('[头像系统] IndexedDB 升级失败');
                // 回退到 localStorage
                this.protagonist = this.getProtagonistAvatarFromLocalStorage();
                resolve();
            };

            request.onsuccess = (event) => {
                this.db = event.target.result;
                console.log('[头像系统] IndexedDB 连接成功');
                resolve();
            };

            request.onupgradeneeded = (event) => {
                const db = event.target.result;
                if (!db.objectStoreNames.contains(this.storeName)) {
                    db.createObjectStore(this.storeName, { keyPath: 'id' });
                    console.log('[头像系统] 创建 avatars 存储表');
                }
                // 确保地图存储表也存在
                if (!db.objectStoreNames.contains('maps')) {
                    db.createObjectStore('maps', { keyPath: 'location' });
                }
            };
        });
    },

    // 从 IndexedDB 加载主角头像
    async loadProtagonistAvatar() {
        if (!this.db) {
            this.protagonist = this.getProtagonistAvatarFromLocalStorage();
            return;
        }

        return new Promise((resolve) => {
            try {
                const transaction = this.db.transaction([this.storeName], 'readonly');
                const store = transaction.objectStore(this.storeName);
                const request = store.get('protagonist');

                request.onsuccess = (event) => {
                    const data = event.target.result;
                    if (data && data.avatar) {
                        this.protagonist = data.avatar;
                        console.log('[头像系统] 从IndexedDB加载主角头像成功');
                    } else {
                        // 尝试从 localStorage 迁移
                        const localAvatar = this.getProtagonistAvatarFromLocalStorage();
                        if (localAvatar) {
                            this.protagonist = localAvatar;
                            // 迁移到 IndexedDB
                            this.saveProtagonistAvatar(localAvatar);
                            // 清除 localStorage
                            localStorage.removeItem('rpg-protagonist-avatar');
                            console.log('[头像系统] 已从localStorage迁移到IndexedDB');
                        }
                    }
                    resolve();
                };

                request.onerror = () => {
                    this.protagonist = this.getProtagonistAvatarFromLocalStorage();
                    resolve();
                };
            } catch (e) {
                this.protagonist = this.getProtagonistAvatarFromLocalStorage();
                resolve();
            }
        });
    },

    // 从 localStorage 获取头像（兼容旧数据）
    getProtagonistAvatarFromLocalStorage() {
        try {
            const customAvatar = localStorage.getItem('rpg-protagonist-avatar');
            if (customAvatar) {
                return customAvatar;
            }
            // 回退到SillyTavern角色头像
            const st = typeof parent.SillyTavern !== 'undefined' ? parent.SillyTavern : null;
            if (st && st.characters && st.this_chid !== undefined) {
                const char = st.characters[st.this_chid];
                if (char && char.avatar) {
                    return char.avatar;
                }
            }
            return null;
        } catch (e) {
            return null;
        }
    },

    // 保存主角头像到 IndexedDB
    async saveProtagonistAvatar(avatarData) {
        if (!this.db) {
            // 回退到 localStorage
            localStorage.setItem('rpg-protagonist-avatar', avatarData);
            return true;
        }

        return new Promise((resolve) => {
            try {
                const transaction = this.db.transaction([this.storeName], 'readwrite');
                const store = transaction.objectStore(this.storeName);
                const request = store.put({
                    id: 'protagonist',
                    avatar: avatarData,
                    timestamp: Date.now()
                });

                request.onsuccess = () => {
                    this.protagonist = avatarData;
                    console.log('[头像系统] 主角头像已保存到IndexedDB');
                    resolve(true);
                };

                request.onerror = () => {
                    // 回退到 localStorage
                    localStorage.setItem('rpg-protagonist-avatar', avatarData);
                    this.protagonist = avatarData;
                    resolve(true);
                };
            } catch (e) {
                localStorage.setItem('rpg-protagonist-avatar', avatarData);
                this.protagonist = avatarData;
                resolve(true);
            }
        });
    },

    // 删除主角头像
    async deleteProtagonistAvatar() {
        this.protagonist = null;

        if (this.db) {
            return new Promise((resolve) => {
                const transaction = this.db.transaction([this.storeName], 'readwrite');
                const store = transaction.objectStore(this.storeName);
                const request = store.delete('protagonist');

                request.onsuccess = () => {
                    console.log('[头像系统] 主角头像已删除');
                    resolve(true);
                };
                request.onerror = () => {
                    resolve(false);
                };
            });
        }

        localStorage.removeItem('rpg-protagonist-avatar');
        return true;
    },

    getProtagonistAvatar() {
        return this.protagonist;
    },

    getCharacterAvatar(charName) {
        if (this.characters[charName]) return this.characters[charName];

        try {
            const st = typeof parent.SillyTavern !== 'undefined' ? parent.SillyTavern : null;
            if (st && st.characters) {
                for (const key in st.characters) {
                    const char = st.characters[key];
                    if (char.name === charName && char.avatar) {
                        this.characters[charName] = char.avatar;
                        return char.avatar;
                    }
                }
            }
            return null;
        } catch (e) {
            return null;
        }
    }
};

/**
 * 获取主角当前位置
 */
async function getCurrentLocation() {
    try {
        const api = getAutoCardAPI();
        if (!api) return '';

        const jsonData = api.exportTableAsJson();
        const tables = typeof jsonData === 'string' ? JSON.parse(jsonData) : jsonData;

        // 遍历查找全局数据表
        for (const uid in tables) {
            const sheet = tables[uid];
            if (sheet && (sheet.name === '全局数据表' || sheet.name === '全局表')) {
                if (!sheet.content || sheet.content.length < 2) continue;

                const headers = sheet.content[0];
                const row = sheet.content[1];
                const locationIndex = headers.indexOf('主角当前所在地点');

                if (locationIndex !== -1 && locationIndex < row.length) {
                    return String(row[locationIndex] || '').trim();
                }
            }
        }

        return '';
    } catch (e) {
        console.error('[地图系统] 获取位置失败:', e);
        return '';
    }
}

/**
 * 获取最近剧情上下文（优先从数据库占位符获取）
 */
function getRecentStoryContext(maxTurns = 3) {
    try {
        // 方案1（优先）：从数据库API获取正文数据
        const api = getAutoCardAPI();
        if (api && typeof api.getStoryContext === 'function') {
            const context = api.getStoryContext(maxTurns);
            if (context) {
                console.log('[地图系统] 从数据库获取正文数据成功, 长度:', context.length);
                return context.substring(0, 60000);
            }
        }

        // 方案2：从数据库的exportTableAsJson获取全局数据表中的正文
        if (api && typeof api.exportTableAsJson === 'function') {
            try {
                const jsonData = api.exportTableAsJson();
                const tables = typeof jsonData === 'string' ? JSON.parse(jsonData) : jsonData;

                for (const uid in tables) {
                    const sheet = tables[uid];
                    if (sheet && (sheet.name === '全局数据表' || sheet.name === '全局表')) {
                        const headers = sheet.headers || [];
                        const rows = sheet.rows || [];

                        // 查找正文相关列
                        const storyIndex = headers.indexOf('正文');
                        const contextIndex = headers.indexOf('上下文');
                        const descIndex = headers.indexOf('场景描述');

                        if (rows.length > 0) {
                            const latestRow = rows[rows.length - 1];
                            let storyText = '';

                            if (storyIndex >= 0 && latestRow[storyIndex]) {
                                storyText = latestRow[storyIndex];
                            } else if (contextIndex >= 0 && latestRow[contextIndex]) {
                                storyText = latestRow[contextIndex];
                            } else if (descIndex >= 0 && latestRow[descIndex]) {
                                storyText = latestRow[descIndex];
                            }

                            if (storyText) {
                                console.log('[地图系统] 从全局数据表获取正文数据成功');
                                return storyText.substring(0, 3000);
                            }
                        }
                    }
                }
            } catch (e) {
                console.warn('[地图系统] 从全局数据表获取正文失败:', e);
            }
        }

        // 方案3（回退）：从SillyTavern聊天记录获取
        const st = typeof parent.SillyTavern !== 'undefined' ? parent.SillyTavern : null;
        const chat = st ? st.chat : [];

        if (!Array.isArray(chat) || chat.length === 0) return '';

        const aiMessages = [];
        let turnCount = 0;

        for (let i = chat.length - 1; i >= 0 && turnCount < maxTurns; i--) {
            const msg = chat[i];
            if (msg && !msg.is_user && msg.mes) {
                aiMessages.unshift(msg.mes);
                turnCount++;
            }
        }

        return aiMessages.join('\n\n').substring(0, 2000);
    } catch (e) {
        console.error('[地图系统] 获取剧情上下文失败:', e);
        return '';
    }
}

/**
 * 计算文本哈希
 */
function hashText(text) {
    let hash = 0;
    for (let i = 0; i < text.length; i++) {
        const char = text.charCodeAt(i);
        hash = ((hash << 5) - hash) + char;
        hash = hash & hash;
    }
    return Math.abs(hash).toString(36);
}

/**
 * 获取在场角色
 */
function getCharactersInCurrentLocation() {
    const result = {
        protagonist: null,
        allies: [],
        enemies: []
    };

    if (GameState.protagonist) {
        const hpData = GameState.protagonist.hp;
        const hpCur = hpData && hpData.cur !== undefined ? hpData.cur : 0;
        const hpMax = hpData && hpData.max !== undefined ? hpData.max : 100;
        result.protagonist = {
            name: GameState.protagonist.name,
            hp: `${hpCur}/${hpMax}`,
            isPlayer: true
        };
    }

    const currentLocation = MapState.currentLocation;
    console.log('[地图系统] 当前地点:', currentLocation, '角色总数:', GameState.characters.length);

    // 获取在场角色（使用 inScene 属性或 location 匹配）
    result.allies = GameState.characters
        .filter(char => {
            // 优先使用 inScene 属性判断是否在场
            if (char.inScene === false) return false;

            // 如果有 location 属性，检查是否匹配当前位置
            const location = char.location || '';
            if (location) {
                return location === currentLocation || location === currentLocation.substring(0, 4);
            }

            // 如果没有 location 属性但有 inScene 属性为 true，则认为在场
            return char.inScene === true;
        })
        .map(char => {
            const hpData = char.res?.hp;
            const hpCur = hpData && hpData.cur !== undefined ? hpData.cur : 0;
            const hpMax = hpData && hpData.max !== undefined ? hpData.max : 100;
            return {
                name: char.name,
                hp: `${hpCur}/${hpMax}`
            };
        });

    console.log('[地图系统] 在场友方角色数:', result.allies.length, result.allies.map(c => c.name).join(', '));

    // 战斗模式下，从战斗场景表获取主角方的队友和敌方角色
    if (GameState.currentMode === 'battle') {
        result.allies = GameState.battleCharacters
            .filter(char => char.faction === '主角方' && char.name !== GameState.protagonist?.name)
            .map(char => {
                const hpData = char.res?.hp;
                const hpCur = hpData && hpData.cur !== undefined ? hpData.cur : 0;
                const hpMax = hpData && hpData.max !== undefined ? hpData.max : 100;
                return {
                    name: char.name,
                    hp: `${hpCur}/${hpMax}`
                };
            });
        console.log('[地图系统] 战斗模式 - 友方角色数:', result.allies.length, result.allies.map(c => c.name).join(', '));

        // 获取敌方角色
        result.enemies = GameState.battleCharacters
            .filter(char => char.faction === '敌方')
            .map(char => {
                const hpData = char.res?.hp;
                const hpCur = hpData && hpData.cur !== undefined ? hpData.cur : 0;
                const hpMax = hpData && hpData.max !== undefined ? hpData.max : 100;
                return {
                    name: char.name,
                    hp: `${hpCur}/${hpMax}`
                };
            });
        console.log('[地图系统] 战斗模式 - 敌方角色数:', result.enemies.length, result.enemies.map(c => c.name).join(', '));
    }

    return result;
}

