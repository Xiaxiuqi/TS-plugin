// 用户设置对象
const Settings = {
    apiSource: 'database',  // 'database' | 'custom'
    customApiUrl: '',
    customApiKey: '',
    customModelName: 'gpt-4',
    enableMapGeneration: true,  // 是否启用地图生成

    // 从 localStorage 加载设置
    load() {
        const saved = localStorage.getItem('rpg_settings');
        if (saved) {
            try {
                const data = JSON.parse(saved);
                this.apiSource = data.apiSource || 'database';
                this.customApiUrl = data.customApiUrl || '';
                this.customApiKey = data.customApiKey || '';
                this.customModelName = data.customModelName || 'gpt-4';
                this.enableMapGeneration = data.enableMapGeneration !== false; // 默认true
                console.log('[设置] 加载成功:', this.apiSource, '地图生成:', this.enableMapGeneration);
            } catch (e) {
                console.warn('[设置] 加载失败:', e);
            }
        }
    },

    // 保存到 localStorage
    save() {
        const data = {
            apiSource: this.apiSource,
            customApiUrl: this.customApiUrl,
            customApiKey: this.customApiKey,
            customModelName: this.customModelName,
            enableMapGeneration: this.enableMapGeneration
        };
        localStorage.setItem('rpg_settings', JSON.stringify(data));
        console.log('[设置] 保存成功');
    }
};

