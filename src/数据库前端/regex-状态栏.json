// ==================== 主角头像功能 ====================
const AVATAR_STORAGE_KEY = 'rpg-protagonist-avatar';

async function loadProtagonistAvatar(protagonistName) {
    const container = document.getElementById('protagonistAvatar');
    const imgElement = document.getElementById('protagonistAvatarImg');
    const textElement = document.getElementById('protagonistAvatarText');

    if (!container || !imgElement || !textElement) return;

    // 确保 AvatarCache 已初始化
    await AvatarCache.init();

    // 从 IndexedDB 加载自定义头像
    const customAvatar = AvatarCache.getProtagonistAvatar();

    if (customAvatar) {
        imgElement.src = customAvatar;
        imgElement.style.display = 'block';
        textElement.style.display = 'none';
        imgElement.onerror = function() {
            // 加载失败，回退到文字头像
            imgElement.style.display = 'none';
            textElement.style.display = 'block';
            textElement.textContent = protagonistName ? protagonistName.charAt(0) : '?';
            AvatarCache.deleteProtagonistAvatar();
        };
    } else {
        imgElement.style.display = 'none';
        textElement.style.display = 'block';
        textElement.textContent = protagonistName ? protagonistName.charAt(0) : '?';
    }
}

function initAvatarUpload() {
    const container = document.getElementById('protagonistAvatar');
    if (!container) return;

    container.addEventListener('click', function() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.onchange = async function(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = async function(e) {
                const img = new Image();
                img.onload = async function() {
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    const TARGET_SIZE = 120; // 头像尺寸
                    canvas.width = TARGET_SIZE;
                    canvas.height = TARGET_SIZE;

                    // 裁剪为正方形
                    const size = Math.min(img.width, img.height);
                    const x = (img.width - size) / 2;
                    const y = (img.height - size) / 2;

                    ctx.drawImage(img, x, y, size, size, 0, 0, TARGET_SIZE, TARGET_SIZE);

                    const dataUrl = canvas.toDataURL('image/png');

                    try {
                        // 保存到 IndexedDB
                        await AvatarCache.saveProtagonistAvatar(dataUrl);
                        await loadProtagonistAvatar(GameState.protagonist?.name);
                        console.log('[头像系统] 自定义头像已保存');
                    } catch (err) {
                        console.error("保存自定义头像失败:", err);
                        alert('保存头像失败，请重试。');
                    }
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        };
        input.click();
    });
}

function updateBar(id, cur, max) {
    const bar = document.getElementById(id + 'Bar');
    const val = document.getElementById(id + 'Value');
    if (bar) bar.style.width = Math.max(0, Math.min(100, (cur / max) * 100)) + '%';
    if (val) val.textContent = cur + '/' + max;
}

