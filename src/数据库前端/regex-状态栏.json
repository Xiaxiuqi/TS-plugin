function getSkillIcon(name) {
    if (name.includes('火')) return '🔥';
    if (name.includes('冰')) return '❄️';
    if (name.includes('治愈') || name.includes('治疗')) return '💚';
    if (name.includes('护盾')) return '🛡️';
    if (name.includes('雷')) return '⚡';
    if (name.includes('重击') || name.includes('斩')) return '⚔️';
    return '✨';
}

// ==================== 雷达图 ====================
function drawRadarChart() {
    const canvas = document.getElementById('radarCanvas');
    const ctx = canvas.getContext('2d');
    const p = GameState.protagonist;
    if (!p) return;

    // 使用基础属性和装备加成
    const baseAttrs = GameState.baseAttrs;
    const bonus = GameState.equipmentBonus;
    const keys = ['str', 'dex', 'con', 'int', 'wis', 'cha'];
    const labels = ['力量', '敏捷', '体质', '智力', '感知', '魅力'];

    // 基础值和总值
    const baseValues = keys.map(k => baseAttrs[k] || 0);
    const totalValues = keys.map(k => (baseAttrs[k] || 0) + (bonus[k] || 0));
    const maxVal = 25;

    // 设置canvas实际像素尺寸
    canvas.width = 200;
    canvas.height = 200;

    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const cx = canvas.width / 2;
    const cy = canvas.height / 2;
    const r = Math.min(cx, cy) - 30;

    // 绘制网格
    ctx.strokeStyle = 'rgba(139, 69, 19, 0.2)';
    ctx.lineWidth = 1;
    for (let i = 1; i <= 5; i++) {
        ctx.beginPath();
        const ri = r * i / 5;
        for (let j = 0; j <= 6; j++) {
            const angle = Math.PI * 2 * j / 6 - Math.PI / 2;
            const x = cx + ri * Math.cos(angle);
            const y = cy + ri * Math.sin(angle);
            if (j === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
        }
        ctx.closePath();
        ctx.stroke();
    }

    // 绘制轴线
    for (let i = 0; i < 6; i++) {
        const angle = Math.PI * 2 * i / 6 - Math.PI / 2;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle));
        ctx.stroke();
    }

    // 绘制基础属性区域（灰色）
    ctx.beginPath();
    ctx.fillStyle = 'rgba(100, 100, 100, 0.2)';
    ctx.strokeStyle = 'rgba(100, 100, 100, 0.5)';
    ctx.lineWidth = 1;
    for (let i = 0; i <= 6; i++) {
        const idx = i % 6;
        const angle = Math.PI * 2 * i / 6 - Math.PI / 2;
        const val = Math.min(baseValues[idx], maxVal);
        const ri = r * val / maxVal;
        const x = cx + ri * Math.cos(angle);
        const y = cy + ri * Math.sin(angle);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.fill();
    ctx.stroke();

    // 绘制总属性区域（金色）
    ctx.beginPath();
    ctx.fillStyle = 'rgba(184, 134, 11, 0.3)';
    ctx.strokeStyle = 'rgba(184, 134, 11, 0.8)';
    ctx.lineWidth = 2;
    for (let i = 0; i <= 6; i++) {
        const idx = i % 6;
        const angle = Math.PI * 2 * i / 6 - Math.PI / 2;
        const val = Math.min(totalValues[idx], maxVal);
        const ri = r * val / maxVal;
        const x = cx + ri * Math.cos(angle);
        const y = cy + ri * Math.sin(angle);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.fill();
    ctx.stroke();

    // 绘制标签（显示总值，有加成时显示绿色）
    ctx.font = '11px Microsoft YaHei';
    ctx.textAlign = 'center';

    for (let i = 0; i < 6; i++) {
        const angle = Math.PI * 2 * i / 6 - Math.PI / 2;
        const x = cx + (r + 18) * Math.cos(angle);
        const y = cy + (r + 18) * Math.sin(angle);

        const hasBonus = bonus[keys[i]] > 0;
        ctx.fillStyle = hasBonus ? '#2e7d32' : '#3d2914';

        const label = labels[i] + totalValues[i];
        ctx.fillText(label, x, y + 4);
    }
}

// ==================== 弹窗控制 ====================
function openModal(id) { document.getElementById(id).classList.add('active'); }
function closeModal(id) { document.getElementById(id).classList.remove('active'); }

// ==================== 技能弹窗 ====================
function openSkillModal() {
    const container = document.getElementById('skillList');
    container.innerHTML = GameState.skills.map(s => {
        const icon = getSkillIcon(s.name);
        const profPct = (s.prof.cur / s.prof.max) * 100;
        return '<div class="skill-item">' +
            '<div class="skill-item-icon">' + icon + '</div>' +
            '<div class="skill-item-info">' +
            '<div class="skill-item-header">' +
            '<span class="skill-item-name">' + s.name + '</span>' +
            '<span class="skill-item-level">Lv.' + s.level + '</span></div>' +
            '<div class="skill-item-meta">类型: ' + s.type + ' | 消耗: ' + s.costType + ' ' + s.costVal + '</div>' +
            '<div class="skill-item-desc">' + s.desc + '</div>' +
            '<div class="skill-item-proficiency">' +
            '<div class="proficiency-bar"><div class="proficiency-fill" style="width:' + profPct + '%"></div></div>' +
            '<div class="proficiency-text">熟练度: ' + s.prof.cur + '/' + s.prof.max + '</div></div></div></div>';
    }).join('');
    openModal('skillModal');
}

// ==================== 背包弹窗 ====================
function openInventoryModal() {
    renderInventory();
    openModal('inventoryModal');
}

function filterInventory(category) {
    GameState.currentFilter = category;
    document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
    event.target.classList.add('active');
    renderInventory();
}

function renderInventory() {
    const container = document.getElementById('inventoryGrid');
    let items = GameState.inventory;

    if (GameState.currentFilter !== 'all') {
        items = items.filter(i => i.category === GameState.currentFilter);
    }

    container.innerHTML = items.map((item, i) => {
        const icon = getItemIcon(item.category);
        const equipable = item.slot ? ' equipable' : '';
        // 使用 data-original-index 存储原始索引，而不是筛选后的索引
        const originalIndex = GameState.inventory.indexOf(item);
        return '<div class="inventory-item' + equipable + '" data-original-index="' + originalIndex + '" onclick="showItemDetail(' + originalIndex + ')">' +
            '<div class="inventory-item-icon">' + icon + '</div>' +
            '<div class="inventory-item-name">' + item.name + '</div>' +
            (item.count > 1 ? '<div class="inventory-item-count">x' + item.count + '</div>' : '') + '</div>';
    }).join('');
}

function getItemIcon(category) {
    const icons = { '武器': '⚔️', '防具': '🛡️', '饰品': '💍', '消耗品': '🧪', '材料': '💎', '杂物': '📦' };
    return icons[category] || '📦';
}

function showItemDetail(index) {
    const item = GameState.inventory[index];
    document.getElementById('itemDetailTitle').textContent = item.name;

    let content = '<div style="font-size:36px;margin-bottom:10px;">' + getItemIcon(item.category) + '</div>';
    content += '<div style="font-size:12px;color:var(--ink-light);margin-bottom:8px;">' + item.category + '</div>';
    content += '<div style="font-size:13px;margin-bottom:10px;">' + item.desc + '</div>';

    if (item.slot) {
        content += '<div style="font-size:11px;color:var(--border-gold);">装备部位: ' + item.slot + '</div>';
        if (item.stats) content += '<div style="font-size:11px;color:var(--success);">属性: ' + item.stats + '</div>';
        if (item.effect) content += '<div style="font-size:11px;color:var(--accent-blue);">效果: ' + item.effect + '</div>';
    }

    // 消耗品显示数量选择器
    if (item.category === '消耗品' && item.count > 1) {
        content += '<div style="margin-top:10px;font-size:12px;">使用数量: ';
        content += '<button style="width:28px;height:28px;border:1px solid var(--border-dark);background:var(--parchment-bg);cursor:pointer;" onclick="adjustUseCount(-1)">-</button>';
        content += '<span id="useCount" style="margin:0 10px;font-weight:bold;">1</span>';
        content += '<button style="width:28px;height:28px;border:1px solid var(--border-dark);background:var(--parchment-bg);cursor:pointer;" onclick="adjustUseCount(1)">+</button>';
        content += ' <span style="color:var(--ink-light);">(拥有: ' + item.count + ')</span></div>';
        // 存储当前物品索引和最大数量
        GameState.currentItemIndex = index;
        GameState.currentUseCount = 1;
    }

    document.getElementById('itemDetailContent').innerHTML = content;

    let buttons = '<button class="modal-btn secondary" onclick="closeModal(\'itemDetailModal\')">关闭</button>';
    if (item.slot) {
        buttons += '<button class="modal-btn primary" onclick="equipItem(' + index + ')">装备</button>';
    } else if (item.category === '消耗品') {
        buttons += '<button class="modal-btn primary" onclick="useItem(' + index + ')">使用</button>';
    }
    document.getElementById('itemDetailButtons').innerHTML = buttons;

    openModal('itemDetailModal');
}

// 调整使用数量
function adjustUseCount(delta) {
    const item = GameState.inventory[GameState.currentItemIndex];
    if (!item) return;

    let newCount = GameState.currentUseCount + delta;
    if (newCount < 1) newCount = 1;
    if (newCount > item.count) newCount = item.count;

    GameState.currentUseCount = newCount;
    const el = document.getElementById('useCount');
    if (el) el.textContent = newCount;
}

// 发送游戏动作到酒馆输入框（追加模式，支持多个动作）
function sendGameActionRequest(msg) {
    console.log("Action sent:", msg);

    if (typeof parent.triggerSlash === 'function') {
        try {
            // 获取当前输入框内容
            const input = parent.document.getElementById('send_textarea');
            const currentInput = input ? input.value : '';

            // 追加新动作（如果有内容则换行）
            const newInput = currentInput ? (currentInput + '\n' + msg) : msg;

            parent.triggerSlash('/setinput ' + newInput);
            console.log('[RPG前端] 动作已追加到输入框:', msg);
        } catch(e) {
            console.error("triggerSlash error:", e);
            alert('发送失败: ' + e.toString());
        }
    } else {
        // 回退方案：直接操作输入框
        const input = parent.document.getElementById('send_textarea');
        if (input) {
            const currentInput = input.value;
            input.value = currentInput ? (currentInput + '\n' + msg) : msg;
            input.focus();
            console.log('[RPG前端] 动作已追加到输入框(回退模式):', msg);
        } else {
            console.error("Cannot find input box");
            alert('错误: 无法找到输入框。');
        }
    }
}

// 使用物品
function useItem(index) {
    const item = GameState.inventory[index];
    if (!item) return;

    const useCount = GameState.currentUseCount || 1;
    const actualCount = Math.min(useCount, item.count);

    // 发送到酒馆输入框
    let msg = `使用物品 ${item.name}`;
    if (actualCount > 1) {
        msg += ` x${actualCount}`;
    }
    sendGameActionRequest(msg);

    // 关闭弹窗
    closeModal('itemDetailModal');

    // 重置使用数量
    GameState.currentUseCount = 1;

    console.log(`Used ${actualCount}x ${item.name}`);
}

// ==================== 装备弹窗 ====================
function openEquipmentModal() {
    updateEquipmentDisplay();
    openModal('equipmentModal');
}

function updateEquipmentDisplay() {
    const slots = ['头部', '左手', '右手', '身体', '腿部', '饰品1', '饰品2'];
    let totalStats = {};

    // 属性名称映射（中文→英文缩写）
    const attrMap = {
        '力量': 'STR', '敏捷': 'DEX', '体质': 'CON',
        '智力': 'INT', '感知': 'WIS', '魅力': 'CHA',
        'STR': 'STR', 'DEX': 'DEX', 'CON': 'CON',
        'INT': 'INT', 'WIS': 'WIS', 'CHA': 'CHA'
    };

    slots.forEach(slot => {
        const el = document.querySelector('.equip-slot[data-slot="' + slot + '"]');
        if (!el) return; // 安全检查

        const equip = GameState.equipment[slot];

        if (equip) {
            el.classList.remove('empty');
            const iconEl = el.querySelector('.equip-slot-icon');
            const nameEl = el.querySelector('.equip-slot-name');
            const tooltipEl = el.querySelector('.equip-slot-tooltip');

            if (iconEl) iconEl.textContent = getItemIcon(equip.type === '武器' ? '武器' : (equip.type === '饰品' ? '饰品' : '防具'));
            if (nameEl) nameEl.textContent = equip.name;

            // 设置tooltip显示完整装备名称和属性
            if (tooltipEl) {
                let tooltipText = equip.name;
                if (equip.stats) tooltipText += ' | ' + equip.stats;
                tooltipEl.textContent = tooltipText;
            }

            // 解析属性加成，支持多种格式
            if (equip.stats) {
                equip.stats.split(',').forEach(s => {
                    const trimmed = s.trim();
                    // 支持格式: "力量+5", "智力+3", "STR+5" 等
                    const m = trimmed.match(/(.+)\+(\d+)/);
                    if (m) {
                        const attrName = m[1].trim();
                        const attrKey = attrMap[attrName] || attrName;
                        totalStats[attrKey] = (totalStats[attrKey] || 0) + parseInt(m[2]);
                    }
                });
            }
        } else {
            el.classList.add('empty');
            const iconEl = el.querySelector('.equip-slot-icon');
            const nameEl = el.querySelector('.equip-slot-name');
            const tooltipEl = el.querySelector('.equip-slot-tooltip');
            if (iconEl) iconEl.textContent = '+';
            if (nameEl) nameEl.textContent = '';
            if (tooltipEl) tooltipEl.textContent = '';
        }
    });

    const statsEl = document.getElementById('equipmentStats');
    if (statsEl) {
        if (Object.keys(totalStats).length > 0) {
            statsEl.textContent = Object.entries(totalStats).map(([k, v]) => k + '+' + v).join(', ');
        } else {
            statsEl.textContent = '无装备加成';
        }
    }
}

// 当前选择的装备槽位
GameState.currentEquipSlot = null;

async function handleEquipSlot(slot) {
    console.log('[装备系统] 点击槽位:', slot);
    const equip = GameState.equipment[slot];
    console.log('[装备系统] 槽位中的装备:', equip);
    console.log('[装备系统] 当前所有装备:', JSON.stringify(GameState.equipment));

    if (equip) {
        const confirmMsg = '要卸下 ' + equip.name + ' 吗？';
        console.log('[装备系统] 确认消息:', confirmMsg);

        if (confirm(confirmMsg)) {
            const equipSlot = normalizeInventoryEquipSlot(equip.originalSlot || slot);
            const equipCategory = (equip.type || '').startsWith('武器')
                ? '武器'
                : ((equip.type || '').startsWith('饰品') ? '饰品' : (equip.type || '防具'));

            GameState.inventory.push({
                name: equip.name,
                count: 1,
                desc: equip.effect || '',
                category: equipCategory,
                slot: equipSlot,
                stats: equip.stats || '',
                effect: equip.effect || ''
            });
            delete GameState.equipment[slot];

            console.log('[装备系统] 已卸下装备:', equip.name, '返回背包，装备部位:', equipSlot);

            updateEquipmentDisplay();
            renderInventory();

            // 等待表格写入完成
            try {
                await onEquipmentChanged();
                console.log('[装备系统] 卸下装备后表格同步完成');
            } catch (e) {
                console.error('[装备系统] 卸下装备后的同步失败:', e);
            }
        }
    } else {
        showEquipSelectModal(slot);
    }
}

// 显示装备选择弹窗
function showEquipSelectModal(slot) {
    GameState.currentEquipSlot = slot;

    // 更新标题
    document.getElementById('equipSelectTitle').textContent = '选择' + slot + '装备';

    // 获取背包中可用于该槽位的装备
    const availableItems = [];

    // 确定要匹配的槽位类型
    const slotMatch = (slot === '饰品1' || slot === '饰品2') ? '饰品' : normalizeInventoryEquipSlot(slot);

    GameState.inventory.forEach((item, index) => {
        // 检查物品是否有装备部位属性
        if (item.slot) {
            // 饰品可以装备到饰品1或饰品2
            const itemSlot = item.slot === '饰品' ? '饰品' : item.slot;
            if (itemSlot === slotMatch) {
                availableItems.push({ ...item, originalIndex: index });
            }
        }
    });

    const listEl = document.getElementById('equipSelectList');

    if (availableItems.length === 0) {
        listEl.innerHTML = '<div class="equip-select-empty">背包中没有可装备到该部位的物品</div>';
    } else {
        listEl.innerHTML = availableItems.map((item, i) => {
            const icon = getItemIcon(item.category);
            return '<div class="equip-select-item" onclick="selectEquipFromList(' + item.originalIndex + ')">' +
                '<span class="equip-select-icon">' + icon + '</span>' +
                '<div class="equip-select-info">' +
                '<div class="equip-select-name">' + item.name + '</div>' +
                (item.stats ? '<div class="equip-select-stats">' + item.stats + '</div>' : '') +
                '</div></div>';
        }).join('');
    }

    openModal('equipSelectModal');
}

// 从列表选择装备
async function selectEquipFromList(inventoryIndex) {
    const item = GameState.inventory[inventoryIndex];
    if (!item || !item.slot) return;

    const slot = GameState.currentEquipSlot;
    let targetSlot = slot;
    if (item.slot === '饰品') {
        targetSlot = slot;
    }

    GameState.equipment[targetSlot] = {
        name: item.name,
        type: item.category === '武器' ? '武器' : (item.category === '饰品' ? '饰品' : '防具'),
        stats: item.stats,
        effect: item.effect,
        originalSlot: normalizeInventoryEquipSlot(item.slot)
    };

    item.count--;
    if (item.count <= 0) {
        GameState.inventory.splice(inventoryIndex, 1);
    }

    closeModal('equipSelectModal');
    updateEquipmentDisplay();
    renderInventory();

    // 等待表格写入完成
    try {
        await onEquipmentChanged();
        console.log('[装备系统] 装备选择后表格同步完成');
    } catch (e) {
        console.error('[装备系统] 装备选择后的同步失败:', e);
    }

    console.log('[装备系统] 装备了 ' + item.name + ' 到 ' + targetSlot);
}

async function equipItem(index) {
    const item = GameState.inventory[index];
    if (!item.slot) return;

    const targetSlot = item.slot === '饰品'
        ? (GameState.equipment['饰品1'] ? '饰品2' : '饰品1')
        : (item.slot === '手部' ? (GameState.equipment['右手'] ? '左手' : '右手') : item.slot);

    if (GameState.equipment[targetSlot]) {
        alert('该部位已有装备，请先卸下');
        return;
    }

    GameState.equipment[targetSlot] = {
        name: item.name,
        type: item.category === '武器' ? '武器' : (item.category === '饰品' ? '饰品' : '防具'),
        stats: item.stats,
        effect: item.effect,
        originalSlot: normalizeInventoryEquipSlot(item.slot)
    };

    item.count--;
    if (item.count <= 0) GameState.inventory.splice(index, 1);

    closeModal('itemDetailModal');
    updateEquipmentDisplay();
    renderInventory();

    // 等待表格写入完成
    try {
        await onEquipmentChanged();
        console.log('[装备系统] 快捷装备后表格同步完成');
    } catch (e) {
        console.error('[装备系统] 快捷装备后的同步失败:', e);
    }
}

// ==================== 装备变化处理（回写表格） ====================
async function onEquipmentChanged() {
    const p = GameState.protagonist;
    if (!p) return;

    // 重新计算装备加成
    const newBonus = GameState.calcEquipmentBonus();
    GameState.equipmentBonus = newBonus;

    // 计算新的总属性 = 基础属性 + 新加成
    const newTotalAttrs = {
        str: GameState.baseAttrs.str + newBonus.str,
        dex: GameState.baseAttrs.dex + newBonus.dex,
        con: GameState.baseAttrs.con + newBonus.con,
        int: GameState.baseAttrs.int + newBonus.int,
        wis: GameState.baseAttrs.wis + newBonus.wis,
        cha: GameState.baseAttrs.cha + newBonus.cha
    };

    // 更新主角的总属性
    p.attrs = newTotalAttrs;

    // 更新装备哈希
    GameState.lastEquipmentHash = GameState.getEquipmentHash();

    // 刷新UI显示
    updateProtagonistDisplay();
    drawRadarChart();

    // 回写到表格（属性、装备表、背包表）
    await writeAllToTables(newTotalAttrs);
}

async function persistMergedDataSnapshot(reason = 'manual_sync') {
    const api = getAutoCardAPI();
    if (!api || typeof api.exportTableAsJson !== 'function' || typeof api.importTableAsJson !== 'function') {
        console.warn('[RPG前端] 当前API不支持快照固化，跳过:', reason);
        return false;
    }

    if (GameState.isPersistingSnapshot) {
        console.log('[RPG前端] 快照固化进行中，跳过重复调用:', reason);
        return false;
    }

    try {
        GameState.isPersistingSnapshot = true;
        const snapshot = api.exportTableAsJson();
        if (!snapshot || typeof snapshot !== 'object' || !Object.keys(snapshot).some(key => key.startsWith('sheet_'))) {
            console.warn('[RPG前端] 当前没有可固化的合并表格数据:', reason);
            return false;
        }

        const success = await api.importTableAsJson(JSON.stringify(snapshot));
        if (success) {
            console.log('[RPG前端] 已将当前合并态固化到最新楼层:', reason);
            return true;
        }

        console.warn('[RPG前端] 合并态固化失败:', reason);
        return false;
    } catch (e) {
        console.error('[RPG前端] 合并态固化异常:', reason, e);
        return false;
    } finally {
        GameState.isPersistingSnapshot = false;
    }
}

// 将所有数据回写到表格
async function writeAllToTables(attrs) {
    const api = getAutoCardAPI();
    if (!api) return;

    // 设置写入标志，阻止 loadTableData 在写入期间被触发
    GameState.isWritingToTables = true;

    try {
        if (api.unregisterTableUpdateCallback) {
            api.unregisterTableUpdateCallback(loadTableData);
        }

        // 1. 更新主角信息表的属性列
        await writeAttrsToTable(attrs);

        // 2. 更新主角装备表
        await writeEquipmentToTable();

        // 3. 更新背包物品表
        await writeInventoryToTable();

        // 4. 在全部分表写回完成后，再统一刷新世界书
        if (api.refreshDataAndWorldbook) {
            await api.refreshDataAndWorldbook();
            console.log('[装备系统] 已触发世界书刷新');
        }

        // 5. 将当前合并态固化到最新楼层，避免下一层重新初始化时被旧楼层数据覆盖
        await persistMergedDataSnapshot('equipment_inventory_sync');

        console.log('[装备系统] 所有数据已回写表格');
    } catch (e) {
        console.error('[装备系统] 回写表格失败:', e);
    } finally {
        if (api.registerTableUpdateCallback) {
            api.registerTableUpdateCallback(loadTableData);
        }
        // 无论成功或失败，都要重置写入标志
        GameState.isWritingToTables = false;
    }
}

// 将属性回写到主角信息表
async function writeAttrsToTable(attrs) {
    const api = getAutoCardAPI();
    if (!api) {
        console.warn('[装备系统] API不可用，无法回写属性');
        return false;
    }

    try {
        // 优先使用新的 updateRow API
        if (api.updateRow) {
            const success = await api.updateRow('主角信息', 1, {
                '力量': attrs.str,
                '敏捷': attrs.dex,
                '体质': attrs.con,
                '智力': attrs.int,
                '感知': attrs.wis,
                '魅力': attrs.cha
            });

            if (success) {
                console.log('[装备系统] 属性已通过updateRow回写:', attrs);
                return true;
            } else {
                console.warn('[装备系统] updateRow失败，尝试使用importTableAsJson');
            }
        }

        // 回退方案：使用 importTableAsJson（全量覆盖）
        const jsonData = await api.exportTableAsJson();
        if (!jsonData) {
            console.warn('[装备系统] 无法获取表格数据');
            return false;
        }

        const tables = typeof jsonData === 'string' ? JSON.parse(jsonData) : jsonData;

        // 找到主角信息表
        for (const uid in tables) {
            if (tables[uid].name === '主角信息') {
                const sheet = tables[uid];
                const headers = sheet.content[0];
                const row = sheet.content[1]; // 第一行数据

                if (!row) {
                    console.warn('[装备系统] 主角信息表没有数据行');
                    return false;
                }

                // 更新属性列
                const attrMap = {
                    '力量': attrs.str,
                    '敏捷': attrs.dex,
                    '体质': attrs.con,
                    '智力': attrs.int,
                    '感知': attrs.wis,
                    '魅力': attrs.cha
                };

                for (const colName in attrMap) {
                    const idx = headers.indexOf(colName);
                    if (idx !== -1 && idx < row.length) {
                        row[idx] = attrMap[colName];
                    }
                }

                // 写回数据
                const success = await api.importTableAsJson(JSON.stringify(tables));
                if (success) {
                    console.log('[装备系统] 属性已回写表格:', attrs);
                    return true;
                } else {
                    console.error('[装备系统] 回写属性失败');
                    return false;
                }
            }
        }

        console.warn('[装备系统] 未找到主角信息表');
    } catch (e) {
        console.error('[装备系统] 回写属性表格失败:', e);
    }

    return false;
}

// 将装备回写到主角装备表
async function writeEquipmentToTable() {
    const api = getAutoCardAPI();
    if (!api) return;

    try {
        const equipmentRows = getEquipmentTableRows();

        if (api.updateRow && api.insertRow && api.deleteRow) {
            console.log('[装备系统] 使用新API回写装备');

            const jsonData = await api.exportTableAsJson();
            const tables = typeof jsonData === 'string' ? JSON.parse(jsonData) : jsonData;

            let equipTable = null;
            for (const uid in tables) {
                if (tables[uid].name === '主角装备表') {
                    equipTable = tables[uid];
                    break;
                }
            }

            let newApiSucceeded = !!equipTable;

            if (equipTable) {
                const existingRows = equipTable.content.length - 1;
                for (let rowIndex = existingRows; rowIndex >= 1; rowIndex--) {
                    try {
                        const deleted = await api.deleteRow('主角装备表', rowIndex);
                        if (!deleted) {
                            console.warn('[装备系统] 删除旧装备行返回失败:', rowIndex);
                            newApiSucceeded = false;
                        }
                    } catch (e) {
                        newApiSucceeded = false;
                        console.warn('[装备系统] 删除旧装备行失败:', rowIndex, e);
                    }
                }
            } else {
                console.warn('[装备系统] 新API未找到主角装备表');
            }

            if (newApiSucceeded) {
                for (const row of equipmentRows) {
                    try {
                        const insertedIndex = await api.insertRow('主角装备表', {
                            '装备名称': row.equip.name,
                            '装备部位': row.tableSlot,
                            '装备类型': row.tableType,
                            '属性加成': row.equip.stats || '',
                            '特殊效果': row.equip.effect || ''
                        });
                        if (insertedIndex === -1) {
                            console.warn('[装备系统] 插入装备行返回失败:', row);
                            newApiSucceeded = false;
                            break;
                        }
                    } catch (e) {
                        newApiSucceeded = false;
                        console.warn('[装备系统] 插入装备行失败:', row, e);
                        break;
                    }
                }
            }

            if (newApiSucceeded) {
                console.log('[装备系统] 装备已通过新API回写');
                return;
            }

            console.error('[装备系统] 新API回写装备失败，已停止回退分支');
            return;
        }

        console.error('[装备系统] 缺少逐表写回所需API，无法回写主角装备表');
    } catch (e) {
        console.error('[装备系统] 回写装备表格失败:', e);
    }
}

// 将背包回写到背包物品表
async function writeInventoryToTable() {
    const api = getAutoCardAPI();
    if (!api) return;

    try {
        // 优先使用新的 API
        if (api.updateRow && api.insertRow && api.deleteRow) {
            console.log('[装备系统] 使用新API回写背包');

            // 获取当前背包表的行数
            const jsonData = await api.exportTableAsJson();
            const tables = typeof jsonData === 'string' ? JSON.parse(jsonData) : jsonData;

            let invTable = null;
            for (const uid in tables) {
                if (tables[uid].name === '背包物品表') {
                    invTable = tables[uid];
                    break;
                }
            }

            let newApiSucceeded = !!invTable;

            if (invTable) {
                const existingRows = invTable.content.length - 1; // 减去表头

                // 先清空现有数据（从后往前删除）
                for (let i = existingRows; i >= 1; i--) {
                    try {
                        const deleted = await api.deleteRow('背包物品表', i);
                        if (!deleted) newApiSucceeded = false;
                    } catch (e) {
                        newApiSucceeded = false;
                        console.warn('[装备系统] 删除背包行失败:', i, e);
                    }
                }
            } else {
                console.warn('[装备系统] 新API未找到背包物品表');
            }

            if (newApiSucceeded) {
                // 添加新物品
                for (const item of GameState.inventory) {
                    if (item.count > 0) {
                        try {
                            const insertedIndex = await api.insertRow('背包物品表', {
                                '物品名称': item.name,
                                '数量': item.count,
                                '描述/效果': item.desc || '',
                                '类别': item.category || '',
                                '装备部位': item.slot || '',
                                '属性加成': item.stats || '',
                                '特殊效果': item.effect || ''
                            });
                            if (insertedIndex === -1) {
                                newApiSucceeded = false;
                                console.warn('[装备系统] 插入背包行返回失败:', item);
                                break;
                            }
                        } catch (e) {
                            newApiSucceeded = false;
                            console.warn('[装备系统] 插入背包行失败:', e);
                            break;
                        }
                    }
                }
            }

            if (newApiSucceeded) {
                console.log('[装备系统] 背包已通过新API回写');
                return;
            }

            console.error('[装备系统] 新API回写背包失败，已停止回退分支');
            return;
        }

        console.error('[装备系统] 缺少逐表写回所需API，无法回写背包物品表');
    } catch (e) {
        console.error('[装备系统] 回写背包表格失败:', e);
    }
}

// ==================== 角色详情弹窗 ====================
function openCharacterDetail(name) {
    console.log('[地图系统] 打开角色详情:', name);

    // 先尝试从角色列表查找
    let char = GameState.characters.find(c => c.name === name);

    // 如果没找到，尝试从主角数据查找
    if (!char && GameState.protagonist && GameState.protagonist.name === name) {
        console.log('[地图系统] 使用主角数据');
        char = {
            name: GameState.protagonist.name,
            gender: GameState.protagonist.gender || '未知',
            profession: GameState.protagonist.profession || '冒险者',
            level: GameState.protagonist.level || 1,
            attrs: GameState.protagonist.attrs || {},
            res: GameState.protagonist.res || { hp: {cur: 0, max: 100}, sp: {cur: 0, max: 100}, mp: {cur: 0, max: 100} },
            skills: GameState.protagonist.skills || '',
            intro: GameState.protagonist.intro || '主角',
            appearance: GameState.protagonist.appearance || '',
            inScene: true
        };
    }

    if (!char) {
        console.warn('[地图系统] 未找到角色:', name, '可用角色:', GameState.characters.map(c => c.name).join(', '));
        // 显示提示信息而不是静默返回
        alert('未找到角色信息：' + name);
        return;
    }

    GameState.currentNpc = char;
    document.getElementById('characterModalTitle').textContent = char.name;

    const a = char.attrs;
    const maxHP = GameState.calcMaxHP(a.con);
    const maxSP = GameState.calcMaxSP(a.con, a.str);
    const maxMP = GameState.calcMaxMP(a.int);

    let html = '<div class="character-detail-header">' +
        '<div class="character-detail-avatar">' + char.name.charAt(0) + '</div>' +
        '<div class="character-detail-info">' +
        '<div class="character-detail-name">' + char.name + '</div>' +
        '<div class="character-detail-meta">' + char.gender + ' | ' + char.profession + ' | Lv.' + char.level + '</div>' +
        '<div class="character-detail-resources">' +
        '<div class="resource-item"><span class="resource-label">HP</span>' +
        '<div class="resource-bar-container"><div class="resource-bar hp" style="width:' + (char.res.hp.cur/maxHP*100) + '%"></div>' +
        '<span class="resource-value">' + char.res.hp.cur + '/' + maxHP + '</span></div></div>' +
        '<div class="resource-item"><span class="resource-label">SP</span>' +
        '<div class="resource-bar-container"><div class="resource-bar sp" style="width:' + (char.res.sp.cur/maxSP*100) + '%"></div>' +
        '<span class="resource-value">' + char.res.sp.cur + '/' + maxSP + '</span></div></div>' +
        '<div class="resource-item"><span class="resource-label">MP</span>' +
        '<div class="resource-bar-container"><div class="resource-bar mp" style="width:' + (char.res.mp.cur/maxMP*100) + '%"></div>' +
        '<span class="resource-value">' + char.res.mp.cur + '/' + maxMP + '</span></div></div></div></div></div>';

    // NPC详细资料
    html += '<div class="character-info-section">';
    html += '<div class="info-row"><span class="info-label">一句话介绍</span><span class="info-value">' + char.intro + '</span></div>';
    html += '<div class="info-row"><span class="info-label">外貌特征</span><span class="info-value">' + char.appearance + '</span></div>';
    html += '</div>';

    html += '<div class="character-attributes">';
    ['力量', '敏捷', '体质', '智力', '感知', '魅力'].forEach(n => {
        const key = Object.keys(GameState.attrNames).find(k => GameState.attrNames[k] === n);
        html += '<div class="attribute-item"><span class="attribute-name">' + n + '</span><span class="attribute-value">' + a[key] + '</span></div>';
    });
    html += '</div>';

    if (char.skills) {
        html += '<div class="character-skills"><div class="character-skills-title">当前技能</div>';
        char.skills.split(',').forEach(s => {
            html += '<span class="character-skill-tag">' + s.trim() + '</span>';
        });
        html += '</div>';
    }

    // 只有在场角色才显示互动按钮
    if (char.inScene) {
        html += '<div class="interaction-buttons">' +
            '<button class="interaction-btn" onclick="sendInteraction(\'交谈\')">💬 交谈</button>' +
            '<button class="interaction-btn" onclick="sendInteraction(\'询问\')">❓ 询问</button>' +
            '<button class="interaction-btn" onclick="sendInteraction(\'交易\')">💰 交易</button>' +
            '<button class="interaction-btn" onclick="sendInteraction(\'赠礼\')">🎁 赠礼</button>' +
            '</div>';
    }

    document.getElementById('characterDetail').innerHTML = html;
    openModal('characterModal');
}

function sendInteraction(action) {
    const msg = '[' + action + '] 与 ' + GameState.currentNpc.name;
    sendToChat(msg);
    closeModal('characterModal');
}

// ==================== 加点弹窗 ====================
function openPointAllocation() {
    const p = GameState.protagonist;
    if (!p || GameState.freePoints <= 0) return;

    GameState.pendingAllocation = { str: 0, dex: 0, con: 0, int: 0, wis: 0, cha: 0 };
    document.getElementById('freePointsValue').textContent = GameState.freePoints;

    const container = document.getElementById('pointAllocationContent');
    container.innerHTML = Object.keys(GameState.attrNames).map(key =>
        '<div class="allocation-row">' +
        '<span class="allocation-name">' + GameState.attrNames[key] + '</span>' +
        '<span class="allocation-current" id="alloc-cur-' + key + '">' + p.attrs[key] + '</span>' +
        '<div class="allocation-controls">' +
        '<button class="allocation-btn" onclick="adjustAllocation(\'' + key + '\',-1)">-</button>' +
        '<span class="allocation-change" id="alloc-chg-' + key + '">+0</span>' +
        '<button class="allocation-btn" onclick="adjustAllocation(\'' + key + '\',1)">+</button></div></div>'
    ).join('');

    updateResourcePreview();
    openModal('pointAllocationModal');
}

function adjustAllocation(attr, delta) {
    const p = GameState.protagonist;
    const cur = GameState.pendingAllocation[attr];
    const used = Object.values(GameState.pendingAllocation).reduce((a, b) => a + b, 0);

    if (delta > 0 && used >= GameState.freePoints) return;
    if (delta < 0 && cur <= 0) return;

    GameState.pendingAllocation[attr] += delta;
    document.getElementById('alloc-chg-' + attr).textContent = (cur + delta >= 0 ? '+' : '') + (cur + delta);
    document.getElementById('alloc-chg-' + attr).className = 'allocation-change' + (cur + delta > 0 ? ' positive' : (cur + delta < 0 ? ' negative' : ''));
    document.getElementById('alloc-cur-' + attr).textContent = p.attrs[attr] + cur + delta;

    updateResourcePreview();
}

function updateResourcePreview() {
    const p = GameState.protagonist;
    const a = GameState.pendingAllocation;

    const oldHP = GameState.calcMaxHP(p.attrs.con);
    const oldSP = GameState.calcMaxSP(p.attrs.con, p.attrs.str);
    const oldMP = GameState.calcMaxMP(p.attrs.int);

    const newHP = GameState.calcMaxHP(p.attrs.con + a.con);
    const newSP = GameState.calcMaxSP(p.attrs.con + a.con, p.attrs.str + a.str);
    const newMP = GameState.calcMaxMP(p.attrs.int + a.int);

    document.getElementById('resourcePreview').innerHTML =
        '<div class="preview-item"><div class="preview-label">生命上限</div>' +
        '<div class="preview-values"><span class="preview-old">' + oldHP + '</span> → <span class="preview-new">' + newHP + '</span></div></div>' +
        '<div class="preview-item"><div class="preview-label">体力上限</div>' +
        '<div class="preview-values"><span class="preview-old">' + oldSP + '</span> → <span class="preview-new">' + newSP + '</span></div></div>' +
        '<div class="preview-item"><div class="preview-label">法力上限</div>' +
        '<div class="preview-values"><span class="preview-old">' + oldMP + '</span> → <span class="preview-new">' + newMP + '</span></div></div>';
}

async function confirmPointAllocation() {
    const p = GameState.protagonist;
    const allocation = GameState.pendingAllocation;

    // 计算使用的点数
    const usedPoints = Object.values(allocation).reduce((a, b) => a + b, 0);

    // 更新基础属性
    for (const key in allocation) {
        GameState.baseAttrs[key] += allocation[key];
    }

    // 重新计算总属性
    const newTotalAttrs = GameState.getTotalAttrs();
    p.attrs = newTotalAttrs;
    p.baseAttrs = { ...GameState.baseAttrs };

    // 更新前端维护的自由点数
    GameState.freePoints -= usedPoints;
    GameState.usedFreePoints += usedPoints;  // 累加已使用点数
    p.freePoints = GameState.freePoints;

    // 保存已使用点数到 localStorage
    localStorage.setItem('rpg_usedFreePoints', GameState.usedFreePoints.toString());

    console.log('[RPG前端] 属性分配完成，使用点数:', usedPoints, '剩余自由点:', GameState.freePoints, '累计已使用:', GameState.usedFreePoints);

    closeModal('pointAllocationModal');
    updateUI();

    // 只回写属性到表格（不再写入自由点数），并将当前合并态固化到最新楼层
    const api = getAutoCardAPI();
    GameState.isWritingToTables = true;

    try {
        if (api && api.unregisterTableUpdateCallback) {
            api.unregisterTableUpdateCallback(loadTableData);
        }

        const success = await writeAttrsToTable(newTotalAttrs);
        if (success) {
            await persistMergedDataSnapshot('point_allocation');
        }
    } finally {
        if (api && api.registerTableUpdateCallback) {
            api.registerTableUpdateCallback(loadTableData);
        }
        GameState.isWritingToTables = false;
    }
}

// 属性回写逻辑已统一复用上方的 [`writeAttrsToTable()`](rpg_frontend_v2.html:4245)

// ==================== 战斗技能选择 ====================
function toggleSkillSelection(index) {
    const skill = GameState.skills[index];
    const p = GameState.protagonist;

    // 检查资源
    let resOk = true;
    if (skill.costType === '法力') resOk = p.res.mp.cur >= skill.costVal;
    else if (skill.costType === '体力') resOk = p.res.sp.cur >= skill.costVal;
    if (!resOk) return;

    const i = GameState.selectedSkills.findIndex(s => s.name === skill.name);
    if (i >= 0) {
        GameState.selectedSkills.splice(i, 1);
    } else {
        GameState.selectedSkills.push(skill);
    }

    updateBattleSkills();
}

function clearSelectedSkills() {
    GameState.selectedSkills = [];
    updateBattleSkills();
}

function confirmSkills() {
    if (GameState.selectedSkills.length === 0) {
        alert('请先选择技能');
        return;
    }

    // 检查总消耗
    let totalMP = 0, totalSP = 0;
    GameState.selectedSkills.forEach(s => {
        if (s.costType === '法力') totalMP += s.costVal;
        if (s.costType === '体力') totalSP += s.costVal;
    });

    const p = GameState.protagonist;
    if (totalMP > p.res.mp.cur || totalSP > p.res.sp.cur) {
        alert('资源不足！');
        return;
    }

    const msg = GameState.selectedSkills.map(s => '[使用技能] ' + s.name).join('\n');
    sendToChat(msg);
    GameState.selectedSkills = [];
    updateBattleSkills();
}

