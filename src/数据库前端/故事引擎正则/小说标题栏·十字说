    <script>
        (function() {
            const widget = document.getElementById('novel-widget');
            const mainContent = document.getElementById('widget-main');
            const expandBtn = document.getElementById('expand-btn');
            const themeBtn = document.getElementById('theme-btn');
            const settingsBtn = document.getElementById('settings-btn');
            const settingsPanel = document.getElementById('settings-panel');
            const btnV = document.getElementById('layout-v'), btnH = document.getElementById('layout-h');

            const iconSun = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" class="icon-sun"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="M4.93 4.93l1.41 1.41"></path><path d="M17.66 17.66l1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="M6.34 17.66l-1.41 1.41"></path><path d="M19.07 4.93l-1.41 1.41"></path></svg>';
            const iconMoon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>';

            let currentSize = 16;

            const initStorage = () => {
                if(localStorage.getItem('novelTheme') === 'night') {
                    widget.classList.add('night-mode');
                    themeBtn.innerHTML = iconMoon;
                }
                if(localStorage.getItem('novelLayout') === 'h') {
                    widget.classList.add('layout-horizontal');
                    btnH.classList.add('active'); btnV.classList.remove('active');
                }
                const savedSize = localStorage.getItem('novelSize');
                if(savedSize) {
                    currentSize = parseInt(savedSize);
                    widget.style.setProperty('--base-font-size', currentSize + 'px');
                }
                const savedColor = localStorage.getItem('novelColor');
                if(savedColor) {
                    widget.style.setProperty('--novel-accent', savedColor);
                    document.getElementById('custom-color').value = savedColor;
                }
            };
            initStorage();

            expandBtn.addEventListener('click', () => {
                mainContent.classList.toggle('is-expanded');
            });

            settingsBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                settingsPanel.classList.toggle('active');
            });

            document.addEventListener('click', (e) => {
                if (!settingsPanel.contains(e.target) && e.target !== settingsBtn) {
                    settingsPanel.classList.remove('active');
                }
            });

            themeBtn.addEventListener('click', () => {
                widget.classList.toggle('night-mode');
                const isNight = widget.classList.contains('night-mode');
                themeBtn.innerHTML = isNight ? iconMoon : iconSun;
                localStorage.setItem('novelTheme', isNight ? 'night' : 'day');
            });

            const updateColor = (color) => {
                widget.style.setProperty('--novel-accent', color);
                document.getElementById('custom-color').value = color;
                localStorage.setItem('novelColor', color);
            };

            document.querySelectorAll('.color-dot').forEach(dot => {
                dot.addEventListener('click', (e) => updateColor(e.target.dataset.color));
            });
            document.getElementById('custom-color').addEventListener('input', (e) => updateColor(e.target.value));

            btnV.addEventListener('click', () => {
                widget.classList.remove('layout-horizontal');
                btnV.classList.add('active'); btnH.classList.remove('active');
                localStorage.setItem('novelLayout', 'v');
            });
            btnH.addEventListener('click', () => {
                widget.classList.add('layout-horizontal');
                btnH.classList.add('active'); btnV.classList.remove('active');
                localStorage.setItem('novelLayout', 'h');
            });

            document.getElementById('size-minus').addEventListener('click', () => {
                if(currentSize > 12) {
                    currentSize -= 1;
                    widget.style.setProperty('--base-font-size', currentSize + 'px');
                    localStorage.setItem('novelSize', currentSize);
                }
            });
            document.getElementById('size-plus').addEventListener('click', () => {
                if(currentSize < 26) {
                    currentSize += 1;
                    widget.style.setProperty('--base-font-size', currentSize + 'px');
                    localStorage.setItem('novelSize', currentSize);
                }
            });

            const metaContainer = document.getElementById('meta-container');
            let metaHtml = '';
            if (metaContainer.dataset.cp) {
                const parsedCp = metaContainer.dataset.cp.split(/[,，]/).map(g => g.split(/\s*([×xX&])\s*/).map((p, i) => i % 2 === 1 ? `<span class="cp-relation">${p}</span>` : `<span>${p}</span>`).join('')).join('<span style="opacity:0.3; margin:0 5px;">/</span>');
                metaHtml += `<div class="meta-row"><span class="meta-label">C P</span><div class="meta-value">${parsedCp}</div></div>`;
            }

            const sceneMetaItems = [
                { label: 'TIME', value: metaContainer.dataset.time },
                { label: 'LOC', value: metaContainer.dataset.loc },
                { label: 'WW', value: metaContainer.dataset.weather }
            ].filter(item => item.value);

            if (sceneMetaItems.length) {
                const sceneMetaHtml = sceneMetaItems.map((item, index) => {
                    const separator = index > 0 ? '<span class="meta-separator">·</span>' : '';
                    return `${separator}<span class="meta-label">${item.label}</span><div class="meta-value">${item.value}</div>`;
                }).join('');
                metaHtml += `<div class="meta-row">${sceneMetaHtml}</div>`;
            }
            metaContainer.innerHTML = metaHtml;

            const tagsContainer = document.getElementById('tags-container');
            if (tagsContainer.dataset.tags) {
                tagsContainer.innerHTML = tagsContainer.dataset.tags.split(/[\/，,]/).map(t => `<span class="tag-item"># ${t.trim()}</span>`).join('');
            }

            const prefaceEl = document.getElementById('preface-text');
            if (prefaceEl) {
                let rawText = prefaceEl.innerHTML.replace(/。/g, '');
                let lines = rawText.split(/，/);

                if (lines.length > 0 && rawText.trim() !== '') {
                    let firstLineText = lines[0].trim();
                    let firstChar = firstLineText.charAt(0);
                    let remFirstLine = firstLineText.slice(1);

                    lines[0] = '<span class="quote-mark">「</span><span class="drop-cap">' + firstChar + '</span>' + remFirstLine;
                    lines[lines.length - 1] = lines[lines.length - 1].trim() + '<span class="quote-mark">」</span>';

                    prefaceEl.innerHTML = lines.map((line, index) => {
                        return line.trim() ? `<span class="stepped-line" style="--step: ${index};">${line.trim()}</span>` : '';
                    }).join('');
                }
            }

            mainContent.classList.add('is-expanded');
        })();
    </script>
</div>

