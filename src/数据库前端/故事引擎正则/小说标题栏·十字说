        .novel-inline-widget.layout-horizontal .left-section { grid-area: meta; align-items: center; }
        .novel-inline-widget.layout-horizontal .right-section { grid-area: preface; align-items: flex-start; }
        .novel-inline-widget.layout-horizontal .tags-container { grid-area: tags; justify-self: center; margin-top: 0; }

        @media (max-width: 600px) {
            .novel-inline-widget { margin: 1em auto; }
