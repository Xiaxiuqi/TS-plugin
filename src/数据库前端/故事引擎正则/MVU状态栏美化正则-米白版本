  <script type="module">
    function safeSetText(selector, text) {
      const el = $(selector);
      const str = String(text);
      if (el.text() !== str) el.text(str);
    }

    function safeSetHtml(selector, html) {
      const el = $(selector);
      if (el.html() !== html) el.html(html);
    }

    function emptyText(text = '无') {
      return `<div class="muted-empty">${text}</div>`;
    }

    function clampPercent(value, max = 100) {
      const numericValue = Number(value) || 0;
      const numericMax = Number(max) || 0;
      if (numericMax <= 0) return 0;
      return Math.max(0, Math.min(100, (numericValue / numericMax) * 100));
    }

    function renderClothes(clothes = {}) {
      const slots = [
        ['外套', clothes.外套 || '无'],
        ['内搭', clothes.内搭 || '无'],
        ['下装', clothes.下装 || '无'],
        ['足具', clothes.足具 || '无'],
      ];
      return `<div class="clothes-line">${slots.map(([slot, value]) => {
        const isEmpty = !value || value === '无';
        return `<span class="cloth-chip ${isEmpty ? 'cloth-empty' : ''}"><span class="cloth-slot">${slot}</span>${value}</span>`;
      }).join('')}</div>`;
    }

    function renderIdentityTags(idents) {
      const list = (_.isArray(idents) ? idents : String(idents || '').split(/[、,，]/))
        .map(item => String(item).trim())
        .filter(Boolean);
      const deduped = [...new Set(list)];
      if (deduped.length === 0) return emptyText('未知身份');
      return `<div class="profile-tags">${deduped.map(item => `<span class="profile-tag">${item}</span>`).join('')}</div>`;
    }

    function normalizeTitleList(titles, fallback) {
      const list = (_.isArray(titles) ? titles : String(titles || fallback || '').split(/[、,，]/))
        .map(item => String(item).trim())
        .filter(Boolean);
      return [...new Set(list)];
    }

    function renderFameLine(score, titles, type, fallback) {
      const list = normalizeTitleList(titles, fallback);
      const scoreText = Number(score || 0);
      const tagHtml = list.map(item => `<span class="fame-tag ${type}">${item}</span>`).join('');
      return `<div class="fame-line"><span class="fame-score">名望 ${scoreText}</span><span class="fame-tags">${tagHtml}</span></div>`;
    }

    function renderWorld(all_variables) {
      const sys = _.get(all_variables, 'stat_data.系统', {});
      const time = sys.时间 || {};
      const loc = sys.地点 || {};
      const timeStr = `${time.年 || 2018}年${time.月日 || ''} ${time.时分 || ''} (${time.星期 || ''})`;
      const locStr = `${loc.国家 || ''} ${loc.地域 || ''} ${loc.场所 || ''} ${loc.具体位置 || ''}`.trim() || '未知位置';
      safeSetText('#world-time', timeStr);
      safeSetText('#world-loc', locStr);
    }

    function renderUser(all_variables) {
      const user = _.get(all_variables, 'stat_data.user', {});
      const tasksModule = _.get(all_variables, 'stat_data.任务系统', {});

      safeSetText('#u-lv', user.等级 || 1);
      safeSetText('#u-rank', user.战力评级 || '普通人');

      const expValue = Number(user.EXP || 0);
      safeSetText('#u-exp', `${expValue} / 100`);
      $('#u-exp-bar').css('width', `${clampPercent(expValue, 100)}%`);

      const ce = user.咒力 || {};
      const spValue = Number(ce.当前值 || 0);
      const spMax = Number(ce.最大值 || 0);
      safeSetText('#u-sp', `${spValue} / ${spMax}`);
      $('#u-sp-bar').css('width', `${clampPercent(spValue, spMax)}%`);
      safeSetText('#u-kp', user.KP || 0);
      safeSetText('#u-health', user.身体状况 || '未知');
      safeSetText('#u-taijutsu', user.肉搏等级 || '未入门');
      safeSetText('#u-scar', user.永久损伤或疤痕 || '无');

      const clo = user.当前服装 || {};
      safeSetHtml('#u-clothes', renderClothes(clo));

      const idents = user.公开身份 || [];
      safeSetHtml('#u-identity', renderIdentityTags(idents));

      const fw = user.名望 || {};
      const pw = fw.正道 || {};
      const ew = fw.邪道 || {};
      safeSetHtml('#u-fame-pos', renderFameLine(pw.数值, pw.称号, 'pos', '寂寂无名的路人'));
      safeSetHtml('#u-fame-neg', renderFameLine(ew.数值, ew.称号, 'neg', '无人知晓的普通人'));
      safeSetText('#u-money', user.持有金钱 || 0);
      safeSetText('#u-home', user.居住地 || '未知');

      function buildItemList(dataObj, mark, title, renderContentFn) {
        let html = `<div class="sub-toggle-header">${mark} ${title} <span class="toggle-icon">▼</span></div><div class="sub-content">`;
        if (_.isEmpty(dataObj) || dataObj === '待初始化') {
          html += emptyText();
        } else {
          html += '<div class="mvu-mini-grid">';
          Object.entries(dataObj).forEach(([k, v]) => {
            html += `<article class="mvu-mini-card"><div class="mvu-mini-title">${k}</div><div class="mvu-mini-body">${renderContentFn(v)}</div></article>`;
          });
          html += '</div>';
        }
        html += `</div>`;
        return html;
      }

      const vows = user.束缚 || {};
      let vowHtml = `<div class="sub-toggle-header">✦ 束缚 <span class="toggle-icon">▼</span></div><div class="sub-content">`;
      if (_.isEmpty(vows) || vows === '待初始化') {
        vowHtml += emptyText();
      } else {
        vowHtml += '<div class="mvu-mini-grid">';
        Object.entries(vows).forEach(([k, v]) => {
          const isPermanent = (!v.恢复条件 || v.恢复条件 === '无');
          const typeLabel = isPermanent ? '永久' : '临时';
          let itemContent = `<p><span class="c-lbl">类型:</span> ${typeLabel}</p><p><span class="c-lbl">代价:</span> ${v.代价 || ''}</p>`;
          if (!isPermanent) itemContent += `<p><span class="c-lbl">恢复条件:</span> ${v.恢复条件 || ''}</p>`;
          vowHtml += `<article class="mvu-mini-card"><div class="mvu-mini-title">${k}</div><div class="mvu-mini-body">${itemContent}</div></article>`;
        });
        vowHtml += '</div>';
      }
      vowHtml += `</div>`;
      safeSetHtml('#list-vows', vowHtml);

      safeSetHtml('#list-skills', buildItemList(user.战技, '✦', '战技', (v) => {
        return `<p><span class="c-lbl">熟练度:</span> ${v.熟练度 || 0} <span class="sub-lbl">⇒</span> <span class="val">${v.阶段 || '入门'}</span></p><p><span class="c-lbl">描述:</span> ${v.描述 || ''}</p>`;
      }));

      const innateCt = user.生得术式 || {};
      const extendedCts = user.扩展术式 || {};
      let allCtsItemsHtml = '';

      if (innateCt.名称 && innateCt.名称 !== '' && innateCt.名称 !== '无' && innateCt.名称 !== '待觉醒') {
        allCtsItemsHtml += `<article class="mvu-mini-card innate-ct-header"><div class="mvu-mini-title">[生得术式] ${innateCt.名称}</div><div class="mvu-mini-body">
          <p><span class="c-lbl">属性:</span> ${innateCt.属性 || '无'}</p>
          <p><span class="c-lbl">熟练度:</span> ${innateCt.熟练度 || 0} <span class="sub-lbl">⇒</span> <span class="val">${innateCt.阶段 || '入门'}</span></p>
          <p><span class="c-lbl">描述:</span> ${innateCt.描述 || ''}</p>
        </div></article>`;
      }

      if (!_.isEmpty(extendedCts) && extendedCts !== '待初始化') {
        Object.entries(extendedCts).forEach(([k, v]) => {
          allCtsItemsHtml += `<article class="mvu-mini-card"><div class="mvu-mini-title">${k}</div><div class="mvu-mini-body">
            <p><span class="c-lbl">熟练度:</span> ${v.熟练度 || 0} <span class="sub-lbl">⇒</span> <span class="val">${v.阶段 || '入门'}</span></p>
            <p><span class="c-lbl">描述:</span> ${v.描述 || ''}</p>
          </div></article>`;
        });
      }

      let finalCtHtml = `<div class="sub-toggle-header">✦ 术式 <span class="toggle-icon">▼</span></div><div class="sub-content">`;
      finalCtHtml += allCtsItemsHtml !== '' ? `<div class="mvu-mini-grid">${allCtsItemsHtml}</div>` : emptyText();
      finalCtHtml += `</div>`;
      safeSetHtml('#list-all-cts', finalCtHtml);

      safeSetHtml('#list-special', buildItemList(user.特殊体质, '✧', '特殊体质', (v) => `<p>${v}</p>`));
      safeSetHtml('#list-spirits', buildItemList(user.咒灵操术, '✧', '咒灵操术', (v) => `<p>${v}</p>`));
      safeSetHtml('#list-inventory', buildItemList(user.行囊, '✦', '行囊', (v) => {
        return `<p><span class="c-lbl">数量:</span> ${v.数量 || 0}</p><p><span class="c-lbl">描述:</span> ${v.描述 || ''}</p>`;
      }));

      const tasks = tasksModule || {};
      let taskHtml = `<div class="sub-toggle-header" style="box-shadow: inset 3px 0 0 rgba(160,126,116,.58), var(--mvu-shadow-soft);">✦ 当前任务 <span class="toggle-icon">▼</span></div><div class="sub-content">`;
      if (_.isEmpty(tasks) || tasks === '待初始化') {
        taskHtml += emptyText('暂无任务');
      } else {
        Object.entries(tasks).forEach(([k, v]) => {
          const reward = v.报酬 || {};
          const itemsObj = reward.物品 || {};
          let itemsHtml = '';
          if (_.isEmpty(itemsObj)) {
            itemsHtml = emptyText('暂无附加物品');
          } else {
            Object.entries(itemsObj).forEach(([itemName, itemNum]) => {
              itemsHtml += `<p><span class="c-lbl">- ${itemName}:</span> ${itemNum}</p>`;
            });
          }

          const rewardSectionHtml = `
            <div class="reward-section">
              <div class="reward-toggle-header">
                <span>报酬 金钱:${reward.金钱 || 0} | 名望:+${reward.名望提升值 || 0}</span>
                <span class="toggle-icon collapsed">▼</span>
              </div>
              <div class="reward-content">
                <p class="c-lbl">[包含物品]</p>
                ${itemsHtml}
              </div>
            </div>
          `;

          taskHtml += `<div class="item-toggle-header">${v.任务名 || k} <span class="toggle-icon collapsed">▼</span></div>`;
          taskHtml += `<div class="item-content">
            <p><span class="c-lbl">等级:</span> ${v.任务等级 || ''}</p>
            <p><span class="c-lbl">类型:</span> ${v.类型 || ''}</p>
            <p><span class="c-lbl">委托方:</span> ${v.委托人或势力 || ''}</p>
            <p><span class="c-lbl">描述:</span> ${v.任务描述 || ''}</p>
            ${rewardSectionHtml}
            <p><span class="c-lbl">完成条件:</span> ${v.完成条件 || ''}</p>
            <p><span class="c-lbl">失败条件:</span> ${v.失败条件 || ''}</p>
          </div>`;
        });
      }
      taskHtml += `</div>`;
      safeSetHtml('#list-tasks', taskHtml);
    }

    function populateCharacterData(all_variables) {
      const npcs = _.get(all_variables, 'stat_data.人际档案', {});
      let fullHtml = '';

      Object.entries(npcs).forEach(([name, data]) => {
        const affinity = Number(_.get(data, '好感数值', 0));
        const trust = Number(_.get(data, '信任度', 0));
        const stage = _.get(data, '关系阶段', '未知');

        const affinityWidth = Math.min(Math.abs(affinity), 100) / 100 * 50;
        const trustWidth = Math.min(Math.abs(trust), 100) / 100 * 50;

        const affinityStyle = affinity >= 0
          ? `left: 50%; width: ${affinityWidth}%; background: linear-gradient(90deg, #d0b8a9, #a07e74);`
          : `right: 50%; width: ${affinityWidth}%; background: #9a9389;`;

        const trustStyle = trust >= 0
          ? `left: 50%; width: ${trustWidth}%; background: linear-gradient(90deg, #cdbd8d, #b79a62);`
          : `right: 50%; width: ${trustWidth}%; background: #9a9389;`;

        fullHtml += `
          <div class="character-card">
            <div class="char-name" title="${name}">✦ ${name}</div>
            <div class="stat-row">
              <span class="stat-label">关系阶段</span>
              <span class="stat-value">${stage}</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">好感度: ${affinity}</span>
              <div class="bar-bg">
                <div class="bar-center"></div>
                <div class="bar-fill" style="${affinityStyle}"></div>
              </div>
            </div>
            <div class="stat-row">
              <span class="stat-label">信任度: ${trust}</span>
              <div class="bar-bg">
                <div class="bar-center"></div>
                <div class="bar-fill" style="${trustStyle}"></div>
              </div>
            </div>
          </div>
        `;
      });

      if (Object.keys(npcs).length === 0) {
        fullHtml = emptyText('暂无羁绊数据...');
      }

      safeSetHtml('#jujutsu-container', fullHtml);
    }

    function renderSexStatus(all_variables) {
      const sys = _.get(all_variables, 'stat_data.系统', {});
      const sex = sys.性爱状态 || {};
      const npcs = _.get(all_variables, 'stat_data.人际档案', {});
      const wrapper = $('#sex-wrapper');

      if (sex.进行中 === true) {
        wrapper.show();
        let fullHtml = '';
        const participants = sex.参与者 || [];

        if (participants.length === 0) {
          fullHtml = '<div class="muted-empty">正在感受爱意...</div>';
        } else {
          participants.forEach(name => {
            const npcData = npcs[name] || {};
            const lust = Number(npcData.欲望值 || 0);
            fullHtml += `
              <div class="sex-row">
                <span class="sex-char-name">${name}</span>
                <div class="lust-bar-bg">
                  <div class="lust-bar-fill" style="width: ${Math.min(lust, 100)}%;"></div>
                </div>
                <span class="lust-value-text">${lust} / 100</span>
              </div>
            `;
          });
        }
        safeSetHtml('#sex-container', fullHtml);
      } else {
        wrapper.hide();
      }
    }

    function populateData() {
      const all_variables = getAllVariables();
      renderWorld(all_variables);
      renderUser(all_variables);
      populateCharacterData(all_variables);
      renderSexStatus(all_variables);
    }

    async function init() {
      await waitGlobalInitialized('Mvu');
      populateData();

      eventOn(Mvu.events.VARIABLE_UPDATE_ENDED, () => {
        populateData();
      });

      $('body').on('click', '.main-toggle', function() {
        const targetId = $(this).data('target');
        const iconId = $(this).data('icon');
        $('#' + targetId).slideToggle(260);
        $('#' + iconId).toggleClass('collapsed');
      });

      $('body').on('click', '.sub-toggle-header, .item-toggle-header, .reward-toggle-header', function(e) {
        e.stopPropagation();
        $(this).next('.sub-content, .item-content, .reward-content').slideToggle(180);
        $(this).find('.toggle-icon').toggleClass('collapsed');
      });
    }

    $(errorCatched(init));
  </script>
