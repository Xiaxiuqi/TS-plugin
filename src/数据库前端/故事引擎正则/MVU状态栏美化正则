  </style>

  <script type="module">
    /* 性能优化：按需更新DOM辅助函数 */
    function safeSetText(selector, text) {
      const el = $(selector);
      const str = String(text);
      if (el.text() !== str) el.text(str);
    }

    function safeSetHtml(selector, html) {
      const el = $(selector);
      if (el.html() !== html) el.html(html);
    }

    /* 渲染世界状态 */
    function renderWorld(all_variables) {
      const sys = _.get(all_variables, 'stat_data.系统', {});
      const time = sys.时间 || {};
      const loc = sys.地点 || {};

      const timeStr = `${time.年 || 2018}年${time.月日 || ''} ${time.时分 || ''} (${time.星期 || ''})`;
      const locStr = `${loc.国家 || ''} ${loc.地域 || ''} ${loc.场所 || ''} ${loc.具体位置 || ''}`.trim() || '未知位置';

      safeSetText('#world-time', timeStr);
      safeSetText('#world-loc', locStr);
    }

    /* 渲染 User 竖状状态栏 */
    function renderUser(all_variables) {
      const user = _.get(all_variables, 'stat_data.user', {});
      const tasksModule = _.get(all_variables, 'stat_data.任务系统', {});

      safeSetText('#u-lv', user.等级 || 1);
      safeSetText('#u-rank', user.战力评级 || '普通人');
      safeSetText('#u-exp', `${user.EXP || 0} / 100`);

      const ce = user.咒力 || {};
      safeSetText('#u-sp', `${ce.当前值 || 0} / ${ce.最大值 || 0}`);
      safeSetText('#u-kp', user.KP || 0);
      safeSetText('#u-health', user.身体状况 || '未知');
      safeSetText('#u-taijutsu', user.肉搏等级 || '未入门');
      safeSetText('#u-scar', user.永久损伤或疤痕 || '无');

      const clo = user.当前服装 || {};
      const cloStr = `[${clo.外套||'无'}] + [${clo.内搭||'无'}] + [${clo.下装||'无'}] + [${clo.足具||'无'}]`;
      safeSetText('#u-clothes', cloStr);

      const idents = user.公开身份 || [];
      safeSetText('#u-identity', _.isArray(idents) ? idents.join('、') : idents);

      const fw = user.名望 || {};
      const pw = fw.正道 || {};
      const ew = fw.邪道 || {};
      const pTitle = _.isArray(pw.称号) ? pw.称号.join('、') : (pw.称号 || '寂寂无名的路人');
      const eTitle = _.isArray(ew.称号) ? ew.称号.join('、') : (ew.称号 || '无人知晓的普通人');

      safeSetText('#u-fame-pos', `${pw.数值||0}，${pTitle}`);
      safeSetText('#u-fame-neg', `${ew.数值||0}，${eTitle}`);
      safeSetText('#u-money', user.持有金钱 || 0);
      safeSetText('#u-home', user.居住地 || '未知');

      function buildItemList(dataObj, icon, title, renderContentFn) {
        let html = `<div class="sub-toggle-header">${icon} ${title} <span class="toggle-icon">▼</span></div><div class="sub-content">`;
        if (_.isEmpty(dataObj) || dataObj === '待初始化') {
          html += `<div style="color:#666;">无</div>`;
        } else {
          Object.entries(dataObj).forEach(([k, v]) => {
            html += `<div class="item-toggle-header">${k} <span class="toggle-icon collapsed">▼</span></div>`;
            html += `<div class="item-content">${renderContentFn(v)}</div>`;
          });
        }
        html += `</div>`;
        return html;
      }

      const vows = user.束缚 || {};
      let vowHtml = `<div class="sub-toggle-header">⛓️ 束缚 <span class="toggle-icon">▼</span></div><div class="sub-content">`;
      if (_.isEmpty(vows) || vows === '待初始化') {
          vowHtml += `<div style="color:#666;">无</div>`;
      } else {
          Object.entries(vows).forEach(([k, v]) => {
              const isPermanent = (!v.恢复条件 || v.恢复条件 === '无');
              const typeLabel = isPermanent ? '永久' : '临时';
              vowHtml += `<div class="item-toggle-header">[${typeLabel}] ${k} <span class="toggle-icon collapsed">▼</span></div>`;
              let itemContent = `<p><span class="c-lbl">代价:</span> ${v.代价||''}</p>`;
              if (!isPermanent) {
                  itemContent += `<p><span class="c-lbl">恢复条件:</span> ${v.恢复条件||''}</p>`;
              }
              vowHtml += `<div class="item-content">${itemContent}</div>`;
          });
      }
      vowHtml += `</div>`;
      safeSetHtml('#list-vows', vowHtml);

      safeSetHtml('#list-skills', buildItemList(user.战技, '⚔️', '战技', (v) => {
        return `<p><span class="c-lbl">熟练度:</span> ${v.熟练度||0} <span class="sub-lbl" style="margin-left: 8px; color: #888;">⇒</span> <span class="val" style="color: #fff;">${v.阶段||'入门'}</span></p><p><span class="c-lbl">描述:</span> ${v.描述||''}</p>`;
      }));

      const innateCt = user.生得术式 || {};
      const extendedCts = user.扩展术式 || {};
      let allCtsItemsHtml = '';

      if (innateCt.名称 && innateCt.名称 !== '' && innateCt.名称 !== '无' && innateCt.名称 !== '待觉醒') {
        allCtsItemsHtml += `<div class="item-toggle-header innate-ct-header">[生得术式] ${innateCt.名称} <span class="toggle-icon collapsed">▼</span></div>`;
        allCtsItemsHtml += `<div class="item-content">
                             <p><span class="c-lbl">属性:</span> ${innateCt.属性||'无'}</p>
                             <p><span class="c-lbl">熟练度:</span> ${innateCt.熟练度||0} <span class="sub-lbl" style="margin-left: 8px; color: #888;">⇒</span> <span class="val" style="color: #fff;">${innateCt.阶段||'入门'}</span></p>
                             <p><span class="c-lbl">描述:</span> ${innateCt.描述||''}</p>
                           </div>`;
      }

      if (!_.isEmpty(extendedCts) && extendedCts !== '待初始化') {
        Object.entries(extendedCts).forEach(([k, v]) => {
          allCtsItemsHtml += `<div class="item-toggle-header">${k} <span class="toggle-icon collapsed">▼</span></div>`;
          allCtsItemsHtml += `<div class="item-content">
                               <p><span class="c-lbl">熟练度:</span> ${v.熟练度||0} <span class="sub-lbl" style="margin-left: 8px; color: #888;">⇒</span> <span class="val" style="color: #fff;">${v.阶段||'入门'}</span></p>
                               <p><span class="c-lbl">描述:</span> ${v.描述||''}</p>
                             </div>`;
        });
      }

      let finalCtHtml = `<div class="sub-toggle-header">🔮 术式 <span class="toggle-icon">▼</span></div><div class="sub-content">`;
      if (allCtsItemsHtml !== '') {
        finalCtHtml += allCtsItemsHtml;
      } else {
        finalCtHtml += `<div style="color:#666;">无</div>`;
      }
      finalCtHtml += `</div>`;
      safeSetHtml('#list-all-cts', finalCtHtml);

      safeSetHtml('#list-special', buildItemList(user.特殊体质, '✨', '特殊体质', (v) => `<p>${v}</p>`));
      safeSetHtml('#list-spirits', buildItemList(user.咒灵操术, '👻', '咒灵操术', (v) => `<p>${v}</p>`));
      safeSetHtml('#list-inventory', buildItemList(user.行囊, '💼', '行囊', (v) => {
        return `<p><span class="c-lbl">数量:</span> ${v.数量||0}</p><p><span class="c-lbl">描述:</span> ${v.描述||''}</p>`;
      }));

      const tasks = tasksModule || {};
      let taskHtml = `<div class="sub-toggle-header" style="background:#200505; border-left: 3px solid #f00;">🎯 当前任务 <span class="toggle-icon">▼</span></div><div class="sub-content">`;
      if (_.isEmpty(tasks) || tasks === '待初始化') {
        taskHtml += `<div style="color:#666;">暂无任务</div>`;
      } else {
        Object.entries(tasks).forEach(([k, v]) => {
          const reward = v.报酬 || {};
          const itemsObj = reward.物品 || {};
          let itemsHtml = '';
          if (_.isEmpty(itemsObj)) {
            itemsHtml = '<p style="color:#666;">暂无附加物品</p>';
          } else {
            Object.entries(itemsObj).forEach(([itemName, itemNum]) => {
              itemsHtml += `<p><span class="c-lbl">- ${itemName}:</span> ${itemNum}</p>`;
            });
          }

          const rewardSectionHtml = `
            <div class="reward-section">
              <div class="reward-toggle-header">
                <span>🎁 报酬 (金钱: ${reward.金钱||0} | 名望: +${reward.名望提升值||0})</span>
                <span class="toggle-icon collapsed" style="font-size: 10px;">▼</span>
              </div>
              <div class="reward-content">
                <p class="c-lbl" style="margin-bottom: 4px;">[包含物品]</p>
                ${itemsHtml}
              </div>
            </div>
          `;

          taskHtml += `<div class="item-toggle-header">${v.任务名||k} <span class="toggle-icon collapsed">▼</span></div>`;
          taskHtml += `<div class="item-content">
            <p><span class="c-lbl">等级:</span> ${v.任务等级||''}</p>
            <p><span class="c-lbl">类型:</span> ${v.类型||''}</p>
            <p><span class="c-lbl">委托方:</span> ${v.委托人或势力||''}</p>
            <p><span class="c-lbl">描述:</span> ${v.任务描述||''}</p>
            ${rewardSectionHtml}
            <p><span class="c-lbl">完成条件:</span> ${v.完成条件||''}</p>
            <p><span class="c-lbl">失败条件:</span> ${v.失败条件||''}</p>
          </div>`;
        });
      }
      taskHtml += `</div>`;
      safeSetHtml('#list-tasks', taskHtml);
    }

    /* 渲染原版好感度羁绊档案 */
    function populateCharacterData(all_variables) {
      const npcs = _.get(all_variables, 'stat_data.人际档案', {});
      let fullHtml = '';

      Object.entries(npcs).forEach(([name, data]) => {
        const affinity = Number(_.get(data, '好感数值', 0));
        const trust = Number(_.get(data, '信任度', 0));
        const stage = _.get(data, '关系阶段', '未知');

        let affinityStyle = '';
        if (affinity >= 0) {
          const width = (affinity / 100) * 50;
          affinityStyle = `left: 50%; width: ${width}%; background: linear-gradient(90deg, #5c0000, #b30000); box-shadow: inset 0 0 2px rgba(0,0,0,0.5);`;
        } else {
          const width = (Math.abs(affinity) / 100) * 50;
          affinityStyle = `right: 50%; width: ${width}%; background-color: #444;`;
        }

        let trustStyle = '';
        if (trust >= 0) {
          const width = (trust / 100) * 50;
          trustStyle = `
            left: 50%;
            width: ${width}%;
            background: linear-gradient(90deg, #6b5011 0%, #a67c00 50%, #c59b27 100%);
            box-shadow: inset 0 1px 1px rgba(255, 215, 0, 0.3), inset 0 -1px 2px rgba(0, 0, 0, 0.6);
            border-right: 1px solid #ffdf00;
          `;
        } else {
          const width = (Math.abs(trust) / 100) * 50;
          trustStyle = `right: 50%; width: ${width}%; background-color: #444;`;
        }

        fullHtml += `
          <div class="character-card">
            <div class="ink-splatter"></div>
            <div class="char-name" title="${name}">${name}</div>
            <div class="stat-row">
              <span class="stat-label">关系阶段</span>
              <span class="stat-value">${stage}</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">好感度: ${affinity}</span>
              <div class="bar-bg">
                <div class="bar-center"></div>
                <div class="bar-fill" style="${affinityStyle}"></div>
              </div>
            </div>
            <div class="stat-row">
              <span class="stat-label" style="color:#b89947;">信任度: ${trust}</span>
              <div class="bar-bg">
                <div class="bar-center"></div>
                <div class="bar-fill" style="${trustStyle}"></div>
              </div>
            </div>
          </div>
        `;
      });

      if (Object.keys(npcs).length === 0) {
        fullHtml = '<div style="color: #666; font-style: italic; padding: 10px;">暂无羁绊数据...</div>';
      }

      safeSetHtml('#jujutsu-container', fullHtml);
    }

    /* 渲染性爱状态 */
    function renderSexStatus(all_variables) {
      const sys = _.get(all_variables, 'stat_data.系统', {});
      const sex = sys.性爱状态 || {};
      const npcs = _.get(all_variables, 'stat_data.人际档案', {});
      const wrapper = $('#sex-wrapper');

      if (sex.进行中 === true) {
        wrapper.show();
        let fullHtml = '';
        const participants = sex.参与者 || [];

        if (participants.length === 0) {
          fullHtml = '<div><span style="color:#ff1493;">♥</span> 正在感受爱意...</div>';
        } else {
          participants.forEach(name => {
            const npcData = npcs[name] || {};
            const lust = Number(npcData.欲望值 || 0);

            fullHtml += `
              <div class="sex-row">
                <span class="sex-char-name">${name}</span>
                <div class="lust-bar-bg">
                  <div class="lust-bar-fill" style="width: ${lust}%;"></div>
                </div>
                <span class="lust-value-text">${lust} / 100</span>
              </div>
            `;
          });
        }
        safeSetHtml('#sex-container', fullHtml);
      } else {
        wrapper.hide();
      }
    }

    function populateData() {
      const all_variables = getAllVariables();
      renderWorld(all_variables);
      renderUser(all_variables);
      populateCharacterData(all_variables);
      renderSexStatus(all_variables);
    }

    async function init() {
      await waitGlobalInitialized('Mvu');
      populateData();

      eventOn(Mvu.events.VARIABLE_UPDATE_ENDED, () => {
        populateData();
      });

      $('body').on('click', '.main-toggle', function() {
        const targetId = $(this).data('target');
        const iconId = $(this).data('icon');
        $('#' + targetId).slideToggle(300);
        $('#' + iconId).toggleClass('collapsed');
      });

      $('body').on('click', '.sub-toggle-header, .item-toggle-header, .reward-toggle-header', function(e) {
        e.stopPropagation();
        $(this).next('.sub-content, .item-content, .reward-content').slideToggle(200);
        $(this).find('.toggle-icon').toggleClass('collapsed');
      });
    }

    $(errorCatched(init));
  </script>
