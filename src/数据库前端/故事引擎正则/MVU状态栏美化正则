```html
<!doctype html>
<html lang="zh-CN">
<head>
  <style>
    /* 全局基础设置 */
    body {
      margin: 0;
      padding: 0;
      background-color: transparent;
      font-family: "Microsoft YaHei", "微软雅黑", sans-serif;
      overflow-x: hidden;
    }

