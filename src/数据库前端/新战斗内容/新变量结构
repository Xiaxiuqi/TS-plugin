      术式条目Schema
    ).prefault({}),

    特殊体质: z.record(z.string().describe('体质名'), z.string().describe('描述')).prefault({}),

    咒灵操术: z.record(z.string().describe('咒灵名'), z.string().describe('描述')).prefault({}),

    行囊: z.record(
      z.string().describe('物品名'),
      z.object({
        数量: z.coerce.number().transform(v => nonNegativeNumber(v)).prefault(1),
        描述: z.string().prefault(''),
      })
    ).transform(data => _.pickBy(data, ({ 数量 }) => 数量 > 0)).prefault({}),

  }).transform(user => {
    const traits = user.特殊体质 || {};
    const pureHeavenly = hasTrait(traits, ['天与咒缚（纯肉体）', '天与咒缚(纯肉体)', '天与暴君', '完全零咒力肉体']);
    const mutatedHeavenly = hasTrait(traits, ['天与咒缚（咒力异化）', '天与咒缚(咒力异化)', '咒力异化']);
    const sixEyes = hasTrait(traits, ['六眼']);
    const blackFlashFavored = hasTrait(traits, ['黑闪眷顾者']);
    const deathPainting = hasTrait(traits, ['九相图']);

    const maxPrecision = sixEyes ? 3 : 2;
    user.咒力.咒力操纵精度 = clampNumber(user.咒力.咒力操纵精度, 0.1, maxPrecision);

    const rawCeTotal = nonNegativeNumber(user.咒力.总量);
    const effectiveCeTotal = pureHeavenly ? 0 : (mutatedHeavenly ? rawCeTotal * 3 : rawCeTotal);
    user.咒力.有效总量 = roundNumber(effectiveCeTotal);
    user.咒力.当前值 = _.clamp(user.咒力.当前值, 0, Math.max(0, effectiveCeTotal));

    user.生得术式.潜力等级 = getPotentialLevel(user.生得术式.潜力值);
    user.生得术式.阶段 = (!user.生得术式.名称 || user.生得术式.名称 === '待觉醒' || user.生得术式.名称 === '无')
      ? '未入门'
      : getMasteryStage(user.生得术式.精通等级);

    const precision = user.咒力.咒力操纵精度;
    const brainPenalty = getBrainResetPenalty(user.术式熔断.大脑重置次数);
    const ctPenalty = user.术式熔断.熔断中 ? 0 : brainPenalty;
    const regenPenalty = user.术式熔断.熔断中 ? 0.1 : brainPenalty;
    user.术式熔断.术式强度惩罚系数 = ctPenalty;
    user.术式熔断.咒力回复惩罚系数 = regenPenalty;

    const martialProfile = getMartialProfile(user.基础肉体.武艺值);
    user.基础肉体.武艺阶段 = martialProfile.阶段;
    user.基础肉体.武艺输出比例 = martialProfile.输出比例;
    user.基础肉体.武艺防御系数 = martialProfile.防御系数;

    const jujutsuOutputRatio = sixEyes ? 1 : martialProfile.输出比例;
    const ceCostMultiplier = sixEyes ? 0.001 : 1;
    user.咒力.消耗倍率 = ceCostMultiplier;

    const baseCtStrength = (user.生得术式.潜力值 + user.生得术式.精通等级 + effectiveCeTotal * 0.2) * precision;
    const currentCtStrength = baseCtStrength * ctPenalty;
    user.生得术式.基础强度 = roundNumber(baseCtStrength);
    user.生得术式.当前强度 = roundNumber(currentCtStrength);
    user.战斗面板.术式强度_BPB = roundNumber(currentCtStrength);

    const mutationFleshBonus = mutatedHeavenly ? user.生得术式.潜力值 * 0.3 : 0;
    const fleshMultiplier = pureHeavenly ? 2 : 1;
    const totalFlesh = (user.基础肉体.基础肉体值 + effectiveCeTotal * 0.1 * precision + user.基础肉体.武艺值 + mutationFleshBonus) * fleshMultiplier;
    user.战斗面板.总肉体值_BPA = roundNumber(totalFlesh);

    const defense = effectiveCeTotal * 0.2 * precision * martialProfile.防御系数;
    user.战斗面板.防御 = roundNumber(defense);

    const reverseProfile = getReverseProfile(user.反转术式.熟练等级, sixEyes && user.反转术式.掌握治疗);
    user.反转术式.熟练等级 = user.反转术式.掌握治疗 ? reverseProfile.熟练等级 : '未掌握';
    user.反转术式.熟练系数 = user.反转术式.掌握治疗 ? reverseProfile.熟练系数 : 0;
    user.反转术式.可外放 = user.反转术式.掌握治疗 ? reverseProfile.可外放 : false;

    const reverseHpBonus = user.反转术式.掌握治疗 ? baseCtStrength * 0.5 : 0;
    const hpMultiplier = mutatedHeavenly ? 0.75 : 1;
    const maxHp = Math.max(1, (effectiveCeTotal * precision + totalFlesh + currentCtStrength + reverseHpBonus) * hpMultiplier);
    user.战斗面板.最大生命值 = roundNumber(maxHp);
    user.战斗面板.当前血量 = roundNumber(_.clamp(user.战斗面板.当前血量, 0, user.战斗面板.最大生命值));

    const damageBonus = mutatedHeavenly ? 1.2 : 1;
    user.战斗面板.伤害补正 = damageBonus;

    const jujutsuAttack = pureHeavenly
      ? 0
      : (effectiveCeTotal * 0.2 * precision + currentCtStrength) * jujutsuOutputRatio * damageBonus;
    user.战斗面板.咒术攻击 = roundNumber(jujutsuAttack);

    const heavenlyPhysicalBonus = pureHeavenly ? 2 : (mutatedHeavenly ? 1.5 : 1);
    const physicalAttack = ((totalFlesh * 0.5 * heavenlyPhysicalBonus + user.基础肉体.武艺值) * martialProfile.输出比例 + user.战斗面板.咒具值) * damageBonus;
    user.战斗面板.物理攻击 = roundNumber(physicalAttack);

    const ceRegen = (effectiveCeTotal * 0.2 + user.生得术式.潜力值) * precision * regenPenalty;
    user.咒力.每轮回复量 = roundNumber(ceRegen);

    const reverseHeal = user.反转术式.熟练系数 * (effectiveCeTotal * 0.1 * precision);
    let reverseCostRate = getPrecisionCostRate(precision);
    if (sixEyes) reverseCostRate *= 0.001;
    if (deathPainting) reverseCostRate *= 0.5;
    user.反转术式.常规回复量 = roundNumber(reverseHeal);
    user.反转术式.常规治疗消耗 = roundNumber(reverseHeal * reverseCostRate);
    user.反转术式.熔断修复消耗 = roundNumber(reverseHeal * user.术式熔断.熔断修复时间缩短倍率);

    if (blackFlashFavored && !user.特殊体质['黑闪眷顾者']) {
      user.特殊体质['黑闪眷顾者'] = '打出黑闪概率提升200%；黑闪触发时，本次攻击伤害按攻击值×2.5结算。';
    }

    const totalBp = Math.max(totalFlesh, currentCtStrength, jujutsuAttack, physicalAttack);
    user.战斗面板.总BP = roundNumber(totalBp);
    user.战斗面板.战力等级 = getCombatGrade(totalBp);
    user.战力评级 = getJujutsuRank(totalBp);

    while (user.EXP >= 100) {
      user.EXP -= 100;
      user.等级 += 1;
      user.KP += 5;
    }

    return user;
  }).prefault({}),

  任务系统: z.record(
    z.string().describe('任务名'),
    任务Schema
  ).prefault({}),

  人际档案: z.record(
    z.string().describe('角色名'),
    人际档案Schema
  ).prefault({}),

});

