import { registerMvuSchema } from 'https://testingcf.jsdelivr.net/gh/StageDog/tavern_resource/dist/util/mvu_zod.js';

const clampNumber = (value, min, max) => _.clamp(Number(value) || 0, min, max);
const nonNegativeNumber = value => Math.max(0, Number(value) || 0);
const roundNumber = value => Math.round((Number(value) || 0) * 100) / 100;

function traitText(traits) {
  if (!traits || typeof traits !== 'object') return '';
  return JSON.stringify(traits);
}

function hasTrait(traits, names) {
  const text = traitText(traits);
  return names.some(name => text.includes(name));
}

function getBrainResetPenalty(count) {
  const value = Math.max(0, Math.floor(Number(count) || 0));
  if (value <= 2) return 1;
  if (value === 3) return 0.5;
  if (value === 4) return 0.2;
  return 0.01;
}

function getPrecisionCostRate(precision) {
  if (precision >= 2) return 0.4;
  if (precision >= 1.5) return 0.7;
  return 1;
}

function getMartialProfile(value) {
  const martial = nonNegativeNumber(value);
  if (martial >= 200) {
    return {
      阶段: '出神入化',
      输出比例: 1,
      防御系数: 3,
    };
  }
  if (martial >= 180) {
    return {
      阶段: '登峰造极',
      输出比例: 0.8,
      防御系数: 2,
    };
  }
  if (martial >= 150) {
    return {
      阶段: '出类拔萃',
      输出比例: 0.6,
      防御系数: 1,
    };
  }
  if (martial >= 100) {
    return {
      阶段: '登堂入室',
      输出比例: 0.4,
      防御系数: 1,
    };
  }
  if (martial >= 50) {
    return {
      阶段: '初学乍练',
      输出比例: 0.2,
      防御系数: 1,
    };
  }
  if (martial > 0) {
    return {
      阶段: '初觉醒',
      输出比例: 0.1,
      防御系数: 1,
    };
  }
  return {
    阶段: '未入门',
    输出比例: 0.1,
    防御系数: 1,
  };
}

function getPotentialLevel(value) {
  const potential = nonNegativeNumber(value);
  if (potential >= 800) return '篡改现实·编织者型';
  if (potential >= 400) return '干涉现实·规则干涉型';
  if (potential >= 200) return '第一等·天才型术式';
  if (potential >= 100) return '第二等·精英型术式';
  if (potential >= 50) return '第三等·标准型术式';
  if (potential >= 20) return '第四等·砥砺型术式';
  return '未定型术式';
}

function getMasteryStage(value) {
  const mastery = nonNegativeNumber(value);
  if (mastery >= 800) return '轮外熟练';
  if (mastery >= 500) return '特级熟练';
  if (mastery >= 200) return '精通';
  if (mastery >= 100) return '入门';
  if (mastery >= 1) return '初步觉醒';
  return '未入门';
}

function getCombatGrade(bp) {
  const value = nonNegativeNumber(bp);
  if (value > 3001) return 'S级·论外';
  if (value >= 1501) return 'AA级·强特级';
  if (value >= 801) return 'A级·特级';
  if (value >= 501) return 'B级·一级';
  if (value >= 301) return 'C级·准一级';
  if (value >= 151) return 'D级·二级';
  if (value >= 100) return 'E级·三级';
  return 'F级·四级';
}

function getJujutsuRank(bp) {
  const grade = getCombatGrade(bp);
  if (grade.startsWith('S级')) return '论外';
  if (grade.startsWith('AA级')) return '强特级';
  if (grade.startsWith('A级')) return '特级';
  if (grade.startsWith('B级')) return '一级';
  if (grade.startsWith('C级')) return '准一级';
  if (grade.startsWith('D级')) return '二级';
  if (grade.startsWith('E级')) return '三级';
  return '四级';
}

function getReverseProfile(level, hasSixEyes) {
  if (hasSixEyes && level !== '未掌握') {
    return {
      熟练等级: '六眼等天赋控制',
      熟练系数: 2,
      可外放: false,
    };
  }
  if (level === '能够外放') {
    return {
      熟练等级: level,
      熟练系数: 2,
      可外放: true,
    };
  }
  if (level === '能够熟练运用') {
    return {
      熟练等级: level,
      熟练系数: 1.5,
      可外放: false,
    };
  }
  if (level === '初步了解运用') {
    return {
      熟练等级: level,
      熟练系数: 1,
      可外放: false,
    };
  }
  return {
    熟练等级: '未掌握',
    熟练系数: 0,
    可外放: false,
  };
}

const 战技条目Schema = z.object({
  熟练度: z.coerce.number().transform(v => clampNumber(v, 0, 100)).prefault(0),
  阶段: z.string().prefault('入门'),
  描述: z.string().prefault(''),
}).transform(item => {
  if (item.熟练度 <= 40) item.阶段 = '入门';
  else if (item.熟练度 <= 80) item.阶段 = '熟练';
  else item.阶段 = '精通';
  return item;
});

const 术式条目Schema = z.object({
  熟练度: z.coerce.number().transform(v => clampNumber(v, 0, 100)).prefault(0),
  阶段: z.string().prefault('入门'),
  描述: z.string().prefault(''),
}).transform(item => {
  if (item.熟练度 <= 40) item.阶段 = '入门';
  else if (item.熟练度 <= 80) item.阶段 = '熟练';
  else item.阶段 = '精通';
  return item;
});

const 生得术式Schema = z.object({
  名称: z.string().prefault('待觉醒'),
  属性: z.string().prefault('无'),
  潜力等级: z.string().prefault('第三等·标准型术式'),
  潜力值: z.coerce.number().transform(v => clampNumber(v, 1, 2000)).prefault(50),
  精通等级: z.coerce.number().transform(v => nonNegativeNumber(v)).prefault(0),
  阶段: z.string().prefault('未入门'),
  基础强度: z.coerce.number().transform(v => nonNegativeNumber(v)).prefault(0),
  当前强度: z.coerce.number().transform(v => nonNegativeNumber(v)).prefault(0),
  描述: z.string().prefault(''),
}).transform(item => {
  item.潜力等级 = getPotentialLevel(item.潜力值);
  if (!item.名称 || item.名称 === '待觉醒' || item.名称 === '无') {
    item.阶段 = '未入门';
  } else {
    item.阶段 = getMasteryStage(item.精通等级);
  }
  return item;
});

