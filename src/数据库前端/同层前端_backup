  /**
   * 添加产业
   * @param {string} id - 产业ID（可选，自动生成）
   * @param {Object} industry - 产业数据
   * @returns {string} 产业ID
   * @throws {Error} 添加失败时抛出错误
   */
  addIndustry(id, industry) {
    try {
      // 生成唯一ID（如果未提供）
      if (!id) {
        id = this._generateUniqueId();
      }

      // 添加时间戳（使用游戏时间）
      const currentGameTime = this.gameApp.currentMvuState?.stat_data?.当前时间纪元 || '';
      industry.创建时间 = industry.创建时间 || currentGameTime;
      industry.上次结算时间 = industry.上次结算时间 || currentGameTime;  // 初始化上次结算时间

      this.industries[id] = industry;

      // 性能优化：增量更新总估值
      this._incrementalUpdateValuation(industry, 'add');
      this._invalidateStatsCache();
      this._saveToGameData();

      console.log(`[IndustryManager] 已添加产业: ${id} - ${industry.名称} (创建时间: ${currentGameTime})`);

      // 显示成功提示
      if (this.gameApp.showTemporaryMessage) {
        this.gameApp.showTemporaryMessage(`✅ 成功添加产业：${industry.名称}`);
      }

      return id;
    } catch (error) {
      console.error('[IndustryManager] 添加产业失败:', error);

      // 显示错误提示
      if (this.gameApp.showTemporaryMessage) {
        this.gameApp.showTemporaryMessage(`❌ 添加产业失败：${error.message}`);
      }

      throw error;
    }
