    { current: '当前敏捷', max: '敏捷', base: '基础敏捷', prefaultMax: 40 }
  ];

  attributePairs.forEach(({ current, max, base, prefaultMax }) => {
    const currentVal = value[current];
    const maxVal = value[max];
    const baseVal = value[base];

    // 如果上限值等于prefault默认值，说明可能是AI未输出导致的
    if (maxVal === prefaultMax) {
