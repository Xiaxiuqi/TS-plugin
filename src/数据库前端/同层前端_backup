   性能优化 - CSS优化
   优化时间: 2026-01-12
   ======================================== */

/* 优化1: 使用transform替代left/right（关键优化） */
.drawer-panel {
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;  /* 🔥 优化：从0.3s缩短到0.25s */
    will-change: transform;
    /* 🔥 优化：移除contain让浏览器自动优化 */
    /* 🔥 性能优化：添加硬件加速 */
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
}

.drawer-panel.left {
    left: 0 !important;
    transform: translateX(-100%);
}

.drawer-panel.right {
    right: 0 !important;
    transform: translateX(100%);
}

.drawer-panel.left.open {
    transform: translateX(0) !important;
}

.drawer-panel.right.open {
    transform: translateX(0) !important;
}

/* 优化2: 简化交互按钮样式（移动端优化） */
.interaction-btn {
    background: rgba(139, 69, 19, 0.7) !important;
    transition: background-color 0.2s ease, border-color 0.2s ease !important;
    transform: translateZ(0);
    -webkit-tap-highlight-color: transparent;
    user-select: none;
}

.interaction-btn::before {
    display: none !important;
}

.interaction-btn:hover,
.interaction-btn:active {
    background: rgba(160, 82, 45, 0.9) !important;
    transform: translateZ(0) !important;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3) !important;
}

/* 优化3: 移动端特定优化 */
@media (max-width: 768px) {
    .interaction-btn {
        transition: none !important;
    }

    .interaction-btn:hover {
        background: rgba(139, 69, 19, 0.7) !important;
        border-color: rgba(218, 165, 32, 0.5) !important;
        transform: translateZ(0) !important;
    }

    .drawer-panel {
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;  /* 🔥 优化：移动端更快 */
    }
}

/* 优化4: 抽屉内容区域优化 */
.drawer-content {
    /* 🔥 优化：移除contain让浏览器自动优化 */
    /* 🔥 性能优化：添加硬件加速（不使用transform避免影响子元素定位） */
    -webkit-overflow-scrolling: touch;
    will-change: scroll-position;
}

.drawer-header {
    /* 🔥 优化：移除contain */
}

