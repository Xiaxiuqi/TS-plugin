(function() {
  'use strict';

  /**
   * 弹幕优化器
   * 优化弹幕系统性能，减少CPU和GPU负担
   * 使用transform替代position，RAF替代CSS动画，限制数量
   */
  class DanmakuOptimizer {
    constructor(domCache) {
      this.domCache = domCache || (window.PerformanceOptimizer && window.PerformanceOptimizer.domCache);
      this.isEnabled = false;
      this.activeDanmaku = [];      // 活动弹幕列表
      this.animationFrame = null;    // RAF ID
      this.isMobile = window.PerformanceOptimizer ? window.PerformanceOptimizer.isMobile : false;

      // 根据设备类型设置配置
      const config = window.PerformanceOptimizer ? window.PerformanceOptimizer.config.danmaku : {};
      this.maxDanmaku = this.isMobile ? (config.maxCountMobile || 10) : (config.maxCount || 20);
      this.animationDuration = this.isMobile ? (config.animationDurationMobile || 50000) : (config.animationDuration || 75000);

      console.log('[DanmakuOptimizer] 已创建');
      console.log(`[DanmakuOptimizer] 配置: 最大数量=${this.maxDanmaku}, 动画时长=${this.animationDuration}ms`);
    }

    /**
     * 启用弹幕系统
     */
    enable() {
      if (this.isEnabled) {
        console.log('[DanmakuOptimizer] 已启用，跳过重复启用');
        return;
      }

      this.isEnabled = true;
      const layer = this.domCache ? this.domCache.get('danmaku-layer') : document.getElementById('danmaku-layer');

      if (layer) {
        layer.style.display = 'block';
        // ✅ 优化：不在启用时就启动动画，等有弹幕时再启动
        console.log('[DanmakuOptimizer] 弹幕系统已启用（动画将在添加弹幕时启动）');
      } else {
        console.warn('[DanmakuOptimizer] 未找到弹幕层元素');
      }
    }

    /**
     * 禁用弹幕系统
     */
    disable() {
      if (!this.isEnabled) {
        console.log('[DanmakuOptimizer] 已禁用，跳过重复禁用');
        return;
      }

      this.isEnabled = false;
      this.stopAnimation();

      const layer = this.domCache ? this.domCache.get('danmaku-layer') : document.getElementById('danmaku-layer');

      if (layer) {
        layer.style.display = 'none';
        // 清空所有弹幕DOM
        layer.innerHTML = '';
      }

      this.activeDanmaku = [];
      console.log('[DanmakuOptimizer] 弹幕系统已禁用');
    }

    /**
     * 切换弹幕开关
     */
    toggle() {
      if (this.isEnabled) {
        this.disable();
      } else {
        this.enable();
      }
    }

    /**
     * 添加弹幕
     * @param {string} text - 弹幕文本
     * @param {Object} options - 可选配置
     */
    addDanmaku(text, options = {}) {
      if (!this.isEnabled) {
        console.warn('[DanmakuOptimizer] 弹幕系统未启用');
        return null;
      }

      if (!text || typeof text !== 'string') {
        console.warn('[DanmakuOptimizer] 无效的弹幕文本');
        return null;
      }

      // 限制数量 - 移除最老的弹幕
      if (this.activeDanmaku.length >= this.maxDanmaku) {
        const oldest = this.activeDanmaku.shift();
        if (oldest && oldest.element && oldest.element.parentNode) {
          oldest.element.parentNode.removeChild(oldest.element);
        }
        console.log(`[DanmakuOptimizer] 已移除最老的弹幕（当前: ${this.activeDanmaku.length}/${this.maxDanmaku}）`);
      }

      const layer = this.domCache ? this.domCache.get('danmaku-layer') : document.getElementById('danmaku-layer');
      if (!layer) {
        console.warn('[DanmakuOptimizer] 未找到弹幕层元素');
        return null;
      }

      // 创建弹幕元素
      const pill = document.createElement('div');
      pill.className = 'danmaku-pill';
      pill.textContent = text;

      // 使用transform而非left/top（GPU加速）
      const randomTop = Math.random() * 45; // 0-45% (上半屏)
      pill.style.top = `${randomTop}%`;
      pill.style.transform = 'translateX(0)';
      pill.style.opacity = '1'; // 🔥 修复：设置不透明度为1
      pill.style.willChange = 'transform'; // 提示浏览器优化

      // 应用自定义样式
      if (options.color) pill.style.color = options.color;
      if (options.fontSize) pill.style.fontSize = options.fontSize;

      layer.appendChild(pill);

      // 添加到活动列表
      const danmaku = {
        element: pill,
        text: text,
        startTime: Date.now(),
        duration: options.duration || this.animationDuration
      };

      this.activeDanmaku.push(danmaku);

      // ✅ 优化：添加弹幕时才启动动画（如果未运行）
      if (!this.animationFrame) {
        console.log('[DanmakuOptimizer] 检测到新弹幕，启动动画循环');
        this.startAnimation();
      }

      console.log(`[DanmakuOptimizer] 已添加弹幕 (当前: ${this.activeDanmaku.length}/${this.maxDanmaku})`);
      return danmaku;
    }

    /**
     * 启动动画循环
     * @private
     */
    startAnimation() {
      if (this.animationFrame) {
        console.log('[DanmakuOptimizer] 动画已在运行');
        return;
      }

      // ✅ 优化：只在有弹幕时启动动画
      if (this.activeDanmaku.length === 0) {
        console.log('[DanmakuOptimizer] 无弹幕，不启动动画循环');
        return;
      }

      console.log('[DanmakuOptimizer] 启动动画循环');

      const animate = () => {
        if (!this.isEnabled) {
          this.animationFrame = null;
          console.log('[DanmakuOptimizer] 弹幕已禁用，停止动画');
          return;
        }

        const now = Date.now();
        const toRemove = [];

        // 更新所有活动弹幕
        this.activeDanmaku.forEach((danmaku, index) => {
          const elapsed = now - danmaku.startTime;
          const progress = elapsed / danmaku.duration;

          if (progress >= 1) {
            // 动画完成，标记为移除
            toRemove.push(index);
            if (danmaku.element && danmaku.element.parentNode) {
              danmaku.element.parentNode.removeChild(danmaku.element);
            }
          } else {
            // 使用transform实现动画（GPU加速）
            const translateX = -progress * 600; // 移动600%
            danmaku.element.style.transform = `translateX(${translateX}%)`;
          }
        });

        // 移除已完成的弹幕（从后往前删除避免索引问题）
        toRemove.reverse().forEach(index => {
          this.activeDanmaku.splice(index, 1);
        });

        // ✅ 关键优化：没有弹幕时停止循环，避免空转
        if (this.activeDanmaku.length === 0) {
          console.log('[DanmakuOptimizer] 所有弹幕已完成，停止动画循环');
          this.animationFrame = null;
          return;
        }

        this.animationFrame = requestAnimationFrame(animate);
      };

      this.animationFrame = requestAnimationFrame(animate);
    }

    /**
     * 停止动画循环
     * @private
     */
    stopAnimation() {
      if (this.animationFrame) {
        cancelAnimationFrame(this.animationFrame);
        this.animationFrame = null;
        console.log('[DanmakuOptimizer] 动画循环已停止');
      }
    }

    /**
     * 清除所有弹幕
     */
    clearAll() {
      console.log('[DanmakuOptimizer] 清除所有弹幕');

      this.activeDanmaku.forEach(danmaku => {
        if (danmaku.element && danmaku.element.parentNode) {
          danmaku.element.parentNode.removeChild(danmaku.element);
        }
      });

      this.activeDanmaku = [];
    }

    /**
     * 获取统计信息
     * @returns {Object}
     */
    getStats() {
      return {
        isEnabled: this.isEnabled,
        activeCount: this.activeDanmaku.length,
        maxCount: this.maxDanmaku,
        animationDuration: this.animationDuration,
        isMobile: this.isMobile,
        isAnimating: this.animationFrame !== null
      };
    }

    /**
     * 更新配置
     * @param {Object} config - 新配置
     */
    updateConfig(config) {
      if (config.maxDanmaku !== undefined) {
        this.maxDanmaku = config.maxDanmaku;
        console.log(`[DanmakuOptimizer] 最大弹幕数已更新: ${this.maxDanmaku}`);
      }

      if (config.animationDuration !== undefined) {
        this.animationDuration = config.animationDuration;
        console.log(`[DanmakuOptimizer] 动画时长已更新: ${this.animationDuration}ms`);
      }
    }

    /**
     * 清理资源
     */
    cleanup() {
      console.log('[DanmakuOptimizer] 开始清理...');
      this.disable();
      this.clearAll();
    }
  }

  // 创建全局实例并集成到PerformanceOptimizer
  const danmakuOptimizer = new DanmakuOptimizer();

  if (window.PerformanceOptimizer) {
    window.PerformanceOptimizer.danmakuOptimizer = danmakuOptimizer;

    // 扩展清理方法
    const originalCleanup = window.PerformanceOptimizer.cleanup;
    window.PerformanceOptimizer.cleanup = function() {
      danmakuOptimizer.cleanup();
      originalCleanup.call(this);
    };

    console.log('[DanmakuOptimizer] 已集成到PerformanceOptimizer');
  }

  // 导出到全局（用于调试）
  window.DanmakuOptimizer = DanmakuOptimizer;
})();

