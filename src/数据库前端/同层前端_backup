    background: rgba(36, 24, 16, 0.6);
    border-radius: 10px;
    border: 1px solid rgba(139, 69, 19, 0.2);
}

::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, rgba(139, 69, 19, 0.8) 0%, rgba(90, 61, 43, 0.8) 100%);
    border-radius: 10px;
    border: 1px solid rgba(218, 165, 32, 0.3);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1), 0 0 8px rgba(218, 165, 32, 0.2);
}

::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, rgba(160, 82, 45, 0.9) 0%, rgba(139, 69, 19, 0.9) 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.15), 0 0 12px rgba(218, 165, 32, 0.4);
}

/* 🔥 移动端性能优化：简化滚动条样式 */
@media (max-width: 768px) {
    ::-webkit-scrollbar {
        width: 3px !important;
        height: 3px !important;
    }

    ::-webkit-scrollbar-track {
        background: rgba(36, 24, 16, 0.3) !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        border: none !important;
    }

    ::-webkit-scrollbar-thumb {
        background: rgba(139, 69, 19, 0.5) !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        border: none !important;
    }

    ::-webkit-scrollbar-thumb:hover {
        background: rgba(139, 69, 19, 0.7) !important;
        box-shadow: none !important;
    }

    /* 🔥 性能优化：禁用移动端不需要的hover效果 */
    .interaction-btn:hover,
    .quick-options-item:hover,
    .theater-tab:hover,
    .gacha-tab:hover,
    .option-btn:hover {
        transform: none !important;
        box-shadow: none !important;
    }

    /* 🔥 性能优化：为滚动容器添加硬件加速（不使用transform避免影响fixed定位） */
    .modal-body,
    .thinking-content,
    .timeline-events-list,
    #summarizer-input-list,
    #point-history-list,
    .gacha-tab-content,
    .decom-inventory,
    #decom-altar-list,
    .status-effects-popup-list,
    #chronicle-toc-list,
    #chronicle-page-content,
    #mail-list,
    #trade-list {
        -webkit-overflow-scrolling: touch !important;
        /* 注意：不使用transform和will-change避免影响fixed定位 */
    }
}

