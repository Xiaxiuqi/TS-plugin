    /* 默认不运行动画，只有在父容器可见时才运行 */
    animation: none;
    letter-spacing: 2px;
}

/* 只有当弹幕层可见时才启用动画 */
#danmaku-layer:not([style*="display: none"]) .danmaku-pill,
#danmaku-layer[style*="display: block"] .danmaku-pill {
    animation: float-left linear infinite;
    /* 🔥 性能优化：只在动画运行时使用will-change */
    will-change: transform, opacity;
}

/* 超慢速飘过 */
@keyframes float-left {
    0% { transform: translateX(0); opacity: 0; }
    2% { opacity: 0.85; }
    92% { opacity: 0.85; }
    100% { transform: translateX(-600%); opacity: 0; }
}

/* 移动端 */
@media (max-width: 768px) {
    .danmaku-pill {
        font-size: 14px;
        padding: 5px 12px;
        border-radius: 15px;
        animation-duration: 50s !important;
    }
