      else if (currentVal === maxVal && maxVal === prefaultMax && baseVal !== prefaultMax) {
        value[max] = baseVal;
        console.log(`[Schema智能修复] ${max}从${prefaultMax}调整为${baseVal}（使用基础值）`);
      }
    }
  });

  // 当前属性不超过对应上限（最终兜底，保留）
