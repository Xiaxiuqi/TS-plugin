  background: #1a1409;
  border: 1px solid #5a3d2b;
  border-radius: 8px;
  padding: 16px;
  position: relative;
}
.map-controls {
  margin-bottom: 10px;
  display: flex;
  gap: 8px;
}
.map-viewport {
  width: 100%;
  height: calc(100% - 60px);
  overflow: hidden;
  border: 1px solid #5a3d2b;
  position: relative;
  cursor: grab;
  user-select: none;
}
.map-viewport:active {
  cursor: grabbing;
}
.map-pannable {
  position: absolute;
  top: 0;
  left: 0;
  transition: transform 0.2s ease;
  transform-origin: top left;
}
#map-image {
  width: 100%;
  height: auto;
  display: block;
}
.map-locations {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  /* pointer-events: none; */
}

/* 彻底隐藏区域和标签 */
.main-region-poly, .region-label {
  display: none !important;
}

/* 地标样式（显眼+脉冲动画） */
#map-locations .landmark-dot {
  position: absolute;
  width: 10px; /* 增大尺寸 */
  height: 10px;
  background: #ff9800; /* 橙色更显眼 */
  border: 2px solid #fff;
  border-radius: 50%;
  transform: translate(-50%, -50%) scale(var(--landmark-scale, 1));
  pointer-events: auto;
  box-shadow: 0 0 5px rgba(255, 152, 0, 0.7);
  animation: pulse-landmark 2s infinite; /* 地标脉冲 */
  transition: transform 0.2s;
  z-index: 10;/* 确保地标在 SVG 上层 */
}
/* 自定义 tooltip 样式 */
#map-locations .landmark-dot::after {
  content: attr(data-name) "\A" attr(data-description) !important;
  /* 1. 用block确保宽度100%生效（比inline-block更稳定） */
  display: block !important;
  /* 2. 固定宽度，不依赖max-width（直接强制宽度） */
  width: 200px !important;
  /* 3. 确保内容不超出宽度，触发换行 */
  overflow: hidden !important;
  /* 4. 彻底重置white-space，排除任何继承干扰 */
  white-space: normal !important;
  /* 5. 恢复正常断词，不强制拆分汉字 */
  word-break: normal !important;
  overflow-wrap: normal !important;

  /* 其他样式保持不变，但微调字体大小确保空间足够 */
  font-size: 10px !important; /* 比8px稍大，避免文字过挤 */
  line-height: 1.5 !important;
  box-sizing: border-box !important;
  padding: 4px 8px !important; /* 适当增加内边距，避免文字贴边 */



  /* 定位样式不变 */
  position: absolute;
  top: calc( -100% - (8px / var(--landmark-scale, 1)) ) !important;
  left: 50%;
  background: #1a1409;
  color: #f5deb3;
  border-radius: 4px;
  opacity: 0;
  transform: translateX(-50%) scale(var(--landmark-scale, 1)) !important;
  transform-origin: bottom center !important;
  min-height: 24px !important;
  visibility: hidden;
  transition: opacity 0.2s, visibility 0.2s;
  pointer-events: none;
}
#map-locations .landmark-dot:hover {
  transform: translate(-50%, -50%) scale(1.1);
  box-shadow: 0 0 8px rgba(255, 152, 0, 0.9);
  z-index: 11;
}
#map-locations .landmark-dot:hover::after {
  opacity: 1;
  visibility: visible;
}
#map-locations .landmark-label {
  position: absolute;
  font-size: clamp(10px, 1.2vw, 13px); /* 缩小最大字号 */
  font-weight: bold;
  color: #f5deb3;
  text-shadow: 0 0 3px #000, 0 0 5px #000, 0 0 2px #fff; /* 增强阴影层次 */
  transform: translate(-50%, calc(-50% + 5px)) scale(var(--landmark-scale, 1));
  white-space: nowrap;
  pointer-events: auto;
}

/* 玩家当前位置标记（强制显示+精致样式） */
#map-locations .map-location-marker.current-location {
  position: absolute;
  transform: translate(-50%, -50%) scale(var(--player-scale, 1)) !important;
  z-index: 9; /* 确保在最上层 */
  pointer-events: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}
#map-locations .map-location-marker.current-location .dot {
  width: 14px; /* 比地标稍大 */
  height: 14px;
  background-color: #00e676;
  border: 2px solid #fff;
  border-radius: 50%;
  box-shadow: 0 0 5px rgba(0, 230, 118, 0.7);
  animation: pulse-player 1.5s infinite; /* 玩家脉冲 */
}
#map-locations .map-location-marker.current-location .label {
  font-size: clamp(9px, 1vw, 14px); /* 缩小文字 */
  color: #f5deb3;
  text-shadow: 0 0 3px #000, 0 0 5px #000;
  margin-top: 3px;
  white-space: nowrap;
  font-weight: bold;
}

/* 脉冲动画定义 */
@keyframes pulse-player {
  0% { box-shadow: 0 0 0 0 rgba(0, 230, 118, 0.7); }
  70% { box-shadow: 0 0 0 12px rgba(0, 230, 118, 0); }
  100% { box-shadow: 0 0 0 0 rgba(0, 230, 118, 0); }
}
@keyframes pulse-landmark {
  0% { box-shadow: 0 0 0 0 rgba(255, 152, 0, 0.7); }
  70% { box-shadow: 0 0 0 10px rgba(255, 152, 0, 0); }
  100% { box-shadow: 0 0 0 0 rgba(255, 152, 0, 0); }
}

/* 隐藏类 */
.hidden {
  display: none !important;
}
