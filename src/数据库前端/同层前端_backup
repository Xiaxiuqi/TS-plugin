/* ========================================
   抽屉式布局优化
   ======================================== */

/* 抽屉容器 */
.drawer-panel {
    position: fixed;
    top: 0;
    bottom: 0;
    width: 320px;
    background: linear-gradient(145deg, rgba(30, 25, 22, 0.98) 0%, rgba(40, 32, 28, 0.98) 100%);
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(2px);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1000;
    overflow-y: auto;
    border: 1px solid rgba(139, 69, 19, 0.3);
}

/* 左侧抽屉 */
.drawer-panel.left {
    left: 0;
    transform: translateX(-100%);
    border-radius: 0 16px 16px 0;
    border-left: none;
}

.drawer-panel.left.open {
    transform: translateX(0);
}

/* 右侧抽屉 */
.drawer-panel.right {
    right: 0;
    transform: translateX(100%);
    border-radius: 16px 0 0 16px;
    border-right: none;
}

.drawer-panel.right.open {
    transform: translateX(0);
}

/* 抽屉触发按钮 */
.drawer-trigger {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 120px;
    background: linear-gradient(135deg, rgba(139, 69, 19, 0.7) 0%, rgba(90, 61, 43, 0.7) 100%);
    border: 1px solid rgba(218, 165, 32, 0.5);
    color: #daa520;
    font-size: 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    font-weight: 600;
    letter-spacing: 2px;
}

.drawer-trigger.left {
    left: 0;
    border-radius: 0 12px 12px 0;
    border-left: none;
}

.drawer-trigger.right {
    right: 0;
    border-radius: 12px 0 0 12px;
    border-right: none;
}

.drawer-trigger:hover {
    background: linear-gradient(135deg, rgba(160, 82, 45, 1) 0%, rgba(139, 69, 19, 1) 100%);
    box-shadow: 0 6px 20px rgba(218, 165, 32, 0.5);
    transform: translateY(-50%) scale(1.05);
}

.drawer-trigger.left:hover {
    transform: translateY(-50%) translateX(5px) scale(1.05);
}

.drawer-trigger.right:hover {
    transform: translateY(-50%) translateX(-5px) scale(1.05);
}

/* 抽屉头部 */
.drawer-header {
    padding: 20px;
    border-bottom: 2px solid transparent;
    border-image: linear-gradient(90deg, transparent, rgba(218, 165, 32, 0.5), transparent) 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.5), rgba(20, 15, 10, 0.5));
    backdrop-filter: blur(8px);
    z-index: 10;
}

.drawer-title {
    font-size: 18px;
    color: #daa520;
    font-weight: 700;
    text-shadow: 0 0 10px rgba(218, 165, 32, 0.4);
    letter-spacing: 1px;
}

.drawer-close {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(139, 69, 19, 0.5);
    color: #a09c91;
    font-size: 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.drawer-close:hover {
    background: rgba(139, 0, 0, 0.5);
    border-color: #ff6b6b;
    color: #fff;
    transform: rotate(90deg);
}

/* 抽屉内容 */
.drawer-content {
    padding: 20px;
}

/* 确保抽屉内的按钮样式正确应用 */
.drawer-content .interaction-btn {
    background: linear-gradient(135deg, rgba(139, 69, 19, 0.7) 0%, rgba(90, 61, 43, 0.7) 100%) !important;
    border: 1px solid rgba(218, 165, 32, 0.5) !important;
}

/* 抽屉遮罩 */
.drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(2px);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 998;
}

.drawer-overlay.active {
    opacity: 1;
    visibility: visible;
}

/* 响应式：移动端和窄屏幕优化 */
@media (max-width: 1024px) {
    /* 确保抽屉触发按钮始终可见并缩小尺寸 */
    .drawer-trigger {
        display: flex !important;
