[data-tooltip] {
    position: relative;
    cursor: help;
}

[data-tooltip]:hover::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 12px;
    background: rgba(0, 0, 0, 0.95);
    color: white;
    font-size: 12px;
    white-space: nowrap;
    border-radius: 4px;
    z-index: 10000;  /* 提高z-index确保在模态框之上 */
    margin-bottom: 8px;
    pointer-events: none;
    animation: tooltipFadeIn 0.2s ease-out;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);  /* 添加阴影增强可见性 */
}

[data-tooltip]:hover::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: rgba(0, 0, 0, 0.95);
    margin-bottom: 2px;
    pointer-events: none;
    animation: tooltipFadeIn 0.2s ease-out;
    z-index: 10000;  /* 确保箭头也在最上层 */
}

@keyframes tooltipFadeIn {
    from {
        opacity: 0;
        transform: translateX(-50%) translateY(5px);
    }
    to {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
}

/* 对于仪表盘卡片（靠近顶部），tooltip显示在下方 */
.dashboard-card[data-tooltip]:hover::after {
    bottom: auto;
    top: 100%;
    margin-bottom: 0;
    margin-top: 8px;
}

.dashboard-card[data-tooltip]:hover::before {
    bottom: auto;
    top: 100%;
    margin-bottom: 0;
    margin-top: 2px;
    border-top-color: transparent;
    border-bottom-color: rgba(0, 0, 0, 0.95);
}

/* 产业卡片淡入动画 */
.industry-card {
    animation: fadeInUp 0.3s ease-out;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* 仪表盘数字变化动画 */
.dashboard-value {
    transition: all 0.3s ease;
}

.dashboard-value.updated {
    animation: pulse 0.5s ease;
}

@keyframes pulse {
    0%, 100% {
        transform: scale(1);
    }
    50% {
        transform: scale(1.1);
        color: #daa520;
    }
}

