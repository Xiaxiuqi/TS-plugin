        default:
            console.warn(`未知的关系操作: ${action}`);
    }
},

         getTierStyle(tier) {
            const lowSequenceGlow = 'text-shadow: 0 0 1px currentColor;'; // 9-8：轻微发光
            const midSequenceGlow = 'text-shadow: 0 0 6px currentColor;'; // 7-5：中等发光
            const highSequenceGlow = 'text-shadow: 0 0 6px currentColor, 0 0 10px currentColor;'; // 4-3：2层发光
            const angel = 'animation: ethereal-pulse 3s infinite; text-shadow: 0 0 10px currentColor, 0 0 20px currentColor;'; // 2-1：强发光+脉动
            const godGlow = `background: linear-gradient(90deg, #f0e6ff, #d8bfff, #c09fff); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; animation: ethereal-pulse 1.5s infinite; text-shadow: 0 0 15px currentColor, 0 0 25px currentColor, 0 0 40px currentColor;`;

            const styles = {
                // 序列9：暖黄三色均匀渐变（使用background-position居中对齐）
                '序列9': `background: linear-gradient(90deg, #F9E6C8, #F5DEB3, #F0D59E); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; ${lowSequenceGlow}`,
                // 序列8：浅蓝三色均匀渐变
                '序列8': `background: linear-gradient(90deg, #B0E2FF, #87CEEB, #5FB8E6); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; ${lowSequenceGlow}`,
                // 序列7：蓝紫系三色均匀渐变
                '序列7': `background: linear-gradient(90deg, #5FB8E6, #7A85D9, #6A5ACD); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; ${midSequenceGlow}`,
                // 序列6：浅墨绿→青绿→浅青均匀渐变
                '序列6': `background: linear-gradient(90deg, #2F4F4F, #3CB371, #48D1CC); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; ${midSequenceGlow}`,
                // 序列5：靛紫→玫粉三色均匀渐变
                '序列5': `background: linear-gradient(90deg, #483D8B, #800080, #FF69B4); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; ${midSequenceGlow}`,
                // 序列4：猩红→橙黄三色均匀渐变
                '序列4': `background: linear-gradient(90deg, #B22222, #DC143C, #FFA500); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; ${highSequenceGlow}`,
                // 序列3：橙黄→亮金三色均匀渐变
                '序列3': `background: linear-gradient(90deg, #FFA500, #FFC145, #FFD700); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; ${highSequenceGlow}`,
                // 序列2：亮金→玫粉三色均匀渐变
                '序列2': `background: linear-gradient(90deg, #FFD700, #FFC0CB, #FF69B4); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; ${angel}`,
                // 序列1：猩红→紫粉三色均匀渐变
                '序列1': `background: linear-gradient(90deg, #B22222, #C71585, #E0BFFF); background-position: center; -webkit-background-clip: text; background-clip: text; color: transparent; ${angel}`,
                // 序列0：紫粉系三色均匀渐变（神级特效）
                '序列0': godGlow
            };
            const baseStyle = 'font-family: "Georgia", serif;';
            // 匹配“序列+数字”的部分
            const tierMatch = tier.match(/序列\d+/);
            // 提取到等级则用该等级，否则用原tier（兼容纯等级的情况）
            const pureTier = tierMatch ? tierMatch[0] : tier;
            return (styles[pureTier] || 'color: #D3D3D3;') + baseStyle;
          },

          getTierOrder(tier) {
            const tierOrder = {
              '普通': 1, '非凡': 2, '罕见': 3, '史诗': 4,
              '传说': 5, '神话': 6, '唯一': 7,

              '序列9': 1, '序列8': 2, '序列7': 3, '序列6': 4,
              '序列5': 5, '序列4': 6, '序列3': 7, '序列2': 8, '序列1': 9, '序列0': 10
            };
            return tierOrder[tier] || 0;
          },

          sortByTier(items, getTierFn) {
            if (!Array.isArray(items)) return items;
            return [...items].sort((a, b) => {
              const tierA = getTierFn(a);
              const tierB = getTierFn(b);
              const orderA = this.getTierOrder(tierA);
              const orderB = this.getTierOrder(tierB);
              if (orderA === orderB) return 0;
              return orderB - orderA;
            });
          },

          getTierColorStyle(tier) {
            const demigodGlow = 'text-shadow: 0 0 5px currentColor, 0 0 8px currentColor;';
            const legendGlow = 'animation: ethereal-pulse 3s infinite; text-shadow: 0 0 8px currentColor, 0 0 12px currentColor;';
            const mythGlow = `background: linear-gradient(90deg, #E6E6FA, #D8BFD8, #DDA0DD); -webkit-background-clip: text; background-clip: text; color: transparent; ${legendGlow}`;

            const tierColors = {
              普通: '#A9A9A9',
              非凡: 'background: linear-gradient(90deg, #B0E2FF 0%, #87CEEB 50%, #5FB8E6 100%); -webkit-background-clip: text; background-clip: text; color: transparent; ${demigodGlow}',
              罕见: 'background: linear-gradient(90deg, #483D8B 0%, #800080 50%, #FF69B4 100%); -webkit-background-clip: text; background-clip: text; color: transparent; ${demigodGlow}',
              史诗: `background: linear-gradient(90deg, #FFA500 0%, #FFC145 50%, #FFD700 100%); -webkit-background-clip: text; background-clip: text; color: transparent; ${demigodGlow}`,
              传说: `background: linear-gradient(90deg, #FFD700 0%, #FFC0CB 50%, #FF69B4 100%); -webkit-background-clip: text; background-clip: text; color: transparent; ${legendGlow}`,
              神话: `background: linear-gradient(90deg, #B22222 0%, #C71585 50%, #E0BFFF 100%); -webkit-background-clip: text; background-clip: text; color: transparent; ${legendGlow}`,
              唯一: mythGlow,
            };
            const color = tierColors[tier] || '#D3D3D3';
            if (typeof color === 'string' && color.startsWith('color')) return color;
            if (typeof color === 'string' && color.startsWith('background')) return color;
            return `color: ${color};`;
          },

          updateTalentAndLinggen(data) {
    const container = document.getElementById('talent-linggen-list');
