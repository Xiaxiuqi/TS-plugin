  // [新增] 填充注入目标选择器
  async function populateInjectionTargetSelector_ACU() {
      if (!$popupInstance_ACU) return;
      const $select = $popupInstance_ACU.find(`#${SCRIPT_ID_PREFIX_ACU}-worldbook-injection-target`);
      $select.empty();
      try {
