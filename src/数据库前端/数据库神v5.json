                        /* 中止按钮样式 */
                    #toast-container .qrf-abort-btn {
                        margin-left: 10px;
                        padding: 4px 12px;
                        background-color: rgba(255, 59, 48, 0.8);
                        border: 1px solid rgba(255, 59, 48, 0.6);
