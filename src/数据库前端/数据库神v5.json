              if (oldLorebookName) {
                  showToastr_ACU('info', `正在从旧目标 [${oldLorebookName}] 中清除条目...`);
                  try {
                      await deleteAllGeneratedEntries_ACU(oldLorebookName);
                      // [修复] 增加短暂延迟，确保后端/API完成删除操作
                      await new Promise(resolve => setTimeout(resolve, 300));
