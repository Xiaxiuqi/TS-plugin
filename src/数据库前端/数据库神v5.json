  const MAX_DATA_ISOLATION_HISTORY = 20;

  // 规范化标识历史，去重、去空并限制长度
  function normalizeDataIsolationHistory_ACU(list = settings_ACU.dataIsolationHistory) {
      const seen = new Set();
      const cleaned = [];
      if (Array.isArray(list)) {
          list.forEach(code => {
              if (typeof code !== 'string') return;
              const trimmed = code.trim();
              if (!trimmed || seen.has(trimmed)) return;
              seen.add(trimmed);
              cleaned.push(trimmed);
          });
      }
      settings_ACU.dataIsolationHistory = cleaned.slice(0, MAX_DATA_ISOLATION_HISTORY);
      return settings_ACU.dataIsolationHistory;
  }

  function getDataIsolationHistory_ACU() {
      return normalizeDataIsolationHistory_ACU();
  }

  function addDataIsolationHistory_ACU(code, { save = true } = {}) {
      if (typeof code !== 'string') return;
      const trimmed = code.trim();
      if (!trimmed) return;
      const history = getDataIsolationHistory_ACU();
      settings_ACU.dataIsolationHistory = [trimmed, ...history.filter(item => item !== trimmed)].slice(
          0,
          MAX_DATA_ISOLATION_HISTORY,
      );
      if (save) saveSettings_ACU();
  }

  function removeDataIsolationHistory_ACU(code, { save = true } = {}) {
      if (typeof code !== 'string') return;
      const history = getDataIsolationHistory_ACU();
      settings_ACU.dataIsolationHistory = history.filter(item => item !== code);
      if (save) saveSettings_ACU();
  }

