                        color: #fff;
                        cursor: pointer;
                        font-size: 0.9em;
                        font-weight: 500;
                        transition: all 0.2s ease;
                        flex-shrink: 0;
                        white-space: nowrap;
                    }

                    #toast-container .qrf-abort-btn:hover {
                        background-color: rgba(255, 59, 48, 1);
                        border-color: rgba(255, 59, 48, 0.8);
                        transform: translateY(-1px);
                    }

                    #toast-container .qrf-abort-btn:active {
                        transform: translateY(0);
                    }

                    /* 表格容器优化 */
                        #${POPUP_ID_ACU} .acu-card table {
                            display: block;
                            overflow-x: auto;
                            -webkit-overflow-scrolling: touch;
                        }
                        #${POPUP_ID_ACU} .acu-card table thead,
                        #${POPUP_ID_ACU} .acu-card table tbody,
