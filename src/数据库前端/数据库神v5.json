                        /* 状态栏flex布局改为垂直堆叠 */
                        #${POPUP_ID_ACU} .acu-card > div[style*="display: flex"][style*="justify-content: space-between"] {
                            flex-direction: column !important;
                            gap: 10px;
                            align-items: stretch !important;
                        }
                        #${POPUP_ID_ACU} .acu-card > div[style*="display: flex"][style*="justify-content: space-between"] > span {
                            width: 100%;
