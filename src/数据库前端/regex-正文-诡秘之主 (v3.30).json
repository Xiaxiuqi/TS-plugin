/* --- Source: 05.-relationships-npcs.css --- */
/* ==========================================
   05. Relationships & NPCs (社交、好感度与NPC系统)
   ========================================== */

.relationship-stats-grid {
  display: grid;
  grid-template-columns: repeat(a uto-fit, minmax(120px, 1fr));
  gap: 10px;
  padding-top: 15px;
  /* 修正：调整内边距 */
  margin-top: 15px;
  /* 修正：调整外边距 */
  border-top: 1px dashed rgba(var(--rgb-secondary), 0.3);
  /* 修正：改为虚线分隔 */
}

.relationship-stats-grid .stat-item {
  font-size: var(--text-sm);
  color: var(--text-muted);
}

.relationship-stats-grid .stat-item strong {
  color: var(--text-subtle);
  margin-right: 5px;
}

/* --- 新增：人物关系卡片立绘样式 --- */
.relationship-body {
  display: flex;
  /* 启用flex布局，让图片和文字并排 */
  gap: 20px;
  /* 在图片和文字之间创建间距 */
}

.relationship-portrait {
  width: 120px;
  height: 180px;
  flex-shrink: 0;
  /* 防止图片被压缩 */
  background-size: cover;
  background-position: center 30%;
  /* 视觉重心偏上 */
  border-radius: 6px;
  border: 1px solid rgba(var(--rgb-secondary), 0.5);
  box-shadow: 0 2px 5px var(--overlay-light);
}

.relationship-content-wrapper {
  flex-grow: 1;
  /* 让右侧的文字内容占据所有剩余空间 */
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.relationship-card {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px 18px;
  background: linear-gradient(145deg, var(--bg-base), var(--bg-base));
  border-radius: 12px;
  box-shadow: 0 4px 8px var(--overlay-base), inset 0 0 5px rgba(var(--rgb-secondary), 0.1);
  transition: all 0.3s ease;
  --current-border: 1px solid rgba(var(--rgb-border-dark), 0.5);
  border-top: 1px solid var(--color-primary);
}

.relationship-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 15px rgba(var(--rgb-bg-dark), 0.4);
  border-color: rgba(var(--rgb-border-dark), 0.7);
}

.relationship-card-important {
  /* 显式设置四周全边框，颜色使用你的金色变量 */
  border: 2px solid var(--color-primary) !important;
  box-shadow: inset 0 0 8px rgba(var(--rgb-primary), 0.1), 0 2px 4px var(--overlay-base);
  /* 更新变量，确保 hover 时逻辑一致 */
  --current-border: var(--color-primary);
}

/* 优化 hover 状态，保持边框一致性 */
.relationship-card-important:hover {
  border-color: var(--color-primary);
  border-width: 2px;
  filter: brightness(1.1);
  /* 修复原有代码中可能导致颜色混淆的 --current-border 引用 */
  box-shadow: 0 8px 25px rgba(var(--rgb-primary), 0.3);
}

/* 人物关系头部（可点击折叠） */
.relationship-header {
  background: linear-gradient(90deg, var(--bg-base), rgba(255, 255, 255, 0.05), var(--bg-base));
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(var(--rgb-secondary), 0.3);
  cursor: pointer;
  gap: 10px;
  /* 移除 user-select: none; 以允许复制文本 */
}

.rel-info-group {
  display: flex;
  align-items: center;
  gap: 8px;       /* 名字和 ▼ 的间距 */
  flex: 1;
  min-width: 0;     /* flex 容器内文字截断的关键 */
}

/* 折叠图标 */
.relationship-toggle-icon {
  font-size: var(--text-sm);
  color: var(--text-muted);
  transition: transform 0.3s ease;
}

.relationship-card.expanded .relationship-toggle-icon {
  transform: rotate(180deg);
}

/* 人物关系详情区域（可折叠） */
.relationship-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, opacity 0.3s ease, margin-top 0.3s ease;
  opacity: 0;
  display: flex;
  gap: 16px;
  align-items: flex-start;
}

.relationship-card.expanded .relationship-body {
  opacity: 1;
  margin-top: 12px;
  max-height: 5000px !important;
  /* 增加最大高度 */
  overflow-y: auto !important;
  /* 允许垂直滚动 */
}

.relationship-name {
  font-size: var(--text-lg);
  white-space: nowrap;  /* 强制一行，不准换行 */
  font-weight: 700;
  color: var(--text-muted);
  white-space: nowrap;
  text-shadow: 0 1px 2px rgba(var(--rgb-bg-dark), 0.4);
}

.relationship-actions {
  display: flex;
  align-items: center;
  gap: 5px;       /* 按钮之间的间距 */
  flex-shrink: 0;   /* 按钮组绝对不准缩小或换行 */
}

/* 人物头像 */
.relationship-portrait {
  flex-shrink: 0;
  width: 100px;
  height: 100px;
  background-size: cover;
  background-position: center;
  border-radius: 8px;
  border: 2px solid rgba(var(--rgb-primary), 0.4);
  box-shadow: 0 2px 8px var(--overlay-light);
}

/* 内容包装器 */
.relationship-content-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
  font-size: var(--text-base);
  line-height: 1.7;
}

.relationship-description {
  color: var(--text-highlight);
  padding: 12px;
  background: var(--overlay-light);
  border-radius: 8px;
  border-left: 3px solid rgba(var(--rgb-primary), 0.5);
  white-space: normal;
  word-wrap: break-word;
}

/* 属性网格 */
.relationship-stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
  gap: 8px;
}

.relationship-stats-grid .stat-item {
  padding: 6px 10px;
  background: var(--overlay-light);
  border-radius: 6px;
  font-size: var(--text-sm);
  color: var(--text-muted);
  text-align: center;
}

.relationship-stats-grid .stat-item strong {
  color: var(--color-primary);
  margin-right: 4px;
}

.relationship-meta-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.relationship-meta {
  border-top: 1px solid rgba(var(--rgb-secondary), 0.2);
}

/* --- 最终边距强制修正 --- */
#relationships-modal .relationship-header {
  padding-left: 30px !important;
  padding-right: 30px !important;
}

@media (max-width: 600px) {
  #relationships-modal .relationship-header {
    padding-left: 0 !important;
    padding-right: 0 !important;
    gap: 12px;
    flex-wrap: wrap; /* 允许子元素换行 */
  }

  #relationships-modal .rel-info-group {
