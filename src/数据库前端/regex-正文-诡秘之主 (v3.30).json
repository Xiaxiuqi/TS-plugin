        0 0 20px var(--perfect-control-glow),
        inset 0 1px 0 rgba(255, 191, 0, 0.2);
      position: relative;
    }

    /* 完美掌控 - 文字颜色（琥珀黄主题）*/
    .judgment-block[data-collapsed="false"].theme-perfect-control .judgment-type {
      color: #ffbf00;
      text-shadow: 0 0 8px rgba(255, 191, 0, 0.8);
      font-weight: bold;
    }

    .judgment-block[data-collapsed="false"].theme-perfect-control .judgment-scenario {
      color: #f5deb3;
    }

    .judgment-block[data-collapsed="false"].theme-perfect-control .judgment-section h4 {
      color: #ffd700;
      text-shadow: 0 0 6px rgba(255, 191, 0, 0.6);
    }

    .judgment-block[data-collapsed="false"].theme-perfect-control .request-info,
    .judgment-block[data-collapsed="false"].theme-perfect-control .calculation-step,
    .judgment-block[data-collapsed="false"].theme-perfect-control .result-summary,
    .judgment-block[data-collapsed="false"].theme-perfect-control .judgment-details {
      color: #e0d2b0;
    }

    /* 完美掌控 - 高亮文字 */
    .judgment-block[data-collapsed="false"].theme-perfect-control .highlight {
      color: #ffbf00;
      text-shadow: 0 0 8px rgba(255, 191, 0, 0.7);
    }

    .judgment-block[data-collapsed="false"].theme-perfect-control .info-label {
      color: #d2b48c;
    }

    .judgment-block[data-collapsed="false"].theme-perfect-control .info-value {
      color: #ffd700;
    }

    /* 完美掌控 - 悬停效果（琥珀黄色）*/
    .judgment-block[data-collapsed="false"].theme-perfect-control:hover {
      border-color: #ffd700;
      box-shadow: 0 4px 16px rgba(255, 191, 0, 0.4),
        inset 0 1px 0 rgba(255, 191, 0, 0.15);
    }

    /* 3. 勉力成功 (success) - 灰棕色主题（移除网格扫描特效）*/
    .judgment-block[data-collapsed="false"].theme-narrow-success {
      border: 2px solid var(--narrow-success-primary);
      background:
        radial-gradient(ellipse at center,
        rgba(139, 115, 85, 0.15) 0%,
        rgba(139, 115, 85, 0.08) 50%,
        var(--judgment-bg-primary) 100%);
      box-shadow: 0 0 20px var(--narrow-success-glow);
      position: relative;
    }

    .judgment-block[data-collapsed="false"].theme-narrow-success>* {
      position: relative;
      z-index: 1;
    }

    /* 勉力成功 - 文字颜色（灰棕色主题）*/
    .judgment-block[data-collapsed="false"].theme-narrow-success .judgment-type {
      color: #c9a876;
      text-shadow: 0 0 8px rgba(139, 115, 85, 0.8);
      font-weight: bold;
    }

    .judgment-block[data-collapsed="false"].theme-narrow-success .judgment-scenario {
      color: #b8a488;
    }

    .judgment-block[data-collapsed="false"].theme-narrow-success .judgment-section h4 {
      color: #a89968;
      text-shadow: 0 0 6px rgba(139, 115, 85, 0.6);
    }

    .judgment-block[data-collapsed="false"].theme-narrow-success .request-info,
    .judgment-block[data-collapsed="false"].theme-narrow-success .calculation-step,
    .judgment-block[data-collapsed="false"].theme-narrow-success .result-summary,
    .judgment-block[data-collapsed="false"].theme-narrow-success .judgment-details {
      color: #d0c4b0;
    }

    /* 勉力成功 - 高亮文字 */
    .judgment-block[data-collapsed="false"].theme-narrow-success .highlight {
      color: #c9a876;
      text-shadow: 0 0 8px rgba(139, 115, 85, 0.7);
    }

    .judgment-block[data-collapsed="false"].theme-narrow-success .info-label {
      color: #a89968;
    }

    .judgment-block[data-collapsed="false"].theme-narrow-success .info-value {
      color: #c9a876;
    }

    /* 勉力成功 - 悬停效果（灰棕色）*/
    .judgment-block[data-collapsed="false"].theme-narrow-success:hover {
      border-color: #a89968;
      box-shadow: 0 4px 16px rgba(139, 115, 85, 0.4),
        inset 0 1px 0 rgba(139, 115, 85, 0.15);
    }

    /* 特效已交换：完美掌控用烛光闪烁（琥珀黄），勉力成功用网格扫描（青色）*/

    /* 4. 尝试失败 (failure) - 幽灵灰主题 */
    .judgment-block[data-collapsed="false"].theme-attempt-failure-old {
      position: relative;
      z-index: 1;
    }

    /* 4. 尝试失败 (failure) - 黑色边框主题 */
    .judgment-block[data-collapsed="false"].theme-attempt-failure {
      border: 2px solid var(--attempt-failure-primary);
      background: linear-gradient(135deg,
        rgba(26, 26, 26, 0.25) 0%,
        rgba(42, 42, 42, 0.18) 50%,
        rgba(20, 20, 20, 0.12) 100%);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.8),
        inset 0 0 20px rgba(0, 0, 0, 0.5);
      position: relative;
      /* 黑色边框，深色背景 */
    }

    /* 断裂纹理效果 - 已移除（移交给大失败）*/
    /* 尝试失败主题不再有断裂纹理特效 */

    .judgment-block[data-collapsed="false"].theme-attempt-failure>* {
      position: relative;
      z-index: 1;
    }

    /* 尝试失败 - 文字颜色（黑色边框主题）*/
    .judgment-block[data-collapsed="false"].theme-attempt-failure .judgment-type {
      color: #808080;
      text-shadow: 0 0 5px rgba(128, 128, 128, 0.6);
      font-weight: bold;
    }

    .judgment-block[data-collapsed="false"].theme-attempt-failure .judgment-scenario {
      color: #707070;
    }

    .judgment-block[data-collapsed="false"].theme-attempt-failure .judgment-section h4 {
      color: #909090;
    }

    .judgment-block[data-collapsed="false"].theme-attempt-failure .request-info,
    .judgment-block[data-collapsed="false"].theme-attempt-failure .calculation-step,
    .judgment-block[data-collapsed="false"].theme-attempt-failure .result-summary,
    .judgment-block[data-collapsed="false"].theme-attempt-failure .judgment-details {
      color: #a0a0a0;
    }

    /* 尝试失败 - 高亮文字 */
    .judgment-block[data-collapsed="false"].theme-attempt-failure .highlight {
      color: #909090;
      text-shadow: 0 0 5px rgba(128, 128, 128, 0.5);
    }

    .judgment-block[data-collapsed="false"].theme-attempt-failure .info-label {
      color: #707070;
    }

    .judgment-block[data-collapsed="false"].theme-attempt-failure .info-value {
      color: #909090;
    }

    /* 尝试失败 - 悬停效果（黑色边框）*/
    .judgment-block[data-collapsed="false"].theme-attempt-failure:hover {
      border-color: #000000;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.6),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    /* 悬停时无动画（动画已移交给大失败）*/
    /* 尝试失败主题悬停时不再有故障抖动 */

    @keyframes glitch-shake {

      0%,
      100% {
        transform: translate(0, 0);
      }

      20% {
        transform: translate(-2px, 1px);
      }

      40% {
        transform: translate(2px, -1px);
      }

      60% {
        transform: translate(-1px, 2px);
      }

      80% {
        transform: translate(1px, -2px);
      }
    }

    /* 5. 失控预兆 (critical_failure) - 血月红主题 */
    .judgment-block[data-collapsed="false"].theme-loss-control-old::before {
      background-size: 60px 60px;
      opacity: 0.3;
      pointer-events: none;
      z-index: 0;
    }

    .theme-attempt-failure>* {
      position: relative;
      z-index: 1;
    }

    /* 5. 失控预兆 (critical_failure) - 黑红主题 */
    .judgment-block[data-collapsed="false"].theme-loss-control {
      border: 3px solid var(--loss-control-primary);
      background:
        radial-gradient(ellipse at 30% 40%,
        rgba(220, 20, 60, 0.25) 0%,
        rgba(139, 0, 139, 0.12) 30%,
        rgba(0, 0, 0, 0.6) 60%,
        rgba(0, 0, 0, 0.85) 100%);
      box-shadow:
        0 0 40px var(--loss-control-glow),
        0 0 20px rgba(220, 20, 60, 0.5),
        inset 0 0 30px rgba(0, 0, 0, 0.8);
      animation: abyss-pulse 2s ease-in-out infinite;
      position: relative;
      overflow: hidden;
    }

    @keyframes abyss-pulse {

      0%,
      100% {
        box-shadow: 0 0 40px var(--loss-control-glow),
          0 0 20px rgba(220, 20, 60, 0.5),
          inset 0 0 30px rgba(220, 20, 60, 0.15);
      }

      50% {
        box-shadow: 0 0 60px var(--loss-control-glow),
          0 0 30px rgba(220, 20, 60, 0.7),
          inset 0 0 40px rgba(220, 20, 60, 0.2);
      }
    }

    /* 蠕动暗影 - 增强动画（保留）*/
    .judgment-block[data-collapsed="false"].theme-loss-control::before {
      content: '';
      position: absolute;
      inset: -50%;
      background:
        radial-gradient(circle at 20% 30%, rgba(220, 20, 60, 0.3) 0%, transparent 25%),
        radial-gradient(circle at 80% 70%, rgba(139, 0, 139, 0.3) 0%, transparent 25%),
        radial-gradient(circle at 50% 50%, rgba(220, 20, 60, 0.25) 0%, transparent 35%);
      animation: shadow-crawl 8s ease-in-out infinite;
      pointer-events: none;
      z-index: 0;
    }

    /* 断裂纹理效果 - 已移除 */
    /* 大失败主题不再有断裂纹理特效 */
    @keyframes shadow-crawl {

      0%,
      100% {
        transform: translate(0, 0) scale(1);
      }

      25% {
        transform: translate(10%, -10%) scale(1.1);
      }

      50% {
        transform: translate(-10%, 10%) scale(0.9);
      }

      75% {
        transform: translate(10%, 10%) scale(1.05);
      }
    }

    .judgment-block[data-collapsed="false"].theme-loss-control>* {
      position: relative;
      z-index: 1;
    }

    /* 失控预兆 - 文字颜色（黑红主题）*/
    .judgment-block[data-collapsed="false"].theme-loss-control .judgment-type {
      color: #ff4444;
      text-shadow: 0 0 12px rgba(220, 20, 60, 1.0), 0 0 6px rgba(0, 0, 0, 0.8);
      font-weight: bold;
    }

    .judgment-block[data-collapsed="false"].theme-loss-control .judgment-scenario {
      color: #d8a0a0;
    }

    .judgment-block[data-collapsed="false"].theme-loss-control .judgment-section h4 {
      color: #ff6b6b;
      text-shadow: 0 0 10px rgba(220, 20, 60, 0.9);
    }

    .judgment-block[data-collapsed="false"].theme-loss-control .request-info,
    .judgment-block[data-collapsed="false"].theme-loss-control .calculation-step,
    .judgment-block[data-collapsed="false"].theme-loss-control .result-summary,
    .judgment-block[data-collapsed="false"].theme-loss-control .judgment-details {
      color: #c8b0b0;
    }

    /* 失控预兆 - 高亮文字 */
    .judgment-block[data-collapsed="false"].theme-loss-control .highlight {
      color: #ff6b6b;
      text-shadow: 0 0 12px rgba(220, 20, 60, 0.9);
    }

    .judgment-block[data-collapsed="false"].theme-loss-control .info-label {
      color: #d8a0a0;
    }

    .judgment-block[data-collapsed="false"].theme-loss-control .info-value {
      color: #ff4444;
    }

    /* 失控预兆 - 悬停效果（血红色）+ 故障抖动动画（从失败移交）*/
    .judgment-block[data-collapsed="false"].theme-loss-control:hover {
      border-color: #ff0000;
      box-shadow: 0 4px 20px rgba(220, 20, 60, 0.6),
        0 0 30px rgba(220, 20, 60, 0.4),
        inset 0 0 30px rgba(220, 20, 60, 0.2);
      animation: abyss-pulse 2s ease-in-out infinite, glitch-shake 0.3s ease-in-out;
    }


    /* ===== 简化模式 - 移动端性能优化 ===== */

    /* 核心优化：禁用所有动画、过渡、滤镜和阴影 */
    .simplified-mode .judgment-block,
    .simplified-mode .judgment-block *,
    .simplified-mode .judgment-block::before,
    .simplified-mode .judgment-block::after {
      animation: none !important;
      transition: none !important;
      filter: none !important;
      box-shadow: none !important;
    }

    /* 移除伪元素（复杂背景效果） */
    .simplified-mode .judgment-block::before,
    .simplified-mode .judgment-block::after {
      display: none !important;
    }

    /* 使用简单边框替代阴影来表示状态 */
    .simplified-mode .judgment-block {
      border-width: 2px !important;
      background: #1a1a1a !important;
      /* 纯色背景替代渐变 */
    }

    /* 保留关键信息的可视化区别 - 五种主题 */
    .simplified-mode .theme-fate-blessing {
      border-color: #ffffff !important;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), rgba(218, 165, 32, 0.15)) !important;
    }

    .simplified-mode .theme-perfect-control {
      border-color: #ffbf00 !important;
      background: linear-gradient(135deg, rgba(255, 191, 0, 0.15), rgba(139, 69, 19, 0.15)) !important;
    }

    .simplified-mode .theme-narrow-success {
      border-color: #8b7355 !important;
      background: linear-gradient(135deg, rgba(139, 115, 85, 0.15), rgba(90, 61, 43, 0.15)) !important;
    }

    .simplified-mode .theme-attempt-failure {
      border-color: #1a1a1a !important;
      background: linear-gradient(135deg, rgba(26, 26, 26, 0.25), rgba(0, 0, 0, 0.18)) !important;
    }

    .simplified-mode .theme-loss-control {
      border-color: #8b0000 !important;
      background: linear-gradient(135deg, rgba(139, 0, 0, 0.25), rgba(0, 0, 0, 0.6)) !important;
    }

    /* 只为可见区域的判定块启用动画（配合IntersectionObserver） */
    .simplified-mode .judgment-block:not(.animate-active) {
      animation: none !important;
    }

    .simplified-mode .judgment-block:not(.animate-active) * {
      animation: none !important;
    }

    /* 移除SVG滤镜效果 */
    .simplified-mode svg {
      filter: none !important;
    }

    /* 简化模式下移除大失败的部分动画 */
    .simplified-mode .theme-loss-control.revealed {
      animation: abyss-pulse 2s ease-in-out infinite !important;
      /* 只保留脉冲动画 */
    }

    /* 简化悬停效果 */
    .simplified-mode .judgment-block:hover {
      transform: none !important;
      box-shadow: none !important;
    }

    /* 判定块标题栏 */
    .judgment-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 15px;
      background: var(--judgment-bg-secondary);
      border-bottom: 1px solid var(--judgment-border-color);
      cursor: pointer;
      transition: var(--judgment-transition);
    }

    .judgment-header:hover {
      background: rgba(139, 69, 19, 0.2);
    }

    .judgment-icon {
      font-size: 18px;
      /* 从 20px 减小到 18px */
      flex-shrink: 0;
    }

    .judgment-title {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      gap: 2px;
      /* 从 3px 减小到 2px */
    }

    .judgment-type {
      font-size: 13px;
      /* 从 14px 减小到 13px */
      font-weight: bold;
      color: var(--judgment-text-primary);
    }

    .judgment-scenario {
      font-size: 11px;
      /* 从 12px 减小到 11px */
      color: var(--judgment-text-secondary);
      line-height: 1.3;
    }

    /* 神秘符文 - 折叠状态下显示 */
    .judgment-rune-seal {
      width: 28px;
      /* 从 32px 减小到 28px */
      height: 28px;
      /* 从 32px 减小到 28px */
      flex-shrink: 0;
      color: var(--judgment-accent-gold);
      opacity: 0.8;
      transition: all 0.3s ease;
      animation: rune-pulse 2s ease-in-out infinite;
    }

    @keyframes rune-pulse {

      0%,
      100% {
        opacity: 0.6;
        transform: scale(1);
      }

      50% {
        opacity: 1;
        transform: scale(1.05);
      }
    }

    .judgment-header:hover .judgment-rune-seal {
      opacity: 1;
      transform: scale(1.1);
    }

    /* 折叠状态下隐藏符文，展开后显示 */
    .judgment-block[data-collapsed="true"] .judgment-rune-seal {
      display: block;
    }

    .judgment-block[data-collapsed="false"] .judgment-rune-seal {
      display: none;
    }

    /* 结果徽章 - 只在展开状态下显示 */
    .judgment-result-badge {
      padding: 4px 8px;
      /* 从 5px 10px 减小到 4px 8px */
      border-radius: 3px;
      /* 从 4px 减小到 3px */
      font-size: 12px;
      /* 从 13px 减小到 12px */
      font-weight: bold;
      flex-shrink: 0;
      display: none;
    }

    .judgment-block[data-collapsed="false"] .judgment-result-badge {
      display: block;
    }

    .judgment-result-badge.critical-success {
      background: var(--judgment-critical-success);
      color: #000;
    }

    .judgment-result-badge.perfect {
      background: var(--judgment-perfect);
      color: #000;
    }

    .judgment-result-badge.success {
      background: var(--judgment-success);
      color: #000;
    }

    .judgment-result-badge.failure {
      background: var(--judgment-failure);
      color: #fff;
    }

    .judgment-result-badge.critical-failure {
      background: var(--judgment-critical-failure);
      color: #fff;
    }

    .judgment-toggle {
      font-size: 14px;
      /* 从 16px 减小到 14px */
      color: var(--judgment-text-muted);
      transition: transform 0.3s ease;
      flex-shrink: 0;
    }

    .judgment-block[data-collapsed="false"] .judgment-toggle {
      transform: rotate(180deg);
    }

    /* 判定详情区域 */
    .judgment-details {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease-out, opacity 0.3s ease;
      opacity: 0;
    }

    .judgment-block[data-collapsed="false"] .judgment-details {
      max-height: 2000px;
      opacity: 1;
    }

    .judgment-section {
      padding: 10px 12px;
      /* 从 12px 15px 减小到 10px 12px */
      border-bottom: 1px dashed var(--judgment-border-color);
    }

    .judgment-section:last-child {
      border-bottom: none;
    }

    .judgment-section h4 {
      font-size: 12px;
      /* 从 13px 减小到 12px */
      color: var(--judgment-accent-gold);
      margin-bottom: 6px;
      /* 从 8px 减小到 6px */
      font-weight: bold;
    }

    /* 判定请求样式 */
    .judgment-request {
      background: rgba(0, 0, 0, 0.3);
      /* 从 0.2 增加到 0.3，减少透明度 */
    }

    /* 原始信息区域样式 */
    .judgment-raw-info {
      background: linear-gradient(135deg, rgba(139, 69, 19, 0.15) 0%, rgba(90, 61, 43, 0.2) 100%);
      border: 1px solid rgba(139, 69, 19, 0.3);
      border-radius: 4px;
    }

    .raw-info-list {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .raw-info-line {
      font-size: 12px;
      color: var(--judgment-text-primary);
      padding: 4px 8px;
      background: rgba(0, 0, 0, 0.2);
      border-radius: 3px;
      border-left: 2px solid rgba(139, 69, 19, 0.5);
    }

    /* 高亮先攻结果 */
    .raw-info-line.highlight-initiative {
      background: linear-gradient(135deg, rgba(255, 215, 0, 0.2) 0%, rgba(255, 140, 0, 0.15) 100%);
      border-left-color: #ffd700;
      color: #ffd700;
      font-weight: bold;
      box-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
    }

    /* 高亮判定结果 */
    .raw-info-line.highlight-result {
      background: linear-gradient(135deg, rgba(30, 144, 255, 0.2) 0%, rgba(100, 149, 237, 0.15) 100%);
      border-left-color: #1e90ff;
      color: #87ceeb;
      font-weight: bold;
      box-shadow: 0 0 10px rgba(30, 144, 255, 0.3);
    }

    .request-info {
      display: flex;
      gap: 6px;
      /* 从 8px 减小到 6px */
      margin-bottom: 4px;
      /* 从 5px 减小到 4px */
      font-size: 11px;
      /* 从 12px 减小到 11px */
    }

    .info-label {
      color: var(--judgment-text-muted);
      font-weight: bold;
    }

    .info-value {
      color: var(--judgment-text-primary);
    }

    /* 计算过程样式 */
    .judgment-calculation {
      background: rgba(0, 0, 0, 0.25);
      /* 从 0.15 增加到 0.25 */
    }

    .calculation-steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      /* 从 180px 减小到 160px */
      gap: 6px;
      /* 从 8px 减小到 6px */
    }

    .calc-step {
      background: rgba(139, 69, 19, 0.3);
      /* 从 0.2 增加到 0.3 */
      padding: 5px;
      /* 从 6px 减小到 5px */
      border-radius: 3px;
      /* 保持 3px */
      border: 1px solid rgba(139, 69, 19, 0.4);
      /* 从 0.3 增加到 0.4 */
    }

    /* 活力伤害 - 红色主题 */
    .calc-step.damage-vitality {
      background: linear-gradient(135deg, rgba(220, 20, 60, 0.25) 0%, rgba(139, 0, 0, 0.2) 100%);
      border: 1px solid rgba(220, 20, 60, 0.5);
      box-shadow: 0 0 8px rgba(220, 20, 60, 0.3);
    }

    .calc-step.damage-vitality .step-label {
      color: #ff6b6b;
    }

    .calc-step.damage-vitality .step-value {
      color: #ff4444;
      text-shadow: 0 0 8px rgba(220, 20, 60, 0.6);
    }

    /* 污染伤害 - 紫色主题 */
    .calc-step.damage-pollution {
      background: linear-gradient(135deg, rgba(138, 43, 226, 0.25) 0%, rgba(75, 0, 130, 0.2) 100%);
      border: 1px solid rgba(138, 43, 226, 0.5);
      box-shadow: 0 0 8px rgba(138, 43, 226, 0.3);
    }

    .calc-step.damage-pollution .step-label {
      color: #ba68c8;
    }

    .calc-step.damage-pollution .step-value {
      color: #ab47bc;
      text-shadow: 0 0 8px rgba(138, 43, 226, 0.6);
    }

    .step-label {
      display: block;
      font-size: 10px;
      /* 从 11px 减小到 10px */
      color: var(--judgment-text-muted);
      margin-bottom: 2px;
      /* 从 3px 减小到 2px */
    }

    .step-value {
      display: block;
      font-size: 13px;
      /* 从 14px 减小到 13px */
      font-weight: bold;
      color: var(--judgment-text-primary);
      margin-bottom: 2px;
      /* 从 2px 保持不变 */
    }

    .step-formula {
      display: block;

      /* ===== 先攻判定特殊样式 ===== */

      /* 先攻判定区域 */
      .judgment-initiative {
        background: linear-gradient(135deg, rgba(255, 215, 0, 0.08) 0%, rgba(139, 69, 19, 0.15) 100%);
        border: 1px solid rgba(255, 215, 0, 0.3);
        border-radius: 4px;
        position: relative;
        overflow: hidden;
      }

      /* 先攻判定标题 */
      .judgment-initiative h4 {
        color: #ffd700;
        text-shadow: 0 0 8px rgba(255, 215, 0, 0.8);
      }

      /* 先攻值显示 - 攻方 */
      .calc-step.initiative-attacker {
        background: linear-gradient(135deg, rgba(255, 69, 0, 0.2) 0%, rgba(255, 140, 0, 0.15) 100%);
        border-color: rgba(255, 69, 0, 0.5);
        box-shadow: 0 0 10px rgba(255, 69, 0, 0.3);
      }

      /* 先攻值显示 - 防方 */
      .calc-step.initiative-defender {
        background: linear-gradient(135deg, rgba(30, 144, 255, 0.2) 0%, rgba(100, 149, 237, 0.15) 100%);
        border-color: rgba(30, 144, 255, 0.5);
        box-shadow: 0 0 10px rgba(30, 144, 255, 0.3);
      }

      /* 先攻结果容器 */
      .initiative-result-container {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 215, 0, 0.3);
      }

      /* 先攻结果横幅 - 基础样式 */
      .initiative-result-banner {
        display: flex !important;
        flex-direction: row !important;
        align-items: center !important;
        justify-content: center !important;
        padding: 12px 20px;
        border-radius: 6px;
        position: relative;
        overflow: hidden;
        gap: 15px;
      }

      /* 抢占先机 - 金色闪电主题 */
      .initiative-result-banner.seize-initiative {
        background: linear-gradient(135deg,
          rgba(255, 215, 0, 0.3) 0%,
          rgba(255, 165, 0, 0.25) 50%,
          rgba(255, 215, 0, 0.3) 100%);
        border: 2px solid #ffd700;
        box-shadow:
          0 0 20px rgba(255, 215, 0, 0.6),
          inset 0 0 20px rgba(255, 215, 0, 0.2);
      }

      /* 抢占先机 - 闪电动画背景 */
      .initiative-result-banner.seize-initiative::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(45deg,
          transparent 30%,
          rgba(255, 255, 255, 0.1) 50%,
          transparent 70%);
        animation: lightning-sweep 2s ease-in-out infinite;
      }

      /* 攻守逆转 - 蓝色旋转主题 */
      .initiative-result-banner.reverse-initiative {
        background: linear-gradient(135deg,
          rgba(30, 144, 255, 0.3) 0%,
          rgba(100, 149, 237, 0.25) 50%,
          rgba(30, 144, 255, 0.3) 100%);
        border: 2px solid #1e90ff;
        box-shadow:
          0 0 20px rgba(30, 144, 255, 0.6),
          inset 0 0 20px rgba(30, 144, 255, 0.2);
      }

      /* 攻守逆转 - 旋转动画背景 */
      .initiative-result-banner.reverse-initiative::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 150%;
        height: 150%;
        background: conic-gradient(from 0deg,
          transparent 0deg,
          rgba(255, 255, 255, 0.1) 30deg,
          transparent 60deg,
          rgba(255, 255, 255, 0.1) 210deg,
          transparent 240deg);
        transform: translate(-50%, -50%);
        animation: reverse-spin 3s linear infinite;
      }

      /* 先攻结果文字 */
      .initiative-result-text {
        font-size: 16px;
        font-weight: bold;
        letter-spacing: 2px;
        position: relative;
        z-index: 1;
        text-align: center;
        flex: 1;
      }

      .seize-initiative .initiative-result-text {
        color: #ffd700;
        text-shadow:
          0 0 10px rgba(255, 215, 0, 1),
          0 0 20px rgba(255, 215, 0, 0.8),
          0 0 30px rgba(255, 215, 0, 0.6);
      }

      .reverse-initiative .initiative-result-text {
        color: #1e90ff;
        text-shadow:
          0 0 10px rgba(30, 144, 255, 1),
          0 0 20px rgba(30, 144, 255, 0.8),
          0 0 30px rgba(30, 144, 255, 0.6);
      }

      /* 装饰图标 - 左右两侧 */
      .initiative-decor {
        font-size: 28px;
        position: relative;
        z-index: 1;
        flex-shrink: 0;
        animation: decor-pulse 1.5s ease-in-out infinite;
      }

      .initiative-decor.left {
        margin-right: 15px;
      }

      .initiative-decor.right {
        margin-left: 15px;
      }

      .seize-initiative .initiative-decor {
        filter: drop-shadow(0 0 8px rgba(255, 215, 0, 0.8));
      }

      .reverse-initiative .initiative-decor {
        filter: drop-shadow(0 0 8px rgba(30, 144, 255, 0.8));
      }

      /* 动画定义 */

      /* 闪电扫过动画 */
      @keyframes lightning-sweep {
        0% {
          transform: translate(-100%, -100%) rotate(45deg);
        }

        100% {
          transform: translate(100%, 100%) rotate(45deg);
        }
      }

      /* 旋转动画 */
      @keyframes reverse-spin {
        from {
          transform: translate(-50%, -50%) rotate(0deg);
        }

        to {
          transform: translate(-50%, -50%) rotate(360deg);
        }
      }

      /* 装饰脉冲动画 */
      @keyframes decor-pulse {

        0%,
        100% {
          transform: scale(1);
          opacity: 1;
        }

        50% {
          transform: scale(1.2);
          opacity: 0.8;
        }
      }

      /* 移动端优化 */
      @media (max-width: 768px) {
        .initiative-result-banner {
          padding: 10px 15px;
        }

        .initiative-result-text {
          font-size: 14px;
          letter-spacing: 1px;
        }

        .initiative-decor {
          font-size: 22px;
        }

        .initiative-decor.left {
          margin-right: 10px;
        }

        .initiative-decor.right {
          margin-left: 10px;
        }
      }

      font-size: 10px;
      /* 从 11px 减小到 10px */
      color: var(--judgment-text-secondary);
      font-style: italic;
    }

    /* 关键信息高亮 */
    .highlight {
      color: var(--judgment-accent-gold);
      font-weight: bold;
      text-shadow: 0 0 8px rgba(218, 165, 32, 0.5);
      padding: 0 2px;
      border-radius: 2px;
      background: rgba(218, 165, 32, 0.1);
    }

    .highlight-number {
      color: var(--fate-blessing-primary);
      font-weight: bold;
      font-family: 'Courier New', monospace;
      text-shadow: 0 0 10px rgba(255, 215, 0, 0.6);
      padding: 0 3px;
      border-radius: 3px;
      background: rgba(255, 215, 0, 0.1);
    }

    .highlight-success {
      color: var(--judgment-positive);
      font-weight: bold;
    }

    .highlight-failure {
      color: var(--judgment-negative);
      font-weight: bold;
    }

    /* 判定结果样式 */
    .judgment-result {
      display: flex;
      align-items: center;
      gap: var(--judgment-spacing-md);
      padding: var(--judgment-spacing-md);
    }

    .result-icon {
      font-size: 24px;
      /* 从 28px 进一步减小到 24px */
      flex-shrink: 0;
    }

    .judgment-result.critical-success .result-icon {
      color: var(--judgment-critical-success);
    }

    .judgment-result.perfect .result-icon {
      color: var(--judgment-perfect);
    }

    .judgment-result.success .result-icon {
      color: var(--judgment-success);
    }

    .judgment-result.failure .result-icon {
      color: var(--judgment-failure);
    }

    .judgment-result.critical-failure .result-icon {
      color: var(--judgment-critical-failure);
    }

    .result-text {
      font-size: 14px;
      /* 从 16px 减小到 14px */
      font-weight: bold;
      color: var(--judgment-text-primary);
    }

    .result-description {
      font-size: 10px;
      /* 从 11px 减小到 10px */
      color: var(--judgment-text-secondary);
      margin-top: 2px;
      /* 从 3px 减小到 2px */
    }

    /* 状态更新样式 */
    .judgment-status-updates {
      background: rgba(0, 0, 0, 0.3);
      /* 从 0.2 增加到 0.3 */
    }

    .status-update-container {
      margin-bottom: var(--judgment-spacing-md);
    }

    .status-update-container:last-child {
      margin-bottom: 0;
    }

    .status-update-name {
      font-size: 13px;
      /* 从 14px 减小到 13px */
      font-weight: bold;
      color: var(--judgment-accent-gold);
      margin-bottom: var(--judgment-spacing-sm);
    }

    .status-update-changes {
      display: flex;
      flex-wrap: wrap;
      gap: var(--judgment-spacing-sm);
    }

    /* 状态胶囊组件优化 - 已在上方定义 */

    /* 先攻判定样式 */
    .judgment-initiative {
      background: rgba(0, 0, 0, 0.15);
    }

    /* 对抗判定样式 - VS对称布局 */
    .judgment-combat {
      background: rgba(0, 0, 0, 0.25);
      /* 从 0.15 增加到 0.25 */
    }

    .combat-vs-layout {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: var(--judgment-spacing-md);
      align-items: center;
      padding: var(--judgment-spacing-md);
    }

    .combat-side {
      padding: var(--judgment-spacing-sm);
      border-radius: var(--judgment-border-radius);
      background: rgba(0, 0, 0, 0.3);
      /* 从 0.2 增加到 0.3 */
    }

    .combat-side.attacker {
      text-align: right;
      border-left: 3px solid var(--judgment-accent-gold);
    }

    .combat-side.defender {
      text-align: left;
      border-right: 3px solid var(--judgment-accent-bronze);
    }

    .combat-clash-point {
      font-size: 24px;
      /* 从 28px 减小到 24px */
      color: var(--judgment-accent-gold);
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        transform: scale(1);
        opacity: 1;
      }

      50% {
        transform: scale(1.1);
        opacity: 0.8;
      }
    }

    .combat-side-label {
      font-size: 11px;
      /* 从 12px 减小到 11px */
      color: var(--judgment-text-muted);
      margin-bottom: 3px;
      /* 从 4px 减小到 3px */
    }

    .combat-side-value {
      font-size: 14px;
      /* 从 16px 减小到 14px */
      font-weight: bold;
      color: var(--judgment-text-primary);
    }

    .combat-side.winner .combat-side-value {
      color: var(--judgment-accent-gold);
      text-shadow: 0 0 10px rgba(218, 165, 32, 0.5);
    }

    /* 伤害标签 */
    .damage-tag {
      display: inline-block;
      padding: 3px 10px;
      /* 从 4px 12px 减小到 3px 10px */
      background: linear-gradient(135deg, rgba(220, 20, 60, 0.8) 0%, rgba(139, 0, 0, 0.8) 100%);
      color: #fff;
      font-size: 14px;
      /* 从 16px 减小到 14px */
      font-weight: bold;
      border-radius: 4px;
      box-shadow: 0 2px 8px rgba(220, 20, 60, 0.4);
      animation: damage-float 1s ease-in-out infinite;
    }

    @keyframes damage-float {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-5px);
      }
    }

    /* 伤害计算样式 */

    /* 状态胶囊样式 */
    .status-changes-container {
      margin-top: 10px;
    }

    .status-changes-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .status-change-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: bold;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    /* 正向变动 - 明亮绿色 */
