  transition: width 0.3s ease;
  box-shadow: 0 0 6px rgba(var(--rgb-primary), 0.4);
  min-width: 2px;
}

/* 雷达图容器 */
.radar-chart-container {
  width: 100%;
  height: 260px;
  /* 从220px增加到260px，适度增加高度 */
  min-height: 260px;
  display: flex;
  justify-content: center;
  align-items: center;
