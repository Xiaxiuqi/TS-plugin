.ai-var-error-list { margin: 0; padding-left: 20px; font-size: var(--text-sm); color: var(--color-danger); }
.ai-var-actions { display: flex; gap: 10px; justify-content: flex-end; }

/* =================================================================
   4. 坍缩控制台 (Collapse Console)
================================================================= */
.collapse-console-container { background: var(--bg-panel); border: 1px solid rgba(var(--rgb-primary), 0.4); border-radius: 8px; padding: 15px; margin-bottom: 15px; box-shadow: 0 4px 12px var(--overlay-base); }
.collapse-console-title { color: var(--color-primary); font-size: var(--text-md); margin-bottom: 12px; border-bottom: 1px solid rgba(var(--rgb-primary), 0.2); padding-bottom: 6px; text-shadow: 0 0 5px rgba(var(--rgb-primary), 0.3); }
.collapse-console-body { display: flex; flex-direction: column; gap: 12px; font-size: var(--text-base); color: var(--text-muted); }
.collapse-stat-row { display: flex; justify-content: space-between; align-items: center; background: var(--overlay-light); padding: 8px; border-radius: 4px; }
.collapse-radio-group { display: flex; flex-direction: column; gap: 6px; background: var(--overlay-light); padding: 8px; border-radius: 4px; border-left: 3px solid var(--color-primary); }
.collapse-radio-label { cursor: pointer; display: flex; align-items: flex-start; gap: 8px; }
.collapse-radio-desc { font-size: var(--text-xs); color: var(--text-subtle); line-height: 1.4; display: block; margin-top: 2px;}
.collapse-action-row { display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed rgba(var(--rgb-secondary), 0.4); padding-top: 12px; margin-top: 4px; }

/* =================================================================
   5. 剧场沉浸编辑器 (Immersive Editor) & 时间线抽屉
================================================================= */
.immersive-editor-wrapper { display: flex; flex-direction: column; width: 100%; z-index: 10; }
.editor-header-title { color: var(--color-primary); font-weight: bold; letter-spacing: 1px; font-size: var(--text-md); text-shadow: 0 0 8px rgba(var(--rgb-primary), 0.3); }
.editor-btn-save { border: 1px solid rgba(var(--rgb-primary), 0.5); background: var(--color-primary); }

.timeline-dir-divider { height: 1px; background: rgba(var(--rgb-secondary), 0.3); margin: 25px 0 15px 0; }
.timeline-dir-title { font-size: var(--text-md); margin-bottom: 15px; color: var(--color-secondary); }
.timeline-dir-list { display: flex; flex-direction: column; gap: 8px; }
.timeline-detailed-info { margin-top: 15px; padding-top: 15px; border-top: 1px solid rgba(var(--rgb-secondary), 0.3); }
.detail-section-pre { white-space: pre-wrap; font-size: var(--text-xs); color: var(--text-muted); }
.timeline-dir-divider { height: 1px; background: rgba(var(--rgb-secondary), 0.3); margin: 25px 0 15px 0; }
/* 避免和抽屉主标题的 .drawer-title 冲突，我们用一个子级标题类 */
.timeline-dir-title { font-size: var(--text-md); margin-bottom: 15px; color: var(--color-secondary); font-weight: bold;}
/* 补充你缺失的容器类 */
.timeline-dir-container { display: flex; flex-direction: column; gap: 8px; }
.editor-header-actions { display: flex; gap: 8px; }
.text-muted-input { color: var(--text-muted) !important; }
.flex-col-gap4 { display: flex; flex-direction: column; gap: 4px; }




