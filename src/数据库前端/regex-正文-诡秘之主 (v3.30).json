/* --- Source: 01.-global-layout.css --- */
/* ==========================================
   01. Global & Layout (全局与布局)
   ========================================== */

:root {
  /* 🎨 1. 核心颜色 RGB 拆分 (高级技巧：方便后续加透明度) */
  --rgb-primary: 218, 165, 32;     /* 对应高频的 #daa520 */
  --rgb-secondary: 139, 69, 19;    /* 对应高频的 #8b4513 */
  --rgb-bg-dark: 0, 0, 0;      /* 基础纯黑 */
  --rgb-white: 255, 255, 255;
  --rgb-panel-dark: 26, 22, 16;
  /* 🔮 新增：魔法/史诗紫色系基础 RGB */
  --rgb-magic: 138, 43, 226; /* 对应高频的 #8a2be2 (BlueViolet) */

  /* 💡 新增：为了支撑散乱 RGBA 动态替换的底层 RGB 变量 */
  --rgb-border-dark: 90, 61, 43;   /* #5a3d2b */
  --rgb-danger: 255, 107, 107;     /* #ff6b6b */
  --rgb-success: 76, 175, 80;    /* #4caf50 */
  --rgb-info: 26, 95, 122;       /* #1a5f7a */
  --rgb-text-subtle: 210, 180, 140;  /* #d2b48c */

  /* 🎨 2. 主题与品牌色 (Brand & Accent) */
  --color-primary: rgb(var(--rgb-primary));
  --color-secondary: rgb(var(--rgb-secondary));
  --color-border-dark: rgb(var(--rgb-border-dark));
  --color-danger: rgb(var(--rgb-danger));
  --color-warning: #ff9800;      /* 新增：橙色警告 */
    /* 🔮 新增：魔法/史诗紫品牌色 */
  --color-magic: rgb(var(--rgb-magic));

  /* 🎨 3. 文本颜色 (Text Colors) */
  --text-main: #f5deb3;
  --text-muted: #a09c91;
  --text-subtle: rgb(var(--rgb-text-subtle));
  --text-highlight: #dcd5c7;

  /* 📖 新增：特殊叙事正文色提取为变量 */
  --text-language: #d1a9a9;
  --text-psychology: rgba(200, 200, 220, 0.9);
  --text-scenery: #a8c196;

  /* 🎨 4. 基础背景与遮罩 (Background & Overlays) */
  --bg-base: #171717;
  --bg-panel: rgba(26, 22, 16, 0.95);

  --overlay-light: rgba(var(--rgb-bg-dark), 0.3);
  --overlay-base: rgba(var(--rgb-bg-dark), 0.5);
  --overlay-dark: rgba(var(--rgb-bg-dark), 0.8);

  --bg-primary-hover: rgba(var(--rgb-primary), 0.2);
  --bg-secondary-hover: rgba(var(--rgb-secondary), 0.3);

  /* --- 暗色模式 (保留你最爱的经典原味) --- */
  --rgb-ui-bg-1: 139, 69, 19;     /* 原版 Secondary */
  --rgb-ui-bg-2: 90, 61, 43;    /* 原版 Border-Dark */
  --color-ui-border: var(--rgb-ui-bg-1);
  --color-ui-text: var(--rgb-primary);
  /* 🧹 修复：去除发黄光，改为纯正的深色阴影 */
  --rgb-ui-shadow: 0, 0, 0;
  --color-ui-shadow: rgba(var(--rgb-ui-shadow), 0.5);

  /* 悬停状态 (严格使用 RGB 数字，以支持 rgba 函数) */
  --rgb-ui-hover-1:  139, 69, 19; /* 原 #ffffff 拆分 */
  --rgb-ui-hover-2:  139, 69, 19; /* 原 #ffffff 拆分 */
  --color-ui-hover-text: #1a1610; /* 悬停背景变白时，文字必须变黑，否则看不见 */
  --color-ui-hover-border: #ffd700;
  --rgb-ui-hover-shadow: 0, 0, 0; /* 悬停依然保持纯黑立体阴影，拒绝发光 */

  /* 🅰️ 5. 字体族 (Font Families - 优雅中文字体升级) */
  /* 默认主字体变量，由 JS 动态覆盖 */
  --main-font-family: var(--font-serif);
  /* 📜 5.1 衬线体 (宋体/明体) - 适合长篇沉浸式阅读，带有经典文学复古感 */
  --font-serif: "Noto Serif SC", "Source Han Serif SC", "PingFang SC", "STSong", "SimSun", Georgia, serif;
  /* 📱 5.2 无衬线体 (黑体) - 适合现代UI界面、系统提示，清晰易读 */
  --font-sans: "Noto Sans SC", "Source Han Sans SC", "PingFang SC", "Microsoft YaHei", -apple-system, sans-serif;
  /* ✍️ 5.3 楷体 (强推) - 带有手写温度，非常适合独白、书信、回忆等叙事场景 */
  /* 注：LXGW WenKai (霞鹜文楷) 是目前最美的开源中文阅读字体 */
  --font-kaiti: "LXGW WenKai", "STKaiti", "KaiTi", "BiauKai", serif;
  /* 🖋️ 5.4 仿宋 - 骨架清秀，适合用作旁白、物品描述或注释 */
  --font-fangsong: "STFangsong", "FangSong", serif;
  /* 🎭 5.5 艺术/展示字 (用于标题或特殊判定大字) */
  --font-display: "ZCOOL KuaiLe", "Ma Shan Zheng", cursive, serif;
  /* 💻 5.6 等宽字体 (用于代码、数值面板、骰子结果等对齐场景) */
  --font-mono: "Fira Code", "Courier New", Courier, monospace;

  /* 📏 6. 字号阶层 (动态比例缩放系统) */
  /* 我们定义一个没有单位的纯数字作为“锚点”，默认是 14 */
  --text-base-size: 14;

  /* 其他所有字号，都基于这个锚点乘以特定的比例系数 */
  /* 系数来源于你之前的 Token 报告：11/14, 12/14, 16/14, 18/14, 24/14 */
  --text-xs: calc(var(--text-base-size) * 0.985px);
  --text-sm: calc(var(--text-base-size) * 1.057px);
  --text-base: calc(var(--text-base-size) * 1px);
  --text-md: calc(var(--text-base-size) * 1.242px);
  --text-lg: calc(var(--text-base-size) * 1.385px);
  --text-xl: calc(var(--text-base-size) * 1.714px);

  /* 🚦 7. 功能状态色 (Status Colors) */
  --color-success: rgb(var(--rgb-success));
  --color-info: rgb(var(--rgb-info));
  --color-danger-dark: #8b0000;
}

/* -----------------------------------------------------------------
   🌗 亮色模式 (Light Theme Override - 经典羊皮纸风格)
   ----------------------------------------------------------------- */
:root[data-theme="light"] {
  /* 🔄 1. 底层 RGB 重塑 (打造真实的复古羊皮纸质感) */
  /* 废弃纯白，使用带有历史感的浅暖黄色作为基础“亮色” */
  --rgb-white: 245, 237, 225;    /* 柔和的羊皮纸高光色 (#fdede1) */
  --rgb-bg-dark: 242, 234, 218;     /* 全局背景：陈旧的羊皮纸底色 (#f2eada) */
  --rgb-panel-dark: 230, 220, 200;  /* 面板背景：稍暗的羊皮纸/牛皮纸 (#e6dcc8) */

  /* 边框和辅助色加深，增加页面层次感和立体感 */
  --rgb-border-dark: 180, 150, 110;   /* 柔和的浅棕色边框 */
  --rgb-text-subtle: 140, 120, 95;  /* 辅助文本 RGB 变深 */

  /* 🎨 2. 重新映射边框色 */
  --color-border-dark: rgb(var(--rgb-border-dark));

  /* 📝 3. 基础文本颜色反转 (墨水质感) */
  --text-main: #2b2118;         /* 极深的碳灰棕，接近褪色的黑墨水，极其护眼 */
  --text-muted: #5e4c3a;        /* 灰褐色次要文本，像褪色的陈旧笔记 */
  --text-subtle: rgb(var(--rgb-text-subtle)); /* 浅褐色辅助文本 */
  --text-highlight: #140d07;      /* 纯黑高亮，用于需要极高对比度的地方 */

  /* 📖 4. 叙事正文染色反转 (与羊皮纸底色完美融合) */
  --text-language: #8b3a3a;       /* 🗣️ 语言：干涸的暗血红/砖红 */
  --text-psychology: rgba(50, 60, 90, 0.95); /* 🧠 心理：深邃的靛蓝/墨蓝 */
  --text-scenery: #3d6333;      /* 🌲 景物：深沉的苔藓绿 */

  /* 🖼️ 5. 基础背景与遮罩重塑 */
  /* 整体大背景：彻底应用羊皮纸底色 */
  --bg-base: rgb(var(--rgb-bg-dark));
  /* 面板背景：使用稍暗的牛皮纸色，并略带透明度以透出底下可能有的纹理 */
  --bg-panel: rgba(var(--rgb-panel-dark), 0.95);

  /* 💡 6. 遮罩反转魔法的微调 */
  /* 在羊皮纸上，我们需要深色的遮罩来表现阴影或弹窗背景，
     因此这里我们将 --rgb-bg-dark 的遮罩反向映射为深灰色，
     否则你会得到奇怪的“浅色半透明”遮罩，导致弹窗文字看不清 */
  --overlay-light: rgba(40, 30, 20, 0.15); /* 极轻的暖灰阴影 */
  --overlay-base: rgba(40, 30, 20, 0.4);  /* 标准的模态框背景暗化 */
  --overlay-dark: rgba(20, 15, 10, 0.7);  /* 极暗的深空遮罩 */

  /* 💡 7. 悬停效果的适配 */
  /* 在浅色底上，原有的悬停效果可能不够明显，稍微加深一点对比度 */
  --bg-primary-hover: rgba(var(--rgb-primary), 0.15);  /* 金色微光 */
  --bg-secondary-hover: rgba(var(--rgb-secondary), 0.15);/* 棕色微光 */

  /* 🎨 1. 核心颜色加深 (适配羊皮纸底色) */
  --rgb-primary: 184, 115, 51;     /* 从明亮的金色 -> 深邃的古铜金/暗金 */
  --rgb-secondary: 90, 50, 20;     /* 变成更深的焦茶色 */
  --rgb-border-dark: 160, 130, 90;   /* 边框加深 */

  /* 🔮 2. 状态/魔法色加深 (变成深色墨水质感) */
  --rgb-magic: 75, 0, 130;       /* 从亮紫 -> 深靛紫 (Indigo) */
  --rgb-danger: 178, 34, 34;     /* 从粉红 -> 凝血暗红 (Firebrick) */
  --rgb-success: 34, 139, 34;    /* 从浅绿 -> 森林深绿 */
  --rgb-info: 0, 90, 156;      /* 从浅蓝 -> 普鲁士蓝 */

  /* 重新映射 */
  --color-primary: rgb(var(--rgb-primary));
  --color-secondary: rgb(var(--rgb-secondary));
  --color-border-dark: rgb(var(--rgb-border-dark));
  --color-danger: rgb(var(--rgb-danger));
  --color-warning: #c76a00;      /* 橙色警告压暗 */
  --color-magic: rgb(var(--rgb-magic));

  /* --- 亮色模式 (复古皮质/高定质感，完美契合羊皮纸) --- */
  /* 1. 底色：保持经典的深茶褐色，与羊皮纸形成高雅的对比 */
  --rgb-ui-bg-1: 107, 68, 35;
  --rgb-ui-bg-2: 60, 40, 20;
  /* 2. 边框：改用“哑光暗金”，避免亮金色在白底上反光看不清 */
  --color-ui-border: #b38b4d;
  /* 3. 文本：羊皮纸白，柔和不刺眼 */
  --color-ui-text: #fdfcf8;
  /* 4. 💡核心修复：亮色模式下的阴影必须是深棕色！金色阴影在白底上直接隐身，导致 hover 没反应 */
  --rgb-ui-shadow: 60, 40, 20;
  --color-ui-shadow: rgba(var(--rgb-ui-shadow), 0.3);

  /* 悬停状态：底色微亮，边框变亮金，阴影加深 */
  --rgb-ui-hover-1: 130, 80, 40;
  --rgb-ui-hover-2: 85, 55, 30;
  --color-ui-hover-border: #d4a359;
  --color-ui-hover-shadow: rgba(60, 40, 20, 0.6); /* 加深的投影让 hover 具有极强的立体浮起感 */
}

.attribute-value[data-theme="light"]{
  font-weight: bolder;
  text-shadow: var(--overlay-dark);
}

/* 全局应用升级后的字体变量（如果你之前没写的话） */
body {
  font-family: var(--main-font-family);
  color: var(--text-main);
  background-color: var(--bg-base);
}

/* --- 正文染色样式 --- */
.text-language {
  color: var(--text-language);
  font-style: italic;
}

.text-psychology {
  color: var(--text-psychology);
  font-style: italic;
}

.text-scenery {
  color: var(--text-scenery);
}


/* --- Source: 01.-global-layout.css --- */
/* ==========================================
   01. Global & Layout (全局与布局)
   ========================================== */

/* =========================================================================
   全局设计令牌 (Design Tokens) - V2.0 精确数据版
   ========================================================================= */
/* 背景设置控件组，让列表和按钮垂直排列 */
.bg-control-group {
  display: flex;
  flex-direction: column;
  width: 100%;
}

/* 纵向滚动的背景容器 */
.bg-scroll-container {
  overflow-y: auto;
  max-height: 300px;
  /* 使用 Grid 布局让图片自动填充为网格，100px 是基础宽度，可根据喜好调整 */
  display: grid;
  grid-auto-rows: max-content;
  grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
  gap: 10px;
  padding: 10px;
  margin-bottom: 10px;
  background: var(--bg-secondary, rgba(0,0,0,0.1)); /* 可选：给容器一点底色区分 */
  border-radius: 6px;
}

/* 按钮组垂直排布 */
.bg-action-buttons {
  display: block; /* 改回常规块级 */
  margin-top: 10px;
}

.bg-action-buttons button {
  display: block;
  margin-bottom: 8px; /* 按钮之间的垂直间距 */
  width: 100%; /* 让按钮宽度包裹文字即可，或者设为 100% 占满 */
}

/* 单个背景图项的完整样式 */
.bg-item {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9; /* 固定图片比例，横屏游戏通常为 16:9 */
  border-radius: 4px;
  overflow: hidden;
  cursor: pointer;
  border: 2px solid transparent;
  transition: all 0.2s ease-in-out;
}

/* 图片铺满并裁剪 */
.bg-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* 选中状态的高亮边框（颜色可以换成你的主题高亮色） */
.bg-item.selected-bg {
  border: 2px solid var(--color-primary);
  box-shadow: 0 0 8px var(--color-primary);
  transform: scale(0.98); /* 点击选中有个微微内缩的阻尼感 */
}

/* 自定义图片的标签美化 */
.bg-tag {
  position: absolute;
  bottom: 4px;
  right: 4px;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  font-size: 11px;
  padding: 2px 6px;
  border-radius: 4px;
  pointer-events: none; /* 防止点击标签时误触 */
}


.panel-header {
  display: none;
  /* 只在移动端显示 */
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
  padding-bottom: 5px;
  border-bottom: 1px solid var(--color-secondary);
}

.panel-toggle-btn {
  display: none;
  /* 只在移动端显示 */
  background: rgba(var(--rgb-white), 0.1);
  border: 1px solid var(--text-muted);
  color: var(--text-muted);
  font-size: var(--text-xs);
  padding: 2px 8px;
  border-radius: 4px;
  cursor: pointer;
}

.bottom-toggle-btn {
  position: absolute;
  top: -30px;
  left: 0px;
  z-index: 5;
}

.panel-content-wrapper {
  display: contents;
  /* 默认情况下，这个包裹元素不影响布局 */
}

/* 面板收起时的核心样式 */
.panel-collapsed .attributes-list,
.panel-collapsed .equipment-grid,
.panel-collapsed .panel-content-wrapper,
.panel-collapsed .quick-send-container,
.panel-collapsed #status-effects-wrapper {
  display: none;
}


/* 全屏模式下悬浮编辑器样式 */
.game-root-container:fullscreen #floating-editor-toggle,
.game-root-container:fullscreen #floating-editor-panel {
  position: fixed !important;
  z-index: 99999 !important;
}

/* 输入框内的滚动条美化（如果超过 max-height） */
.quick-send-input::-webkit-scrollbar {
  width: 4px;
}

.quick-send-input::-webkit-scrollbar-thumb {
  background: rgba(var(--rgb-primary), 0.5);
  border-radius: 4px;
}

.mobile-view .panel-toggle-btn {
  display: block;
}
.mobile-view .panel-header {
  display: flex;
}

/* ========================================
   全局基础与外层容器
   ======================================== */
.game-root-container {
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  color: var(--text-subtle);
  border: none;
  border-radius: 16px;
  width: 100%;
  height: 600px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  margin: auto;
  position: relative;
  box-shadow: 0 8px 32px var(--overlay-base), 0 0 0 1px rgba(var(--rgb-secondary), 0.3), inset 0 1px 0 rgba(var(--rgb-white), 0.05);
  backdrop-filter: blur(10px);
  transition: box-shadow 0.3s ease, max-width 0.3s ease, height 0.3s ease;
}

.game-root-container:hover {
  box-shadow: 0 12px 48px var(--overlay-dark), 0 0 0 1px rgba(var(--rgb-primary), 0.4), inset 0 1px 0 rgba(var(--rgb-white), 0.08);
}

.game-root-container::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(var(--rgb-panel-dark), 0.4);
  z-index: 1;
  pointer-events: none;
}

.game-root-container:fullscreen {
  width: 100%;
  height: 100%;
  max-width: 100%;
  border-radius: 0;
  overflow: hidden !important;
}

.game-root-container:fullscreen .game-container {
  height: 100%;
}

/* ========================================
   ✨ 核心骨架：统一网格布局 (释放层叠上下文)
   ======================================== */
.game-container {
  position: relative;
  /* 核心修复2：移除原本的 z-index: 2，打破层叠囚笼，让 Fixed 的抽屉能浮出去！ */
  display: grid;
  grid-template-columns: 1fr;
  grid-template-rows: auto 1fr auto;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

/* 兼容移动视图的高度 */
.mobile-view .game-container {
  height: 100vh;
  height: -webkit-fill-available;
}

/* 确保基础面板处于背景层 ::before 之上 */
.top-status, .main-content, .bottom-status {
  position: relative;
  z-index: 2;
}

/* --- 面板位置分配 --- */
.top-status {
  grid-column: 1 / -1;
  grid-row: 1;
}

.main-content {
  grid-column: 1 / -1;
  grid-row: 2;
  overflow-y: auto;
}

.bottom-status {
  grid-column: 1 / -1;
  grid-row: 3;
}


/* ========================================
   ✨ 桌面宽屏模式：降维打击 (严格防泄漏版)
   ======================================== */
@media (min-width: 1025px) {
  /* 核心修复1：链式白名单！只要 body、根容器、game-container 任意一个带了 .mobile-view，网格就不生效 */
  body:not(.mobile-view) .game-root-container:not(.mobile-view) .game-container:not(.mobile-view) {
    grid-template-columns: 220px 1fr !important;
  }

  /* 将抽屉强制从 fixed 降级并塞入网格 */
  body:not(.mobile-view) .game-root-container:not(.mobile-view) .game-container:not(.mobile-view) > #left-drawer {
    position: relative !important;
    transform: none !important;
    grid-column: 1;
    grid-row: 2;
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    box-shadow: none !important;
    z-index: 1 !important;
    border-radius: 12px 0 0 12px !important;
    /* 清除你补充的 drawer-panel 里的边框和背景 */
    border: none !important;
    background: transparent !important;
  }

  /* 正文自动退让到右侧 */
  body:not(.mobile-view) .game-root-container:not(.mobile-view) .game-container:not(.mobile-view) > .main-content {
    grid-column: 2;
  }

  /* 隐藏触发按钮 */
  body:not(.mobile-view) .game-root-container:not(.mobile-view) .game-container:not(.mobile-view) #left-drawer-trigger,
  body:not(.mobile-view) .game-root-container:not(.mobile-view) .game-container:not(.mobile-view) #left-drawer .left-drawer-header {
    display: none !important;
  }

  /* 剥离纯桌面状态下的多余背景和边框 */
  body:not(.mobile-view) .game-root-container:not(.mobile-view) .game-container:not(.mobile-view) #left-drawer .character-panel {
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    backdrop-filter: none !important;
    padding: 0;
  }
  body:not(.mobile-view) .game-root-container:not(.mobile-view) .game-container:not(.mobile-view) #left-drawer .character-panel::before {
    display: none !important;
  }
}


/* ========================================
   各面板美化与内部样式
   ======================================== */
.top-status,
.bottom-status {
  background: linear-gradient(135deg, rgba(var(--rgb-panel-dark), 0.95) 0%, rgba(var(--rgb-panel-dark), 0.95) 100%);
  display: flex;
  align-items: center;
  backdrop-filter: blur(8px);
}

.top-status {
  justify-content: space-around;
  align-items: flex-start;
  gap: 15px;
  padding: 2px 10px;
  border-bottom: 1px solid rgba(var(--rgb-primary), 0.2);
  box-shadow: 0 2px 8px var(--overlay-light), inset 0 -1px 0 rgba(var(--rgb-white), 0.05);
  container-type: inline-size;
  container-name: top-bar;
  width: 100%;
}

.bottom-status {
  justify-content: space-between;
  gap: 15px;
  padding: 5px 15px;
  border-top: 1px solid rgba(var(--rgb-primary), 0.2);
  box-shadow: 0 -2px 8px var(--overlay-light), inset 0 1px 0 rgba(var(--rgb-white), 0.05);
}


/* 确保根容器可以包裹绝对定位的背景层 */
.game-root-container {
  position: relative;
  z-index: 0;
  /* 去掉根容器原本直接绑定的背景，我们将用底层的图层代替 */
  background-image: none !important;
  background-color: #000; /* 给个纯黑底色，淡入淡出时防穿帮 */
}

/* 专门用来做背景的图层 */
.game-bg-layer {
  position: absolute; /* 如果你的背景是锁定视口的，这里也可以用 fixed */
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1; /* 必须在所有内容的最下层 */
  pointer-events: none; /* 防止遮挡鼠标点击事件 */

  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;

  /* 核心：只对透明度进行平滑过渡 */
  opacity: 0;
  transition: opacity 0.8s ease-in-out;
}

/* 处于激活状态的图层显示出来 */
.game-bg-layer.active {
  opacity: 1;
}

/* 修改现有的 main-content */
.main-content {
  padding: 20px 45px;
  /* 使用 var() 引入变量，后面的 0.5 和 3px 是默认回退值 */
  background: rgba(var(--rgb-panel-dark), var(--main-content-opacity, 0.5));
  box-shadow: inset 0 0 20px rgba(var(--rgb-bg-dark), 0.2), inset 0 2px 4px rgba(var(--rgb-bg-dark), 0.15);
  backdrop-filter: blur(var(--main-content-blur, 3px));
  /* 为了兼容部分浏览器，可加上 -webkit- 前缀 */
  -webkit-backdrop-filter: blur(var(--main-content-blur, 3px));
}

.main-content::before,
.main-content::after {
  content: '';
  position: absolute;
  top: 15px;
  bottom: 15px;
  width: 2px;
  background: linear-gradient(to bottom, transparent 0%, rgba(var(--rgb-primary), 0.3) 20%, rgba(var(--rgb-primary), 0.3) 80%, transparent 100%);
  opacity: 0.6;
  box-shadow: 0 0 8px rgba(var(--rgb-primary), 0.4);
  background-repeat: repeat-y;
}

.main-content::before { left: 10px; }
.main-content::after { right: 10px; }

/* 确保非纯桌面下，抽屉内部边距正常 */
@media (max-width: 1024px) {
  /* 媒体查询内部可以包含多个选择器 */
  .mobile-view #left-drawer .character-panel,
  #left-drawer .character-panel {
    padding: 16px;
  }
}


/* ========================================
   底栏响应式排版
   ======================================== */
.bottom-controls-layout {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  gap: 10px;
  width: 100%;
}

.layout-left {
  order: 1;
  flex: 0 0 auto;
  padding-bottom: 2px;
}

.layout-center {
  order: 2;
  flex: 1 1 350px;
  min-width: 350px;
}

.layout-right {
  order: 3;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 8px;
  padding-bottom: 6px;
}

@media (max-width: 780px) {
  .layout-left { order: 1; }
  .layout-right { order: 2; margin-left: auto; padding-bottom: 0; }
  .layout-center { order: 3; flex: 1 1 100%; min-width: 100%; margin-top: 5px; }
}

.mobile-view .layout-left { order: 1; }
.mobile-view .layout-right { order: 2; margin-left: auto; padding-bottom: 0; }
.mobile-view .layout-center { order: 3; flex: 1 1 100%; min-width: 100%; margin-top: 5px; }


/* ========================================
   其他组件样式
   ======================================== */
.hidden { display: none !important; }

.game-text-container {
  font-family: var(--main-font-family);
  font-size: var(--text-md);
  line-height: 1.8;
  color: var(--text-highlight);
  white-space: pre-wrap;
  text-shadow: 1px 1px 2px var(--overlay-light);
}









/* --- 全局滚动条美化 --- */
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background: rgba(var(--rgb-panel-dark), 0.6);
  /* 如果需要轨道也有圆角，可以加上 */
  border-radius: 10px;
  border: 1px solid rgba(var(--rgb-secondary), 0.2);
}

::-webkit-scrollbar-thumb {
  /* 1. 使用固定像素圆角，10px 足够让滑块变圆润 */
  border-radius: 10px;

  /* 2. 使用 linear-gradient 时，确保背景裁切在内容框内 */
  background: linear-gradient(180deg, rgba(var(--rgb-secondary), 0.8) 0%, rgba(var(--rgb-border-dark), 0.8) 100%);

  /* 3. 边框建议调细，或者使用 transparent 结合 padding-box 制造空隙感 */
  border: 2px solid transparent;
  background-clip: padding-box;

  box-shadow: inset 0 1px 0 rgba(var(--rgb-white), 0.1), 0 0 8px rgba(var(--rgb-primary), 0.2);
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(var(--rgb-secondary), 0.9); /* Hover时简化背景色通常效果更好 */
  background-clip: padding-box;
  border-radius: 10px;
  box-shadow: inset 0 1px 0 rgba(var(--rgb-white), 0.15), 0 0 12px rgba(var(--rgb-primary), 0.4);
}

/* 🔥 移动端性能优化：简化滚动条样式 */
@media (max-width: 768px) {
  ::-webkit-scrollbar {
    width: 5px !important;
    height: 5px !important;
  }

  ::-webkit-scrollbar-track {
    background: rgba(var(--rgb-panel-dark), 0.3) !important;
    box-shadow: none !important;
    border: none !important;
    border-radius: 5px !important;
  }

  ::-webkit-scrollbar-thumb {
    background: rgba(var(--rgb-secondary), 0.5) !important;
    box-shadow: none !important;
    border: none !important;
    border-radius: 5px !important;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: rgba(var(--rgb-secondary), 0.7) !important;
    box-shadow: none !important;
    border-radius: 5px !important;
  }

  /* 🔥 性能优化：禁用移动端不需要的hover效果 */
  .interaction-btn:hover,
  .action-options-item:hover,
  .theater-tab:hover,
  .gacha-tab:hover,
  .option-btn:hover {
    transform: none !important;
    box-shadow: none !important;
  }

  /* 🔥 性能优化：为滚动容器添加硬件加速（不使用transform避免影响fixed定位） */
  .modal-body,
  .thinking-content,
  .timeline-events-list,
  #summarizer-input-list,
  #point-history-list,
  .gacha-tab-content,
  .decom-inventory,
  #decom-altar-list,
  .status-effects-popup-list,
  #chronicle-toc-list,
  #chronicle-page-content,
  #mail-list,
  #trade-list {
    -webkit-overflow-scrolling: touch !important;
    /* 注意：不使用transform和will-change避免影响fixed定位 */
  }
}


/* --- Source: 02.-typography-fonts.css --- */
/* ==========================================
   02. Typography & Fonts (字体、排版与多语言)
   ========================================== */

/* --- 新增：系统设置面板的移动端响应式布局 --- */
@media (max-width: 768px) {

  /* 1. 让模态框适应手机屏幕宽度 */
  #settings-modal .modal-content {
    width: 95vw;
    /* 宽度占屏幕的95% */
    padding: 15px;
  }

  /* 2. 让每个设置项（标签+控件）垂直排列，而不是左右并排 */
  .setting-item {
    flex-direction: column;
    /* 核心：改为垂直方向布局 */
    align-items: flex-start;
    /* 左对齐 */
    gap: 10px;
    /* 增加标签和控件之间的垂直间距 */
  }

  /* 3. 让右侧的控件区域占满整个宽度 */
  .setting-control {
    width: 100%;
    flex-direction: column;
    /* 让内部控件也垂直排列 */
    align-items: stretch;
    /* 让内部控件拉伸以占满宽度 */
  }

  /* 4. 让下拉框、滑块等控件占满宽度，更易于点击 */
  #background-select,
  #font-select,
  input[type="range"].font-slider,
  .font-size-input {
    width: 100%;
    max-width: none;
    /* 移除最大宽度限制 */
  }

  .setting-control>div {
    width: 100%;
    /* 确保导入/删除按钮的容器也占满宽度 */
  }

}

/* 10种备选字体的CSS类 */
.font-noto-serif-sc {
  --main-font-family: var(--font-serif);
}

.font-zcool-kuaile {
  --main-font-family: var(--font-display);
}

.font-ma-shan-zheng {
  --main-font-family: var(--font-display);
}

.font-crimson-text {
  --main-font-family: 'Crimson Text', serif;
}

.font-lora {
  --main-font-family: 'Lora', serif;
}

.font-merriweather {
  --main-font-family: 'Merriweather', serif;
}

.font-playfair-display {
  --main-font-family: 'Playfair Display', serif;
}

.font-roboto-slab {
  --main-font-family: 'Roboto Slab', serif;
}

.font-spectral {
  --main-font-family: 'Spectral', serif;
}

.font-eb-garamond {
  --main-font-family: 'EB Garamond', serif;
}

/* --- 现代标准系列 --- */
.font-noto-serif { font-family: 'Noto Serif SC', serif; }
.font-noto-sans { font-family: 'Noto Sans SC', sans-serif; }

/* --- 艺术与书法系列 --- */
.font-ma-shan-zheng { font-family: 'Ma Shan Zheng', cursive; }
.font-zhi-mang-xing { font-family: 'Zhi Mang Xing', cursive; }
.font-liu-jian-mao-cao { font-family: 'Liu Jian Mao Cao', cursive; }
.font-long-cang { font-family: 'Long Cang', cursive; }
.font-zcool-xiaowei { font-family: 'ZCOOL XiaoWei', serif; }
.font-zcool-kuaile { font-family: 'ZCOOL KuaiLe', cursive; }
.font-zcool-qingke { font-family: 'ZCOOL QingKe HuangYou', cursive; }

/* 美化正文内插入的图片*/
#game-text-display img {
  max-width: 100%;
  /* 核心修复：确保图片的最大宽度不会超过其容器（也就是正文框）的宽度 */
  height: auto;
  /* 核心修复：让图片的高度自动缩放，以保持其原始的宽高比，防止拉伸变形 */
  border-radius: 6px;
  /* 美化：为图片添加圆角，使其与UI的卡片风格更协调 */
  margin: 15px 0;
  /* 美化：在图片的上下增加15像素的间距，使其与文字段落分开，不显得拥挤 */
  box-shadow: 0 4px 12px var(--overlay-base);
  /* 美化：为图片添加深色阴影，使其看起来有悬浮感和立体感 */
  display: block;
  /* 确保图片独占一行，避免文字环绕在图片周围，排版更整洁 */
}

/* 字体大小滑块样式 */
input[type="range"].font-slider {
  -webkit-appearance: none;
  appearance: none;
  width: 200px;
  height: 6px;
  background: var(--bg-base);
  border-radius: 3px;
  border: 1px solid var(--color-secondary);
  outline: none;
  transition: opacity .2s;
}

input[type="range"].font-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 16px;
  height: 16px;
  background: var(--color-primary);
  cursor: pointer;
  border-radius: 50%;
  border: 2px solid var(--color-border-dark);
  box-shadow: 0 0 5px rgba(var(--rgb-primary), 0.8);
  background-image: radial-gradient(circle, transparent 4px, var(--color-border-dark) 4px);
}

input[type="range"].font-slider::-moz-range-thumb {
  width: 16px;
  height: 16px;
  background: var(--text-subtle);
  cursor: pointer;
  border-radius: 50%;
  border: 2px solid var(--bg-base);
  box-shadow: 0 0 5px rgba(var(--rgb-text-subtle), 0.5);
}



/* =================================================================
   神秘学体系：序列与位阶发光特效库
================================================================= */

/* 1. 基础文字渐变与动画类 */
.text-gradient-glow {
  font-family: var(--font-serif); /* 接入我们之前配好的高级字体 */
  display: inline-block;
  background-size: 200% auto;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent; /* 兼容 */
  transition: all 0.3s ease;
  font-weight: bold;
}

/* 补充定义的传奇呼吸动画 (Ethereal Pulse) */
@keyframes ethereal-pulse {
  0% { filter: brightness(1) drop-shadow(0 0 2px rgba(255,255,255,0.2)); }
  50% { filter: brightness(1.3) drop-shadow(0 0 8px rgba(255,255,255,0.6)); }
  100% { filter: brightness(1) drop-shadow(0 0 2px rgba(255,255,255,0.2)); }
}

.anim-pulse {
  animation: ethereal-pulse 3s infinite ease-in-out;
}

/* --- 2. 顶配序列特效 (Highest Tiers) --- */
.tier-pillar {
  background-image: linear-gradient(45deg, #FFFFFF 0%, #FFD700 20%, #87CEEB 40%, #FF69B4 60%, #FFD700 80%, #FFFFFF 100%);
  background-size: 300% auto;
  text-shadow: 0 0 20px rgba(255, 255, 255, 0.8), 0 0 40px rgba(255, 215, 0, 0.6);
  font-weight: 900;
  letter-spacing: 1px;
  animation: ethereal-pulse 3s infinite ease-in-out;
}
.tier-outer-god {
  background-image: linear-gradient(45deg, #4B0082,  #00CED1, #00d1ce);
  text-shadow: 0 0 15px rgba(138, 43, 226, 0.8), 0 0 30px rgba(75, 0, 130, 0.6);
  font-weight: 900;
  letter-spacing: 1px;
  animation: ethereal-pulse 3s infinite ease-in-out;
}
.tier-seq-0 {
  background-image: linear-gradient(135deg, #FFF5E1 0%, #FFD700 25%, #D8BFFF 50%, #FFD700 75%, #FFF5E1 100%);
  text-shadow: 0 0 12px rgba(216, 191, 255, 0.8), 0 0 25px rgba(255, 215, 0, 0.5);
  animation: ethereal-pulse 3s infinite ease-in-out;
}

/* --- 3. 天使/半神级别特效 (Demigod Tiers) --- */
.tier-angel-high { /* 0.3 - 0.8 */
  background-image: linear-gradient(90deg, #C71585, #D8BFFF, #E0BFFF);
  text-shadow: 0 0 10px rgba(216, 191, 255, 0.8), 0 0 20px rgba(199, 21, 133, 0.5);
}
.tier-seq-1 { /* 0.9 - 1 */
  background-image: linear-gradient(90deg, #B22222, #C71585, #E0BFFF);
  text-shadow: 0 0 10px rgba(224, 191, 255, 0.8), 0 0 20px rgba(178, 34, 34, 0.5);
}
.tier-seq-2 {
  background-image: linear-gradient(90deg, #FFD700, #FFC0CB, #FF69B4);
  text-shadow: 0 0 10px rgba(255, 192, 203, 0.8), 0 0 20px rgba(255, 215, 0, 0.5);
}

/* --- 4. 中高序列特效 (Mid-High Tiers) --- */
.tier-seq-3 {
  background-image: linear-gradient(90deg, #FFA500, #FFC145, #FFD700);
  text-shadow: 0 0 6px rgba(255, 193, 69, 0.8), 0 0 10px rgba(255, 165, 0, 0.5);
}
.tier-seq-4 {
  background-image: linear-gradient(90deg, #B22222, #DC143C, #FFA500);
  text-shadow: 0 0 6px rgba(220, 20, 60, 0.8), 0 0 10px rgba(178, 34, 34, 0.5);
}
.tier-seq-5 {
  background-image: linear-gradient(90deg, #483D8B, #800080, #FF69B4);
  text-shadow: 0 0 6px rgba(128, 0, 128, 0.6);
}
.tier-seq-6 {
  background-image: linear-gradient(90deg, #2F4F4F, #3CB371, #48D1CC);
  text-shadow: 0 0 6px rgba(60, 179, 113, 0.6);
}
.tier-seq-7 {
  background-image: linear-gradient(90deg, #5FB8E6, #7A85D9, #6A5ACD);
  text-shadow: 0 0 6px rgba(122, 133, 217, 0.6);
}

/* --- 5. 低序列特效 (Low Tiers) --- */
.tier-seq-8 {
  background-image: linear-gradient(90deg, #B0E2FF, #87CEEB, #5FB8E6);
  text-shadow: 0 0 4px rgba(135, 206, 235, 0.5);
}
.tier-seq-9 {
  background-image: linear-gradient(90deg, #F9E6C8, #F5DEB3, #F0D59E);
  text-shadow: 0 0 4px rgba(245, 222, 179, 0.5);
}
.tier-default {
  color: var(--text-muted); /* 接入系统黯淡色 */
}

/* =================================================================
   物品/人物稀有度 (Rarity Colors)
================================================================= */
.rarity-normal { color: var(--text-muted); }
.rarity-uncommon {
  background-image: linear-gradient(90deg, #B0E2FF 0%, #87CEEB 50%, #5FB8E6 100%);
  text-shadow: 0 0 5px rgba(135, 206, 235, 0.6);
}
.rarity-rare {
  background-image: linear-gradient(90deg, #483D8B 0%, #800080 50%, #FF69B4 100%);
  text-shadow: 0 0 5px rgba(128, 0, 128, 0.6);
}
.rarity-epic {
  background-image: linear-gradient(90deg, #FFA500 0%, #FFC145 50%, #FFD700 100%);
  text-shadow: 0 0 5px rgba(255, 193, 69, 0.6);
}
.rarity-legendary {
  background-image: linear-gradient(90deg, #FFD700 0%, #FFC0CB 50%, #FF69B4 100%);
  text-shadow: 0 0 8px rgba(255, 192, 203, 0.8), 0 0 12px rgba(255, 105, 180, 0.5);
}
.rarity-mythic {
  background-image: linear-gradient(90deg, #B22222 0%, #C71585 50%, #E0BFFF 100%);
  text-shadow: 0 0 8px rgba(199, 21, 133, 0.8), 0 0 12px rgba(178, 34, 34, 0.5);
}
.rarity-unique {
  background-image: linear-gradient(90deg, #E6E6FA, #D8BFD8, #DDA0DD);
  text-shadow: 0 0 8px rgba(216, 191, 216, 0.8), 0 0 12px rgba(221, 160, 221, 0.5);
}

/* =================================================================
   🔮 亮色模式专属：魔法墨水序列特效 (覆盖暗色模式的荧光)
   只有在 html 挂载 data-theme="light" 时才会生效！
================================================================= */

/* 1. 将外发光变为锐利的实体投影，提升在白底上的可读性 */
[data-theme="light"] .text-gradient-glow {
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15) !important;
  font-weight: 900;
}

/* 2. 顶配序列：由亮白金转为深紫金 */
[data-theme="light"] .tier-pillar { background-image: linear-gradient(45deg, #4B0082, #B8860B, #8B0000, #000080); }
[data-theme="light"] .tier-outer-god { background-image: linear-gradient(45deg, #2A0052, #004d40); }
[data-theme="light"] .tier-seq-0 { background-image: linear-gradient(135deg, #8B6508 0%, #B8860B 50%, #4B0082 100%); }

/* 3. 天使/半神级别：由浅粉/浅紫转为深血红/暗紫 */
[data-theme="light"] .tier-angel-high { background-image: linear-gradient(90deg, #800080, #4B0082, #8B008B); }
[data-theme="light"] .tier-seq-1 { background-image: linear-gradient(90deg, #8B0000, #800080, #4B0082); }
[data-theme="light"] .tier-seq-2 { background-image: linear-gradient(90deg, #B8860B, #8B0000, #C71585); }

/* 4. 中高序列：由明黄/橙色转为焦茶/深橙 */
[data-theme="light"] .tier-seq-3 { background-image: linear-gradient(90deg, #A0522D, #D2691E, #8B4513); }
[data-theme="light"] .tier-seq-4 { background-image: linear-gradient(90deg, #8B0000, #A52A2A, #8B4513); }
[data-theme="light"] .tier-seq-5 { background-image: linear-gradient(90deg, #2F4F4F, #4B0082, #800080); }
[data-theme="light"] .tier-seq-6 { background-image: linear-gradient(90deg, #004d40, #2E8B57, #006400); }
[data-theme="light"] .tier-seq-7 { background-image: linear-gradient(90deg, #005A9C, #483D8B, #27408B); }

/* 5. 低序列：由浅蓝/浅米转为深蓝/深褐 */
[data-theme="light"] .tier-seq-8 { background-image: linear-gradient(90deg, #00688B, #4682B4, #005A9C); }
[data-theme="light"] .tier-seq-9 { background-image: linear-gradient(90deg, #8B6508, #A0522D, #8B4513); }

/* 6. 稀有度标签同步压暗 */
[data-theme="light"] .rarity-uncommon { background-image: linear-gradient(90deg, #00688B, #4682B4); }
[data-theme="light"] .rarity-rare { background-image: linear-gradient(90deg, #4B0082, #800080); }
[data-theme="light"] .rarity-epic { background-image: linear-gradient(90deg, #8B4513, #D2691E); }
[data-theme="light"] .rarity-legendary { background-image: linear-gradient(90deg, #B8860B, #8B0000); }
[data-theme="light"] .rarity-mythic { background-image: linear-gradient(90deg, #8B0000, #800080); }
[data-theme="light"] .rarity-unique { background-image: linear-gradient(90deg, #2A0052, #4B0082); }

/* --- Source: 03.-settings-appearance.css --- */
/* ==========================================
   03. Settings & Appearance (设置、外观与主题)
   ========================================== */

#font-select,
#camp-select {
  max-width: 200px;
  background: rgba(var(--rgb-panel-dark), 0.8);
  border: 1px solid var(--color-secondary);
  color: var(--text-muted);
  border-radius: 4px;
  padding: 4px 8px;
}

/* --- 新增：系统设置面板样式 --- */
.settings-container {
  display: flex;
  flex-direction: column;
  gap: 20px;
  padding: 10px 5px;
  min-width: 0;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid rgba(var(--rgb-secondary), 0.2);
  width: 100%;      /* 强制占满 panel-section 的宽度 */
  box-sizing: border-box;
  overflow: hidden;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: var(--text-base);
  color: var(--text-subtle);
}

.setting-control {
  display: flex;
  align-items: center;
  gap: 15px;
  flex: 1;        /* 占据除了 label 之外的所有剩余空间 */
  min-width: 0;     /* 极其重要：允许 flex 子元素收缩到比内容小 */
  justify-content: flex-end; /* 让输入框和开关保持靠右 */
}


/* 开关按钮 (Toggle Switch) 样式 */
.switch {
  position: relative;
  display: inline-block;
  width: 50px;
  height: 26px;
}

.switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  box-sizing: border-box;
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--bg-base);
  border: 3px solid var(--color-border-dark);
  -webkit-transition: .4s;
  transition: .4s;
  border-radius: 34px;
}

/* 只需要修改这一个地方 */
input:checked + .slider:before {
  background-color: var(--text-main);
  /* 移动距离改为 24px */
  transform: translateX(24px) scale(1.1);
}

/* 建议同步优化 .slider:before 的定位，确保垂直方向也完美居中 */
.slider:before {
  position: absolute;
  content: "";
  height: 16px;
  width: 16px;
  /* 内部高度是 26 - 3 - 3 = 20px */
  /* 滑块 16px，上下各留 2px 刚好居中 */
  left: 2px;
  bottom: 2px;
  background-color: var(--text-muted);
  transition: .4s;
  border-radius: 50%;
  transition: transform 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55), background-color 0.3s;
}


input:checked+.slider {
  background-color: rgba(var(--rgb-secondary), 0.8)
}


/* --- Source: 04.-character-attributes.css --- */
/* ==========================================
   04. Character & Attributes (角色、装备、属性、序列能力列表)
   ========================================== */

/* --- 移动端布局默认优化 --- */

.mobile-view .interaction-panel {
  flex-shrink: 0;
  max-height: 30vh;
  /* 限制顶部和交互面板的最大高度为屏幕的30% */
  overflow-y: auto;
  /* 超出部分可滚动 */
}

/* --- 各面板样式 (美化第三步) --- */
.character-panel,
.interaction-panel {
  padding: 10px;
  overflow-y: auto;
  /* 🔥 性能优化：添加硬件加速（不使用transform避免影响子元素定位） */
  -webkit-overflow-scrolling: touch;
  will-change: scroll-position;
  background: linear-gradient(145deg, rgba(var(--rgb-panel-dark), 0.95) 0%, rgba(var(--rgb-panel-dark), 0.95) 100%);
  border: 1px solid rgba(var(--rgb-secondary), 0.3);
  border-radius: 12px 0 0 12px;
  position: relative;
  box-shadow: inset 0 1px 0 rgba(var(--rgb-white), 0.05), 0 4px 12px var(--overlay-light);
  backdrop-filter: blur(2px);
}

.character-panel::before,
.interaction-panel::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--color-secondary), var(--color-primary), var(--color-secondary));
  box-shadow: 0 2px 3px var(--overlay-base);
}

.character-panel {
  border-right: none;
}

.equipment-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  /* 新增：设置容器类型 */
  container-type: inline-size;
  container-name: equipment;
}

/* 3. 美化装备槽 */
.equipment-slot {
  aspect-ratio: 1;
  background: linear-gradient(135deg, var(--overlay-base) 0%, rgba(var(--rgb-panel-dark), 0.6) 100%);
  border: 2px solid rgba(var(--rgb-secondary), 0.4);
  border-radius: 10px;
  box-shadow: inset 0 2px 6px var(--overlay-base), 0 2px 4px var(--overlay-light);
  /* --- 核心修复：增强居中控制 --- */
  display: flex !important;
  /* 使用 !important 防止被 JS 的 inline style 意外覆盖 */
  align-items: center;
  /* 垂直居中 */
  justify-content: center;
  /* 水平居中 */
  text-align: center;
  /* 关键：确保多行文本在内部也是居中的 */
  padding: 4px;
  /* 增加内边距，防止长名称贴边 */
  box-sizing: border-box;
  /* 确保 padding 不撑大盒子 */
  line-height: 1.2;
  /* 控制行高，防止文字垂直偏移过多 */
  word-break: break-all;
  /* 允许长单词换行 */
  font-size: clamp(10px, 8cqw, 20px);
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}
.equipment-slot::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(var(--rgb-primary), 0.1) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.equipment-slot:hover::before {
  opacity: 1;
}

.equipment-slot:hover {
  border-color: var(--color-primary);
  transform: translateY(-2px) scale(1.02);
  box-shadow: inset 0 2px 6px var(--overlay-base), 0 4px 12px rgba(var(--rgb-primary), 0.3);
}

.equipment-slot.equipped {
  /* 确保已装备状态依然保持 flex 布局 */
  display: flex !important;
  border-color: var(--color-primary);
  border-width: 2px;
  color: var(--text-main);
  font-size: var(--text-sm);
  font-weight: 600;
  background: linear-gradient(135deg, rgba(var(--rgb-secondary), 0.3) 0%, rgba(var(--rgb-border-dark), 0.3) 100%);
  box-shadow: inset 0 0 12px rgba(var(--rgb-primary), 0.3), 0 0 16px rgba(var(--rgb-primary), 0.4), 0 4px 8px rgba(var(--rgb-bg-dark), 0.4);
  animation: equip-glow 2s ease-in-out infinite;
}

/* ================= 补充提取的档案辅助类 ================= */
.attribute-row-col { flex-direction: column; align-items: flex-start; gap: 5px; }
.attribute-value-desc { font-size: var(--text-sm); color: var(--text-muted); word-wrap: break-word; white-space: normal; width: 100%; }
.attribute-value-sm { font-size: var(--text-sm); font-weight: normal; }
.camp-resource-item { font-size: var(--text-sm); color: var(--text-muted); margin-top: 3px; }
.w-full { width: 100%; }

/* ================= 物品详情与排版优化 (已修复硬编码颜色) ================= */

/* 去除详情部分多余的边距 */
.item-details-content { margin-top: 10px; padding-top: 10px; border-top: 1px dashed rgba(var(--rgb-border-dark), 0.3); }

/* 属性合集条 (Stats Row) */
.stats-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }
.stats-row span { font-size: var(--text-sm); padding: 3px 8px; border-radius: 4px; background: rgba(var(--rgb-bg-dark), 0.2); border: 1px solid rgba(var(--rgb-border-dark), 0.2); display: inline-flex; align-items: center; white-space: nowrap; }

/* 消耗品特有高亮 */
.stats-row .stat-highlight.target-attr { color: var(--color-info); border-left: 2px solid var(--color-info); background: rgba(var(--rgb-info), 0.1); }
.stats-row .stat-highlight.dmg-bonus { color: var(--color-danger); border-left: 2px solid var(--color-danger); background: rgba(var(--rgb-danger), 0.1); }

/* 常规属性与百分比 */
.stats-row .stat-core { color: var(--text-muted); }
.stats-row .stat-core strong { color: var(--text-muted); margin-right: 4px; font-weight: normal; }
.stats-row .stat-percent { color: var(--color-success); border-color: rgba(var(--rgb-success), 0.3); }
.stats-row .stat-percent strong { color: var(--text-muted); margin-right: 4px; font-weight: normal; }

/* 副作用面板 (克制、低调) */
.side-effect-panel { background: rgba(var(--rgb-danger), 0.05); border: 1px solid rgba(var(--rgb-danger), 0.3); border-radius: 6px; padding: 8px 12px; margin-top: 8px; box-shadow: inset 0 0 10px var(--overlay-light); }
.side-effect-header { font-size: var(--text-sm); color: var(--color-danger); margin-bottom: 4px; font-weight: 600; letter-spacing: 1px; }
.side-effect-content { font-size: var(--text-base); color: var(--text-main); display: flex; flex-direction: column; }

.extra-attr-line { margin-bottom: 2px; }
.extra-attr-key { color: var(--text-muted); }
.extra-attr-val { color: var(--text-main); }

/* 分别定义色彩：低饱和度风格 */
/* --- 修复标签背景裁剪问题的新类 --- */
.tier-tag-box {
  border: 1px solid rgba(var(--rgb-border-dark), 0.6);
  background: var(--overlay-light); /* 极淡的暗色底 */
  display: inline-flex;
  align-items: center;
  justify-content: center;
  /* 取消内部 padding，因为 .item-tag 已经有了 */
}

/* 顺便修复一下特质前缀，它没有背景框，直接发光即可 */
.item-trait-prefix {
  font-weight: 900;
  letter-spacing: 1px;
  margin-right: 4px;
}

.pathway-tag { border: 1px solid rgba(var(--rgb-info), 0.3); color: var(--color-info); background: rgba(var(--rgb-info), 0.15); }

/* --- 细节折叠面板 --- */
.details-container { margin-bottom: 5px; }
.details-container summary { cursor: pointer; display: flex; justify-content: flex-start; align-items: flex-start; font-size: var(--text-sm); list-style: none; padding: 4px 0; transition: all 0.2s; gap: 10px; }
.details-container summary .attribute-name { flex-shrink: 0; }
.details-container summary .attribute-value { flex-shrink: 1; text-align: left; min-width: 0; }
.details-container summary:hover { color: var(--text-main); }
.details-container summary::-webkit-details-marker { display: none; }
.details-content { padding: 10px; margin-top: 5px; font-size: var(--text-xs); background: var(--overlay-light); border-radius: 4px; border-top: 1px solid rgba(var(--rgb-secondary), 0.3); color: var(--text-muted); }
.details-content p { margin-bottom: 4px; }

.number {
  font-size: clamp(10px, 8cqw, var(--text-base)) !important;
  white-space: nowrap !important;
}

/* --- 属性行垂直/多行排列辅助 --- */
.attr-item-col {
  flex-direction: column;
  align-items: flex-start;
  gap: 4px;
}
.attr-row-between {
  display: flex;
  justify-content: space-between;
  width: 100%;
  align-items: center;
}

/* --- 进度条 --- */
.attr-progress-wrapper {
  width: 100%;
}
.attribute-progress-bar {
  width: 100%;
  height: 6px;
  background: var(--overlay-base);
  border-radius: 3px;
  overflow: hidden;
  border: 1px solid rgba(var(--rgb-secondary), 0.3);
}
.attribute-progress-fill {
  height: 100%;
  transition: width 0.3s ease;
  border-radius: 3px;
}
.attribute-progress-fill.high {
  background: linear-gradient(
    90deg,
    var(--color-success) 0%,
    #a8d08d 100%
  );
}

/* --- 阵营属性多行/长文本修饰 --- */
.attr-label-mb {
  margin-bottom: 5px;
}
.attr-val-multiline {
  color: var(--text-subtle);
  text-shadow: 0 0 2px rgba(var(--rgb-primary), 0.3);
  white-space: normal;
  word-wrap: break-word;
  width: 100%;
  font-weight: normal !important;
}


/* ------------------ 其他部分保留你的原代码，但修复底色 ------------------ */

/* 修复：角色详情模态框底色支持亮暗模式 */
#character-details-modal .modal-content {
  background: var(--bg-panel);
  border: 1px solid var(--color-border-dark);
  box-shadow: inset 0 0 40px var(--overlay-light); /* 用内阴影替代原来的硬编码 radial-gradient */
}
/* 新增：属性进度条容器 */
.attribute-progress-container {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-grow: 1;
}

/* 新增：属性进度条 */
.attribute-progress-bar {
  flex-grow: 1;
  height: 6px;
  background: var(--overlay-base);
  border-radius: 10px;
  border: 1px solid rgba(var(--rgb-secondary), 0.3);
  overflow: hidden;
  position: relative;
}

.attribute-progress-bar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to bottom, rgba(var(--rgb-white), 0.1), transparent);
  border-radius: 10px 10px 0 0;
}

.attribute-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-secondary) 0%, var(--color-primary) 50%, var(--text-main) 100%);
  border-radius: 8px;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  box-shadow: inset 0 1px 2px rgba(var(--rgb-white), 0.3), 0 0 8px rgba(var(--rgb-primary), 0.4);
}

.attribute-progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(var(--rgb-white), 0.4), transparent);
  animation: progress-shimmer 2s infinite;
}

/* 低值警告色 */
.attribute-progress-fill.low {
  background: linear-gradient(90deg, var(--color-danger-dark) 0%, var(--color-danger) 50%, var(--color-danger) 100%);
}

/* 中等值 */
.attribute-progress-fill.medium {
  background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-primary) 50%, var(--text-subtle) 100%);
}

/* 高值 */
.attribute-progress-fill.high {
  background: linear-gradient(90deg, var(--color-success) 0%, var(--color-success) 50%, var(--color-success) 100%);
}

#character-details-modal .attribute-item {
  border-bottom: 1px solid rgba(var(--rgb-secondary), 0.1);
}

/* --- 档案详情现代化Grid布局 --- */
.details-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  padding: 15px;
}

.details-card {
  background: var(--overlay-light);
  border: 1px solid rgba(var(--rgb-secondary), 0.4);
  border-radius: 8px;
  padding: 15px;
  box-shadow: 0 2px 8px var(--overlay-light);
  transition: all 0.3s ease;
}

.details-card:hover {
  border-color: rgba(var(--rgb-primary), 0.6);
  box-shadow: 0 4px 12px rgba(var(--rgb-primary), 0.2);
  transform: translateY(-2px);
}

.details-card-title {
  font-size: var(--text-lg);
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 15px;
  padding-bottom: 10px;
  border-bottom: 2px solid rgba(var(--rgb-primary), 0.3);
  display: flex;
  align-items: center;
  gap: 8px;
}

.details-card-title::before {
  content: '◆';
  color: var(--color-primary);
  font-size: var(--text-base);
}

.details-card-full {
