  font-weight: bold;
  font-size: var(--text-base);
  text-shadow: 0 1px 2px var(--overlay-light);
  flex: 0 0 auto;
  word-wrap: break-word;
  word-break: break-word;
  overflow-wrap: break-word;
  max-width: 100%;
  white-space: normal;
}


.attribute-value-wrapper {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1 1 auto;
  /* 占据剩余空间 */
  flex-wrap: wrap;
  /* 允许换行 */
  min-width: 0;
  /* 允许收缩 */
}

.attribute-value {
  color: var(--text-main);
  font-weight: bold;
  font-size: var(--text-base);
  flex: 0 0 auto;
  /* 不伸缩 */
}

/* 进度条样式 */
.attribute-progress {
  flex: 1 1 100%;
  /* 占满整行 */
  width: 100%;
  /* 确保占满宽度 */
