}

/* 新增：入场动画 */
@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 新增：出场动画 */
@keyframes fadeOutUp {
  from {
    opacity: 1;
    transform: translateY(0);
  }

  to {
    opacity: 0;
    transform: translateY(-20px);
  }
}

@keyframes new-tag-pop {
  0% {
    transform: scale(0) translateX(-100%);
  }

  80% {
    transform: scale(1.1) translateX(0);
  }

  100% {
    transform: scale(1.0) translateX(0);
  }
}

@keyframes ssr-glow {
  from {
    box-shadow: 0 0 12px var(--color-primary), inset 0 0 5px rgba(var(--rgb-primary), 0.3);
  }

  to {
    box-shadow: 0 0 25px var(--color-primary), 0 0 10px white, inset 0 0 10px rgba(var(--rgb-primary), 0.5);
  }
}

/* ========================================
   1. 沉浸式编辑器：终极无界融合样式
   ======================================== */
#immersive-editor-container {
  background: transparent;
  animation: fadeIn 0.3s ease;
  padding-bottom: 50px;
  /* 底部留白，方便滚动到底部 */
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes tooltipFadeIn {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(5px);
  }

  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {

  0%,
  100% {
    transform: scale(1);
  }

  50% {
    transform: scale(1.1);
    color: var(--color-primary);
  }
}

/* --- 新增：状态效果弹出窗口样式 (已适配主题色) --- */
@keyframes slideUpFadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* --- 美化版：选项浮窗样式 --- */
@keyframes slideUpFadeIn {
  from {
    opacity: 0;
    transform: translateY(15px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

