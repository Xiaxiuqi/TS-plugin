  gap: 20px;
  padding: 8px;
}

/* 能力清单容器样式 */
.relationship-abilities {
  margin: 10px 0;
  padding: 8px 12px;
  background-color: rgba(var(--rgb-panel-dark), 0.3);
  border-radius: 4px;
}
/* 能力清单标题样式 */
.relationship-abilities strong {
  color: var(--text-muted);
  font-size: var(--text-base);
  margin-right: 6px;
}
/* 能力清单内容样式 */
.abilities-list {
  color: var(--text-subtle);
  font-size: var(--text-sm);
  line-height: 1.5;
  white-space: normal;
}
/* 能力项前缀符号 */
.abilities-list::before {
  content: "• ";
  opacity: 0.7;
}

/* 新增：信息卡片网格布局 */
.relationship-info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin: 12px 0;
}

.relationship-info-item {
  background: rgba(var(--rgb-bg-dark), 0.25);
  padding: 10px 12px;
  border-radius: 6px;
  border: 1px solid rgba(var(--rgb-secondary), 0.2);
}

.relationship-info-item strong {
  display: block;
  color: var(--text-subtle);
  font-size: var(--text-sm);
  margin-bottom: 4px;
  font-weight: 600;
}

.relationship-info-item span {
  color: var(--text-highlight);
  font-size: var(--text-base);
  line-height: 1.5;
  word-break: break-word;
}

/* 属性显示优化 */
.relationship-stats-enhanced {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin: 12px 0;
  background: rgba(var(--rgb-bg-dark), 0.2);
  border-radius: 6px;
}

.stat-item-enhanced {
  text-align: center;
  padding: 8px;
  background: rgba(var(--rgb-secondary), 0.15);
  border-radius: 4px;
}

.stat-item-enhanced .stat-label {
  display: block;
  font-size: var(--text-xs);
  color: var(--text-muted);
  margin-bottom: 4px;
}

.stat-item-enhanced .stat-value {
  display: block;
  font-size: var(--text-base);
  font-weight: bold;
  color: var(--text-main);
}

.stat-item-enhanced .stat-current {
  color: var(--text-scenery)
}

.stat-item-enhanced .stat-max {
