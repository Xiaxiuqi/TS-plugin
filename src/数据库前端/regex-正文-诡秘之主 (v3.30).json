}

/* 属性项样式 */
.attribute-row {
  display: flex;
  flex-wrap: wrap;
  /* 允许换行 */
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px dashed rgba(var(--rgb-secondary), 0.2);
  gap: 8px;
  /* 添加间距 */
}

.attribute-row:last-child {
  border-bottom: none;
}

.attribute-label {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--text-subtle);
  font-size: var(--text-base);
  flex: 0 0 auto;
  /* 不伸缩 */
}

.attribute-icon {
  font-size: var(--text-md);
}

/* 属性行通用样式 */
.attribute-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--text-sm);
  padding: 8px;
  border-radius: 6px;
  transition: all 0.2s ease;
  border-bottom: 1px solid rgba(var(--rgb-secondary), 0.1);
  gap: 10px;
