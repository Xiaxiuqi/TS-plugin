    modal.innerHTML = /* HTML */ `
      <div class="re-sidebar">
        <div class="re-sidebar-header">
          <span class="re-sidebar-title">🎲 随机事件库</span>
          <button
            class="interaction-btn"
            data-action="add-entry"
          >
            新建
          </button>
