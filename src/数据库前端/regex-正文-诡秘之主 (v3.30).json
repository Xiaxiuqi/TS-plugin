  <script src="https://cdn.jsdelivr.net/npm/lodash@4.17.21/lodash.min.js"></script>
  <style>
    /* 类脑Gouy古弈作品，基于原作者梦星、起物修改，禁止二传，禁止商业化，均无偿免费开源分享 */
    /* --- 新增：导入自定义字体 --- */
@import url('https://fonts.googleapis.com/css2?family=ZCOOL+KuaiLe&family=Ma+Shan+Zheng&family=Cormorant+Garamond:ital@1&family=Crimson+Text&family=Lora&family=Merriweather&family=Playfair+Display&family=Roboto+Slab&family=Spectral:wght@300&family=EB+Garamond&display=swap');

