  height: auto;
}

/* =================================================================
   调查员档案 (Character Panel) & 阵营卡片 优化样式
================================================================= */

/* --- 标题栏定位辅助 --- */
.title-flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}
.btn-absolute-right {
