/* ==========================================
   14. World & Map (世界地图、阵营与地标)
   ========================================== */

.astrolabe-container {
  position: relative;
  width: 250px;
  height: 250px;
  margin-bottom: 20px;
}

.astrolabe-ring {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  border-style: solid;
  mix-blend-mode: screen;
  /* 混合模式让光环效果更佳 */
}

/* 阵营名称：亮金+轻微发光（更显眼） */
.camp-name-highlight {
  color: var(--color-primary);
  /* 亮金色 */
  font-weight: bold;
  text-shadow: 0 0 3px rgba(var(--rgb-primary), 0.5);
  /* 轻量发光，不占性能 */
