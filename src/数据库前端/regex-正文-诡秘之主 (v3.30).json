  /* 平滑过渡，无渲染压力 */
}

.camp-name-highlight:hover {
  text-shadow: 0 0 5px rgba(var(--rgb-primary), 0.7);
  /* hover时增强一点，不卡顿 */
}

/* 职位：亚金+细阴影（次要突出） */
.camp-position-highlight {
  color: var(--text-main);
  /* 亚金色（比亮金稍暗） */
