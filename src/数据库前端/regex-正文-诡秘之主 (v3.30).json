.btn-sm-auto { padding: 6px 12px; font-size: var(--text-sm); }

/* =================================================================
   3. AI 变量更新面板 (Variable Panel)
================================================================= */
.ai-var-panel { border: 1px solid var(--text-muted); border-radius: 15px; padding: 12px; margin: 10px 0; background: var(--bg-base); }
.ai-var-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
