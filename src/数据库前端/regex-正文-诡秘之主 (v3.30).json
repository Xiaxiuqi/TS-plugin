  color: var(--text-subtle);
  background: rgba(var(--rgb-border-dark), 0.7);
  padding: 4px 8px;
  border-radius: 6px;
  white-space: nowrap;
  box-shadow: 0 1px 3px rgba(var(--rgb-bg-dark), 0.2);
}

.item-quantity {
  color: var(--color-success);
}

/* 按钮样式：现代化圆角+过渡 */
.item-actions {
  display: flex;
  gap: 8px;
  margin-top: 4px;
}

.item-actions button {
  padding: 6px 12px;
  border: none;
  border-radius: 6px;
  color: var(--text-muted);
  /* 文字保持浅色对比 */
  font-size: var(--text-sm);
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  box-shadow: 0 2px 4px rgba(var(--rgb-bg-dark), 0.2);
}

.item-actions button:hover {
  background: var(--color-border-dark);
  transform: translateY(-1px);
  box-shadow: 0 3px 6px var(--overlay-light);
}

.item-actions button:active {
  transform: translateY(0);
}

/* 空分类文本：更柔和 */
.empty-category-text {
  padding: 20px;
  text-align: center;
  color: var(--text-muted);
  background: rgba(var(--rgb-panel-dark), 0.6);
  border-radius: 8px;
}

.tag-item {
  font-size: var(--text-xs);
  padding: 3px 8px;
  background: rgba(var(--rgb-primary), 0.15);
  border: 1px solid rgba(var(--rgb-primary), 0.3);
  color: var(--color-primary);
  border-radius: 10px;
}


/* ================= 手机端终极适配 ================= */
@media (max-width: 768px) {
  .inventory-item {
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
    padding: 12px 14px;
  }

  /* 核心修复 1：底部栏改为上下两行布局 */
  .item-bottom-bar {
    flex-direction: column;
    /* 强制纵向排布：标签在上，按钮在下 */
    align-items: flex-start;
    /* 整体贴左 */
    gap: 12px;
    /* 标签和按钮之间的上下间距 */
    margin-top: 10px;
  }

  /* 核心修复 2：上方的胶囊标签确保从左到右横向排列 */
  .item-tags-container {
    width: 100%;
    justify-content: flex-start;
    /* 靠左排列 */
    /* 继承了桌面端的 flex-wrap: wrap，超长会自动换行，不会超出屏幕 */
  }

  /* 核心修复 3：下方的按钮区域占满整行，并将按钮死死推向右侧 */
  .item-meta {
    flex-direction: row;
    /* 强制横向 */
    align-items: center;
    justify-content: flex-end;
    /* 绝对靠右对齐 */
    width: 100%;
  }

  /* 确保按钮组本身的布局在移动端也保持紧凑 */
  .item-actions {
    margin-top: 0;
    justify-content: flex-end;
    flex-wrap: wrap;
    /* 如果按钮极多，允许在右侧内部换行 */
  }

  /* 头部标题稍作微调 */
  .item-name {
    font-size: var(--text-md);
  }

  /* 移动端的额外属性字体稍微调大一点保证可读性 */
  .extra-attrs-container,
  .item-details {
    font-size: var(--text-base);
  }

  /* 移动端字体整体微调，确保不费眼 */
  .item-description {
    font-size: var(--text-base);
    /* 手机屏幕上再稍微放大一点点 */
    line-height: 1.65;
  }
}

/* --- Source: 16.-loading-overlays.css --- */
/* ==========================================
   16. Loading & Overlays (加载界面与雾效)
   ========================================== */

/* --- 修改：置顶悬浮加载提示条样式 (美化版) --- */
.loading-indicator-bar {
  position: sticky;
  /* 如果你想让它完全贴紧顶部，无视父容器的 20px top-padding，可以将 top 改为 -20px */
  top: -20px;
  z-index: 5;
  padding: 15px 20px 25px;
  pointer-events: none;

  /* 核心修复：使用负边距抵消父容器的 padding */
  margin-top: -20px;   /* 抵消 .main-content 的 20px 上边距 */
  margin-left: -45px;  /* 抵消 .main-content 的 45px 左边距 */
  margin-right: -45px; /* 抵消 .main-content 的 45px 右边距 */
  margin-bottom: 10px;

  /* 原有的背景和其他样式保持不变 */
  background: linear-gradient(to bottom, rgba(var(--rgb-panel-dark), 0.9) 0%, rgba(var(--rgb-panel-dark), 0.75) 60%, rgba(var(--rgb-panel-dark), 0) 100%);
  border-bottom: 1px solid rgba(var(--rgb-secondary), 0.3);
  text-align: center;
  color: var(--text-subtle);
  font-size: var(--text-base);
  text-shadow: 0 0 8px rgba(var(--rgb-text-subtle), 0.5);
  display: none;
}

.loading-indicator-bar.fade-in {
  display: block;
  /* 先设为block才能播放动画 */
  animation: fadeInDown 0.4s ease-out forwards;
}

.loading-indicator-bar.fade-out {
  animation: fadeOutUp 0.4s ease-in forwards;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(var(--rgb-secondary), 0.2);
  border-top-color: var(--color-secondary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 16px;
  font-size: var(--text-base);
}


/* --- 全新的“灰雾”加载动画 --- */
.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
  min-height: 250px;
  /* 确保在空文本框中也有足够空间显示 */
}

.loading-fog {
  position: absolute;
  width: 250%;
  height: 250%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(var(--rgb-white), 0.25) 0%, rgba(var(--rgb-white), 0) 65%);
  border-radius: 50%;
  animation: fog-breath 8s infinite ease-in-out;
}

.loading-fog.fog-1 {
  animation-delay: 0s;
}

.loading-fog.fog-2 {
  animation-delay: -4s;
  transform: translate(-50%, -50%) scale(0.8);
}

.loading-text {
  position: relative;
  z-index: 2;
  font-family: var(--font-serif);
  font-size: var(--text-md);
  color: var(--text-subtle);
  text-shadow: 0 0 10px rgba(var(--rgb-bg-dark), 0.9), 0 0 15px rgba(var(--rgb-text-subtle), 0.5);
  padding: 0 20px;
  text-align: center;
  animation: text-fade-in 4s infinite ease-in-out;
}

/* --- 新增：星盘占卜加载动画样式 --- */
#loading-overlay {
  display: none;
  /* 默认隐藏 */
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(var(--rgb-panel-dark), 0.9);
  z-index: 9999;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  opacity: 0;
  transition: opacity 0.5s ease-in-out;
}

.ring-1 {
  width: 100%;
  height: 100%;
  border-width: 2px;
  border-color: rgba(var(--rgb-text-subtle), 0.5) transparent rgba(var(--rgb-text-subtle), 0.5) transparent;
  animation: spin-cw 20s linear infinite;
}

.ring-2 {
  width: 80%;
  height: 80%;
  margin: 10%;
  border-width: 1px;
  border-color: transparent rgba(var(--rgb-info), 0.6) transparent rgba(var(--rgb-info), 0.6);
  animation: spin-ccw 15s linear infinite;
}

.ring-3 {
  width: 60%;
  height: 60%;
  margin: 20%;
  border-width: 3px;
  border-style: dotted;
  border-color: rgba(var(--rgb-text-subtle), 0.4);
  animation: spin-cw 25s linear infinite;
}

.ring-4 {
  width: 40%;
  height: 40%;
  margin: 30%;
  border-width: 1px;
  border-color: rgba(var(--rgb-info), 0.7);
  box-shadow: 0 0 10px rgba(var(--rgb-info), 0.5), inset 0 0 10px rgba(var(--rgb-info), 0.5);
  animation: spin-ccw 10s linear infinite;
}

#loading-text-overlay {
  position: relative;
  color: var(--text-muted);
  font-size: var(--text-base);
  text-shadow: 0 0 5px var(--overlay-base);
  max-width: 300px;
}


